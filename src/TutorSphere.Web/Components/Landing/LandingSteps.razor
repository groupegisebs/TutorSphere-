@inject IStringLocalizer<SharedResources> L

<section class="lp-steps lp-reveal" id="how-it-works">
    <div class="lp-container">
        <div class="lp-section-header">
            <span class="lp-section-label">@L["Steps_Label"]</span>
            <h2>@L["Steps_Title"]</h2>
            <p>@L["Steps_Subtitle"]</p>
        </div>

        <div class="lp-steps-grid">
            <div class="lp-step-card">
                <span class="lp-step-num">01</span>
                <div class="lp-step-icon"><i class="bi bi-person-plus-fill"></i></div>
                <h3>@L["Steps_1_Title"]</h3>
                <p>@L["Steps_1_Desc"]</p>
            </div>
            <div class="lp-step-connector" aria-hidden="true"></div>
            <div class="lp-step-card">
                <span class="lp-step-num">02</span>
                <div class="lp-step-icon"><i class="bi bi-palette-fill"></i></div>
                <h3>@L["Steps_2_Title"]</h3>
                <p>@L["Steps_2_Desc"]</p>
            </div>
            <div class="lp-step-connector" aria-hidden="true"></div>
            <div class="lp-step-card">
                <span class="lp-step-num">03</span>
                <div class="lp-step-icon"><i class="bi bi-rocket-takeoff-fill"></i></div>
                <h3>@L["Steps_3_Title"]</h3>
                <p>@L["Steps_3_Desc"]</p>
            </div>
        </div>
    </div>
</section>
