@inject IStringLocalizer<SharedResources> L

<section class="lp-why lp-reveal" id="why">
    <div class="lp-container">
        <div class="lp-section-header">
            <span class="lp-section-label">@L["Why_Label"]</span>
            <h2>@L["Why_Title"]</h2>
            <p>@L["Why_Subtitle"]</p>
        </div>

        <div class="lp-why-grid">
            <div class="lp-glass-card">
                <div class="lp-glass-icon"><i class="bi bi-building"></i></div>
                <h3>@L["Why_Card1_Title"]</h3>
                <p>@L["Why_Card1_Desc"]</p>
            </div>
            <div class="lp-glass-card">
                <div class="lp-glass-icon lp-glass-icon--teal"><i class="bi bi-lightning-charge-fill"></i></div>
                <h3>@L["Why_Card2_Title"]</h3>
                <p>@L["Why_Card2_Desc"]</p>
            </div>
            <div class="lp-glass-card">
                <div class="lp-glass-icon lp-glass-icon--amber"><i class="bi bi-graph-up-arrow"></i></div>
                <h3>@L["Why_Card3_Title"]</h3>
                <p>@L["Why_Card3_Desc"]</p>
            </div>
        </div>
    </div>
</section>
