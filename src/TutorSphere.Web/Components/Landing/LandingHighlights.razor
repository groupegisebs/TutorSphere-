@inject IStringLocalizer<SharedResources> L

<section class="lp-highlight lp-highlight--classroom lp-reveal">
    <div class="lp-container lp-highlight-inner">
        <div class="lp-highlight-copy">
            <span class="lp-section-label">@L["Highlight_Classroom_Label"]</span>
            <h2>@L["Highlight_Classroom_Title"]</h2>
            <p>@L["Highlight_Classroom_Desc"]</p>
            <ul class="lp-highlight-list">
                <li><i class="bi bi-check-circle-fill"></i>@L["Highlight_Classroom_F1"]</li>
                <li><i class="bi bi-check-circle-fill"></i>@L["Highlight_Classroom_F2"]</li>
                <li><i class="bi bi-check-circle-fill"></i>@L["Highlight_Classroom_F3"]</li>
            </ul>
        </div>
        <div class="lp-highlight-visual">
            <LandingDashboardMockup Variant="classroom" CssClass="lp-mockup--highlight" L="L" />
        </div>
    </div>
</section>

<section class="lp-mobile lp-reveal" id="mobile">
    <div class="lp-container lp-mobile-inner">
        <div class="lp-mobile-visual">
            <div class="lp-phone-stack">
                <div class="lp-phone-frame lp-float">
                    <LandingDashboardMockup Variant="mobile" CssClass="lp-mockup--phone-lg" L="L" />
                </div>
            </div>
        </div>
        <div class="lp-mobile-copy">
            <span class="lp-section-label">@L["Mobile_Label"]</span>
            <h2>@L["Mobile_Title"]</h2>
            <p>@L["Mobile_Desc"]</p>
            <div class="lp-store-badges">
                <span class="lp-store-badge"><i class="bi bi-apple"></i> App Store</span>
                <span class="lp-store-badge"><i class="bi bi-google-play"></i> Google Play</span>
            </div>
        </div>
    </div>
</section>
