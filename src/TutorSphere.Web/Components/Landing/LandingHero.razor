@inject IStringLocalizer<SharedResources> L

<section class="lp-hero lp-reveal">
    <div class="lp-hero-bg">
        <div class="lp-hero-orb lp-hero-orb--1"></div>
        <div class="lp-hero-orb lp-hero-orb--2"></div>
        <div class="lp-hero-orb lp-hero-orb--3"></div>
        <div class="lp-hero-grid"></div>
    </div>

    <div class="lp-hero-inner">
        <div class="lp-hero-left">
            <h1 class="lp-hero-headline">
                @L["Hero_Headline_Prefix"] <span class="lp-hero-highlight">@L["Hero_Headline_Highlight"]</span>
            </h1>
            <p class="lp-hero-lead">@L["Hero_Lead"]</p>

            <div class="lp-hero-actions">
                <a href="/register/eleve" class="btn btn-primary btn-lg lp-btn-cta">
                    @L["Hero_StartFree"] <i class="bi bi-arrow-right ms-2" aria-hidden="true"></i>
                </a>
                <a href="#platform" class="btn btn-outline-secondary btn-lg lp-btn-demo">
                    <i class="bi bi-play-circle me-2" aria-hidden="true"></i>@L["Hero_WatchVideo"]
                </a>
            </div>

            <div class="lp-social-proof">
                <div class="lp-social-avatars" aria-hidden="true">
                    <span class="lp-social-avatar lp-avatar av-violet">S</span>
                    <span class="lp-social-avatar lp-avatar av-teal">T</span>
                    <span class="lp-social-avatar lp-avatar av-amber">M</span>
                    <span class="lp-social-avatar lp-avatar av-violet">E</span>
                </div>
                <div class="lp-social-rating">
                    <span class="lp-social-stars" aria-hidden="true">
                        @for (var i = 0; i < 5; i++) { <i class="bi bi-star-fill"></i> }
                    </span>
                    <span class="lp-social-text">@L["Hero_SocialProof"]</span>
                </div>
            </div>
        </div>

        <div class="lp-hero-right" aria-hidden="true">
            <div class="lp-hero-glow"></div>
            <div class="lp-device lp-device--laptop lp-float">
                <LandingDashboardMockup Variant="student" CssClass="lp-mockup--hero" L="L" AriaLabel="Tableau de bord élève TutorSphere" />
            </div>
            <div class="lp-device lp-device--phone lp-float lp-float--delay">
                <LandingDashboardMockup Variant="mobile" CssClass="lp-mockup--phone" L="L" AriaLabel="Application mobile" />
            </div>
        </div>
    </div>
</section>
