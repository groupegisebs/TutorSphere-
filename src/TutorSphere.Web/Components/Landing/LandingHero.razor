@inject IStringLocalizer<SharedResources> L

<section class="lp-hero lp-reveal">
    <div class="lp-hero-bg">
        <div class="lp-hero-orb lp-hero-orb--1"></div>
        <div class="lp-hero-orb lp-hero-orb--2"></div>
        <div class="lp-hero-orb lp-hero-orb--3"></div>
        <div class="lp-hero-grid"></div>
    </div>

    <div class="lp-hero-inner">
        <div class="lp-hero-left">
            <div class="lp-hero-badge">
                <i class="bi bi-stars" aria-hidden="true"></i>
                @L["Hero_Badge"]
            </div>

            <h1 class="lp-hero-headline">@L["Hero_Headline"]</h1>
            <p class="lp-hero-lead">@L["Hero_Lead"]</p>

            <div class="lp-hero-actions">
                <a href="/tutor/register" class="btn btn-primary btn-lg lp-btn-cta">
                    <i class="bi bi-plus-circle me-2" aria-hidden="true"></i>@L["Hero_CreateSchool"]
                </a>
                <a href="#video" class="btn btn-outline-secondary btn-lg lp-btn-demo">
                    <i class="bi bi-play-circle me-2" aria-hidden="true"></i>@L["Hero_DiscoverPlatform"]
                </a>
            </div>

            <div class="lp-trust-bar">
                <div class="lp-trust-item">
                    <i class="bi bi-grid-3x3-gap-fill"></i>
                    <span>@L["Trust_Features"]</span>
                </div>
                <div class="lp-trust-item">
                    <i class="bi bi-shield-lock-fill"></i>
                    <span>@L["Trust_SecurePay"]</span>
                </div>
                <div class="lp-trust-item">
                    <i class="bi bi-translate"></i>
                    <span>@L["Trust_Languages"]</span>
                </div>
                <div class="lp-trust-item">
                    <i class="bi bi-headset"></i>
                    <span>@L["Trust_Support"]</span>
                </div>
            </div>
        </div>

        <div class="lp-hero-right" aria-hidden="true">
            <div class="lp-hero-glow"></div>
            <div class="lp-device lp-device--laptop lp-float">
                <LandingDashboardMockup Variant="dashboard" CssClass="lp-mockup--hero" L="L" AriaLabel="Tableau de bord TutorSphere" />
            </div>
            <div class="lp-device lp-device--phone lp-float lp-float--delay">
                <LandingDashboardMockup Variant="mobile" CssClass="lp-mockup--phone" L="L" AriaLabel="Application mobile" />
            </div>
        </div>
    </div>
</section>
