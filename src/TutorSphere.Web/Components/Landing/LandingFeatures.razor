@inject IStringLocalizer<SharedResources> L

<section class="lp-features-student lp-reveal" id="features">
    <div class="lp-container">
        <div class="lp-features-student-grid">
            @foreach (var f in _features)
            {
                <article class="lp-feature-student-card">
                    <div class="lp-feature-student-icon @f.IconClass">
                        <i class="bi @f.Icon" aria-hidden="true"></i>
                    </div>
                    <h3>@L[f.TitleKey]</h3>
                    <p>@L[f.DescKey]</p>
                </article>
            }
        </div>
    </div>
</section>

@code {
    private readonly record struct FeatureItem(string TitleKey, string DescKey, string Icon, string IconClass);

    private readonly FeatureItem[] _features =
    [
        new("Landing_Feature_Courses", "Landing_Feature_Courses_Desc", "bi-journal-richtext", "icon-violet"),
        new("Landing_Feature_Homework", "Landing_Feature_Homework_Desc", "bi-pencil-square", "icon-green"),
        new("Landing_Feature_Progress", "Landing_Feature_Progress_Desc", "bi-graph-up-arrow", "icon-amber"),
        new("Landing_Feature_Messaging", "Landing_Feature_Messaging_Desc", "bi-chat-dots-fill", "icon-rose"),
        new("Landing_Feature_Calendar", "Landing_Feature_Calendar_Desc", "bi-calendar3", "icon-blue"),
        new("Landing_Feature_Documents", "Landing_Feature_Documents_Desc", "bi-folder2-open", "icon-violet"),
    ];
}
