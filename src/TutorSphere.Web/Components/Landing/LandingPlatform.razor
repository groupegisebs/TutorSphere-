@inject IStringLocalizer<SharedResources> L

<section class="lp-platform lp-reveal" id="platform">
    <div class="lp-container lp-platform-inner">
        <div class="lp-platform-copy">
            <h2>@L["Platform_Title"]</h2>
            <ul class="lp-platform-checklist">
                <li><i class="bi bi-check-circle-fill" aria-hidden="true"></i>@L["Platform_F1"]</li>
                <li><i class="bi bi-check-circle-fill" aria-hidden="true"></i>@L["Platform_F2"]</li>
                <li><i class="bi bi-check-circle-fill" aria-hidden="true"></i>@L["Platform_F3"]</li>
                <li><i class="bi bi-check-circle-fill" aria-hidden="true"></i>@L["Platform_F4"]</li>
            </ul>
            <a href="#features" class="lp-platform-link">
                @L["Platform_Link"] <i class="bi bi-arrow-right" aria-hidden="true"></i>
            </a>
        </div>

        <div class="lp-platform-collage" aria-hidden="true">
            <div class="lp-collage-window lp-collage-window--video lp-float">
                <div class="lp-collage-chrome">
                    <span></span><span></span><span></span>
                </div>
                <div class="lp-collage-video-main">
                    <div class="lp-collage-tutor-av"><i class="bi bi-person-fill"></i></div>
                </div>
                <div class="lp-collage-video-thumbs">
                    <span></span><span></span><span></span>
                </div>
            </div>

            <div class="lp-collage-window lp-collage-window--whiteboard lp-float lp-float--delay">
                <div class="lp-collage-chrome">
                    <span></span><span></span><span></span>
                </div>
                <div class="lp-collage-whiteboard">
                    <div class="lp-collage-equation">x² − 5x + 6 = 0</div>
                    <div class="lp-collage-geometry">
                        <svg viewBox="0 0 120 60" aria-hidden="true">
                            <polygon points="10,50 60,10 110,50" fill="none" stroke="#5831E0" stroke-width="2"/>
                            <text x="55" y="45" font-size="10" fill="#64748b">α</text>
                        </svg>
                    </div>
                </div>
            </div>

            <div class="lp-collage-window lp-collage-window--notes lp-float">
                <div class="lp-collage-notes-header">Notes</div>
                <div class="lp-collage-chart">
                    <svg viewBox="0 0 200 50" preserveAspectRatio="none" aria-hidden="true">
                        <path d="M0,40 L30,35 L60,28 L90,32 L120,18 L150,22 L180,12 L200,8" fill="none" stroke="#5831E0" stroke-width="2"/>
                    </svg>
                </div>
                <div class="lp-collage-grades">
                    <div><span>Mathématiques</span><strong>17,2/20</strong></div>
                    <div><span>Physique</span><strong>15,8/20</strong></div>
                    <div><span>Français</span><strong>16,5/20</strong></div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="lp-resources-anchor" id="resources" aria-hidden="true"></section>
<section class="lp-about-anchor" id="about" aria-hidden="true"></section>
