@* CSS-only dashboard mockup for hero & showcase *@
<div class="lp-mockup @CssClass" role="img" aria-label="@AriaLabel">
    <div class="lp-mockup-chrome">
        <span class="lp-mockup-dot lp-mockup-dot--r"></span>
        <span class="lp-mockup-dot lp-mockup-dot--y"></span>
        <span class="lp-mockup-dot lp-mockup-dot--g"></span>
    </div>
    <div class="lp-mockup-body">
        <aside class="lp-mockup-sidebar @(Variant == "student" ? "lp-mockup-sidebar--student" : "")">
            @if (Variant == "student")
            {
                <div class="lp-mockup-brand">
                    <span class="lp-mockup-brand-icon"></span>
                    <span class="lp-mockup-brand-text">TutorSphere</span>
                </div>
                @foreach (var item in StudentSidebarItems)
                {
                    <div class="lp-mockup-nav @(item.Active ? "active" : "")">
                        <span class="lp-mockup-nav-icon"><i class="bi @item.Icon"></i></span>
                        <span class="lp-mockup-nav-label">@item.Label</span>
                        @if (item.HasBadge)
                        {
                            <span class="lp-mockup-nav-badge" aria-hidden="true"></span>
                        }
                    </div>
                }
            }
            else if (Variant != "mobile")
            {
                <div class="lp-mockup-logo"></div>
                @foreach (var item in SidebarItems)
                {
                    <div class="lp-mockup-nav @(item.Active ? "active" : "")">
                        <span class="lp-mockup-nav-icon"><i class="bi @item.Icon"></i></span>
                    </div>
                }
            }
        </aside>
        <main class="lp-mockup-main">
            @if (Variant == "student")
            {
                <header class="lp-mockup-header">
                    <div class="lp-mockup-header-greet">Bonjour <span aria-hidden="true">👋</span> Emma</div>
                    <div class="lp-mockup-header-search">
                        <i class="bi bi-search" aria-hidden="true"></i>
                        <span>Rechercher…</span>
                    </div>
                    <div class="lp-mockup-header-actions">
                        <img class="lp-mockup-header-avatar" src="images/landing/avatar-1.png" alt="" width="20" height="20" />
                        <i class="bi bi-list" aria-hidden="true"></i>
                    </div>
                </header>

                <div class="lp-mockup-stats lp-mockup-stats--4">
                    <div class="lp-mockup-stat"><span class="lbl">Cours aujourd'hui</span><span class="val">3</span></div>
                    <div class="lp-mockup-stat"><span class="lbl">Devoirs à rendre</span><span class="val">2</span></div>
                    <div class="lp-mockup-stat"><span class="lbl">Moyenne générale</span><span class="val">16.4/20</span></div>
                    <div class="lp-mockup-stat"><span class="lbl">Heures passées</span><span class="val">13hr 50m</span></div>
                </div>

                <div class="lp-mockup-dashboard-row">
                    <div class="lp-mockup-schedule">
                        <div class="lp-mockup-schedule-days">
                            @foreach (var day in ScheduleDays)
                            {
                                <span class="lp-mockup-schedule-day">@day</span>
                            }
                        </div>
                        <div class="lp-mockup-schedule-grid">
                            <div class="lp-mockup-schedule-times">
                                <span>10:00</span>
                                <span>14:00</span>
                                <span>18:00</span>
                            </div>
                            <div class="lp-mockup-schedule-cols">
                                @foreach (var evt in ScheduleEvents)
                                {
                                    <div class="lp-mockup-event lp-mockup-event--@evt.Color"
                                         style="grid-column:@evt.Col; grid-row:@evt.Row;">
                                        @evt.Label
                                    </div>
                                }
                            </div>
                        </div>
                    </div>

                    <aside class="lp-mockup-aside">
                        <div class="lp-mockup-ring-card">
                            <span class="lp-mockup-ring-title">Progression mensuelle</span>
                            <div class="lp-mockup-ring-wrap">
                                <svg class="lp-mockup-ring" viewBox="0 0 36 36" aria-hidden="true">
                                    <path class="lp-mockup-ring-bg"
                                          d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" />
                                    <path class="lp-mockup-ring-fill"
                                          stroke-dasharray="72, 100"
                                          d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" />
                                </svg>
                                <span class="lp-mockup-ring-val">72%</span>
                            </div>
                        </div>
                        <div class="lp-mockup-activities">
                            <span class="lp-mockup-activities-title">Activités récentes</span>
                            @foreach (var act in RecentActivities)
                            {
                                <div class="lp-mockup-activity">
                                    <span class="lp-mockup-activity-dot lp-mockup-activity-dot--@act.Color"></span>
                                    <span class="lp-mockup-activity-text">@act.Text</span>
                                </div>
                            }
                        </div>
                    </aside>
                </div>
            }
            else if (Variant == "dashboard")
            {
                <div class="lp-mockup-topbar">
                    <span class="lp-mockup-title">@L["TutorDashboard_Title"]</span>
                </div>
                <div class="lp-mockup-stats">
                    <div class="lp-mockup-stat"><span class="lbl">@L["Stat_ActiveStudents"]</span><span class="val">32</span></div>
                    <div class="lp-mockup-stat"><span class="lbl">@L["Stat_UpcomingLessons"]</span><span class="val">6</span></div>
                </div>
                <div class="lp-mockup-chart">
                    <svg viewBox="0 0 200 60" preserveAspectRatio="none">
                        <defs>
                            <linearGradient id="mockFill" x1="0" y1="0" x2="0" y2="1">
                                <stop offset="0%" stop-color="#5831E0" stop-opacity="0.25"/>
                                <stop offset="100%" stop-color="#5831E0" stop-opacity="0"/>
                            </linearGradient>
                        </defs>
                        <path d="M0,45 C20,40 35,30 55,32 C75,34 90,18 110,15 C130,12 150,25 170,20 C185,17 195,22 200,18 L200,60 L0,60 Z" fill="url(#mockFill)"/>
                        <path d="M0,45 C20,40 35,30 55,32 C75,34 90,18 110,15 C130,12 150,25 170,20 C185,17 195,22 200,18" fill="none" stroke="#5831E0" stroke-width="2"/>
                    </svg>
                </div>
                <div class="lp-mockup-lessons">
                    <div class="lp-mockup-lesson"><span class="t">10:00</span><span class="av">EJ</span><span class="n">Emma — Maths</span></div>
                    <div class="lp-mockup-lesson"><span class="t">14:00</span><span class="av av--g">LB</span><span class="n">Liam — Physique</span></div>
                </div>
            }
            else if (Variant == "calendar")
            {
                <div class="lp-mockup-topbar"><span class="lp-mockup-title">Calendrier</span></div>
                <div class="lp-mockup-cal-grid">
                    @for (var d = 1; d <= 28; d++)
                    {
                        var cls = d is 5 or 12 or 19 ? " has-event" : "";
                        <span class="lp-mockup-cal-day@cls">@d</span>
                    }
                </div>
            }
            else if (Variant == "classroom")
            {
                <div class="lp-mockup-vc">
                    <div class="lp-mockup-vc-main"><i class="bi bi-camera-video"></i></div>
                    <div class="lp-mockup-vc-thumbs">
                        <span></span><span></span><span></span>
                    </div>
                    <div class="lp-mockup-vc-bar">
                        <i class="bi bi-mic-fill"></i><i class="bi bi-camera-video-fill"></i><i class="bi bi-chat-dots"></i>
                    </div>
                </div>
            }
            else if (Variant == "mobile")
            {
                <div class="lp-mockup-mobile-header">Bonjour <span aria-hidden="true">👋</span></div>
                <div class="lp-mockup-mobile-stats lp-mockup-mobile-stats--4">
                    <div><span class="val">5</span><span class="lbl">Matières</span></div>
                    <div><span class="val">3</span><span class="lbl">Cours</span></div>
                    <div><span class="val">16.4/20</span><span class="lbl">Moyenne</span></div>
                    <div><span class="val">9</span><span class="lbl">Messages</span></div>
                </div>
                <div class="lp-mockup-mobile-contacts">
                    @foreach (var contact in MobileContacts)
                    {
                        <div class="lp-mockup-contact">
                            <img class="lp-mockup-contact-avatar" src="@contact.Avatar" alt="" width="22" height="22" />
                            <span class="lp-mockup-contact-name">@contact.Name</span>
                            <span class="lp-mockup-contact-status lp-mockup-contact-status--@contact.Status">@contact.StatusLabel</span>
                        </div>
                    }
                </div>
                <nav class="lp-mockup-mobile-tabs" aria-hidden="true">
                    <span class="active"><i class="bi bi-house-fill"></i>Accueil</span>
                    <span><i class="bi bi-calendar3"></i>Calendrier</span>
                    <span><i class="bi bi-journal-text"></i>Cours</span>
                    <span><i class="bi bi-chat-dots"></i>Messages</span>
                    <span><i class="bi bi-person"></i>Profil</span>
                </nav>
            }
        </main>
    </div>
</div>

@code {
    [Parameter] public string Variant { get; set; } = "dashboard";
    [Parameter] public string CssClass { get; set; } = "";
    [Parameter] public string AriaLabel { get; set; } = "Aperçu TutorSphere";
    [Parameter] public IStringLocalizer<SharedResources> L { get; set; } = default!;

    private static readonly (string Icon, string Label, bool Active, bool HasBadge)[] StudentSidebarItems =
    [
        ("bi-house-fill", "Accueil", true, false),
        ("bi-journal-text", "Cours", false, false),
        ("bi-calendar3", "Calendrier", false, false),
        ("bi-folder2", "Documents", false, false),
        ("bi-bar-chart-line", "Rapports", false, false),
        ("bi-chat-dots", "Messages", false, true),
        ("bi-collection", "Programmes", false, false),
        ("bi-graph-up", "Progrès", false, false),
        ("bi-gear", "Paramètres", false, false),
    ];

    private static readonly string[] ScheduleDays = ["Lun 20", "Mar 21", "Mer 22", "Jeu 23", "Ven 24"];

    private static readonly (string Label, string Color, int Col, int Row)[] ScheduleEvents =
    [
        ("Maths", "green", 1, 1),
        ("Physique-Chimie", "purple", 2, 2),
        ("Anglais", "orange", 3, 1),
        ("SVT", "pink", 4, 3),
        ("Maths", "green", 5, 2),
    ];

    private static readonly (string Text, string Color)[] RecentActivities =
    [
        ("Devoir maths à rendre", "orange"),
        ("Cours de physique demain", "purple"),
        ("Message de M. Dupont", "green"),
    ];

    private static readonly (string Name, string Avatar, string Status, string StatusLabel)[] MobileContacts =
    [
        ("Sophie Martin", "images/landing/avatar-2.png", "online", "En ligne"),
        ("Lucas Bernard", "images/landing/avatar-3.png", "busy", "Occupé"),
        ("Emma Dubois", "images/landing/avatar-4.png", "online", "En ligne"),
    ];

    private IEnumerable<(string Icon, string Label, bool Active)> SidebarItems => Variant switch
    {
        "calendar" => [("bi-calendar3", "Calendrier", true), ("bi-house", "Accueil", false), ("bi-people", "Élèves", false)],
        "classroom" => [("bi-camera-video", "Salle virtuelle", true), ("bi-calendar3", "Calendrier", false)],
        _ => [("bi-house", "Tableau de bord", true), ("bi-people", "Élèves", false), ("bi-calendar3", "Calendrier", false)]
    };
}
