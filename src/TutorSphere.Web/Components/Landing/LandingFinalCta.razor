@inject IStringLocalizer<SharedResources> L

<section class="lp-final-cta lp-reveal">
    <div class="lp-final-cta-bg"></div>
    <div class="lp-container lp-final-cta-row">
        <div class="lp-final-cta-illus" aria-hidden="true">
            <div class="lp-graduation-scene">
                <div class="lp-graduation-books">
                    <span class="lp-book lp-book--1"></span>
                    <span class="lp-book lp-book--2"></span>
                    <span class="lp-book lp-book--3"></span>
                </div>
                <div class="lp-graduation-cap">
                    <i class="bi bi-mortarboard-fill"></i>
                </div>
            </div>
        </div>
        <h2 class="lp-final-cta-title">@L["FinalCta_Title"]</h2>
        <a href="/register/eleve" class="btn btn-light btn-lg lp-final-cta-btn">
            @L["Hero_StartFree"] <i class="bi bi-arrow-right ms-2" aria-hidden="true"></i>
        </a>
    </div>
</section>

<footer class="lp-devices-strip">
    <div class="lp-container lp-devices-inner">
        <span class="lp-devices-label">@L["Footer_Devices"]</span>
        <div class="lp-devices-icons" aria-hidden="true">
            <span class="lp-device-icon"><i class="bi bi-globe2"></i> Web</span>
            <span class="lp-device-icon"><i class="bi bi-apple"></i> iOS</span>
            <span class="lp-device-icon"><i class="bi bi-google-play"></i> Android</span>
        </div>
    </div>
</footer>
