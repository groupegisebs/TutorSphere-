@inject IStringLocalizer<SharedResources> L

<section class="lp-final-cta lp-reveal">
    <div class="lp-final-cta-bg"></div>
    <div class="lp-container lp-final-cta-inner">
        <h2>@L["FinalCta_Title"]</h2>
        <p>@L["FinalCta_Subtitle"]</p>
        <div class="lp-final-cta-actions">
            <a href="/tutor/register" class="btn btn-light btn-lg">
                <i class="bi bi-plus-circle me-2"></i>@L["Hero_CreateSchool"]
            </a>
            <a href="/login" class="btn btn-ghost-light btn-lg">@L["Nav_Login"]</a>
        </div>
    </div>
</section>

<footer class="lp-footer">
    <div class="lp-container lp-footer-inner">
        <div class="lp-footer-brand">
            <img src="images/tutorsphere-logo.png" alt="@L["AppName"]" height="32" />
            <span>@L["AppName"]</span>
        </div>
        <nav class="lp-footer-links">
            <a href="#features">@L["Nav_Features"]</a>
            <a href="#pricing">@L["Nav_Pricing"]</a>
            <a href="#faq">@L["Faq_Label"]</a>
            <a href="/login">@L["Nav_Login"]</a>
        </nav>
        <p class="lp-footer-copy">&copy; @DateTime.UtcNow.Year @L["AppName"]. @L["Footer_Rights"]</p>
    </div>
</footer>
