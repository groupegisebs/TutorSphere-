@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject AuthService Auth

@* Restores JWT from cookie / sessionStorage once the circuit is ready (no prerender — avoids blank shell while WS connects). *@

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        await Auth.EnsureSessionRestoredAsync(forceJs: true);
    }
}
