@rendermode InteractiveServer
@inject IStringLocalizer<SharedResources> L
@inject AuthService AuthSvc
@inject NavigationManager Navigation
@inject ParentProfileState ParentProfile

<div class="sidebar-brand sidebar-brand--navy">
    <a class="sidebar-brand-link" href="parent/dashboard">
        <img class="sidebar-brand-logo app-logo-compact" src="images/tutorsphere-logo-full.png" alt="@L["AppName"]" />
        <div class="sidebar-brand-text-group">
            <span class="sidebar-brand-text">@L["AppName"]</span>
            <span class="sidebar-brand-tagline">@L["AppTagline"]</span>
        </div>
    </a>
</div>

<input type="checkbox" title="@L["Nav_MenuToggle"]" class="navbar-toggler navbar-toggler--light" aria-label="@L["Nav_MenuToggle"]" />

<div class="nav-scrollable nav-scrollable--navy" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="nav flex-column">
        <div class="nav-item">
            <NavLink class="nav-link" href="parent/dashboard" Match="NavLinkMatch.All">
                <i class="bi bi-speedometer2" aria-hidden="true"></i>
                <span>@L["Nav_Dashboard"]</span>
            </NavLink>
        </div>
        <div class="nav-item">
            <NavLink class="nav-link" href="parent/children">
                <i class="bi bi-people-fill" aria-hidden="true"></i>
                <span>@L["Nav_MyChildren"]</span>
            </NavLink>
        </div>
        <div class="nav-item">
            <NavLink class="nav-link" href="parent/search">
                <i class="bi bi-person-workspace" aria-hidden="true"></i>
                <span>@L["Nav_Tutors"]</span>
            </NavLink>
        </div>
        <div class="nav-item">
            <NavLink class="nav-link" href="parent/subscriptions">
                <i class="bi bi-arrow-repeat" aria-hidden="true"></i>
                <span>@L["Nav_Subscriptions"]</span>
            </NavLink>
        </div>
        <div class="nav-item">
            <NavLink class="nav-link" href="parent/calendar">
                <i class="bi bi-calendar-event" aria-hidden="true"></i>
                <span>@L["Nav_Calendar"]</span>
            </NavLink>
        </div>
        <div class="nav-item">
            <NavLink class="nav-link" href="parent/homework">
                <i class="bi bi-journal-text" aria-hidden="true"></i>
                <span>@L["Nav_Homework"]</span>
            </NavLink>
        </div>
        <div class="nav-item">
            <NavLink class="nav-link" href="parent/progress">
                <i class="bi bi-graph-up-arrow" aria-hidden="true"></i>
                <span>@L["Nav_Progress"]</span>
            </NavLink>
        </div>
        <div class="nav-item">
            <NavLink class="nav-link" href="parent/reports">
                <i class="bi bi-file-earmark-bar-graph" aria-hidden="true"></i>
                <span>@L["Nav_Reports"]</span>
            </NavLink>
        </div>
        <div class="nav-item">
            <NavLink class="nav-link" href="parent/messages">
                <i class="bi bi-chat-left-text" aria-hidden="true"></i>
                <span>@L["Nav_Messages"]</span>
                @if (_unreadMessages > 0)
                {
                    <span class="sidebar-badge sidebar-badge--purple">@_unreadMessages</span>
                }
            </NavLink>
        </div>
        <div class="nav-item">
            <NavLink class="nav-link" href="parent/payments">
                <i class="bi bi-credit-card" aria-hidden="true"></i>
                <span>@L["Nav_Payments"]</span>
            </NavLink>
        </div>
        <div class="nav-item">
            <NavLink class="nav-link" href="parent/documents">
                <i class="bi bi-folder2-open" aria-hidden="true"></i>
                <span>@L["Nav_Documents"]</span>
            </NavLink>
        </div>
        <div class="nav-item">
            <NavLink class="nav-link" href="parent/favorites">
                <i class="bi bi-heart" aria-hidden="true"></i>
                <span>@L["Nav_Favorites"]</span>
            </NavLink>
        </div>
        <div class="nav-item">
            <NavLink class="nav-link" href="parent/settings">
                <i class="bi bi-sliders" aria-hidden="true"></i>
                <span>@L["Nav_Settings"]</span>
            </NavLink>
        </div>
    </nav>
</div>

@code {
    private int _unreadMessages;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        await AuthSvc.EnsureSessionRestoredAsync(forceJs: true);
        await ParentProfile.EnsureLoadedAsync();
        _unreadMessages = ParentProfile.UnreadMessagesCount;
        StateHasChanged();
    }
}
