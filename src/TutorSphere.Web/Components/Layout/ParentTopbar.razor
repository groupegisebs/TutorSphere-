@rendermode InteractiveServer
@inject IStringLocalizer<SharedResources> L
@inject NavigationManager Navigation
@inject AuthService AuthSvc
@inject ApiClient Api

<div class="top-row top-row--parent px-4 @(_showUserMenu ? "top-row--menu-open" : null)">
    <div class="top-row-actions ms-auto">
        <button type="button" class="topbar-notification" aria-label="@L["Nav_Notifications"]">
            <i class="bi bi-bell" aria-hidden="true"></i>
            <span class="topbar-notification-badge topbar-notification-badge--danger">@NotificationCount</span>
        </button>
        <div class="topbar-user-menu-wrapper">
            <button type="button" class="topbar-user-btn topbar-user-btn--parent" aria-label="@L["Nav_UserMenu"]"
                    @onclick="ToggleUserMenu" @onclick:stopPropagation="true">
                <img class="topbar-user-photo" src="images/parent/parent-profile.png" alt="" />
                <span class="topbar-user-info d-none d-md-flex">
                    <span class="topbar-user-name">@_displayName</span>
                    <span class="topbar-user-role">
                        <i class="bi bi-star-fill" aria-hidden="true"></i>
                        @L["Parent_PremiumBadge"]
                    </span>
                </span>
                <i class="bi bi-chevron-down topbar-user-chevron" aria-hidden="true"></i>
            </button>
            @if (_showUserMenu)
            {
                <div class="topbar-dropdown-menu" @onclick:stopPropagation="true">
                    <div class="topbar-dropdown-header">
                        <span class="topbar-dropdown-name">@_displayName</span>
                        <span class="topbar-dropdown-email">@AuthSvc.UserEmail</span>
                        <span class="topbar-dropdown-badge">@L["Parent_PremiumBadge"]</span>
                    </div>
                    <div class="topbar-dropdown-divider"></div>
                    <a class="topbar-dropdown-item" href="parent/profile" @onclick="CloseUserMenu">
                        <i class="bi bi-person me-2" aria-hidden="true"></i>@L["Nav_MyProfile"]
                    </a>
                    <a class="topbar-dropdown-item" href="parent/settings" @onclick="CloseUserMenu">
                        <i class="bi bi-sliders me-2" aria-hidden="true"></i>@L["Nav_Settings"]
                    </a>
                    <div class="topbar-dropdown-divider"></div>
                    <button type="button" class="topbar-dropdown-item topbar-dropdown-item--danger"
                            @onclick="LogoutAsync">
                        <i class="bi bi-box-arrow-left me-2" aria-hidden="true"></i>@L["Nav_Logout"]
                    </button>
                </div>
            }
        </div>
    </div>
</div>

@if (_showUserMenu)
{
    <div class="topbar-backdrop" @onclick="CloseUserMenu"></div>
}

@code {
    private bool _showUserMenu;
    private const int NotificationCount = 5;
    private string _displayName = "Parent";

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var me = await Api.GetAsync<ParentMeDto>("api/parent/me");
            if (me is not null)
            {
                var name = $"{me.FirstName} {me.LastName}".Trim();
                if (!string.IsNullOrWhiteSpace(name))
                    _displayName = name;
            }
        }
        catch { }

        if (_displayName == "Parent")
            _displayName = AuthSvc.UserName ?? AuthSvc.UserEmail ?? "Parent";
    }

    private void ToggleUserMenu() => _showUserMenu = !_showUserMenu;
    private void CloseUserMenu() => _showUserMenu = false;

    private Task LogoutAsync()
    {
        _showUserMenu = false;
        AuthSvc.Logout();
        Navigation.NavigateTo("/login", forceLoad: true);
        return Task.CompletedTask;
    }

    private record ParentMeDto(string FirstName, string LastName, string Email, int ChildrenCount);
}
