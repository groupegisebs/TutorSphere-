@inject IStringLocalizer<SharedResources> L

<div class="sidebar-brand sidebar-brand--navy">
    <a class="sidebar-brand-link" href="admin/dashboard">
        <img class="sidebar-brand-logo app-logo-compact" src="images/tutorsphere-logo-full.png" alt="@L["AppName"]" />
        <div class="sidebar-brand-text-group">
            <span class="sidebar-brand-text">@L["AppName"]</span>
            <span class="sidebar-brand-tagline">@L["AppTagline"]</span>
        </div>
    </a>
</div>

<input type="checkbox" title="@L["Nav_MenuToggle"]" class="navbar-toggler navbar-toggler--light" aria-label="@L["Nav_MenuToggle"]" />

<div class="nav-scrollable nav-scrollable--navy" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="nav flex-column">
        <div class="nav-item">
            <NavLink class="nav-link" href="admin/dashboard" Match="NavLinkMatch.All">
                <i class="bi bi-shield-check" aria-hidden="true"></i>
                <span>@L["Nav_AdminDashboard"]</span>
            </NavLink>
        </div>
        <div class="nav-item">
            <NavLink class="nav-link" href="admin/tutors">
                <i class="bi bi-person-badge" aria-hidden="true"></i>
                <span>@L["Nav_AdminTutors"]</span>
            </NavLink>
        </div>
        <div class="nav-item">
            <NavLink class="nav-link" href="admin/users">
                <i class="bi bi-people" aria-hidden="true"></i>
                <span>@L["Nav_AdminUsers"]</span>
            </NavLink>
        </div>
        <div class="nav-item">
            <NavLink class="nav-link" href="admin/payments">
                <i class="bi bi-cash-stack" aria-hidden="true"></i>
                <span>@L["Nav_AdminPayments"]</span>
            </NavLink>
        </div>
        <div class="nav-item">
            <NavLink class="nav-link" href="admin/disputes">
                <i class="bi bi-exclamation-triangle" aria-hidden="true"></i>
                <span>@L["Nav_AdminDisputes"]</span>
            </NavLink>
        </div>
        <div class="nav-item">
            <NavLink class="nav-link" href="admin/content">
                <i class="bi bi-layout-text-window" aria-hidden="true"></i>
                <span>@L["Nav_AdminContent"]</span>
            </NavLink>
        </div>
        <div class="nav-item">
            <NavLink class="nav-link" href="admin/security">
                <i class="bi bi-lock" aria-hidden="true"></i>
                <span>@L["Nav_AdminSecurity"]</span>
            </NavLink>
        </div>
        <div class="nav-item">
            <NavLink class="nav-link" href="admin/settings">
                <i class="bi bi-sliders" aria-hidden="true"></i>
                <span>@L["Nav_AdminSettings"]</span>
            </NavLink>
        </div>
    </nav>

    <div class="sidebar-user sidebar-user--navy" onclick="event.stopPropagation()">
        <div class="sidebar-user-avatar">AD</div>
        <div class="sidebar-user-info">
            <span class="sidebar-user-name">Admin</span>
            <span class="sidebar-user-role">@L["Nav_Role_Admin"]</span>
        </div>
        <i class="bi bi-chevron-down sidebar-user-chevron" aria-hidden="true"></i>
    </div>
</div>
