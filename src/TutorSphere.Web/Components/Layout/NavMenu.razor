@inject IStringLocalizer<SharedResources> L

<div class="sidebar-brand">
    <a class="sidebar-brand-link" href="tutor/dashboard">
        <img class="sidebar-brand-logo" src="images/tutorsphere-logo.png" alt="@L["AppName"]" />
        <span class="sidebar-brand-text">@L["AppName"]</span>
    </a>
</div>

<input type="checkbox" title="@L["Nav_MenuToggle"]" class="navbar-toggler" aria-label="@L["Nav_MenuToggle"]" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="nav flex-column">
        <div class="nav-item">
            <NavLink class="nav-link" href="tutor/dashboard">
                <i class="bi bi-house-door" aria-hidden="true"></i>
                <span>@L["Nav_Dashboard"]</span>
            </NavLink>
        </div>
        <div class="nav-item">
            <NavLink class="nav-link" href="search">
                <i class="bi bi-search" aria-hidden="true"></i>
                <span>@L["Nav_Search"]</span>
            </NavLink>
        </div>

        <div class="nav-section-label">@L["Nav_Section_Tutor"]</div>
        <div class="nav-item">
            <NavLink class="nav-link" href="tutor/profile">
                <i class="bi bi-person" aria-hidden="true"></i>
                <span>@L["Nav_MyProfile"]</span>
            </NavLink>
        </div>
        <div class="nav-item">
            <NavLink class="nav-link" href="tutor/students">
                <i class="bi bi-people" aria-hidden="true"></i>
                <span>@L["Nav_MyStudents"]</span>
            </NavLink>
        </div>
        <div class="nav-item">
            <NavLink class="nav-link" href="tutor/register">
                <i class="bi bi-plus-circle" aria-hidden="true"></i>
                <span>@L["Nav_CreateSchool"]</span>
            </NavLink>
        </div>
        <div class="nav-item">
            <NavLink class="nav-link" href="tutor/parents">
                <i class="bi bi-person-hearts" aria-hidden="true"></i>
                <span>@L["Nav_Parents"]</span>
            </NavLink>
        </div>
        <div class="nav-item">
            <NavLink class="nav-link" href="tutor/offers">
                <i class="bi bi-tags" aria-hidden="true"></i>
                <span>@L["Nav_Offers"]</span>
            </NavLink>
        </div>
        <div class="nav-item">
            <NavLink class="nav-link" href="tutor/calendar">
                <i class="bi bi-calendar3" aria-hidden="true"></i>
                <span>@L["Nav_Calendar"]</span>
            </NavLink>
        </div>
        <div class="nav-item">
            <NavLink class="nav-link" href="tutor/lessons">
                <i class="bi bi-journal-bookmark" aria-hidden="true"></i>
                <span>@L["Nav_Lessons"]</span>
            </NavLink>
        </div>
        <div class="nav-item">
            <NavLink class="nav-link" href="tutor/homework">
                <i class="bi bi-journal-text" aria-hidden="true"></i>
                <span>@L["Nav_Homework"]</span>
            </NavLink>
        </div>
        <div class="nav-item">
            <NavLink class="nav-link" href="tutor/reports">
                <i class="bi bi-file-earmark-bar-graph" aria-hidden="true"></i>
                <span>@L["Nav_Reports"]</span>
            </NavLink>
        </div>
        <div class="nav-item">
            <NavLink class="nav-link" href="tutor/payments">
                <i class="bi bi-credit-card" aria-hidden="true"></i>
                <span>@L["Nav_Payments"]</span>
            </NavLink>
        </div>
        <div class="nav-item">
            <NavLink class="nav-link" href="tutor/messages">
                <i class="bi bi-chat-dots" aria-hidden="true"></i>
                <span>@L["Nav_Messages"]</span>
            </NavLink>
        </div>

        <div class="nav-section-label">@L["Nav_Section_Parent"]</div>
        <div class="nav-item">
            <NavLink class="nav-link" href="parent/dashboard">
                <i class="bi bi-speedometer2" aria-hidden="true"></i>
                <span>@L["Nav_ParentDashboard"]</span>
            </NavLink>
        </div>
        <div class="nav-item">
            <NavLink class="nav-link" href="parent/children">
                <i class="bi bi-people-fill" aria-hidden="true"></i>
                <span>@L["Nav_MyChildren"]</span>
            </NavLink>
        </div>
        <div class="nav-item">
            <NavLink class="nav-link" href="parent/search">
                <i class="bi bi-binoculars" aria-hidden="true"></i>
                <span>@L["Nav_FindTutor"]</span>
            </NavLink>
        </div>
        <div class="nav-item">
            <NavLink class="nav-link" href="parent/subscriptions">
                <i class="bi bi-arrow-repeat" aria-hidden="true"></i>
                <span>@L["Nav_MySubscriptions"]</span>
            </NavLink>
        </div>
        <div class="nav-item">
            <NavLink class="nav-link" href="parent/payments">
                <i class="bi bi-wallet2" aria-hidden="true"></i>
                <span>@L["Nav_Payments"]</span>
            </NavLink>
        </div>
        <div class="nav-item">
            <NavLink class="nav-link" href="parent/calendar">
                <i class="bi bi-calendar-event" aria-hidden="true"></i>
                <span>@L["Nav_Calendar"]</span>
            </NavLink>
        </div>
        <div class="nav-item">
            <NavLink class="nav-link" href="parent/reports">
                <i class="bi bi-graph-up" aria-hidden="true"></i>
                <span>@L["Nav_Reports"]</span>
            </NavLink>
        </div>
        <div class="nav-item">
            <NavLink class="nav-link" href="parent/messages">
                <i class="bi bi-envelope" aria-hidden="true"></i>
                <span>@L["Nav_Messages"]</span>
            </NavLink>
        </div>

        <div class="nav-section-label">@L["Nav_Section_Student"]</div>
        <div class="nav-item">
            <NavLink class="nav-link" href="student/dashboard">
                <i class="bi bi-mortarboard" aria-hidden="true"></i>
                <span>@L["Nav_StudentDashboard"]</span>
            </NavLink>
        </div>
        <div class="nav-item">
            <NavLink class="nav-link" href="student/courses">
                <i class="bi bi-book" aria-hidden="true"></i>
                <span>@L["Nav_Courses"]</span>
            </NavLink>
        </div>
        <div class="nav-item">
            <NavLink class="nav-link" href="student/homework">
                <i class="bi bi-pencil-square" aria-hidden="true"></i>
                <span>@L["Nav_Homework"]</span>
            </NavLink>
        </div>
        <div class="nav-item">
            <NavLink class="nav-link" href="student/documents">
                <i class="bi bi-folder2-open" aria-hidden="true"></i>
                <span>@L["Nav_Documents"]</span>
            </NavLink>
        </div>
        <div class="nav-item">
            <NavLink class="nav-link" href="student/reports">
                <i class="bi bi-clipboard-data" aria-hidden="true"></i>
                <span>@L["Nav_Reports"]</span>
            </NavLink>
        </div>
        <div class="nav-item">
            <NavLink class="nav-link" href="student/messages">
                <i class="bi bi-chat-left-text" aria-hidden="true"></i>
                <span>@L["Nav_Messages"]</span>
            </NavLink>
        </div>

        <div class="nav-section-label">@L["Nav_Section_Admin"]</div>
        <div class="nav-item">
            <NavLink class="nav-link" href="admin/dashboard">
                <i class="bi bi-shield-check" aria-hidden="true"></i>
                <span>@L["Nav_AdminDashboard"]</span>
            </NavLink>
        </div>
        <div class="nav-item">
            <NavLink class="nav-link" href="admin/tutors">
                <i class="bi bi-person-badge" aria-hidden="true"></i>
                <span>@L["Nav_AdminTutors"]</span>
            </NavLink>
        </div>
        <div class="nav-item">
            <NavLink class="nav-link" href="admin/users">
                <i class="bi bi-people" aria-hidden="true"></i>
                <span>@L["Nav_AdminUsers"]</span>
            </NavLink>
        </div>
        <div class="nav-item">
            <NavLink class="nav-link" href="admin/payments">
                <i class="bi bi-cash-stack" aria-hidden="true"></i>
                <span>@L["Nav_AdminPayments"]</span>
            </NavLink>
        </div>
        <div class="nav-item">
            <NavLink class="nav-link" href="admin/disputes">
                <i class="bi bi-exclamation-triangle" aria-hidden="true"></i>
                <span>@L["Nav_AdminDisputes"]</span>
            </NavLink>
        </div>
        <div class="nav-item">
            <NavLink class="nav-link" href="admin/content">
                <i class="bi bi-layout-text-window" aria-hidden="true"></i>
                <span>@L["Nav_AdminContent"]</span>
            </NavLink>
        </div>
        <div class="nav-item">
            <NavLink class="nav-link" href="admin/security">
                <i class="bi bi-lock" aria-hidden="true"></i>
                <span>@L["Nav_AdminSecurity"]</span>
            </NavLink>
        </div>
        <div class="nav-item">
            <NavLink class="nav-link" href="admin/settings">
                <i class="bi bi-sliders" aria-hidden="true"></i>
                <span>@L["Nav_AdminSettings"]</span>
            </NavLink>
        </div>
    </nav>

    <div class="sidebar-premium" onclick="event.stopPropagation()">
        <div class="sidebar-premium-icon"><i class="bi bi-gem" aria-hidden="true"></i></div>
        <h3>@L["Nav_UpgradeTitle"]</h3>
        <p>@L["Nav_UpgradeDescription"]</p>
        <button type="button" class="btn btn-primary btn-sm w-100">@L["Nav_UpgradeButton"]</button>
    </div>

    <nav class="nav nav-footer" onclick="event.stopPropagation()">
        <div class="nav-item">
            <NavLink class="nav-link" href="admin/settings">
                <i class="bi bi-gear" aria-hidden="true"></i>
                <span>@L["Nav_Settings"]</span>
            </NavLink>
        </div>
        <div class="nav-item">
            <NavLink class="nav-link" href="admin/settings">
                <i class="bi bi-question-circle" aria-hidden="true"></i>
                <span>@L["Nav_Help"]</span>
            </NavLink>
        </div>
    </nav>

    <div class="sidebar-user" onclick="event.stopPropagation()">
        <div class="sidebar-user-avatar">JS</div>
        <div class="sidebar-user-info">
            <span class="sidebar-user-name">John Smith</span>
            <span class="sidebar-user-role">@L["Nav_Role_Tutor"]</span>
        </div>
        <i class="bi bi-chevron-down sidebar-user-chevron" aria-hidden="true"></i>
    </div>
</div>
