@inject IStringLocalizer<SharedResources> L

<div class="sidebar-brand">
    <a class="sidebar-brand-link" href="">
        <span class="sidebar-brand-icon"><i class="bi bi-mortarboard-fill"></i></span>
        <span>
            <span class="sidebar-brand-text">@L["AppName"]</span>
            <span class="sidebar-brand-tagline">Tutor Platform</span>
        </span>
    </a>
</div>

<input type="checkbox" title="@L["Nav_MenuToggle"]" class="navbar-toggler" aria-label="@L["Nav_MenuToggle"]" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="nav flex-column">
        <div class="nav-section-label">@L["Nav_Home"]</div>
        <div class="nav-item">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <i class="bi bi-house-door" aria-hidden="true"></i>
                <span>@L["Nav_Home"]</span>
            </NavLink>
        </div>
        <div class="nav-item">
            <NavLink class="nav-link" href="search">
                <i class="bi bi-search" aria-hidden="true"></i>
                <span>@L["Nav_Search"]</span>
            </NavLink>
        </div>

        <div class="nav-section-label">@L["Nav_Tutor"]</div>
        <div class="nav-item">
            <NavLink class="nav-link" href="tutor/dashboard">
                <i class="bi bi-speedometer2" aria-hidden="true"></i>
                <span>@L["Nav_Tutor"]</span>
            </NavLink>
        </div>
        <div class="nav-item">
            <NavLink class="nav-link" href="tutor/register">
                <i class="bi bi-plus-circle" aria-hidden="true"></i>
                <span>@L["Nav_CreateSchool"]</span>
            </NavLink>
        </div>

        <div class="nav-section-label">@L["Nav_Parent"]</div>
        <div class="nav-item">
            <NavLink class="nav-link" href="parent">
                <i class="bi bi-people" aria-hidden="true"></i>
                <span>@L["Nav_Parent"]</span>
            </NavLink>
        </div>
    </nav>
</div>
