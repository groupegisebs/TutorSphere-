@rendermode InteractiveServer
@implements IDisposable
@inject IStringLocalizer<SharedResources> L
@inject AuthService AuthSvc
@inject MessagingNotificationState NotifyState
@inject RealtimeMessagingClient Realtime

<div class="sidebar-brand sidebar-brand--navy">
    <a class="sidebar-brand-link" href="student/dashboard">
        <img class="sidebar-brand-logo app-logo-compact" src="images/tutorsphere-logo-full.png" alt="@L["AppName"]" />
        <div class="sidebar-brand-text-group">
            <span class="sidebar-brand-text">@L["AppName"]</span>
            <span class="sidebar-brand-tagline">@L["AppTagline"]</span>
        </div>
    </a>
</div>

<input type="checkbox" title="@L["Nav_MenuToggle"]" class="navbar-toggler navbar-toggler--light" aria-label="@L["Nav_MenuToggle"]" />

<div class="nav-scrollable nav-scrollable--navy" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="nav flex-column">
        <div class="nav-item">
            <NavLink class="nav-link" href="student/dashboard" Match="NavLinkMatch.All">
                <i class="bi bi-mortarboard" aria-hidden="true"></i>
                <span>@L["Nav_StudentDashboard"]</span>
            </NavLink>
        </div>
        <div class="nav-item">
            <NavLink class="nav-link" href="student/search">
                <i class="bi bi-binoculars" aria-hidden="true"></i>
                <span>@L["Nav_FindTutor"]</span>
            </NavLink>
        </div>
        <div class="nav-item">
            <NavLink class="nav-link" href="student/subscriptions">
                <i class="bi bi-arrow-repeat" aria-hidden="true"></i>
                <span>Abonnements</span>
            </NavLink>
        </div>
        <div class="nav-item">
            <NavLink class="nav-link" href="student/courses">
                <i class="bi bi-book" aria-hidden="true"></i>
                <span>@L["Nav_Courses"]</span>
            </NavLink>
        </div>
        <div class="nav-item">
            <NavLink class="nav-link" href="student/calendar">
                <i class="bi bi-calendar2-week" aria-hidden="true"></i>
                <span>@L["Nav_Calendar"]</span>
            </NavLink>
        </div>
        <div class="nav-item">
            <NavLink class="nav-link" href="student/homework">
                <i class="bi bi-pencil-square" aria-hidden="true"></i>
                <span>@L["Nav_Homework"]</span>
            </NavLink>
        </div>
        <div class="nav-item">
            <NavLink class="nav-link" href="student/documents">
                <i class="bi bi-folder2-open" aria-hidden="true"></i>
                <span>@L["Nav_Documents"]</span>
            </NavLink>
        </div>
        <div class="nav-item">
            <NavLink class="nav-link" href="student/reports">
                <i class="bi bi-clipboard-data" aria-hidden="true"></i>
                <span>@L["Nav_Reports"]</span>
            </NavLink>
        </div>
        <div class="nav-item">
            <NavLink class="nav-link" href="student/messages">
                <i class="bi bi-chat-left-text" aria-hidden="true"></i>
                <span>@L["Nav_Messages"]</span>
                @if (NotifyState.UnreadTotal > 0)
                {
                    <span class="sidebar-badge">@NotifyState.UnreadTotal</span>
                }
            </NavLink>
        </div>
    </nav>

    <div class="sidebar-user sidebar-user--navy" onclick="event.stopPropagation()">
        <div class="sidebar-user-avatar">@_initials</div>
        <div class="sidebar-user-info">
            <span class="sidebar-user-name">@_displayName</span>
            <span class="sidebar-user-role">@L["Nav_Role_Student"]</span>
        </div>
        <i class="bi bi-chevron-down sidebar-user-chevron" aria-hidden="true"></i>
    </div>
</div>

@code {
    private string _displayName => AuthSvc.UserName ?? AuthSvc.UserEmail ?? "Élève";
    private string _initials
    {
        get
        {
            var name = _displayName;
            if (string.IsNullOrWhiteSpace(name)) return "?";
            var parts = name.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
            return parts.Length >= 2
                ? $"{parts[0][0]}{parts[^1][0]}".ToUpperInvariant()
                : name[..Math.Min(2, name.Length)].ToUpperInvariant();
        }
    }

    protected override async Task OnInitializedAsync()
    {
        NotifyState.Changed += OnNotifyChanged;
        await AuthSvc.EnsureSessionRestoredAsync();
        await Realtime.EnsureConnectedAsync();
    }

    private void OnNotifyChanged() => InvokeAsync(StateHasChanged);

    public void Dispose() => NotifyState.Changed -= OnNotifyChanged;
}
