@rendermode InteractiveServer
@implements IDisposable
@inject IStringLocalizer<SharedResources> L
@inject NavigationManager Navigation
@inject AuthService AuthSvc
@inject AuthenticationStateProvider AuthState
@inject ApiClient Api
@inject MessagingNotificationState NotifyState
@inject RealtimeMessagingClient Realtime

<div class="top-row px-4 @(_showUserMenu ? "top-row--menu-open" : null)">
    @if (!string.IsNullOrWhiteSpace(_schoolName))
    {
        <a href="tutor/school" class="topbar-school-title" title="@_schoolName">@_schoolName</a>
    }
    else
    {
        <div class="topbar-school-title topbar-school-title--spacer" aria-hidden="true"></div>
    }

    <div class="topbar-center">
        @if (NotifyState.ShowToast)
        {
            <button type="button" class="topbar-subtle-toast" @onclick="OpenToastTarget">
                <i class="bi @(NotifyState.ToastHref?.Contains("classroom", StringComparison.OrdinalIgnoreCase) == true ? "bi-camera-video-fill" : "bi-chat-dots-fill")" aria-hidden="true"></i>
                <span class="topbar-subtle-toast-text">
                    <strong>@NotifyState.ToastFrom</strong>
                    <span>@NotifyState.ToastPreview</span>
                </span>
                <span class="topbar-subtle-toast-close" @onclick="DismissToast" @onclick:stopPropagation="true"
                      role="button" aria-label="@L["Common_Close"]">×</span>
            </button>
        }
    </div>

    <div class="top-row-actions ms-auto">
        <LanguageSelector />
        @if (_showSchoolLink)
        {
            <a href="tutor/school" class="topbar-school-link">
                @L["Topbar_ViewMySchool"] <i class="bi bi-box-arrow-up-right ms-1" aria-hidden="true"></i>
            </a>
        }
        <button type="button" class="topbar-notification ms-3" aria-label="@L["Nav_Notifications"]"
                @onclick="OpenMessages">
            <i class="bi bi-bell" aria-hidden="true"></i>
            @if (NotifyState.UnreadTotal > 0)
            {
                <span class="topbar-notification-badge">@(NotifyState.UnreadTotal > 99 ? "99+" : NotifyState.UnreadTotal.ToString())</span>
            }
        </button>
        <div class="topbar-user-menu-wrapper ms-2">
            <button type="button" class="topbar-user-btn" aria-label="@L["Nav_UserMenu"]"
                    @onclick="ToggleUserMenu" @onclick:stopPropagation="true">
                <span class="topbar-user-avatar">@_initials</span>
                <i class="bi bi-chevron-down ms-1" aria-hidden="true"></i>
            </button>
            @if (_showUserMenu)
            {
                <div class="topbar-dropdown-menu" @onclick:stopPropagation="true">
                    <div class="topbar-dropdown-header">
                        <span class="topbar-dropdown-name">@_displayName</span>
                        <span class="topbar-dropdown-email">@AuthSvc.UserEmail</span>
                    </div>
                    <div class="topbar-dropdown-divider"></div>
                    <a class="topbar-dropdown-item" href="@_profileHref">
                        <i class="bi bi-person me-2" aria-hidden="true"></i>@L["Nav_MyProfile"]
                    </a>
                    <a class="topbar-dropdown-item" href="@_settingsHref">
                        <i class="bi bi-sliders me-2" aria-hidden="true"></i>@L["Nav_Settings"]
                    </a>
                    <div class="topbar-dropdown-divider"></div>
                    <button type="button" class="topbar-dropdown-item topbar-dropdown-item--danger"
                            @onclick="LogoutAsync">
                        <i class="bi bi-box-arrow-left me-2" aria-hidden="true"></i>@L["Nav_Logout"]
                    </button>
                </div>
            }
        </div>
    </div>
</div>

@if (_showUserMenu)
{
    <div class="topbar-backdrop" @onclick="CloseUserMenu"></div>
}

@code {
    private bool _showUserMenu;
    private string? _schoolName;
    private bool _realtimeStarted;

    private string _displayName
    {
        get
        {
            if (!string.IsNullOrWhiteSpace(AuthSvc.UserName))
                return AuthSvc.UserName!;
            if (!string.IsNullOrWhiteSpace(AuthSvc.UserEmail))
                return AuthSvc.UserEmail!;
            return "Tuteur";
        }
    }

    private string _initials => GetInitials(_displayName);
    private bool _showSchoolLink => AuthSvc.PrimaryRole is "Tutor" or "TeachingAssistant";
    private string _messagesHref => AuthSvc.PrimaryRole switch
    {
        "Parent" => "parent/messages",
        "Student" => "student/messages",
        _ => "tutor/messages"
    };
    private string _profileHref => AuthSvc.PrimaryRole switch
    {
        "Parent" => "parent/profile",
        "Student" => "student/settings",
        _ => "tutor/profile"
    };
    private string _settingsHref => AuthSvc.PrimaryRole switch
    {
        "Parent" => "parent/settings",
        "Student" => "student/settings",
        _ => "tutor/settings"
    };

    protected override void OnInitialized()
    {
        AuthState.AuthenticationStateChanged += OnAuthStateChanged;
        NotifyState.Changed += OnNotifyChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        await AuthSvc.EnsureSessionRestoredAsync(forceJs: true);
        await LoadSchoolNameAsync();
        if (!_realtimeStarted)
        {
            _realtimeStarted = true;
            await Realtime.EnsureConnectedAsync();
        }
        await InvokeAsync(StateHasChanged);
    }

    private void OnNotifyChanged() => InvokeAsync(StateHasChanged);

    private void DismissToast() => NotifyState.DismissToast();

    private void OpenToastTarget()
    {
        var href = NotifyState.ToastHref;
        NotifyState.DismissToast();
        Navigation.NavigateTo(string.IsNullOrWhiteSpace(href) ? _messagesHref : href!);
    }

    private void OpenMessages()
    {
        NotifyState.DismissToast();
        Navigation.NavigateTo(_messagesHref);
    }

    private async Task LoadSchoolNameAsync()
    {
        if (AuthSvc.TenantId is Guid tenantId)
        {
            try
            {
                var profile = await Api.GetAsync<SchoolProfileDto>($"api/tenants/{tenantId}/profile");
                if (!string.IsNullOrWhiteSpace(profile?.Name))
                {
                    _schoolName = profile.Name;
                    if (!string.Equals(AuthSvc.SchoolName, profile.Name, StringComparison.Ordinal))
                        await AuthSvc.UpdateLocalSchoolNameAsync(profile.Name);
                    return;
                }
            }
            catch
            {
                /* fall back */
            }
        }

        _schoolName = AuthSvc.SchoolName;
    }

    private async void OnAuthStateChanged(Task<AuthenticationState> _)
    {
        await LoadSchoolNameAsync();
        await Realtime.EnsureConnectedAsync();
        await InvokeAsync(StateHasChanged);
    }

    private void ToggleUserMenu() => _showUserMenu = !_showUserMenu;
    private void CloseUserMenu() => _showUserMenu = false;

    private Task LogoutAsync()
    {
        _showUserMenu = false;
        AuthSvc.Logout();
        Navigation.NavigateTo("/login", forceLoad: true);
        return Task.CompletedTask;
    }

    private static string GetInitials(string name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "?";
        var parts = name.Trim().Split([' ', '@'], StringSplitOptions.RemoveEmptyEntries);
        return parts.Length >= 2
            ? $"{char.ToUpperInvariant(parts[0][0])}{char.ToUpperInvariant(parts[^1][0])}"
            : name[..Math.Min(2, name.Length)].ToUpperInvariant();
    }

    public void Dispose()
    {
        AuthState.AuthenticationStateChanged -= OnAuthStateChanged;
        NotifyState.Changed -= OnNotifyChanged;
    }

    private record SchoolProfileDto(Guid Id, string Name);
}
