@inherits LayoutComponentBase
@inject IStringLocalizer<SharedResources> L

<div class="public-layout">
    <header class="public-nav">
        <div class="public-nav-inner">
            <a class="public-nav-brand" href="/">
                <img src="images/tutorsphere-logo.png" alt="@L["AppName"]" class="public-nav-logo" />
                <span class="public-nav-brand-name">@L["AppName"]</span>
            </a>

            <nav class="public-nav-links" aria-label="Navigation principale">
                <a href="#why" class="public-nav-link">@L["Why_Label"]</a>
                <a href="#features" class="public-nav-link">@L["Nav_Features"]</a>
                <a href="#showcase" class="public-nav-link">@L["Showcase_Label"]</a>
                <a href="#pricing" class="public-nav-link">@L["Nav_Pricing"]</a>
                <a href="#faq" class="public-nav-link">@L["Faq_Label"]</a>
            </nav>

            <div class="public-nav-actions">
                <LanguageSelector />
                <a href="/login" class="btn btn-sm btn-outline-secondary public-nav-login">@L["Nav_Login"]</a>
                <a href="/tutor/register" class="btn btn-sm btn-primary public-nav-cta">@L["Hero_CreateSchool"]</a>
            </div>
        </div>
    </header>

    <main class="public-main">
        @Body
    </main>
</div>
