@inherits LayoutComponentBase
@inject IStringLocalizer<SharedResources> L

<div class="public-layout">
    <header class="public-nav">
        <div class="public-nav-inner">
            <a class="public-nav-brand" href="/">
                <span class="public-nav-brand-icon" aria-hidden="true"><i class="bi bi-mortarboard-fill"></i></span>
                <span class="public-nav-brand-name">@L["AppName"]</span>
            </a>

            <nav class="public-nav-links" aria-label="Navigation principale">
                <a href="/" class="public-nav-link">@L["Nav_Home"]</a>
                <a href="#features" class="public-nav-link">@L["Nav_Features"]</a>
                <a href="#platform" class="public-nav-link">@L["Nav_ForWho"]</a>
                <a href="#resources" class="public-nav-link">@L["Nav_Resources"]</a>
                <a href="#about" class="public-nav-link">@L["Nav_About"]</a>
            </nav>

            <div class="public-nav-actions">
                <LanguageSelector />
                <a href="/login" class="btn btn-sm btn-outline-secondary public-nav-login">@L["Nav_Login"]</a>
                <a href="/register/eleve" class="btn btn-sm btn-primary public-nav-cta">@L["Hero_StartFree"]</a>
            </div>
        </div>
    </header>

    <main class="public-main">
        @Body
    </main>
</div>
