@inherits LayoutComponentBase
@inject IStringLocalizer<SharedResources> L
@inject NavigationManager Nav

<div class="public-layout">
    <header class="public-nav">
        <div class="public-nav-inner">
            <a class="public-nav-brand" href="/">
                <img src="images/tutorsphere-logo-full.png" alt="@L["AppName"]" class="public-nav-logo app-logo-full" />
            </a>

            <nav class="public-nav-links" aria-label="Navigation principale">
                <a href="/" class="public-nav-link @(_isHome ? "public-nav-link--active" : "")">@L["Nav_Home"]</a>
                <a href="#features" class="public-nav-link">
                    @L["Nav_Features"] <i class="bi bi-chevron-down public-nav-chevron" aria-hidden="true"></i>
                </a>
                <a href="#benefits" class="public-nav-link">
                    @L["Nav_ForWho"] <i class="bi bi-chevron-down public-nav-chevron" aria-hidden="true"></i>
                </a>
                <a href="#resources" class="public-nav-link">
                    @L["Nav_Resources"] <i class="bi bi-chevron-down public-nav-chevron" aria-hidden="true"></i>
                </a>
                <a href="/#pricing" class="public-nav-link">@L["Nav_Pricing"]</a>
                <a href="#about" class="public-nav-link">@L["Nav_About"]</a>
            </nav>

            <div class="public-nav-actions">
                <LanguageSelector />
                <a href="/login" class="btn btn-sm btn-outline-secondary public-nav-login">@L["Nav_Login"]</a>
                <a href="/register/eleve" class="btn btn-sm btn-primary public-nav-cta">@L["Hero_StartFree"]</a>
            </div>
        </div>
    </header>

    <main class="public-main">
        @Body
    </main>
</div>

@code {
    private bool _isHome;

    protected override void OnInitialized()
    {
        var path = Nav.ToBaseRelativePath(Nav.Uri).Split('?', '#')[0];
        _isHome = string.IsNullOrEmpty(path);
    }
}
