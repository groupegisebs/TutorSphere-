@inherits LayoutComponentBase
@inject NavigationManager Navigation

<link rel="stylesheet" href="css/admin-control-center.css" />

<div class="cc-shell @(_sidebarOpen ? "cc-sidebar-open" : null)">
    <aside class="cc-sidebar">
        <AdminSidebar />
    </aside>
    <div class="cc-main">
        <AdminControlTopbar OnToggleSidebar="ToggleSidebar" />
        <div class="cc-content">
            @Body
        </div>
    </div>
</div>

@code {
    private bool _sidebarOpen;

    private void ToggleSidebar() => _sidebarOpen = !_sidebarOpen;

    protected override void OnParametersSet()
    {
        _sidebarOpen = false;
    }
}
