@inherits LayoutComponentBase

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4">
            <div class="top-row-actions">
                <LanguageSelector />
                <button type="button" class="topbar-notification" aria-label="@L["Nav_Notifications"]">
                    <i class="bi bi-bell" aria-hidden="true"></i>
                    <span class="topbar-notification-badge">3</span>
                </button>
            </div>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

@code {
    [Inject] private IStringLocalizer<SharedResources> L { get; set; } = default!;
}
