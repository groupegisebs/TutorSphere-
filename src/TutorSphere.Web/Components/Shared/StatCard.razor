<div class="stat-card stat-card--@Variant">
    <div class="stat-card-icon"><i class="bi @Icon" aria-hidden="true"></i></div>
    <div class="stat-card-body">
        <span class="stat-label">@Label</span>
        <span class="stat-value">@Value</span>
        @if (!string.IsNullOrEmpty(Change))
        {
            <span class="stat-change stat-change--@ChangeVariant">@Change</span>
        }
    </div>
</div>

@code {
    [Parameter, EditorRequired] public string Label { get; set; } = "";
    [Parameter, EditorRequired] public string Value { get; set; } = "";
    [Parameter] public string Icon { get; set; } = "bi-bar-chart";
    [Parameter] public string Variant { get; set; } = "students";
    [Parameter] public string? Change { get; set; }
    [Parameter] public string ChangeVariant { get; set; } = "positive";
}
