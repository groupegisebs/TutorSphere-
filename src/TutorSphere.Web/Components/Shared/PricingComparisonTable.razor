@inject IStringLocalizer<SharedResources> L

<section class="lp-pricing-table" id="pricing">
    <div class="lp-section-header mb-4">
        <span class="lp-section-label">@L["Plans_Label"]</span>
        <h2>@L["Plans_Title"]</h2>
        <p>@L["Plans_Subtitle"]</p>
    </div>

    <div class="lp-pricing-compare-wrap">
        <table class="lp-pricing-compare">
            <thead>
                <tr>
                    <th class="lp-pricing-feature-col">@L["Pricing_Features"]</th>
                    @foreach (var plan in _plans)
                    {
                        <th class="@(plan.Featured ? "featured" : "")">
                            <span class="plan-name">@L[plan.NameKey]</span>
                            <span class="plan-price">
                                @if (plan.ContactUs)
                                {
                                    @L["Plan_ContactUs"]
                                }
                                else if (plan.IsFree)
                                {
                                    <span class="plan-price-struck" aria-hidden="true">@($"{plan.Price} $")</span>
                                    <span class="plan-price-now">0 $</span>
                                    <small>/@L["Plan_PerMonth"]</small>
                                }
                                else
                                {
                                    @($"{plan.Price} $")
                                    <small>/@L["Plan_PerMonth"]</small>
                                }
                            </span>
                            @if (plan.ContactUs)
                            {
                                <a href="mailto:support@tutorsphere.com" class="btn btn-outline-primary btn-sm w-100 mt-2">
                                    @L["Plan_ContactSales"]
                                </a>
                            }
                            else
                            {
                                <button type="button"
                                        class="btn @(plan.Featured ? "btn-primary" : "btn-outline-primary") btn-sm w-100 mt-2"
                                        disabled="@(Subscribing && SubscribingPlanId == plan.Id)"
                                        @onclick="() => OnSubscribe.InvokeAsync(plan.Id)">
                                    @if (Subscribing && SubscribingPlanId == plan.Id)
                                    {
                                        <span class="spinner-border spinner-border-sm me-1"></span>
                                    }
                                    @(plan.IsFree ? L["Tutor_PricingCta"] : L["PublicProfile_Subscribe"])
                                </button>
                            }
                        </th>
                    }
                </tr>
            </thead>
            <tbody>
                @foreach (var row in _rows)
                {
                    <tr>
                        <td>@L[row.LabelKey]</td>
                        @foreach (var plan in _plans)
                        {
                            <td class="@(plan.Featured ? "featured" : "")">
                                @RenderCell(plan.Id, row.Id)
                            </td>
                        }
                    </tr>
                }
            </tbody>
        </table>
    </div>
</section>

@code {
    [Parameter] public EventCallback<string> OnSubscribe { get; set; }
    [Parameter] public bool Subscribing { get; set; }
    [Parameter] public string? SubscribingPlanId { get; set; }

    private readonly record struct Plan(string Id, string NameKey, string Price, bool Featured, bool ContactUs, bool IsFree = false);
    private readonly record struct Row(string Id, string LabelKey);

    private readonly Plan[] _plans =
    [
        new("starter", "Plan_Starter", "14,99", false, false, IsFree: true),
        new("pro", "Plan_Professional", "29,99", true, false),
        new("business", "Plan_Business", "59,99", false, false),
        new("enterprise", "Plan_Enterprise", "", false, true),
    ];

    private readonly Row[] _rows =
    [
        new("students", "Pricing_Students"),
        new("storage", "Pricing_Storage"),
        new("reports", "Pricing_Reports"),
        new("video", "Pricing_Video"),
        new("support", "Pricing_Support"),
        new("stats", "Pricing_Stats"),
        new("billing", "Pricing_Billing"),
    ];

    private RenderFragment RenderCell(string planId, string rowId) => builder =>
    {
        var (check, textOrKey) = GetValue(planId, rowId);
        if (check == true)
        {
            builder.OpenElement(0, "i");
            builder.AddAttribute(1, "class", "bi bi-check-circle-fill text-success");
            builder.CloseElement();
        }
        else if (check == false)
        {
            builder.OpenElement(0, "i");
            builder.AddAttribute(1, "class", "bi bi-dash text-muted");
            builder.CloseElement();
        }
        else
        {
            builder.OpenElement(0, "span");
            // Keys start with Pricing_Val_; plain numbers/∞ stay as-is
            var display = textOrKey.StartsWith("Pricing_", StringComparison.Ordinal)
                ? L[textOrKey].Value
                : textOrKey;
            builder.AddContent(1, display);
            builder.CloseElement();
        }
    };

    private static (bool? check, string text) GetValue(string plan, string row) => (plan, row) switch
    {
        ("starter", "students") => (null, "10"),
        ("pro", "students") => (null, "50"),
        ("business", "students") => (null, "200"),
        ("enterprise", "students") => (null, "∞"),

        ("starter", "storage") => (null, "Pricing_Val_5Gb"),
        ("pro", "storage") => (null, "Pricing_Val_25Gb"),
        ("business", "storage") => (null, "Pricing_Val_100Gb"),
        ("enterprise", "storage") => (null, "Pricing_Val_Unlimited"),

        ("starter", "reports") => (null, "Pricing_Val_Basic"),
        ("pro", "reports") => (null, "Pricing_Val_Full"),
        ("business", "reports") => (null, "Pricing_Val_Full"),
        ("enterprise", "reports") => (null, "Pricing_Val_Full"),

        ("starter", "video") => (null, "Pricing_Val_5hMonth"),
        ("pro", "video") => (null, "Pricing_Val_Unlimited"),
        ("business", "video") => (null, "Pricing_Val_Unlimited"),
        ("enterprise", "video") => (null, "Pricing_Val_Unlimited"),

        ("starter", "support") => (null, "Pricing_Val_Email"),
        ("pro", "support") => (null, "Pricing_Val_Priority"),
        ("business", "support") => (null, "Pricing_Val_Priority"),
        ("enterprise", "support") => (null, "Pricing_Val_Dedicated"),

        ("starter", "stats") => (null, "Pricing_Val_Basic"),
        ("pro", "stats") => (null, "Pricing_Val_Advanced"),
        ("business", "stats") => (null, "Pricing_Val_Advanced"),
        ("enterprise", "stats") => (null, "Pricing_Val_Advanced"),

        ("starter", "billing") => (null, "Pricing_Val_Basic"),
        ("pro", "billing") => (null, "Pricing_Val_Full"),
        ("business", "billing") => (null, "Pricing_Val_Full"),
        ("enterprise", "billing") => (null, "Pricing_Val_Full"),

        _ => (false, "")
    };
}
