@inject IStringLocalizer<SharedResources> L

<PageTitle>@L[PageTitleKey]</PageTitle>

<PageHeader Title="@L[TitleKey]" Subtitle="@L[SubtitleKey]" Icon="@Icon" />

<EmptyState Icon="@EmptyIcon"
            Title="@L[EmptyTitleKey]"
            Description="@L[EmptyDescriptionKey]" />

@code {
    [Parameter, EditorRequired] public string PageTitleKey { get; set; } = "";
    [Parameter, EditorRequired] public string TitleKey { get; set; } = "";
    [Parameter] public string SubtitleKey { get; set; } = "Skeleton_ComingSoon";
    [Parameter] public string Icon { get; set; } = "bi-grid";
    [Parameter] public string EmptyIcon { get; set; } = "bi-inbox";
    [Parameter] public string EmptyTitleKey { get; set; } = "Empty_NoData_Title";
    [Parameter] public string EmptyDescriptionKey { get; set; } = "Empty_NoData_Description";
}
