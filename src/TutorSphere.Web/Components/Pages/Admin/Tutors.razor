@page "/admin/tutors"
@layout AdminLayout
@rendermode InteractiveServer
@inject AdminService AdminSvc
@inject ApiClient Api
@inject IStringLocalizer<SharedResources> L

<PageTitle>@L["PageTitle_AdminTutors"]</PageTitle>

<AuthorizeView Roles="SuperAdmin,PlatformAdmin">
    <Authorized>
        <div class="dashboard-header">
            <div>
                <h1 class="dashboard-greeting">@L["Nav_AdminTutors"]</h1>
                <p class="dashboard-date">Gérez les répétiteurs et approuvez les écoles.</p>
            </div>
        </div>

        <div class="d-flex align-items-center gap-3 mb-4 flex-wrap">
            <div class="ms-auto" style="min-width:240px;">
                <div class="form-field-icon">
                    <i class="bi bi-search field-icon" aria-hidden="true"></i>
                    <input type="search" class="form-control"
                           placeholder="Rechercher par nom ou courriel…"
                           @bind="_search" @bind:event="oninput" />
                </div>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <div class="alert alert-danger d-flex align-items-center gap-2" role="alert">
                <i class="bi bi-exclamation-circle-fill"></i>
                @_errorMessage
            </div>
        }

        @if (!string.IsNullOrEmpty(_successMessage))
        {
            <div class="alert alert-success d-flex align-items-center gap-2" role="alert">
                <i class="bi bi-check-circle-fill"></i>
                @_successMessage
            </div>
        }

        @if (_isLoading)
        {
            <div class="d-flex align-items-center justify-content-center py-5">
                <span class="spinner-border text-primary me-3" role="status" aria-hidden="true"></span>
                <span class="text-muted">Chargement des répétiteurs…</span>
            </div>
        }
        else
        {
            var filtered = FilteredTutors;
            <div class="section-card">
                @if (!filtered.Any())
                {
                    <div class="text-center py-5 text-muted">
                        <i class="bi bi-person-x fs-1 d-block mb-2 opacity-50"></i>
                        <p>Aucun répétiteur trouvé.</p>
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table admin-users-table">
                            <thead>
                                <tr>
                                    <th>Nom</th>
                                    <th>Courriel</th>
                                    <th class="text-center">Statut</th>
                                    <th class="text-end">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var tutor in filtered)
                                {
                                    <tr>
                                        <td>
                                            <div class="d-flex align-items-center gap-2">
                                                <div class="admin-user-avatar">@Initials(tutor.FullName)</div>
                                                <span class="fw-medium">@tutor.FullName</span>
                                            </div>
                                        </td>
                                        <td class="text-muted small">@tutor.Email</td>
                                        <td class="text-center">
                                            @if (tutor.IsActive)
                                            {
                                                <span class="admin-status-badge admin-status-badge--active">
                                                    <i class="bi bi-circle-fill me-1" style="font-size:.45rem;vertical-align:middle;"></i>Actif
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="admin-status-badge admin-status-badge--inactive">
                                                    <i class="bi bi-circle-fill me-1" style="font-size:.45rem;vertical-align:middle;"></i>Inactif
                                                </span>
                                            }
                                        </td>
                                        <td class="text-end">
                                            <div class="d-flex align-items-center justify-content-end gap-2">
                                                @if (_pendingUserId == tutor.Id)
                                                {
                                                    <span class="spinner-border spinner-border-sm text-primary" role="status" aria-hidden="true"></span>
                                                }
                                                else if (tutor.IsActive)
                                                {
                                                    <button class="btn admin-toggle-btn admin-toggle-btn--deactivate"
                                                            @onclick="() => ToggleUserAsync(tutor)">
                                                        <i class="bi bi-lock me-1"></i>Désactiver
                                                    </button>
                                                }
                                                else
                                                {
                                                    <button class="btn admin-toggle-btn admin-toggle-btn--activate"
                                                            @onclick="() => ToggleUserAsync(tutor)">
                                                        <i class="bi bi-unlock me-1"></i>Activer
                                                    </button>
                                                }
                                                <button class="btn btn-sm btn-outline-primary"
                                                        title="Approuver l'école"
                                                        disabled="@(_approvingTenant == tutor.Id)"
                                                        @onclick="() => ApproveSchoolAsync(tutor.Id)">
                                                    @if (_approvingTenant == tutor.Id)
                                                    {
                                                        <span class="spinner-border spinner-border-sm me-1"></span>
                                                    }
                                                    else
                                                    {
                                                        <i class="bi bi-building-check me-1"></i>
                                                    }
                                                    Approuver école
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        }
    </Authorized>
    <NotAuthorized>
        <div class="d-flex flex-column align-items-center justify-content-center py-5 text-muted">
            <i class="bi bi-shield-lock fs-1 mb-3"></i>
            <p>Accès réservé aux administrateurs.</p>
            <a href="/login" class="btn btn-primary mt-2">Se connecter</a>
        </div>
    </NotAuthorized>
</AuthorizeView>

@code {
    private string _search = "";
    private bool _isLoading;
    private string? _errorMessage;
    private string? _successMessage;
    private string? _pendingUserId;
    private string? _approvingTenant;
    private List<AdminUserItem> _tutors = [];

    private IEnumerable<AdminUserItem> FilteredTutors =>
        string.IsNullOrWhiteSpace(_search)
            ? _tutors
            : _tutors.Where(u =>
                u.FullName.Contains(_search, StringComparison.OrdinalIgnoreCase) ||
                u.Email.Contains(_search, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync()
    {
        _isLoading = true;
        _errorMessage = null;
        try { _tutors = await AdminSvc.GetUsersAsync("Tutor"); }
        catch { _errorMessage = "Impossible de charger les répétiteurs. Vérifiez votre connexion."; }
        finally { _isLoading = false; }
    }

    private async Task ToggleUserAsync(AdminUserItem tutor)
    {
        _pendingUserId = tutor.Id;
        _successMessage = null;
        _errorMessage   = null;
        try
        {
            bool ok = tutor.IsActive
                ? await AdminSvc.DeactivateUserAsync(tutor.Id)
                : await AdminSvc.ActivateUserAsync(tutor.Id);

            if (ok)
            {
                var idx = _tutors.IndexOf(tutor);
                if (idx >= 0) _tutors[idx] = tutor with { IsActive = !tutor.IsActive };
                _successMessage = tutor.IsActive
                    ? $"Compte de {tutor.FullName} désactivé."
                    : $"Compte de {tutor.FullName} activé.";
            }
            else { _errorMessage = "L'opération a échoué. Veuillez réessayer."; }
        }
        catch { _errorMessage = "Une erreur inattendue s'est produite."; }
        finally { _pendingUserId = null; }
    }

    private async Task ApproveSchoolAsync(string userId)
    {
        _approvingTenant = userId;
        _successMessage  = null;
        _errorMessage    = null;
        try
        {
            var result = await Api.PostAsync<object>($"api/admin/tenants/{userId}/approve", new { });
            if (result != null) _successMessage = "École approuvée avec succès.";
            else _errorMessage = "Impossible d'approuver l'école. Vérifiez que le tenantId est correct.";
        }
        catch { _errorMessage = "Erreur lors de l'approbation de l'école."; }
        finally { _approvingTenant = null; }
    }

    private static string Initials(string fullName)
    {
        var parts = fullName.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length >= 2
            ? $"{parts[0][0]}{parts[^1][0]}".ToUpperInvariant()
            : fullName.Length >= 1 ? fullName[..1].ToUpperInvariant() : "?";
    }
}
