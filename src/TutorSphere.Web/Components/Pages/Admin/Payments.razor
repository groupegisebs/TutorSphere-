@page "/admin/payments"
@layout AdminLayout
@rendermode InteractiveServer
@inject IStringLocalizer<SharedResources> L
@inject ApiClient Api

<PageTitle>@L["PageTitle_AdminPayments"]</PageTitle>

<AuthorizeView Roles="SuperAdmin,PlatformAdmin">
    <Authorized>
        <div class="dashboard-header">
            <div>
                <h1 class="dashboard-greeting">@L["Nav_AdminPayments"]</h1>
                <p class="dashboard-date">Vue d'ensemble des paiements de la plateforme.</p>
            </div>
        </div>

        @if (_loading)
        {
            <div class="d-flex align-items-center justify-content-center py-5">
                <span class="spinner-border text-primary me-3" role="status"></span>
                <span class="text-muted">Chargement des paiements…</span>
            </div>
        }
        else
        {
            <div class="row g-3 mb-4">
                <div class="col-6 col-lg-3">
                    <div class="ts-kpi-card ts-kpi-card--success">
                        <span class="ts-kpi-val">@_totalRevenue.ToString("N0") $</span>
                        <span class="ts-kpi-label">Revenu total (payé)</span>
                    </div>
                </div>
                <div class="col-6 col-lg-3">
                    <div class="ts-kpi-card ts-kpi-card--warning">
                        <span class="ts-kpi-val">@_pending.ToString("N0") $</span>
                        <span class="ts-kpi-label">En attente</span>
                    </div>
                </div>
                <div class="col-6 col-lg-3">
                    <div class="ts-kpi-card">
                        <span class="ts-kpi-val">@_invoices.Count</span>
                        <span class="ts-kpi-label">Total factures</span>
                    </div>
                </div>
            </div>

            <div class="ts-toolbar mb-3">
                <div class="ts-search-box">
                    <i class="bi bi-search ts-search-icon"></i>
                    <input class="form-control" placeholder="Chercher…" @bind="_search" @bind:event="oninput" />
                </div>
                <select class="form-select w-auto" @bind="_statusFilter">
                    <option value="">Tous les statuts</option>
                    <option value="paid">Payé</option>
                    <option value="open">En attente</option>
                    <option value="void">Annulé</option>
                </select>
            </div>

            <div class="section-card">
                <div class="table-responsive">
                    <table class="table admin-users-table">
                        <thead>
                            <tr>
                                <th>Date</th>
                                <th>Description</th>
                                <th>Montant</th>
                                <th>Devise</th>
                                <th class="text-center">Statut</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var inv in FilteredInvoices)
                            {
                                var label = inv.Status switch { "paid" => "Payé", "open" => "En attente", "void" => "Annulé", _ => inv.Status };
                                var badge = inv.Status switch { "paid" => "ts-badge-success", "open" => "ts-badge-warning", _ => "ts-badge-danger" };
                                <tr>
                                    <td>@inv.CreatedAt.ToString("dd/MM/yyyy")</td>
                                    <td>@(inv.Description ?? "Facture")</td>
                                    <td class="fw-semibold">@inv.Amount.ToString("N0")</td>
                                    <td>@inv.Currency.ToUpper()</td>
                                    <td class="text-center">
                                        <span class="ts-badge @badge">@label</span>
                                    </td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(inv.PdfUrl))
                                        {
                                            <a class="ts-icon-btn" href="@inv.PdfUrl" target="_blank" title="PDF">
                                                <i class="bi bi-file-pdf"></i>
                                            </a>
                                        }
                                    </td>
                                </tr>
                            }
                            @if (!FilteredInvoices.Any())
                            {
                                <tr><td colspan="6" class="text-center text-muted py-4">Aucune facture trouvée.</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    </Authorized>
    <NotAuthorized>
        <div class="d-flex flex-column align-items-center justify-content-center py-5 text-muted">
            <i class="bi bi-shield-lock fs-1 mb-3"></i>
            <p>Accès réservé aux administrateurs.</p>
            <a href="/login" class="btn btn-primary mt-2">Se connecter</a>
        </div>
    </NotAuthorized>
</AuthorizeView>

@code {
    private bool _loading = true;
    private string _search = "", _statusFilter = "";
    private List<InvoiceDto> _invoices = [];

    private decimal _totalRevenue => _invoices.Where(i => i.Status == "paid").Sum(i => i.Amount);
    private decimal _pending      => _invoices.Where(i => i.Status == "open").Sum(i => i.Amount);

    private IEnumerable<InvoiceDto> FilteredInvoices => _invoices
        .Where(i => string.IsNullOrEmpty(_search) ||
            (i.Description ?? "").Contains(_search, StringComparison.OrdinalIgnoreCase))
        .Where(i => string.IsNullOrEmpty(_statusFilter) || i.Status == _statusFilter);

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var result = await Api.GetAsync<List<InvoiceDto>>("api/invoices");
            _invoices = result ?? [];
        }
        catch { }
        finally { _loading = false; }
    }

    private record InvoiceDto(
        Guid Id, string? Description, decimal Amount, string Currency,
        string Status, DateTime CreatedAt, string? PdfUrl);
}
