@page "/admin/users"
@page "/admin/parents"
@page "/admin/students"
@page "/admin/teachers"
@layout AdminLayout
@rendermode InteractiveServer
@inject AdminService AdminSvc
@inject NavigationManager Navigation
@inject IStringLocalizer<SharedResources> L

<PageTitle>Gestion des utilisateurs — Control Center</PageTitle>

<AuthorizeView Roles="SuperAdmin,PlatformAdmin">
    <Authorized>
        <div class="cc-toolbar">
            <div>
                <h1 class="cc-page-title">@_pageHeading</h1>
                <p class="cc-page-sub">Recherche avancée, actions et supervision des comptes TutorSphere.</p>
            </div>
            <a href="admin/users" class="cc-btn">Tous les rôles</a>
        </div>

        <div class="cc-card mb-3">
            <div class="cc-filters">
                <div class="cc-field">
                    <label>Recherche</label>
                    <input type="search" placeholder="Nom, e-mail, téléphone…" @bind="_search" @bind:event="oninput" />
                </div>
                <div class="cc-field">
                    <label>Rôle</label>
                    <select @bind="_roleFilter">
                        <option value="all">Tous</option>
                        <option value="Parent">Parent</option>
                        <option value="Student">Élève</option>
                        <option value="Tutor">Tuteur</option>
                        <option value="TeachingAssistant">Enseignant</option>
                    </select>
                </div>
                <div class="cc-field">
                    <label>Pays</label>
                    <input @bind="_countryFilter" placeholder="Tous" />
                </div>
                <div class="cc-field">
                    <label>Statut</label>
                    <select @bind="_statusFilter">
                        <option value="all">Tous</option>
                        <option value="active">Actif</option>
                        <option value="inactive">Inactif</option>
                    </select>
                </div>
                <div class="cc-field">
                    <label>École</label>
                    <input @bind="_schoolFilter" placeholder="Toutes" />
                </div>
                <div class="cc-field d-flex align-items-end">
                    <button type="button" class="cc-btn cc-btn-primary w-100" @onclick="ReloadAsync">
                        <i class="bi bi-search"></i> Filtrer
                    </button>
                </div>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <div class="cc-alert cc-alert-danger"><i class="bi bi-exclamation-circle"></i> @_errorMessage</div>
        }
        @if (!string.IsNullOrEmpty(_successMessage))
        {
            <div class="cc-alert cc-alert-success"><i class="bi bi-check-circle"></i> @_successMessage</div>
        }

        <div class="cc-card">
            @if (_isLoading)
            {
                <div class="cc-empty"><span class="spinner-border text-light"></span><p class="mt-3">Chargement des utilisateurs…</p></div>
            }
            else if (!Filtered.Any())
            {
                <div class="cc-empty"><i class="bi bi-person-x"></i><p>Aucun utilisateur trouvé.</p></div>
            }
            else
            {
                <div class="cc-table-wrap">
                    <table class="cc-table">
                        <thead>
                            <tr>
                                <th>Utilisateur</th>
                                <th>Type</th>
                                <th>Pays</th>
                                <th>École</th>
                                <th>Statut</th>
                                <th>Téléphone</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var user in Filtered)
                            {
                                <tr>
                                    <td>
                                        <div class="cc-user-cell">
                                            <span class="cc-user-avatar">@Initials(user.FullName)</span>
                                            <span class="cc-user-cell-text">
                                                <strong>@user.FullName</strong>
                                                <span>@user.Email</span>
                                            </span>
                                        </div>
                                    </td>
                                    <td><span class="cc-pill cc-pill-type @RoleClass(user.Role)">@RoleLabel(user.Role)</span></td>
                                    <td>@(string.IsNullOrWhiteSpace(user.Country) ? "—" : user.Country)</td>
                                    <td>@(string.IsNullOrWhiteSpace(user.SchoolName) ? "—" : user.SchoolName)</td>
                                    <td>
                                        <span class="cc-pill @(user.IsActive ? "cc-pill-ok" : "cc-pill-bad")">
                                            @(user.IsActive ? "Actif" : "Inactif")
                                        </span>
                                    </td>
                                    <td>@(user.Phone ?? "—")</td>
                                    <td>
                                        <div class="cc-actions-wrap">
                                            <button type="button" class="cc-actions-btn" @onclick="() => ToggleMenu(user.Id)">
                                                <i class="bi bi-three-dots-vertical"></i>
                                            </button>
                                            @if (_openMenuId == user.Id)
                                            {
                                                <div class="cc-dropdown">
                                                    <a href="admin/users/@user.Id"><i class="bi bi-eye"></i> Voir</a>
                                                    <a href="admin/users/@user.Id"><i class="bi bi-pencil"></i> Modifier</a>
                                                    @if (user.IsActive)
                                                    {
                                                        <button type="button" @onclick="() => ToggleUserAsync(user)"><i class="bi bi-lock"></i> Suspendre / Désactiver</button>
                                                    }
                                                    else
                                                    {
                                                        <button type="button" @onclick="() => ToggleUserAsync(user)"><i class="bi bi-unlock"></i> Activer</button>
                                                    }
                                                    <button type="button" @onclick="() => ResetPasswordAsync(user)"><i class="bi bi-arrow-repeat"></i> Réinitialiser mot de passe</button>
                                                    <a href="admin/support"><i class="bi bi-envelope"></i> Envoyer un message</a>
                                                    <a href="admin/users/@user.Id?tab=history"><i class="bi bi-graph-up"></i> Historique</a>
                                                </div>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <div class="mt-3" style="font-size:.78rem;color:var(--cc-text-muted);">
                    @Filtered.Count() utilisateur(s) affiché(s)
                </div>
            }
        </div>
    </Authorized>
    <NotAuthorized>
        <div class="cc-empty">
            <i class="bi bi-shield-lock"></i>
            <p>Accès réservé aux administrateurs.</p>
            <a href="/login/admin" class="cc-btn cc-btn-primary mt-3">Se connecter</a>
        </div>
    </NotAuthorized>
</AuthorizeView>

@code {
    private string _pageHeading = "Utilisateurs";
    private string _roleFilter = "all";
    private string _search = "";
    private string _countryFilter = "";
    private string _schoolFilter = "";
    private string _statusFilter = "all";
    private bool _isLoading;
    private string? _errorMessage;
    private string? _successMessage;
    private string? _openMenuId;
    private List<AdminUserItem> _users = [];

    private IEnumerable<AdminUserItem> Filtered
    {
        get
        {
            IEnumerable<AdminUserItem> q = _users;
            if (!string.IsNullOrWhiteSpace(_search))
            {
                q = q.Where(u =>
                    u.FullName.Contains(_search, StringComparison.OrdinalIgnoreCase) ||
                    u.Email.Contains(_search, StringComparison.OrdinalIgnoreCase) ||
                    (u.Phone?.Contains(_search, StringComparison.OrdinalIgnoreCase) ?? false));
            }
            if (!string.IsNullOrWhiteSpace(_countryFilter))
                q = q.Where(u => u.Country?.Contains(_countryFilter, StringComparison.OrdinalIgnoreCase) == true);
            if (!string.IsNullOrWhiteSpace(_schoolFilter))
                q = q.Where(u => u.SchoolName?.Contains(_schoolFilter, StringComparison.OrdinalIgnoreCase) == true);
            if (_statusFilter == "active") q = q.Where(u => u.IsActive);
            if (_statusFilter == "inactive") q = q.Where(u => !u.IsActive);
            return q;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        var path = new Uri(Navigation.Uri).AbsolutePath.Trim('/').ToLowerInvariant();
        (_pageHeading, _roleFilter) = path switch
        {
            "admin/parents" => ("Parents", "Parent"),
            "admin/students" => ("Élèves", "Student"),
            "admin/teachers" => ("Enseignants", "TeachingAssistant"),
            _ => ("Utilisateurs", "all")
        };

        var query = new Uri(Navigation.Uri).Query.TrimStart('?');
        foreach (var part in query.Split('&', StringSplitOptions.RemoveEmptyEntries))
        {
            var kv = part.Split('=', 2);
            if (kv.Length == 2 && kv[0].Equals("q", StringComparison.OrdinalIgnoreCase))
                _search = Uri.UnescapeDataString(kv[1]);
        }

        await ReloadAsync();
    }

    private async Task ReloadAsync()
    {
        _isLoading = true;
        _errorMessage = null;
        _openMenuId = null;
        try
        {
            var role = _roleFilter == "all" ? "all" : _roleFilter;
            _users = await AdminSvc.GetUsersAsync(role, string.IsNullOrWhiteSpace(_search) ? null : _search);
        }
        catch
        {
            _errorMessage = "Impossible de charger les utilisateurs.";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void ToggleMenu(string id) => _openMenuId = _openMenuId == id ? null : id;

    private async Task ToggleUserAsync(AdminUserItem user)
    {
        _openMenuId = null;
        _successMessage = null;
        _errorMessage = null;
        try
        {
            var ok = user.IsActive
                ? await AdminSvc.DeactivateUserAsync(user.Id)
                : await AdminSvc.ActivateUserAsync(user.Id);
            if (!ok) { _errorMessage = "L'opération a échoué."; return; }
            var idx = _users.IndexOf(user);
            if (idx >= 0) _users[idx] = user with { IsActive = !user.IsActive };
            _successMessage = user.IsActive
                ? $"Compte de {user.FullName} désactivé."
                : $"Compte de {user.FullName} activé.";
        }
        catch { _errorMessage = "Une erreur inattendue s'est produite."; }
    }

    private async Task ResetPasswordAsync(AdminUserItem user)
    {
        _openMenuId = null;
        _successMessage = null;
        _errorMessage = null;
        try
        {
            var ok = await AdminSvc.ResetPasswordAsync(user.Id);
            _successMessage = ok
                ? $"Lien de réinitialisation envoyé à {user.Email}."
                : null;
            if (!ok) _errorMessage = "Impossible d'envoyer le lien.";
        }
        catch { _errorMessage = "Une erreur inattendue s'est produite."; }
    }

    private static string Initials(string fullName)
    {
        var parts = fullName.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length >= 2
            ? $"{parts[0][0]}{parts[^1][0]}".ToUpperInvariant()
            : fullName.Length >= 1 ? fullName[..1].ToUpperInvariant() : "?";
    }

    private static string RoleLabel(string role) => role switch
    {
        "Parent" => "Parent",
        "Student" => "Élève",
        "Tutor" => "Tuteur",
        "TeachingAssistant" => "Enseignant",
        _ => role
    };

    private static string RoleClass(string role) => role switch
    {
        "Parent" => "parent",
        "Student" => "student",
        "Tutor" => "tutor",
        "TeachingAssistant" => "teacher",
        _ => ""
    };
}
