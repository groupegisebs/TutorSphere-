@page "/admin/settings"
@layout AdminLayout
@rendermode InteractiveServer
@inject IStringLocalizer<SharedResources> L
@inject IJSRuntime JS

<PageTitle>@L["PageTitle_AdminSettings"]</PageTitle>

<AuthorizeView Roles="SuperAdmin,PlatformAdmin">
    <Authorized>
        <div class="dashboard-header">
            <div>
                <h1 class="dashboard-greeting">@L["Nav_AdminSettings"]</h1>
                <p class="dashboard-date">Configuration générale de la plateforme.</p>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(_successMessage))
        {
            <div class="alert alert-success d-flex align-items-center gap-2 mb-4" role="alert">
                <i class="bi bi-check-circle-fill"></i>
                @_successMessage
            </div>
        }

        <div class="row g-4">
            <div class="col-lg-7">
                <div class="section-card mb-4">
                    <h2 class="section-card-title p-3" style="border-bottom:1px solid var(--ts-border)">
                        <i class="bi bi-building me-2 text-primary"></i>Paramètres généraux
                    </h2>
                    <div style="padding:1.5rem">
                        <div class="ts-form-grid">
                            <div class="mb-3">
                                <label class="form-label fw-semibold">Nom de la plateforme</label>
                                <input class="form-control" @bind="_platformName" placeholder="TutorSphere" />
                            </div>
                            <div class="mb-3">
                                <label class="form-label fw-semibold">Courriel de support</label>
                                <input type="email" class="form-control" @bind="_supportEmail" placeholder="support@tutorsphere.com" />
                            </div>
                            <div class="mb-3">
                                <label class="form-label fw-semibold">URL de base</label>
                                <input type="url" class="form-control" @bind="_baseUrl" placeholder="https://app.tutorsphere.com" />
                            </div>
                            <div class="mb-3">
                                <label class="form-label fw-semibold">Domaines autorisés</label>
                                <input class="form-control" @bind="_allowedDomains"
                                       placeholder="tutorsphere.com, votredomaine.com" />
                                <small class="form-text text-muted">Séparez les domaines par des virgules.</small>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="section-card mb-4">
                    <h2 class="section-card-title p-3" style="border-bottom:1px solid var(--ts-border)">
                        <i class="bi bi-wrench-adjustable me-2 text-warning"></i>Maintenance
                    </h2>
                    <div style="padding:1.5rem">
                        <div class="d-flex align-items-center justify-content-between mb-3">
                            <div>
                                <strong>Mode maintenance</strong>
                                <p class="text-muted small mb-0">Active une page de maintenance pour tous les utilisateurs.</p>
                            </div>
                            <div class="form-check form-switch ms-3">
                                <input class="form-check-input" type="checkbox" role="switch"
                                       @bind="_maintenanceMode" id="maintenanceSwitch"
                                       style="width:3rem;height:1.5rem;" />
                            </div>
                        </div>
                        @if (_maintenanceMode)
                        {
                            <div class="alert alert-warning mb-0">
                                <i class="bi bi-exclamation-triangle-fill me-2"></i>
                                Le mode maintenance est <strong>activé</strong>. Les utilisateurs verront une page de maintenance.
                            </div>
                        }
                    </div>
                </div>

                <div class="section-card mb-4">
                    <h2 class="section-card-title p-3" style="border-bottom:1px solid var(--ts-border)">
                        <i class="bi bi-envelope me-2 text-info"></i>Notifications par courriel
                    </h2>
                    <div style="padding:1.5rem">
                        <div class="d-flex align-items-center justify-content-between mb-3">
                            <div>
                                <strong>Notifications d'inscription</strong>
                                <p class="text-muted small mb-0">Envoyer un courriel lors d'une nouvelle inscription.</p>
                            </div>
                            <div class="form-check form-switch ms-3">
                                <input class="form-check-input" type="checkbox" role="switch"
                                       @bind="_notifyOnRegistration"
                                       style="width:3rem;height:1.5rem;" />
                            </div>
                        </div>
                        <div class="d-flex align-items-center justify-content-between">
                            <div>
                                <strong>Rapport quotidien</strong>
                                <p class="text-muted small mb-0">Recevoir un résumé quotidien d'activité.</p>
                            </div>
                            <div class="form-check form-switch ms-3">
                                <input class="form-check-input" type="checkbox" role="switch"
                                       @bind="_dailyReport"
                                       style="width:3rem;height:1.5rem;" />
                            </div>
                        </div>
                    </div>
                </div>

                <div class="d-flex gap-2">
                    <button class="btn btn-primary" @onclick="SaveSettings" disabled="@_saving">
                        @if (_saving)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                        }
                        else
                        {
                            <i class="bi bi-floppy me-2"></i>
                        }
                        Enregistrer les paramètres
                    </button>
                    <button class="btn btn-outline-secondary" @onclick="ResetSettings">
                        <i class="bi bi-arrow-counterclockwise me-2"></i>Réinitialiser
                    </button>
                </div>
            </div>

            <div class="col-lg-5">
                <div class="section-card mb-4">
                    <h2 class="section-card-title p-3" style="border-bottom:1px solid var(--ts-border)">
                        <i class="bi bi-info-circle me-2 text-secondary"></i>Informations système
                    </h2>
                    <div style="padding:1.5rem">
                        <div class="ts-form-grid">
                            <div class="ts-form-row"><label>Version</label><span>1.0.0</span></div>
                            <div class="ts-form-row"><label>Environnement</label><span>Production</span></div>
                            <div class="ts-form-row"><label>Fuseau horaire</label><span>UTC-4 (Montréal)</span></div>
                            <div class="ts-form-row"><label>Langue par défaut</label><span>Français (CA)</span></div>
                        </div>
                    </div>
                </div>

                <div class="section-card">
                    <h2 class="section-card-title p-3" style="border-bottom:1px solid var(--ts-border)">
                        <i class="bi bi-shield-check me-2 text-success"></i>Sécurité
                    </h2>
                    <div style="padding:1.5rem">
                        <div class="d-flex align-items-center justify-content-between mb-3">
                            <div>
                                <strong>Double authentification</strong>
                                <p class="text-muted small mb-0">Exiger le 2FA pour les administrateurs.</p>
                            </div>
                            <div class="form-check form-switch ms-3">
                                <input class="form-check-input" type="checkbox" role="switch"
                                       @bind="_requireMfa"
                                       style="width:3rem;height:1.5rem;" />
                            </div>
                        </div>
                        <div class="d-flex align-items-center justify-content-between">
                            <div>
                                <strong>Journal d'audit</strong>
                                <p class="text-muted small mb-0">Activer la journalisation des actions admin.</p>
                            </div>
                            <div class="form-check form-switch ms-3">
                                <input class="form-check-input" type="checkbox" role="switch"
                                       @bind="_auditLog"
                                       style="width:3rem;height:1.5rem;" />
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </Authorized>
    <NotAuthorized>
        <div class="d-flex flex-column align-items-center justify-content-center py-5 text-muted">
            <i class="bi bi-shield-lock fs-1 mb-3"></i>
            <p>Accès réservé aux administrateurs.</p>
            <a href="/login" class="btn btn-primary mt-2">Se connecter</a>
        </div>
    </NotAuthorized>
</AuthorizeView>

@code {
    private bool    _saving               = false;
    private string? _successMessage;
    private string  _platformName         = "TutorSphere";
    private string  _supportEmail         = "support@tutorsphere.com";
    private string  _baseUrl              = "https://app.tutorsphere.gisebs.com";
    private string  _allowedDomains       = "tutorsphere.com";
    private bool    _maintenanceMode      = false;
    private bool    _notifyOnRegistration = true;
    private bool    _dailyReport          = false;
    private bool    _requireMfa           = false;
    private bool    _auditLog             = true;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var saved = await JS.InvokeAsync<string>("localStorage.getItem", "ts_admin_settings");
            if (!string.IsNullOrEmpty(saved))
            {
                var obj = System.Text.Json.JsonSerializer.Deserialize<SettingsModel>(saved,
                    new System.Text.Json.JsonSerializerOptions(System.Text.Json.JsonSerializerDefaults.Web));
                if (obj != null)
                {
                    _platformName         = obj.PlatformName;
                    _supportEmail         = obj.SupportEmail;
                    _baseUrl              = obj.BaseUrl;
                    _allowedDomains       = obj.AllowedDomains;
                    _maintenanceMode      = obj.MaintenanceMode;
                    _notifyOnRegistration = obj.NotifyOnRegistration;
                    _dailyReport          = obj.DailyReport;
                    _requireMfa           = obj.RequireMfa;
                    _auditLog             = obj.AuditLog;
                }
            }
        }
        catch { }
    }

    private async Task SaveSettings()
    {
        _saving = true;
        _successMessage = null;
        try
        {
            var model = new SettingsModel(
                _platformName, _supportEmail, _baseUrl, _allowedDomains,
                _maintenanceMode, _notifyOnRegistration, _dailyReport, _requireMfa, _auditLog);
            var json = System.Text.Json.JsonSerializer.Serialize(model,
                new System.Text.Json.JsonSerializerOptions(System.Text.Json.JsonSerializerDefaults.Web));
            await JS.InvokeVoidAsync("localStorage.setItem", "ts_admin_settings", json);
            _successMessage = "Paramètres enregistrés avec succès.";
        }
        catch { }
        finally { _saving = false; }
    }

    private void ResetSettings()
    {
        _platformName         = "TutorSphere";
        _supportEmail         = "support@tutorsphere.com";
        _baseUrl              = "https://app.tutorsphere.gisebs.com";
        _allowedDomains       = "tutorsphere.com";
        _maintenanceMode      = false;
        _notifyOnRegistration = true;
        _dailyReport          = false;
        _requireMfa           = false;
        _auditLog             = true;
        _successMessage       = null;
    }

    private record SettingsModel(
        string PlatformName, string SupportEmail, string BaseUrl, string AllowedDomains,
        bool MaintenanceMode, bool NotifyOnRegistration, bool DailyReport, bool RequireMfa, bool AuditLog);
}
