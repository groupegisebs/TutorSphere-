@page "/reset-password"
@layout LoginLayout
@rendermode InteractiveServer
@inject HttpClient Http
@inject NavigationManager Navigation

<PageTitle>Réinitialiser le mot de passe – TutorSphere</PageTitle>

<div class="login-page login-theme-tutor">

    <!-- Left panel -->
    <div class="login-illustration">
        <div class="login-illustration-content">
            <div class="login-brand">
                <img src="images/tutorsphere-logo.png" alt="TutorSphere" class="login-logo" />
                <div>
                    <span class="login-brand-name">TutorSphere</span>
                    <p class="login-brand-tagline">Plateforme éducative intelligente</p>
                </div>
            </div>
            <div class="login-hero-block">
                <h2 class="login-hero-title">
                    Nouveau<br>
                    <span>mot de passe</span>
                </h2>
                <p class="login-hero-subtitle">Choisissez un mot de passe fort pour sécuriser votre compte.</p>
            </div>
            <svg class="login-illustration-img" viewBox="0 0 420 300" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <circle cx="210" cy="150" r="90" fill="#ede9fe" opacity="0.4"/>
                <rect x="160" y="130" width="100" height="70" rx="10" fill="#fff" stroke="#5831E0" stroke-width="3"/>
                <rect x="185" y="115" width="50" height="35" rx="10" fill="none" stroke="#5831E0" stroke-width="3"/>
                <circle cx="210" cy="155" r="8" fill="#5831E0" opacity="0.7"/>
                <rect x="207" y="158" width="6" height="12" rx="3" fill="#5831E0" opacity="0.6"/>
                <circle cx="280" cy="100" r="4" fill="#5831E0" opacity="0.3"/>
                <circle cx="140" cy="200" r="3" fill="#7C5CFF" opacity="0.25"/>
            </svg>
        </div>
    </div>

    <!-- Right panel -->
    <div class="login-form-panel">
        <div class="login-form-inner">

            @if (_success)
            {
                <div class="text-center mt-4">
                    <div style="font-size:3.5rem;margin-bottom:1rem">✅</div>
                    <h1 style="font-size:1.6rem;margin-bottom:.5rem">Mot de passe mis à jour !</h1>
                    <p class="login-subtitle">Votre mot de passe a été réinitialisé avec succès. Vous pouvez maintenant vous connecter.</p>
                    <a href="/login" class="btn btn-primary mt-3 px-5">
                        <i class="bi bi-box-arrow-in-right me-1"></i>Se connecter
                    </a>
                </div>
            }
            else if (_tokenInvalid)
            {
                <div class="text-center mt-4">
                    <div style="font-size:3.5rem;margin-bottom:1rem">⚠️</div>
                    <h1 style="font-size:1.6rem;margin-bottom:.5rem">Lien invalide ou expiré</h1>
                    <p class="login-subtitle">Ce lien de réinitialisation n'est plus valide. Demandez un nouveau lien.</p>
                    <a href="/forgot-password" class="btn btn-primary mt-3 px-5">
                        <i class="bi bi-arrow-repeat me-1"></i>Nouveau lien
                    </a>
                </div>
            }
            else
            {
                <a href="/forgot-password" class="login-back-link">
                    <i class="bi bi-arrow-left me-1"></i>Retour
                </a>

                <h1>Réinitialiser le mot de passe</h1>
                <p class="login-subtitle">Saisissez votre nouveau mot de passe.</p>

                @if (!string.IsNullOrEmpty(_error))
                {
                    <div class="alert alert-danger mb-3">
                        <i class="bi bi-exclamation-circle me-2"></i>@_error
                    </div>
                }

                <form class="login-form" @onsubmit="ResetAsync" @onsubmit:preventDefault="true">
                    <div class="mb-3">
                        <label class="form-label">Nouveau mot de passe</label>
                        <div class="form-field-icon">
                            <i class="bi bi-lock field-icon"></i>
                            <input type="@(_showPwd ? "text" : "password")" class="form-control"
                                   placeholder="••••••••"
                                   @bind="_password" @bind:event="oninput"
                                   style="padding-right:2.5rem" />
                            <button type="button" class="password-toggle"
                                    @onclick="() => _showPwd = !_showPwd">
                                <i class="bi @(_showPwd ? "bi-eye-slash" : "bi-eye")"></i>
                            </button>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label">Confirmer le mot de passe</label>
                        <div class="form-field-icon">
                            <i class="bi bi-lock-fill field-icon"></i>
                            <input type="@(_showConfirm ? "text" : "password")"
                                   class="form-control @(!string.IsNullOrEmpty(_confirm) && _password != _confirm ? "is-invalid" : "")"
                                   placeholder="••••••••"
                                   @bind="_confirm" @bind:event="oninput"
                                   style="padding-right:2.5rem" />
                            <button type="button" class="password-toggle"
                                    @onclick="() => _showConfirm = !_showConfirm">
                                <i class="bi @(_showConfirm ? "bi-eye-slash" : "bi-eye")"></i>
                            </button>
                        </div>
                        @if (!string.IsNullOrEmpty(_confirm) && _password != _confirm)
                        {
                            <small class="text-danger">Les mots de passe ne correspondent pas.</small>
                        }
                    </div>

                    <button type="submit" class="btn btn-primary btn-lg w-100 login-submit-btn" disabled="@_saving">
                        @if (_saving)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                        }
                        <i class="bi bi-check-lg me-1"></i>Réinitialiser
                    </button>
                </form>
            }
        </div>
    </div>
</div>

@code {
    [SupplyParameterFromQuery] public string? UserId { get; set; }
    [SupplyParameterFromQuery] public string? Token { get; set; }

    private string _password = "";
    private string _confirm = "";
    private bool _showPwd;
    private bool _showConfirm;
    private bool _saving;
    private bool _success;
    private bool _tokenInvalid;
    private string? _error;

    protected override void OnInitialized()
    {
        if (string.IsNullOrWhiteSpace(UserId) || string.IsNullOrWhiteSpace(Token))
            _tokenInvalid = true;
    }

    private async Task ResetAsync()
    {
        _error = null;
        if (string.IsNullOrWhiteSpace(_password) || _password.Length < 8)
        {
            _error = "Le mot de passe doit contenir au moins 8 caractères.";
            return;
        }
        if (_password != _confirm)
        {
            _error = "Les mots de passe ne correspondent pas.";
            return;
        }
        _saving = true;
        try
        {
            var resp = await Http.PostAsJsonAsync("api/auth/reset-password", new
            {
                userId = UserId,
                token = Token,
                newPassword = _password
            });

            if (resp.IsSuccessStatusCode)
            {
                _success = true;
            }
            else
            {
                var body = await resp.Content.ReadAsStringAsync();
                _error = TryExtractError(body) ?? "Le lien est invalide ou a expiré.";
                if (resp.StatusCode == System.Net.HttpStatusCode.BadRequest)
                    _tokenInvalid = true;
            }
        }
        catch
        {
            _error = "Erreur de connexion au serveur. Réessayez dans quelques instants.";
        }
        finally
        {
            _saving = false;
        }
    }

    private static string? TryExtractError(string body)
    {
        if (string.IsNullOrWhiteSpace(body)) return null;
        try
        {
            using var doc = System.Text.Json.JsonDocument.Parse(body);
            if (doc.RootElement.TryGetProperty("error", out var e)) return e.GetString();
        }
        catch { }
        return body;
    }
}
