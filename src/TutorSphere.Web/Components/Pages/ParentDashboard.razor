@page "/parent"
@inject IStringLocalizer<SharedResources> L

<PageTitle>@L["PageTitle_ParentDashboard"]</PageTitle>

<div class="page-header">
    <h1>@L["Parent_Title"]</h1>
    <p class="page-subtitle">@L["Parent_Subtitle"]</p>
</div>

<div class="row g-4">
    <div class="col-md-4">
        <div class="feature-card">
            <div class="feature-icon feature-icon--indigo">
                <i class="bi bi-people-fill"></i>
            </div>
            <h4>@L["Parent_MyChildren_Title"]</h4>
            <p>@L["Parent_MyChildren_Description"]</p>
        </div>
    </div>
    <div class="col-md-4">
        <div class="feature-card">
            <div class="feature-icon feature-icon--cyan">
                <i class="bi bi-credit-card-2-front"></i>
            </div>
            <h4>@L["Parent_Subscriptions_Title"]</h4>
            <p>@L["Parent_Subscriptions_Description"]</p>
        </div>
    </div>
    <div class="col-md-4">
        <div class="feature-card">
            <div class="feature-icon feature-icon--amber">
                <i class="bi bi-file-earmark-bar-graph"></i>
            </div>
            <h4>@L["Parent_Reports_Title"]</h4>
            <p>@L["Parent_Reports_Description"]</p>
        </div>
    </div>
</div>
