@page "/parent/dashboard"
@page "/parent"
@layout ParentLayout
@rendermode InteractiveServer
@using TutorSphere.Application.DTOs.Parents
@inject IStringLocalizer<SharedResources> L
@inject AuthService AuthSvc
@inject ApiClient Api

<PageTitle>@L["PageTitle_ParentDashboard"]</PageTitle>

<div class="parent-dashboard">
    <header class="parent-dashboard-header">
        <div>
            <h1 class="dashboard-greeting">@L["ParentDashboard_Welcome", _parentName] 👋</h1>
            <p class="dashboard-date">@L["ParentDashboard_Subtitle"]</p>
        </div>
    </header>

    @if (_loading)
    {
        <div class="parent-dashboard-loading">
            <span class="spinner-border spinner-border-sm text-primary" role="status"></span>
            <span class="text-muted">@L["Label_Loading"]</span>
        </div>
    }
    else
    {
        <div class="parent-stats-row">
            <StatCard Label="@L["Parent_MyChildren_Title"]" Value="@_children.Count.ToString()"
                      Icon="bi-people-fill" Variant="students"
                      Change="@(_children.Count > 0 ? L["ParentDashboard_ChildrenRegistered", _children.Count].Value : null)" />
            <StatCard Label="@L["ParentDashboard_StatCoursesToday"]" Value="@_lessonsToday.ToString()"
                      Icon="bi-calendar-check" Variant="lessons"
                      Change="@_nextCourseLabel" ChangeVariant="info" />
            <StatCard Label="@L["ParentDashboard_StatAverage"]" Value="@_averageGradeDisplay"
                      Icon="bi-graph-up" Variant="revenue" />
            <StatCard Label="@L["Parent_ActiveSubscription"]" Value="@_subscriptionValue"
                      Icon="bi-wallet2" Variant="subscriptions"
                      Change="@_subscriptionPlan" ChangeVariant="@_subscriptionChangeVariant" />
        </div>

        <div class="parent-row-children-cal">
            <div class="parent-children-grid">
                @if (_children.Count == 0)
                {
                    <div class="section-card parent-children-empty">
                        <EmptyState Icon="bi-people"
                                    Title="@L["ParentDashboard_NoChildren"]"
                                    Description="@L["Empty_NoData_Description"]">
                            <a href="/parent/children" class="btn btn-primary btn-sm">
                                @L["ParentDashboard_AddChild"]
                            </a>
                        </EmptyState>
                    </div>
                }
                else
                {
                    @foreach (var (child, index) in _children.Select((c, i) => (c, i)))
                    {
                        var name = $"{child.FirstName} {child.LastName}".Trim();
                        var initials = GetInitials(name);
                        var color = AvatarColors[index % AvatarColors.Length];
                        var variant = ProgressVariants[index % ProgressVariants.Length];
                        <article class="parent-child-card">
                            <div class="parent-child-card-top">
                                @if (!string.IsNullOrEmpty(child.PhotoUrl))
                                {
                                    <img class="parent-child-photo" src="@child.PhotoUrl" alt="" />
                                }
                                else
                                {
                                    <div class="parent-child-avatar" style="background:@color">@initials</div>
                                }
                                <div class="parent-child-info">
                                    <h3>@name</h3>
                                    <span class="parent-child-level">@(child.SchoolLevel ?? "—")</span>
                                </div>
                                <div class="parent-child-grade">
                                    <span class="parent-child-grade-label">@L["ParentDashboard_AverageLabel"]</span>
                                    <strong>@FormatGrade(child.AverageGrade)</strong>
                                    <span class="parent-child-pct">@FormatPercent(child.ProgressPercent)</span>
                                </div>
                            </div>
                            @if (child.ProgressPercent.HasValue)
                            {
                                <div class="parent-progress-bar">
                                    <div class="parent-progress-fill parent-progress-fill--@variant"
                                         style="width:@child.ProgressPercent%"></div>
                                </div>
                            }
                            <ul class="parent-child-meta">
                                <li><i class="bi bi-calendar3"></i> @FormatNextLesson(child)</li>
                                <li><i class="bi bi-journal-text"></i> @(child.NextLessonSubject ?? "—")</li>
                            </ul>
                            <a href="/parent/children" class="parent-child-link">@L["ParentDashboard_ViewProfile"] →</a>
                        </article>
                    }
                }
            </div>

            <div class="section-card parent-calendar-card">
                <div class="section-card-header">
                    <h2>@L["ParentDashboard_FamilyCalendar"]</h2>
                    <a href="/parent/calendar" class="parent-link-more">@L["Button_ViewAll"]</a>
                </div>
                <div class="parent-week-cal">
                    @foreach (var day in _weekDays)
                    {
                        <div class="parent-week-day @(day.IsToday ? "is-today" : null)">
                            <div class="parent-week-day-label">@day.Label</div>
                            <div class="parent-week-day-body">
                                @if (day.Events.Count == 0)
                                {
                                    <span class="parent-week-empty">@L["ParentDashboard_NoClass"]</span>
                                }
                                else
                                {
                                    @foreach (var ev in day.Events)
                                    {
                                        <div class="parent-cal-event parent-cal-event--@ev.Color">
                                            <strong>@ev.Title</strong>
                                            <span>@ev.Subtitle · @ev.Time</span>
                                        </div>
                                    }
                                }
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="parent-row-charts-side">
            <div class="parent-charts-stack">
                <div class="section-card">
                    <div class="section-card-header">
                        <h2>@L["ParentDashboard_GlobalProgress"]</h2>
                    </div>
                    @if (_children.Count == 0 || !_children.Any(c => c.AverageGrade.HasValue))
                    {
                        <EmptyState Icon="bi-graph-up"
                                    Title="@L["ParentDashboard_NoProgressData"]"
                                    Description="@L["Empty_NoData_Description"]" />
                    }
                    else
                    {
                        <div class="parent-line-chart parent-line-chart--empty-hint">
                            <p class="text-muted mb-0 px-3 pb-3">
                                @L["ParentDashboard_ProgressSummary", _children.Count, FormatGrade(_dashboard?.AverageGrade)]
                            </p>
                        </div>
                    }
                </div>

                <div class="section-card">
                    <div class="section-card-header">
                        <h2>@L["ParentDashboard_StudyTime"] <span class="parent-card-subtitle">@L["ParentDashboard_ThisWeek"]</span></h2>
                    </div>
                    <EmptyState Icon="bi-clock-history"
                                Title="@L["ParentDashboard_NoStudyTime"]"
                                Description="@L["Empty_NoData_Description"]" />
                </div>
            </div>

            <div class="parent-side-stack">
                <div class="section-card">
                    <div class="section-card-header">
                        <h2>@L["ParentDashboard_UpcomingSessions"]</h2>
                        <a href="/parent/calendar" class="parent-link-more">@L["Button_ViewAll"]</a>
                    </div>
                    @if (_upcomingSessions.Count == 0)
                    {
                        <EmptyState Icon="bi-calendar-event" Title="@L["ParentDashboard_NoSessions"]" />
                    }
                    else
                    {
                        <ul class="parent-session-list">
                            @foreach (var session in _upcomingSessions)
                            {
                                <li class="parent-session-item">
                                    <div class="parent-session-avatar">@GetInitials(session.TutorName)</div>
                                    <div class="parent-session-info">
                                        <strong>@session.TutorName</strong>
                                        <span>@(session.Subject ?? "—")</span>
                                        <span class="parent-session-time">@FormatSessionTime(session.StartTime)</span>
                                    </div>
                                    <span class="parent-tag parent-tag--online">@LessonModeLabel(session.Mode)</span>
                                </li>
                            }
                        </ul>
                    }
                </div>

                <div class="section-card">
                    <div class="section-card-header">
                        <h2>@L["ParentDashboard_HomeworkTodo"]</h2>
                        <a href="/parent/homework" class="parent-link-more">@L["Button_ViewAll"]</a>
                    </div>
                    @if (_homeworkItems.Count == 0)
                    {
                        <EmptyState Icon="bi-journal-text" Title="@L["ParentDashboard_NoHomework"]" />
                    }
                    else
                    {
                        <ul class="parent-homework-list">
                            @foreach (var hw in _homeworkItems)
                            {
                                var tag = GetHomeworkTag(hw);
                                <li class="parent-homework-item">
                                    <div>
                                        <strong>@hw.Title</strong>
                                        <span>@hw.ChildName — @FormatDueDate(hw.DueDate)</span>
                                    </div>
                                    <span class="parent-tag parent-tag--@tag.Class">
                                        @if (tag.Class == "done")
                                        {
                                            <i class="bi bi-check-lg"></i>
                                        }
                                        @tag.Label
                                    </span>
                                </li>
                            }
                        </ul>
                    }
                </div>
            </div>
        </div>

        <div class="parent-row-widgets">
            <div class="section-card">
                <div class="section-card-header">
                    <h2>@L["StudentDashboard_RecentReports"]</h2>
                    <a href="/parent/reports" class="parent-link-more">@L["Button_ViewAll"]</a>
                </div>
                @if (_recentReports.Count == 0)
                {
                    <EmptyState Icon="bi-file-earmark-bar-graph" Title="@L["ParentDashboard_NoReports"]" />
                }
                else
                {
                    <ul class="parent-report-list">
                        @foreach (var report in _recentReports)
                        {
                            <li class="parent-report-item">
                                <div class="parent-report-avatar">@GetInitials(report.TutorName)</div>
                                <div class="parent-report-info">
                                    <strong>@report.TutorName</strong>
                                    <span>@(report.Subject ?? report.TopicsStudied ?? "—")</span>
                                    <span class="text-muted small">@report.StudentName</span>
                                </div>
                                <div class="parent-report-grade">
                                    <span>@FormatRelativeDate(report.CreatedAt)</span>
                                </div>
                            </li>
                        }
                    </ul>
                }
            </div>

            <div class="section-card">
                <div class="section-card-header">
                    <h2>@L["ParentDashboard_RecentMessages"]</h2>
                    <a href="/parent/messages" class="parent-link-more">@L["Button_ViewAll"]</a>
                </div>
                @if (_recentMessages.Count == 0)
                {
                    <EmptyState Icon="bi-chat-left-text" Title="@L["ParentDashboard_NoMessages"]" />
                }
                else
                {
                    <ul class="parent-message-list">
                        @foreach (var msg in _recentMessages)
                        {
                            <li class="parent-message-item">
                                <div class="parent-message-avatar">@GetInitials(msg.From)</div>
                                <div class="parent-message-info">
                                    <strong>@msg.From</strong>
                                    <span>@msg.Preview</span>
                                </div>
                                @if (msg.IsUnread)
                                {
                                    <span class="parent-message-badge">1</span>
                                }
                            </li>
                        }
                    </ul>
                }
            </div>

            <div class="section-card parent-payment-card">
                <div class="section-card-header">
                    <h2>@L["Parent_RecentPayment"]</h2>
                </div>
                @if (_recentPayment is null)
                {
                    <EmptyState Icon="bi-credit-card" Title="@L["ParentDashboard_NoPayment"]" />
                }
                else
                {
                    <div class="parent-payment-body">
                        <div class="parent-payment-status">
                            <i class="bi bi-check-circle-fill text-success"></i>
                            <span>@L["ParentDashboard_PaymentSuccess"]</span>
                        </div>
                        <p class="parent-payment-amount">@FormatPaymentAmount(_recentPayment)</p>
                        <span class="text-muted small">@FormatRelativeDate(_recentPayment.CompletedAt ?? DateTime.UtcNow)</span>
                        <a href="/parent/payments" class="parent-payment-link">@L["ParentDashboard_ViewHistory"]</a>
                    </div>
                }
            </div>

            <div class="section-card">
                <div class="section-card-header">
                    <h2>@L["ParentDashboard_RecentDocuments"]</h2>
                    <a href="/parent/documents" class="parent-link-more">@L["Button_ViewAll"]</a>
                </div>
                @if (_recentDocuments.Count == 0)
                {
                    <EmptyState Icon="bi-folder2-open" Title="@L["ParentDashboard_NoDocuments"]" />
                }
                else
                {
                    <ul class="parent-doc-list">
                        @foreach (var doc in _recentDocuments)
                        {
                            <li class="parent-doc-item">
                                <i class="bi @GetDocumentIcon(doc.ContentType) parent-doc-icon"></i>
                                <div class="parent-doc-info">
                                    <strong>@doc.Name</strong>
                                    <span>@FormatFileSize(doc.FileSizeBytes)</span>
                                </div>
                                @if (!string.IsNullOrEmpty(doc.FileUrl))
                                {
                                    <a href="@doc.FileUrl" class="parent-doc-download" aria-label="@L["ParentDashboard_Download"]" download>
                                        <i class="bi bi-download"></i>
                                    </a>
                                }
                            </li>
                        }
                    </ul>
                }
            </div>
        </div>

        <div class="parent-quick-actions">
            <a href="/parent/children" class="parent-quick-action"><i class="bi bi-person-plus"></i>@L["ParentDashboard_AddChild"]</a>
            <a href="/parent/search" class="parent-quick-action"><i class="bi bi-search"></i>@L["ParentDashboard_FindTutor"]</a>
            <a href="/parent/calendar" class="parent-quick-action"><i class="bi bi-calendar-plus"></i>@L["ParentDashboard_ScheduleClass"]</a>
            <a href="/parent/payments" class="parent-quick-action"><i class="bi bi-credit-card"></i>@L["ParentDashboard_PayOnline"]</a>
            <a href="/parent/messages" class="parent-quick-action"><i class="bi bi-send"></i>@L["ParentDashboard_SendMessage"]</a>
        </div>
    }
</div>

@code {
    private static readonly string[] AvatarColors =
        ["#5831e0", "#ec4899", "#0ea5e9", "#10b981", "#f59e0b", "#8b5cf6"];

    private static readonly string[] ProgressVariants = ["purple", "pink", "purple", "pink"];

    private string _parentName = "Parent";
    private bool _loading = true;
    private ParentDashboardDto? _dashboard;
    private int _lessonsToday;
    private string _nextCourseLabel = "—";
    private string _averageGradeDisplay = "—";
    private string _subscriptionValue = "—";
    private string? _subscriptionPlan;
    private string _subscriptionChangeVariant = "warning";
    private List<ParentDashboardChildDto> _children = [];
    private List<ParentDashboardSessionDto> _upcomingSessions = [];
    private List<ParentDashboardHomeworkDto> _homeworkItems = [];
    private List<ParentDashboardMessageDto> _recentMessages = [];
    private List<ParentDashboardDocumentDto> _recentDocuments = [];
    private List<ParentDashboardReportDto> _recentReports = [];
    private List<ParentDashboardCalendarDayDto> _weekDays = [];
    private ParentDashboardPaymentDto? _recentPayment;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _dashboard = await Api.GetAsync<ParentDashboardDto>("api/parent/dashboard");
            if (_dashboard is not null)
            {
                _parentName = $"{_dashboard.Parent.FirstName} {_dashboard.Parent.LastName}".Trim();
                _children = _dashboard.Children.ToList();
                _lessonsToday = _dashboard.LessonsTodayCount;
                _upcomingSessions = _dashboard.UpcomingSessions.Take(3).ToList();
                _homeworkItems = _dashboard.PendingHomework.ToList();
                _recentReports = _dashboard.RecentReports.ToList();
                _recentMessages = _dashboard.RecentMessages.ToList();
                _recentDocuments = _dashboard.RecentDocuments.ToList();
                _recentPayment = _dashboard.RecentPayment;
                _weekDays = _dashboard.WeekCalendar.ToList();

                _nextCourseLabel = _dashboard.NextLessonStartTime is null
                    ? L["ParentDashboard_NextNone"]
                    : L["ParentDashboard_NextAt", _dashboard.NextLessonStartTime.Value.ToLocalTime().ToString("HH:mm")];

                _averageGradeDisplay = FormatGrade(_dashboard.AverageGrade);

                if (_dashboard.ActiveSubscription is not null)
                {
                    _subscriptionValue = L["ParentDashboard_SubscriptionActive"];
                    _subscriptionPlan = _dashboard.ActiveSubscription.PlanName;
                    _subscriptionChangeVariant = "warning";
                }
                else
                {
                    _subscriptionValue = "—";
                    _subscriptionPlan = L["ParentDashboard_NoSubscription"];
                    _subscriptionChangeVariant = "info";
                }
            }
        }
        catch
        {
            _parentName = AuthSvc.UserName ?? AuthSvc.UserEmail ?? "Parent";
        }

        if (string.IsNullOrWhiteSpace(_parentName))
            _parentName = AuthSvc.UserName ?? AuthSvc.UserEmail ?? "Parent";

        _loading = false;
    }

    private static string GetInitials(string name)
    {
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length >= 2
            ? $"{parts[0][0]}{parts[^1][0]}".ToUpperInvariant()
            : name.Length > 0 ? name[..1].ToUpperInvariant() : "?";
    }

    private string FormatGrade(decimal? grade) =>
        grade.HasValue ? $"{grade.Value:0.#}/20" : "—";

    private static string FormatPercent(int? percent) =>
        percent.HasValue ? $"{percent}%" : "—";

    private string FormatNextLesson(ParentDashboardChildDto child) =>
        child.NextLessonStartTime is null
            ? L["ParentDashboard_NoSessions"]
            : L["ParentDashboard_NextAt", child.NextLessonStartTime.Value.ToLocalTime().ToString("ddd · HH:mm")];

    private static string FormatSessionTime(DateTime startTime) =>
        startTime.ToLocalTime().ToString("ddd · HH:mm");

    private static string LessonModeLabel(string mode) => mode switch
    {
        "Online" => "En ligne",
        "InPerson" => "Présentiel",
        "Hybrid" => "Hybride",
        _ => mode
    };

    private (string Label, string Class) GetHomeworkTag(ParentDashboardHomeworkDto hw)
    {
        if (hw.IsGraded)
            return (L["Tag_Done"], "done");

        if (hw.DueDate.HasValue)
        {
            var due = hw.DueDate.Value.Date;
            if (due < DateTime.Today)
                return (L["Tag_Urgent"], "urgent");
            if (due <= DateTime.Today.AddDays(1))
                return (L["Tag_Urgent"], "urgent");
            if (due <= DateTime.Today.AddDays(3))
                return (L["Tag_Important"], "important");
        }

        return (L["Tag_Important"], "important");
    }

    private static string FormatDueDate(DateTime? dueDate) =>
        dueDate?.ToLocalTime().ToString("dd/MM/yyyy") ?? "—";

    private static string FormatRelativeDate(DateTime dateTime)
    {
        var local = dateTime.ToLocalTime();
        var diff = DateTime.Now - local;
        if (diff.TotalDays < 1) return "Aujourd'hui";
        if (diff.TotalDays < 2) return "Hier";
        if (diff.TotalDays < 7) return $"Il y a {(int)diff.TotalDays} j";
        if (diff.TotalDays < 14) return "Il y a 1 sem.";
        return local.ToString("dd/MM/yyyy");
    }

    private static string FormatPaymentAmount(ParentDashboardPaymentDto payment) =>
        $"{payment.Amount:N2} {payment.Currency}";

    private static string FormatFileSize(long bytes)
    {
        if (bytes >= 1_048_576)
            return $"{bytes / 1_048_576.0:0.#} Mo";
        if (bytes >= 1024)
            return $"{bytes / 1024.0:0.#} Ko";
        return $"{bytes} o";
    }

    private static string GetDocumentIcon(string contentType) =>
        contentType.Contains("pdf", StringComparison.OrdinalIgnoreCase)
            ? "bi-file-earmark-pdf-fill"
            : "bi-file-earmark-fill";
}
