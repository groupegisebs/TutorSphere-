@page "/parent/dashboard"
@page "/parent"
@layout ParentLayout
@rendermode InteractiveServer
@using TutorSphere.Application.DTOs.Lessons
@inject IStringLocalizer<SharedResources> L
@inject AuthService AuthSvc
@inject ApiClient Api
@inject LessonService LessonSvc

<PageTitle>@L["PageTitle_ParentDashboard"]</PageTitle>

<div class="parent-dashboard">
    <header class="parent-dashboard-header">
        <div>
            <h1 class="dashboard-greeting">@L["ParentDashboard_Welcome", _parentName] 👋</h1>
            <p class="dashboard-date">@L["ParentDashboard_Subtitle"]</p>
        </div>
    </header>

    @if (_loading)
    {
        <div class="parent-dashboard-loading">
            <span class="spinner-border spinner-border-sm text-primary" role="status"></span>
            <span class="text-muted">@L["Label_Loading"]</span>
        </div>
    }
    else
    {
        <div class="parent-stats-row">
            <StatCard Label="@L["Parent_MyChildren_Title"]" Value="@_children.Count.ToString()"
                      Icon="bi-people-fill" Variant="students"
                      Change="@L["ParentDashboard_ChildrenChange", _children.Count]" />
            <StatCard Label="@L["ParentDashboard_StatCoursesToday"]" Value="@_coursesToday.ToString()"
                      Icon="bi-calendar-check" Variant="lessons"
                      Change="@_nextCourseLabel" ChangeVariant="info" />
            <StatCard Label="@L["ParentDashboard_StatAverage"]" Value="@_averageGrade"
                      Icon="bi-graph-up" Variant="revenue"
                      Change="@L["ParentDashboard_AverageChangeWeek"]" />
            <StatCard Label="@L["Parent_ActiveSubscription"]" Value="@L["ParentDashboard_SubscriptionActive"]"
                      Icon="bi-wallet2" Variant="subscriptions"
                      Change="@L["Parent_SubscriptionPlan"]" ChangeVariant="warning" />
        </div>

        <div class="parent-row-children-cal">
            <div class="parent-children-grid">
                @foreach (var child in _children)
                {
                    <article class="parent-child-card">
                        <div class="parent-child-card-top">
                            @if (!string.IsNullOrEmpty(child.PhotoUrl))
                            {
                                <img class="parent-child-photo" src="@child.PhotoUrl" alt="" />
                            }
                            else
                            {
                                <div class="parent-child-avatar" style="background:@child.Color">@child.Initials</div>
                            }
                            <div class="parent-child-info">
                                <h3>@child.Name</h3>
                                <span class="parent-child-level">@child.Level</span>
                            </div>
                            <div class="parent-child-grade">
                                <span class="parent-child-grade-label">@L["ParentDashboard_AverageLabel"]</span>
                                <strong>@child.GradeDisplay</strong>
                                <span class="parent-child-pct">@child.PercentDisplay</span>
                            </div>
                        </div>
                        <div class="parent-progress-bar">
                            <div class="parent-progress-fill parent-progress-fill--@child.ProgressVariant"
                                 style="width:@child.Percent%"></div>
                        </div>
                        <ul class="parent-child-meta">
                            <li><i class="bi bi-calendar3"></i> @child.NextClass</li>
                            <li><i class="bi bi-journal-text"></i> @child.SubjectLabel</li>
                        </ul>
                        <a href="/parent/children" class="parent-child-link">@L["ParentDashboard_ViewProfile"] →</a>
                    </article>
                }
            </div>

            <div class="section-card parent-calendar-card">
                <div class="section-card-header">
                    <h2>@L["ParentDashboard_FamilyCalendar"]</h2>
                    <a href="/parent/calendar" class="parent-link-more">@L["Button_ViewAll"]</a>
                </div>
                <div class="parent-week-cal">
                    @foreach (var day in _weekDays)
                    {
                        <div class="parent-week-day @(day.IsToday ? "is-today" : null)">
                            <div class="parent-week-day-label">@day.Label</div>
                            <div class="parent-week-day-body">
                                @if (day.Events.Count == 0)
                                {
                                    <span class="parent-week-empty">@L["ParentDashboard_NoClass"]</span>
                                }
                                else
                                {
                                    @foreach (var ev in day.Events)
                                    {
                                        <div class="parent-cal-event parent-cal-event--@ev.Color">
                                            <strong>@ev.Title</strong>
                                            <span>@ev.Subtitle · @ev.Time</span>
                                        </div>
                                    }
                                }
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="parent-row-charts-side">
            <div class="parent-charts-stack">
                <div class="section-card">
                    <div class="section-card-header">
                        <h2>@L["ParentDashboard_GlobalProgress"]</h2>
                    </div>
                    <div class="parent-line-chart">
                        <svg viewBox="0 0 400 150" preserveAspectRatio="none" aria-hidden="true">
                            <defs>
                                <linearGradient id="parentFillNoah" x1="0" y1="0" x2="0" y2="1">
                                    <stop offset="0%" stop-color="#5831E0" stop-opacity="0.18"/>
                                    <stop offset="100%" stop-color="#5831E0" stop-opacity="0"/>
                                </linearGradient>
                                <linearGradient id="parentFillEmma" x1="0" y1="0" x2="0" y2="1">
                                    <stop offset="0%" stop-color="#ec4899" stop-opacity="0.12"/>
                                    <stop offset="100%" stop-color="#ec4899" stop-opacity="0"/>
                                </linearGradient>
                            </defs>
                            @for (var i = 0; i <= 4; i++)
                            {
                                var y = 30 + i * 25;
                                <line x1="0" y1="@y" x2="400" y2="@y" stroke="#e2e8f0" stroke-width="1"/>
                            }
                            <path d="M0,115 L67,98 L133,88 L200,72 L267,58 L333,48 L400,38 L400,150 L0,150 Z" fill="url(#parentFillNoah)"/>
                            <path d="M0,115 L67,98 L133,88 L200,72 L267,58 L333,48 L400,38" fill="none" stroke="#5831E0" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
                            <path d="M0,125 L67,112 L133,102 L200,92 L267,82 L333,74 L400,65" fill="none" stroke="#ec4899" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
                            <path d="M0,125 L67,112 L133,102 L200,92 L267,82 L333,74 L400,65 L400,150 L0,150 Z" fill="url(#parentFillEmma)"/>
                        </svg>
                        <div class="parent-chart-legend">
                            @foreach (var name in _chartChildNames)
                            {
                                var idx = _chartChildNames.IndexOf(name);
                                <span class="parent-chart-legend-item parent-chart-legend-item--@(idx == 0 ? "purple" : "pink")">
                                    <i class="bi bi-circle-fill"></i> @name
                                </span>
                            }
                        </div>
                        <div class="chart-x-labels">
                            @foreach (var lbl in new[] { "Jan", "Fév", "Mar", "Avr", "Mai", "Jun" })
                            {
                                <span>@lbl</span>
                            }
                        </div>
                    </div>
                </div>

                <div class="section-card">
                    <div class="section-card-header">
                        <h2>@L["ParentDashboard_StudyTime"] <span class="parent-card-subtitle">@L["ParentDashboard_ThisWeek"]</span></h2>
                    </div>
                    <div class="parent-donut-wrap">
                        <div class="parent-donut-chart" aria-hidden="true">
                            <svg viewBox="0 0 36 36" class="parent-donut-svg">
                                <circle cx="18" cy="18" r="15.915" fill="none" stroke="#5831E0" stroke-width="3.2"
                                        stroke-dasharray="38.1 61.9" stroke-dashoffset="25"/>
                                <circle cx="18" cy="18" r="15.915" fill="none" stroke="#10b981" stroke-width="3.2"
                                        stroke-dasharray="25.7 74.3" stroke-dashoffset="-13.1"/>
                                <circle cx="18" cy="18" r="15.915" fill="none" stroke="#ec4899" stroke-width="3.2"
                                        stroke-dasharray="22.9 77.1" stroke-dashoffset="-38.8"/>
                                <circle cx="18" cy="18" r="15.915" fill="none" stroke="#f59e0b" stroke-width="3.2"
                                        stroke-dasharray="13.3 86.7" stroke-dashoffset="-61.7"/>
                            </svg>
                            <div class="parent-donut-center">
                                <strong>8h 45m</strong>
                                <span>@L["ParentDashboard_Total"]</span>
                            </div>
                        </div>
                        <ul class="donut-legend parent-donut-legend">
                            <li><span class="donut-legend-color" style="background:#5831E0"></span> @L["Subject_Math"] <em>3h 20m</em></li>
                            <li><span class="donut-legend-color" style="background:#10b981"></span> @L["Subject_Science"] <em>2h 15m</em></li>
                            <li><span class="donut-legend-color" style="background:#ec4899"></span> @L["Subject_English"] <em>2h 00m</em></li>
                            <li><span class="donut-legend-color" style="background:#f59e0b"></span> @L["ParentDashboard_Other"] <em>1h 10m</em></li>
                        </ul>
                    </div>
                </div>
            </div>

            <div class="parent-side-stack">
                <div class="section-card">
                    <div class="section-card-header">
                        <h2>@L["ParentDashboard_UpcomingSessions"]</h2>
                        <a href="/parent/calendar" class="parent-link-more">@L["Button_ViewAll"]</a>
                    </div>
                    <ul class="parent-session-list">
                        @foreach (var session in _upcomingSessions)
                        {
                            <li class="parent-session-item">
                                <div class="parent-session-avatar">@session.Initials</div>
                                <div class="parent-session-info">
                                    <strong>@session.Title</strong>
                                    <span>@session.Subject</span>
                                    <span class="parent-session-time">@session.TimeDisplay</span>
                                </div>
                                <span class="parent-tag parent-tag--online">@L["Tag_Online"]</span>
                            </li>
                        }
                    </ul>
                </div>

                <div class="section-card">
                    <div class="section-card-header">
                        <h2>@L["ParentDashboard_HomeworkTodo"]</h2>
                        <a href="/parent/homework" class="parent-link-more">@L["Button_ViewAll"]</a>
                    </div>
                    <ul class="parent-homework-list">
                        @foreach (var hw in _homeworkItems)
                        {
                            <li class="parent-homework-item">
                                <div>
                                    <strong>@hw.Title</strong>
                                    <span>@hw.Child — @hw.DueDate</span>
                                </div>
                                <span class="parent-tag parent-tag--@hw.TagClass">
                                    @if (hw.TagClass == "done")
                                    {
                                        <i class="bi bi-check-lg"></i>
                                    }
                                    @hw.TagLabel
                                </span>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </div>

        <div class="parent-row-widgets">
            <div class="section-card">
                <div class="section-card-header">
                    <h2>@L["StudentDashboard_RecentReports"]</h2>
                    <a href="/parent/reports" class="parent-link-more">@L["Button_ViewAll"]</a>
                </div>
                <ul class="parent-report-list">
                    @foreach (var report in _recentReports)
                    {
                        <li class="parent-report-item">
                            <div class="parent-report-avatar">@report.Initials</div>
                            <div class="parent-report-info">
                                <strong>@report.TutorName</strong>
                                <span>@report.Subject</span>
                                <div class="parent-stars">
                                    @for (var s = 0; s < 5; s++)
                                    {
                                        <i class="bi bi-star-fill @(s < report.Stars ? "filled" : "")"></i>
                                    }
                                </div>
                            </div>
                            <div class="parent-report-grade">
                                <strong>@report.Grade</strong>
                                <span>@report.When</span>
                            </div>
                        </li>
                    }
                </ul>
            </div>

            <div class="section-card">
                <div class="section-card-header">
                    <h2>@L["ParentDashboard_RecentMessages"]</h2>
                    <a href="/parent/messages" class="parent-link-more">@L["Button_ViewAll"]</a>
                </div>
                <ul class="parent-message-list">
                    @foreach (var msg in _recentMessages)
                    {
                        <li class="parent-message-item">
                            <div class="parent-message-avatar">@msg.Initials</div>
                            <div class="parent-message-info">
                                <strong>@msg.From</strong>
                                <span>@msg.Preview</span>
                            </div>
                            @if (msg.Unread > 0)
                            {
                                <span class="parent-message-badge">@msg.Unread</span>
                            }
                        </li>
                    }
                </ul>
            </div>

            <div class="section-card parent-payment-card">
                <div class="section-card-header">
                    <h2>@L["Parent_RecentPayment"]</h2>
                </div>
                <div class="parent-payment-body">
                    <div class="parent-payment-status">
                        <i class="bi bi-check-circle-fill text-success"></i>
                        <span>@L["ParentDashboard_PaymentSuccess"]</span>
                    </div>
                    <p class="parent-payment-amount">149,00 $</p>
                    <div class="parent-payment-method">
                        <i class="bi bi-credit-card-2-front"></i>
                        <span>Visa •••• 4242</span>
                    </div>
                    <a href="/parent/payments" class="parent-payment-link">@L["ParentDashboard_ViewHistory"]</a>
                </div>
            </div>

            <div class="section-card">
                <div class="section-card-header">
                    <h2>@L["ParentDashboard_RecentDocuments"]</h2>
                    <a href="/parent/documents" class="parent-link-more">@L["Button_ViewAll"]</a>
                </div>
                <ul class="parent-doc-list">
                    @foreach (var doc in _recentDocuments)
                    {
                        <li class="parent-doc-item">
                            <i class="bi @doc.Icon parent-doc-icon"></i>
                            <div class="parent-doc-info">
                                <strong>@doc.Name</strong>
                                <span>@doc.Size</span>
                            </div>
                            <button type="button" class="parent-doc-download" aria-label="@L["ParentDashboard_Download"]">
                                <i class="bi bi-download"></i>
                            </button>
                        </li>
                    }
                </ul>
            </div>
        </div>

        <div class="parent-quick-actions">
            <a href="/parent/children" class="parent-quick-action"><i class="bi bi-person-plus"></i>@L["ParentDashboard_AddChild"]</a>
            <a href="/parent/search" class="parent-quick-action"><i class="bi bi-search"></i>@L["ParentDashboard_FindTutor"]</a>
            <a href="/parent/calendar" class="parent-quick-action"><i class="bi bi-calendar-plus"></i>@L["ParentDashboard_ScheduleClass"]</a>
            <a href="/parent/payments" class="parent-quick-action"><i class="bi bi-credit-card"></i>@L["ParentDashboard_PayOnline"]</a>
            <a href="/parent/messages" class="parent-quick-action"><i class="bi bi-send"></i>@L["ParentDashboard_SendMessage"]</a>
        </div>
    }
</div>

@code {
    private static readonly string[] AvatarColors =
        ["#5831e0", "#ec4899", "#0ea5e9", "#10b981", "#f59e0b", "#8b5cf6"];

    private static readonly string[] ProgressVariants = ["purple", "pink", "purple", "pink"];

    private string _parentName = "Parent";
    private bool _loading = true;
    private int _coursesToday;
    private string _nextCourseLabel = "—";
    private string _averageGrade = "16,8 /20";
    private List<ChildCard> _children = [];
    private List<SessionItem> _upcomingSessions = [];
    private List<HomeworkItem> _homeworkItems = [];
    private List<MessageItem> _recentMessages = [];
    private List<DocumentItem> _recentDocuments = [];
    private List<ReportItem> _recentReports = [];
    private List<WeekDay> _weekDays = [];
    private List<string> _chartChildNames = ["Noah", "Emma"];

    protected override async Task OnInitializedAsync()
    {
        BuildWeekCalendar();
        BuildPlaceholderWidgets();

        try
        {
            var me = await Api.GetAsync<ParentMeDto>("api/parent/me");
            if (me is not null)
                _parentName = $"{me.FirstName} {me.LastName}".Trim();

            var students = await Api.GetAsync<List<StudentDto>>("api/parent/children") ?? [];
            _children = students.Select((s, i) => MapChild(s, i)).ToList();
            _chartChildNames = _children.Take(2).Select(c => c.Name.Split(' ')[0]).ToList();
        }
        catch { }

        if (_children.Count == 0)
            _children = GetDemoChildren();

        if (_chartChildNames.Count == 0)
            _chartChildNames = _children.Take(2).Select(c => c.Name).ToList();

        try
        {
            var lessons = await LessonSvc.GetLessonsAsync();
            var upcoming = lessons
                .Where(l => l.StartTime >= DateTime.UtcNow)
                .OrderBy(l => l.StartTime)
                .Take(5)
                .ToList();

            _coursesToday = lessons.Count(l => l.StartTime.Date == DateTime.Today);
            var next = upcoming.FirstOrDefault();
            _nextCourseLabel = next is null
                ? L["ParentDashboard_NextAt", "17h00"]
                : L["ParentDashboard_NextAt", next.StartTime.ToLocalTime().ToString("HH:mm")];

            if (upcoming.Count > 0)
            {
                _upcomingSessions = upcoming.Take(3).Select(MapSession).ToList();
            }
        }
        catch { }

        if (_upcomingSessions.Count == 0)
            _upcomingSessions = GetDemoSessions();

        if (_coursesToday == 0)
            _coursesToday = 3;

        if (_children.Count >= 2)
            _averageGrade = "16,8 /20";
        else if (_children.Count == 1)
            _averageGrade = _children[0].GradeDisplay;

        _loading = false;
    }

    private List<ChildCard> GetDemoChildren() =>
    [
        new("Noah", "N", AvatarColors[0], "images/parent/noah.png", "6e année",
            "18/20", "91%", 91, "purple",
            L["ParentDashboard_NextClassToday"],
            L["Subject_Math"]),
        new("Emma", "E", AvatarColors[1], "images/parent/emma.png", "5e année",
            "15/20", "78%", 78, "pink",
            L["ParentDashboard_HomeworkDueTomorrow"],
            L["ParentDashboard_HomeworkExercise", "Science", "4"]),
    ];

    private List<SessionItem> GetDemoSessions() =>
    [
        new("Mme Sophie", L["Subject_Math"], "MS", "Aujourd'hui · 17h00"),
        new("M. Robert", L["Subject_Science"], "MR", "Demain · 10h00"),
        new("Mme Julie", L["Subject_English"], "MJ", "Ven. · 14h00"),
    ];

    private ChildCard MapChild(StudentDto s, int index)
    {
        var name = $"{s.FirstName} {s.LastName}".Trim();
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        var initials = parts.Length >= 2
            ? $"{parts[0][0]}{parts[^1][0]}".ToUpperInvariant()
            : name.Length > 0 ? name[..1].ToUpperInvariant() : "?";

        var demoGrades = new[] { (18.0m, 91), (15.0m, 78), (16.5m, 85), (14.0m, 72) };
        var (grade, pct) = index < demoGrades.Length ? demoGrades[index] : (15.0m + index, 70 + index * 3);

        var photo = index switch
        {
            0 => "images/parent/noah.png",
            1 => "images/parent/emma.png",
            _ => null
        };

        return new ChildCard(
            name,
            initials,
            AvatarColors[index % AvatarColors.Length],
            photo,
            s.SchoolLevel ?? "—",
            $"{grade:0.#}/20",
            $"{pct}%",
            pct,
            ProgressVariants[index % ProgressVariants.Length],
            index == 0 ? L["ParentDashboard_NextClassToday"] : L["ParentDashboard_HomeworkDueTomorrow"],
            s.Subjects?.FirstOrDefault() ?? L["Subject_Math"]);
    }

    private static SessionItem MapSession(LessonDto l)
    {
        var title = l.Title;
        var initials = title.Length > 0 ? title[0].ToString().ToUpperInvariant() : "?";
        return new SessionItem(
            title,
            l.Subject ?? "—",
            initials,
            l.StartTime.ToLocalTime().ToString("ddd · HH:mm"));
    }

    private void BuildWeekCalendar()
    {
        var start = DateTime.Today.AddDays(-(int)DateTime.Today.DayOfWeek + (int)DayOfWeek.Monday);
        if (DateTime.Today.DayOfWeek == DayOfWeek.Sunday)
            start = start.AddDays(-7);

        var eventsByDay = new List<List<CalEvent>>
        {
            new() { new(L["Subject_Math"], "Noah", "09:00", "purple") },
            new() { new(L["Subject_English"], "Emma", "11:00", "pink") },
            new() { new(L["Subject_Science"], "Noah", "14:00", "green") },
            new() { new(L["Subject_French"], "Emma", "16:00", "orange") },
            new(),
        };

        _weekDays = Enumerable.Range(0, 5).Select(i =>
        {
            var d = start.AddDays(i);
            return new WeekDay(
                d.ToString("ddd dd"),
                d.Date == DateTime.Today,
                eventsByDay[i]);
        }).ToList();
    }

    private void BuildPlaceholderWidgets()
    {
        _homeworkItems =
        [
            new("Exercices ch. 5 — Algèbre", "Emma", "Demain", L["Tag_Urgent"], "urgent"),
            new("Rédaction — Dissertation", "Noah", "Vendredi", L["Tag_Important"], "important"),
            new("Fiche de révision", "Emma", "Lundi", L["Tag_Done"], "done"),
        ];

        _recentMessages =
        [
            new("Mme Sophie", "MS", "Bonjour ! Le rapport de la séance est disponible.", 2),
            new("M. Robert", "MR", "Prochain cours confirmé pour demain.", 0),
            new("Support TutorSphere", "TS", "Votre facture de juin est prête.", 1),
        ];

        _recentDocuments =
        [
            new("Rapport Mathématiques — Avril", "2,4 Mo", "bi-file-earmark-pdf-fill"),
            new("Devoir Sciences — Exercice 4", "856 Ko", "bi-file-earmark-pdf-fill"),
            new("Facture — Juin 2026", "124 Ko", "bi-file-earmark-pdf-fill"),
        ];

        _recentReports =
        [
            new("Mme Sophie", "MS", L["Subject_Math"], 5, "18/20", "Il y a 2 j"),
            new("M. Robert", "MR", L["Subject_Science"], 5, "16/20", "Il y a 5 j"),
            new("Mme Julie", "MJ", L["Subject_English"], 4, "15/20", "Il y a 1 sem."),
        ];
    }

    private record ChildCard(
        string Name, string Initials, string Color, string? PhotoUrl, string Level,
        string GradeDisplay, string PercentDisplay, int Percent, string ProgressVariant,
        string NextClass, string SubjectLabel);

    private record SessionItem(string Title, string Subject, string Initials, string TimeDisplay);
    private record HomeworkItem(string Title, string Child, string DueDate, string TagLabel, string TagClass);
    private record MessageItem(string From, string Initials, string Preview, int Unread);
    private record DocumentItem(string Name, string Size, string Icon);
    private record ReportItem(string TutorName, string Initials, string Subject, int Stars, string Grade, string When);
    private record WeekDay(string Label, bool IsToday, List<CalEvent> Events);
    private record CalEvent(string Title, string Subtitle, string Time, string Color);

    private record StudentDto(
        Guid Id, string FirstName, string LastName, string? Email,
        DateTime? DateOfBirth, string? SchoolLevel, string? SchoolName,
        IReadOnlyList<string>? Subjects);

    private record ParentMeDto(string FirstName, string LastName, string Email, int ChildrenCount);
}
