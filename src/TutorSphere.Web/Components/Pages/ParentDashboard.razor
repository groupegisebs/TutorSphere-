@page "/parent"
@page "/parent/dashboard"
@inject IStringLocalizer<SharedResources> L

<PageTitle>@L["PageTitle_ParentDashboard"]</PageTitle>

<PageHeader Title="@L["Parent_Title"]" Subtitle="@L["Parent_Subtitle"]" />

<div class="row g-3 mb-4">
    <div class="col-sm-6 col-xl-3">
        <StatCard Label="@L["Nav_MyChildren"]" Value="0" Icon="bi-people-fill" Variant="students" />
    </div>
    <div class="col-sm-6 col-xl-3">
        <StatCard Label="@L["Nav_MySubscriptions"]" Value="0" Icon="bi-arrow-repeat" Variant="subscriptions" />
    </div>
    <div class="col-sm-6 col-xl-3">
        <StatCard Label="@L["Stat_UpcomingLessons"]" Value="0" Icon="bi-calendar-event" Variant="lessons" />
    </div>
    <div class="col-sm-6 col-xl-3">
        <StatCard Label="@L["Stat_PendingPayments"]" Value="0" Icon="bi-wallet2" Variant="payments" />
    </div>
</div>

<div class="row g-4">
    <div class="col-md-4">
        <div class="feature-card">
            <div class="feature-icon feature-icon--indigo"><i class="bi bi-people-fill"></i></div>
            <h4>@L["Parent_MyChildren_Title"]</h4>
            <p>@L["Parent_MyChildren_Description"]</p>
        </div>
    </div>
    <div class="col-md-4">
        <div class="feature-card">
            <div class="feature-icon feature-icon--cyan"><i class="bi bi-credit-card-2-front"></i></div>
            <h4>@L["Parent_Subscriptions_Title"]</h4>
            <p>@L["Parent_Subscriptions_Description"]</p>
        </div>
    </div>
    <div class="col-md-4">
        <div class="feature-card">
            <div class="feature-icon feature-icon--amber"><i class="bi bi-file-earmark-bar-graph"></i></div>
            <h4>@L["Parent_Reports_Title"]</h4>
            <p>@L["Parent_Reports_Description"]</p>
        </div>
    </div>
</div>
