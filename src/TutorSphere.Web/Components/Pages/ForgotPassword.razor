@page "/forgot-password"
@layout LoginLayout
@rendermode InteractiveServer
@inject HttpClient Http
@inject NavigationManager Navigation

<PageTitle>Mot de passe oublié – TutorSphere</PageTitle>

<div class="login-page login-theme-tutor">

    <!-- Left panel -->
    <div class="login-illustration">
        <div class="login-illustration-content">
            <div class="login-brand">
                <img src="images/tutorsphere-logo-full.png" alt="TutorSphere" class="app-logo-full login-logo" />
            </div>
            <div class="login-hero-block">
                <h2 class="login-hero-title">
                    Récupérez<br>
                    <span>votre accès</span>
                </h2>
                <p class="login-hero-subtitle">Entrez votre adresse e-mail et nous vous enverrons un lien pour réinitialiser votre mot de passe.</p>
            </div>
            <svg class="login-illustration-img" viewBox="0 0 420 300" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <circle cx="210" cy="150" r="90" fill="#ede9fe" opacity="0.5"/>
                <rect x="150" y="120" width="120" height="80" rx="10" fill="#fff" stroke="#5831E0" stroke-width="3"/>
                <rect x="165" y="138" width="90" height="6" rx="3" fill="#5831E0" opacity="0.4"/>
                <rect x="165" y="152" width="70" height="6" rx="3" fill="#5831E0" opacity="0.3"/>
                <rect x="165" y="166" width="80" height="6" rx="3" fill="#5831E0" opacity="0.2"/>
                <circle cx="210" cy="108" r="22" fill="#5831E0" opacity="0.15"/>
                <path d="M200 108 L210 100 L220 108 L220 120 L200 120 Z" fill="#5831E0" opacity="0.6"/>
                <circle cx="210" cy="113" r="3" fill="white"/>
                <rect x="208" y="108" width="4" height="7" rx="2" fill="white"/>
                <circle cx="290" cy="90" r="4" fill="#5831E0" opacity="0.3"/>
                <circle cx="130" cy="180" r="3" fill="#7C5CFF" opacity="0.25"/>
                <circle cx="300" cy="200" r="5" fill="#5831E0" opacity="0.2"/>
            </svg>
        </div>
    </div>

    <!-- Right panel -->
    <div class="login-form-panel">
        <div class="login-form-inner">

            <a href="/login" class="login-back-link">
                <i class="bi bi-arrow-left me-1"></i>Retour à la connexion
            </a>

            @if (_success)
            {
                <div class="text-center mt-4">
                    <div style="font-size:3.5rem;margin-bottom:1rem">📧</div>
                    <h1 style="font-size:1.6rem;margin-bottom:.5rem">Vérifiez vos courriels</h1>
                    <p class="login-subtitle">
                        Si l'adresse <strong>@_email</strong> est associée à un compte TutorSphere,
                        un lien de réinitialisation vous a été envoyé.
                    </p>
                    <p class="text-muted" style="font-size:.875rem">
                        Vérifiez votre dossier spam si vous ne recevez rien dans les 5 minutes.
                    </p>
                    <a href="/login" class="btn btn-primary mt-3 px-5">
                        <i class="bi bi-arrow-left me-1"></i>Retour à la connexion
                    </a>
                </div>
            }
            else
            {
                <h1>Mot de passe oublié ?</h1>
                <p class="login-subtitle">Saisissez votre adresse e-mail pour recevoir un lien de réinitialisation.</p>

                @if (!string.IsNullOrEmpty(_error))
                {
                    <div class="alert alert-danger mb-3">
                        <i class="bi bi-exclamation-circle me-2"></i>@_error
                    </div>
                }

                <form class="login-form" @onsubmit="SendResetLinkAsync" @onsubmit:preventDefault="true">
                    <div class="mb-4">
                        <label class="form-label" for="fp-email">Adresse e-mail</label>
                        <div class="form-field-icon">
                            <i class="bi bi-envelope field-icon" aria-hidden="true"></i>
                            <input type="email" id="fp-email" class="form-control"
                                   placeholder="votre@email.com"
                                   @bind="_email" @bind:event="oninput" />
                        </div>
                    </div>

                    <button type="submit" class="btn btn-primary btn-lg w-100 login-submit-btn" disabled="@_sending">
                        @if (_sending)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                            <span>Envoi en cours…</span>
                        }
                        else
                        {
                            <i class="bi bi-send me-2"></i>
                            <span>Envoyer le lien</span>
                        }
                    </button>
                </form>

                <p class="login-footer text-center mt-4">
                    Vous vous souvenez ? <a href="/login/tuteur">Connexion tuteur</a> ·
                    <a href="/login/parent">Parent</a> · <a href="/login/eleve">Élève</a>
                </p>
            }
        </div>
    </div>
</div>

@code {
    private string _email = "";
    private bool _sending;
    private bool _success;
    private string? _error;

    private async Task SendResetLinkAsync()
    {
        _error = null;
        if (string.IsNullOrWhiteSpace(_email))
        {
            _error = "Veuillez saisir votre adresse e-mail.";
            return;
        }
        _sending = true;
        try
        {
            var resp = await Http.PostAsJsonAsync("api/auth/forgot-password", new { email = _email });
            // Always show success to avoid email enumeration (the API does this too)
            _success = true;
        }
        catch
        {
            _error = "Erreur de connexion au serveur. Réessayez dans quelques instants.";
        }
        finally
        {
            _sending = false;
        }
    }
}
