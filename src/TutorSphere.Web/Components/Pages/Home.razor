@page "/"
@layout PublicLayout
@rendermode InteractiveServer
@inject IStringLocalizer<SharedResources> L
@inject IJSRuntime JS

<PageTitle>@L["PageTitle_Home"]</PageTitle>

<HeadContent>
    <link rel="stylesheet" href="css/landing.css" />
</HeadContent>

<LandingHero />
<LandingWhy />
<LandingFeatures />
<LandingSteps />
<LandingHighlights />
<LandingTestimonials />
<LandingIntegrations />
<LandingVideo />
<LandingPricing />
<LandingFaq />
<LandingFinalCta />

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        try { await JS.InvokeVoidAsync("landingInit"); }
        catch { /* prerender / no circuit */ }
    }
}
