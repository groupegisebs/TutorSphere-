@page "/"
@layout PublicLayout
@rendermode InteractiveServer
@inject IStringLocalizer<SharedResources> L
@implements IAsyncDisposable
@inject IJSRuntime JS

<PageTitle>@L["PageTitle_Home"]</PageTitle>

<HeadContent>
    <link rel="stylesheet" href="css/landing.css" />
</HeadContent>

<LandingHero />
<LandingWhy />
<LandingFeatures />
<LandingSteps />
<LandingShowcase />
<LandingHighlights />
<LandingTestimonials />
<LandingIntegrations />
<LandingVideo />
<LandingPricing />
<LandingFaq />
<LandingFinalCta />

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try { await JS.InvokeVoidAsync("landingInit"); }
            catch { /* prerender */ }
        }
    }

    public async ValueTask DisposeAsync()
    {
        try { await JS.InvokeVoidAsync("eval", "window.__landingInitialized = false"); }
        catch { /* ignore */ }
    }
}
