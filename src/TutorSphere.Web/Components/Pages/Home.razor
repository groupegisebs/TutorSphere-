@page "/"
@inject IStringLocalizer<SharedResources> L

<PageTitle>@L["PageTitle_Home"]</PageTitle>

<section class="hero">
    <div class="hero-content">
        <img class="hero-logo" src="images/tutorsphere-logo.png" alt="@L["AppName"]" />
        <p class="hero-tagline">@L["AppTagline"]</p>
        <p class="lead">@L["Hero_Lead"]</p>
        <div class="hero-actions">
            <a class="btn btn-primary btn-lg" href="/tutor/register">
                <i class="bi bi-plus-circle me-2"></i>@L["Hero_CreateSchool"]
            </a>
            <a class="btn btn-ghost-light btn-lg" href="/parent">
                <i class="bi bi-people me-2"></i>@L["Hero_ParentSpace"]
            </a>
        </div>
        <div class="hero-stats">
            <div>
                <span class="hero-stat-value">500+</span>
                <span class="hero-stat-label">@L["Feature_Tutors_Title"]</span>
            </div>
            <div>
                <span class="hero-stat-value">10k+</span>
                <span class="hero-stat-label">@L["Feature_Students_Title"]</span>
            </div>
            <div>
                <span class="hero-stat-value">98%</span>
                <span class="hero-stat-label">@L["Feature_Parents_Title"]</span>
            </div>
        </div>
    </div>
</section>

<section class="features container py-5">
    <div class="row g-4">
        <div class="col-md-4">
            <div class="feature-card">
                <div class="feature-icon feature-icon--indigo">
                    <i class="bi bi-person-workspace"></i>
                </div>
                <h3>@L["Feature_Tutors_Title"]</h3>
                <p>@L["Feature_Tutors_Description"]</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="feature-card">
                <div class="feature-icon feature-icon--cyan">
                    <i class="bi bi-heart"></i>
                </div>
                <h3>@L["Feature_Parents_Title"]</h3>
                <p>@L["Feature_Parents_Description"]</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="feature-card">
                <div class="feature-icon feature-icon--emerald">
                    <i class="bi bi-mortarboard"></i>
                </div>
                <h3>@L["Feature_Students_Title"]</h3>
                <p>@L["Feature_Students_Description"]</p>
            </div>
        </div>
    </div>
</section>

<section class="plans container pb-5">
    <div class="section-header">
        <h2>@L["Plans_Title"]</h2>
    </div>
    <div class="row g-4 justify-content-center">
        <div class="col-md-4 col-lg-3">
            <div class="plan-card">
                <h4>@L["Plan_Starter"]</h4>
                <p class="price">@L["Plan_PricePerMonth", "14,99"]</p>
                <p class="price-period">/ @L["Plan_Starter"]</p>
            </div>
        </div>
        <div class="col-md-4 col-lg-3">
            <div class="plan-card featured">
                <h4>@L["Plan_Professional"]</h4>
                <p class="price">@L["Plan_PricePerMonth", "29,99"]</p>
                <p class="price-period">/ @L["Plan_Professional"]</p>
            </div>
        </div>
        <div class="col-md-4 col-lg-3">
            <div class="plan-card">
                <h4>@L["Plan_Business"]</h4>
                <p class="price">@L["Plan_PricePerMonth", "59,99"]</p>
                <p class="price-period">/ @L["Plan_Business"]</p>
            </div>
        </div>
    </div>
</section>
