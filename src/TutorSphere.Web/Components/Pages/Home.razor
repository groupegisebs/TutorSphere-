@page "/"
@inject IStringLocalizer<SharedResources> L

<PageTitle>@L["PageTitle_Home"]</PageTitle>

<section class="hero">
    <div class="hero-content">
        <h1>@L["AppName"]</h1>
        <p class="lead">
            @L["Hero_Lead"]
        </p>
        <div class="hero-actions">
            <a class="btn btn-primary btn-lg" href="/tutor/register">@L["Hero_CreateSchool"]</a>
            <a class="btn btn-outline-light btn-lg" href="/parent">@L["Hero_ParentSpace"]</a>
        </div>
    </div>
</section>

<section class="features container py-5">
    <div class="row g-4">
        <div class="col-md-4">
            <div class="feature-card">
                <h3>@L["Feature_Tutors_Title"]</h3>
                <p>@L["Feature_Tutors_Description"]</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="feature-card">
                <h3>@L["Feature_Parents_Title"]</h3>
                <p>@L["Feature_Parents_Description"]</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="feature-card">
                <h3>@L["Feature_Students_Title"]</h3>
                <p>@L["Feature_Students_Description"]</p>
            </div>
        </div>
    </div>
</section>

<section class="plans container py-5">
    <h2 class="text-center mb-4">@L["Plans_Title"]</h2>
    <div class="row g-4 justify-content-center">
        <div class="col-md-3">
            <div class="plan-card">
                <h4>@L["Plan_Starter"]</h4>
                <p class="price">@L["Plan_PricePerMonth", "14,99"]</p>
            </div>
        </div>
        <div class="col-md-3">
            <div class="plan-card featured">
                <h4>@L["Plan_Professional"]</h4>
                <p class="price">@L["Plan_PricePerMonth", "29,99"]</p>
            </div>
        </div>
        <div class="col-md-3">
            <div class="plan-card">
                <h4>@L["Plan_Business"]</h4>
                <p class="price">@L["Plan_PricePerMonth", "59,99"]</p>
            </div>
        </div>
    </div>
</section>
