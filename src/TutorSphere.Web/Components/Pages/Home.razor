@page "/"

<PageTitle>TutorSphere — Votre école numérique</PageTitle>

<section class="hero">
    <div class="hero-content">
        <h1>TutorSphere</h1>
        <p class="lead">
            L'ERP de référence pour les répétiteurs indépendants et centres de soutien scolaire.
            Créez votre école virtuelle, gérez vos élèves, vos abonnements et vos revenus en quelques minutes.
        </p>
        <div class="hero-actions">
            <a class="btn btn-primary btn-lg" href="/tutor/register">Créer mon école</a>
            <a class="btn btn-outline-light btn-lg" href="/parent">Espace parent</a>
        </div>
    </div>
</section>

<section class="features container py-5">
    <div class="row g-4">
        <div class="col-md-4">
            <div class="feature-card">
                <h3>Répétiteurs</h3>
                <p>Tableau de bord professionnel : élèves, calendrier, abonnements, facturation, rapports pédagogiques.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="feature-card">
                <h3>Parents</h3>
                <p>Inscrivez vos enfants, suivez leur progression, consultez les rapports et gérez les paiements.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="feature-card">
                <h3>Élèves</h3>
                <p>Accédez à vos cours, devoirs, documents et messages dans un environnement simple et sécurisé.</p>
            </div>
        </div>
    </div>
</section>

<section class="plans container py-5">
    <h2 class="text-center mb-4">Forfaits répétiteurs</h2>
    <div class="row g-4 justify-content-center">
        <div class="col-md-3">
            <div class="plan-card">
                <h4>Starter</h4>
                <p class="price">14,99 $/mois</p>
            </div>
        </div>
        <div class="col-md-3">
            <div class="plan-card featured">
                <h4>Professional</h4>
                <p class="price">29,99 $/mois</p>
            </div>
        </div>
        <div class="col-md-3">
            <div class="plan-card">
                <h4>Business</h4>
                <p class="price">59,99 $/mois</p>
            </div>
        </div>
    </div>
</section>
