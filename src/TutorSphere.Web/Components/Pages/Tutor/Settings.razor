@page "/tutor/settings"
@layout TutorLayout
@rendermode InteractiveServer
@inject IStringLocalizer<SharedResources> L
@inject ApiClient Api
@inject NavigationManager Nav
@inject IJSRuntime JS

<PageTitle>@L["Settings_Title"] – TutorSphere</PageTitle>

<div class="ts-page-header">
    <div>
        <h1><i class="bi bi-sliders me-2"></i>@L["Settings_Title"]</h1>
        <p class="ts-page-subtitle">@L["Settings_Subtitle"]</p>
    </div>
    <button class="btn btn-primary" @onclick="SaveSettings" disabled="@_saving">
        @if (_saving) { <span class="spinner-border spinner-border-sm me-1"></span> }
        @L["Common_Save"]
    </button>
</div>

@if (!string.IsNullOrEmpty(_error))
{
    <div class="alert alert-danger mb-4">@_error</div>
}
@if (_saved)
{
    <div class="alert alert-success mb-4">
        <i class="bi bi-check-circle me-2"></i>@L["Settings_Saved"]
    </div>
}

<div class="settings-layout">
    <nav class="settings-nav">
        @foreach (var s in _sections)
        {
            <button class="settings-nav-item @(_section==s.Key?"active":"")"
                    @onclick="()=>_section=s.Key">
                <i class="bi @s.Icon"></i>
                <span>@s.Label</span>
            </button>
        }
    </nav>

    <div class="settings-content">
        @if (_section == "notifications")
        {
            <div class="settings-section">
                <h2 class="settings-section-title">@L["Settings_EmailNotifications"]</h2>
                <p class="text-muted small mb-3">
                    Les rappels de cours sont envoyés via Mail Sender environ 24&nbsp;h avant la séance
                    (enseignant, élève et parent selon les inscriptions).
                </p>
                <div class="settings-toggle-row">
                    <div>
                        <strong>@L["Settings_LessonReminder"]</strong>
                        <p class="text-muted mb-0 small">@L["Settings_LessonReminderDesc"]</p>
                    </div>
                    <div class="form-check form-switch mb-0">
                        <input class="form-check-input" type="checkbox" @bind="_emailLessonReminders" id="notif-lesson" />
                        <label class="form-check-label small" for="notif-lesson">E-mail</label>
                    </div>
                </div>
            </div>
        }
        else if (_section == "calendar")
        {
            <div class="settings-section">
                <h2 class="settings-section-title">@L["Settings_SyncCalendar"]</h2>
                <p class="text-muted small mb-3">
                    Abonnez-vous à votre calendrier TutorSphere depuis Google Agenda, Outlook, Apple Calendar
                    ou toute application compatible ICS / webcal.
                </p>

                @if (_feedLoading)
                {
                    <div class="text-muted">@L["Common_Loading"]</div>
                }
                else if (_feed is null || !_feed.IsEnabled || string.IsNullOrEmpty(_feed.FeedUrl))
                {
                    <p class="mb-3">@L["Settings_NoActiveSub"]</p>
                    <button class="btn btn-primary" @onclick="EnableFeedAsync" disabled="@_feedBusy">
                        Activer la synchronisation
                    </button>
                }
                else
                {
                    <div class="mb-3">
                        <label class="form-label">@L["Settings_HttpsUrl"]</label>
                        <div class="input-group">
                            <input class="form-control" readonly value="@_feed.FeedUrl" />
                            <button class="btn btn-outline-secondary" type="button" @onclick="() => Copy(_feed.FeedUrl!)">@L["Common_Copy"]</button>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">@L["Settings_WebcalUrl"]</label>
                        <div class="input-group">
                            <input class="form-control" readonly value="@_feed.WebcalUrl" />
                            <button class="btn btn-outline-secondary" type="button" @onclick="() => Copy(_feed.WebcalUrl!)">@L["Common_Copy"]</button>
                        </div>
                    </div>
                    <p class="text-muted small">@_feed.Instructions</p>
                    <div class="d-flex gap-2 mt-3">
                        <button class="btn btn-outline-secondary btn-sm" @onclick="EnableFeedAsync" disabled="@_feedBusy">
                            Régénérer le lien
                        </button>
                        <button class="btn btn-outline-danger btn-sm" @onclick="DisableFeedAsync" disabled="@_feedBusy">
                            Désactiver
                        </button>
                    </div>
                    @if (!string.IsNullOrEmpty(_copyMsg))
                    {
                        <div class="alert alert-info mt-3 py-2 mb-0">@_copyMsg</div>
                    }
                }
            </div>
        }
        else if (_section == "general")
        {
            <div class="settings-section">
                <h2 class="settings-section-title">@L["Common_General"]</h2>
                <div class="row g-3">
                    <div class="col-md-6"><label class="form-label">@L["Common_Language"]</label>
                        <select class="form-select" @bind="_s.Language">
                            <option value="fr">Français</option>
                            <option value="en">English</option>
                            <option value="es">Español</option>
                            <option value="de">Deutsch</option>
                            <option value="pt">Português</option>
                            <option value="zh-Hans">中文</option>
                            <option value="ar">العربية</option>
                        </select></div>
                    <div class="col-md-6"><label class="form-label">@L["Common_Timezone"]</label>
                        <select class="form-select" @bind="_s.Timezone">
                            <option>America/Montreal</option><option>Europe/Paris</option>
                            <option>Europe/Brussels</option><option>Africa/Casablanca</option>
                        </select></div>
                </div>
            </div>
        }
    </div>
</div>

@code {
    private string _section = "notifications";
    private bool _saving, _saved, _feedLoading = true, _feedBusy;
    private bool _emailLessonReminders = true;
    private string? _error;
    private string? _copyMsg;
    private CalendarFeedDto? _feed;

    private (string Key, string Label, string Icon)[] _sections =>
    [
        ("notifications", L["Common_Notifications"], "bi-bell"),
        ("calendar", L["Common_Calendar"], "bi-calendar2-check"),
        ("general", L["Common_General"], "bi-gear"),
    ];

    private class SettingsVM
    {
        public string Language { get; set; } = "Français";
        public string Timezone { get; set; } = "America/Montreal";
    }
    private SettingsVM _s = new();

    private record NotificationPreferencesDto(bool EmailLessonReminders);
    private record CalendarFeedDto(bool IsEnabled, string? FeedUrl, string? WebcalUrl, string Instructions);

    protected override async Task OnInitializedAsync()
    {
        var prefs = await Api.GetAsync<NotificationPreferencesDto>("api/me/notification-preferences");
        if (prefs is not null)
            _emailLessonReminders = prefs.EmailLessonReminders;

        _feed = await Api.GetAsync<CalendarFeedDto>("api/me/calendar-feed");
        _feedLoading = false;
    }

    private async Task SaveSettings()
    {
        _saving = true;
        _saved = false;
        _error = null;
        try
        {
            var result = await Api.PutWithErrorAsync<NotificationPreferencesDto>(
                "api/me/notification-preferences",
                new { emailLessonReminders = _emailLessonReminders });
            if (result.Error is not null)
            {
                _error = result.Error;
                return;
            }
            _saved = true;
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task EnableFeedAsync()
    {
        _feedBusy = true;
        _copyMsg = null;
        try
        {
            _feed = await Api.PostAsync<CalendarFeedDto>("api/me/calendar-feed/regenerate", new { });
        }
        finally
        {
            _feedBusy = false;
        }
    }

    private async Task DisableFeedAsync()
    {
        _feedBusy = true;
        _copyMsg = null;
        try
        {
            await Api.DeleteAsync("api/me/calendar-feed");
            _feed = await Api.GetAsync<CalendarFeedDto>("api/me/calendar-feed");
        }
        finally
        {
            _feedBusy = false;
        }
    }

    private async Task Copy(string value)
    {
        try
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", value);
            _copyMsg = "URL copiée dans le presse-papiers.";
        }
        catch
        {
            _copyMsg = $"Copiez l’URL : {value}";
        }
    }
}
