@page "/tutor/lessons"
@layout TutorLayout
@rendermode InteractiveServer
@inject IStringLocalizer<SharedResources> L
@inject LessonService LessonSvc
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>@L["Lessons_Title"] – TutorSphere</PageTitle>

<div class="ts-page-header">
    <div>
        <h1><i class="bi bi-journal-bookmark me-2"></i>@L["Lessons_Title"]</h1>
        <p class="ts-page-subtitle">@L["Lessons_Subtitle"]</p>
    </div>
    <button class="btn btn-primary" @onclick="OpenAdd">
        <i class="bi bi-plus-lg me-1"></i>@L["Lessons_New"]
    </button>
</div>

<!-- Quick stats -->
<div class="row g-3 mb-4">
    <div class="col-6 col-lg-3">
        <div class="ts-kpi-card"><span class="ts-kpi-val">@_lessons.Count(l=>l.Date.Date == DateTime.Today)</span><span class="ts-kpi-label">@L["Common_Today"]</span></div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="ts-kpi-card"><span class="ts-kpi-val">@_lessons.Count(l=>l.Date >= DateTime.Today.AddDays(-(int)DateTime.Today.DayOfWeek))</span><span class="ts-kpi-label">@L["Common_ThisWeek"]</span></div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="ts-kpi-card"><span class="ts-kpi-val">@_lessons.Count(l=>l.Status=="Terminé")</span><span class="ts-kpi-label">@L["Lessons_CompletedCount"]</span></div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="ts-kpi-card"><span class="ts-kpi-val">@_lessons.Sum(l=>l.Duration) h</span><span class="ts-kpi-label">@L["Lessons_HoursTaught"]</span></div>
    </div>
</div>

<!-- Filters -->
<div class="ts-toolbar">
    <div class="ts-search-box">
        <i class="bi bi-search ts-search-icon"></i>
        <input class="form-control" placeholder="@L["Lessons_SearchPlaceholder"]"
               @bind="_search" @bind:event="oninput" />
    </div>
    <select class="form-select w-auto" @bind="_filterStatus">
        <option value="">@L["Common_AllStatuses"]</option>
        <option value="Planifié">@L["Common_Planned"]</option>
        <option value="En cours">@L["Common_InProgress"]</option>
        <option value="Terminé">@L["Common_Completed"]</option>
        <option value="Annulé">@L["Common_Cancelled"]</option>
        <option value="Validé">@L["Lessons_StatusValidated"]</option>
        <option value="Moniteur absent">@L["Lessons_StatusTutorNoShow"]</option>
    </select>
    <select class="form-select w-auto" @bind="_filterMode">
        <option value="">@L["Common_AllModes"]</option>
        <option value="En ligne">@L["Common_Online"]</option>
        <option value="Présentiel">@L["Common_InPerson"]</option>
    </select>
</div>

<!-- Lessons table -->
<div class="ts-table-card">
    @if (_loading)
    {
        <div class="ts-loading-state">
            <div class="spinner-border text-primary" role="status"></div>
            <span class="ms-3 text-muted">@L["Common_Loading"]</span>
        </div>
    }
    else if (!string.IsNullOrEmpty(_error))
    {
        <div class="alert alert-warning m-3">
            <i class="bi bi-exclamation-triangle me-2"></i>@_error
        </div>
    }
    else
    {
        <table class="table ts-table">
            <thead>
                <tr>
                    <th>@L["Lessons_Col_DateTime"]</th><th>@L["Common_Student"]</th><th>@L["Common_Subject"]</th>
                    <th>@L["Common_Duration"]</th><th>@L["Common_Mode"]</th><th>@L["Common_Status"]</th><th>@L["Common_Actions"]</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var l in FilteredLessons)
                {
                    <tr>
                        <td>
                            <strong>@l.Date.ToString("dd MMM yyyy")</strong><br/>
                            <small class="text-muted">@l.Date.ToString("HH:mm") – @l.EndTime</small>
                        </td>
                        <td>
                            <div class="ts-cell-user">
                                <div class="ts-avatar ts-avatar-sm" style="background:@l.AvatarColor">@l.StudentInitials</div>
                                @(string.IsNullOrEmpty(l.StudentName) ? l.Title : l.StudentName)
                            </div>
                        </td>
                        <td>@l.Subject</td>
                        <td>@l.Duration h</td>
                        <td><span class="ts-badge ts-badge-neutral">@l.Mode</span></td>
                        <td><span class="ts-badge @StatusBadge(l.Status)">@l.Status</span></td>
                        <td>
                            <div class="ts-action-group">
                                @if (l.Status == "Planifié")
                                {
                                    <button class="ts-icon-btn" title="@L["Lessons_Start"]" @onclick="() => StartLesson(l)">
                                        <i class="bi bi-play-fill text-success"></i>
                                    </button>
                                }
                                @if (l.Status is "Terminé" or "En cours" or "Validé")
                                {
                                    <button class="ts-icon-btn" title="@L["Lessons_Report"]"><i class="bi bi-file-earmark-text"></i></button>
                                }
                                <button class="ts-icon-btn" title="@L["Lessons_Attendance"]" @onclick="() => OpenAttendance(l)">
                                    <i class="bi bi-person-check"></i>
                                </button>
                                @if (l.SettlementStatus is "Scheduled" or null or "")
                                {
                                    <button class="ts-icon-btn" title="@L["Lessons_Cancel24h"]" @onclick="async () => await CancelLesson(l)">
                                        <i class="bi bi-calendar-x text-warning"></i>
                                    </button>
                                }
                                @if (l.Status is "Terminé" or "Validé" or "En cours")
                                {
                                    <button class="ts-icon-btn" title="@L["Lessons_TutorNoShow"]" @onclick="async () => await MarkTutorNoShow(l)">
                                        <i class="bi bi-person-x text-danger"></i>
                                    </button>
                                }
                                @if (l.TutorLiable)
                                {
                                    <button class="ts-icon-btn" title="@L["Lessons_ResolveReschedule"]" @onclick="async () => await ResolveLiability(l, RescheduleResolution)">
                                        <i class="bi bi-arrow-repeat text-primary"></i>
                                    </button>
                                    <button class="ts-icon-btn" title="@L["Lessons_ResolveRefund"]" @onclick="async () => await ResolveLiability(l, RefundResolution)">
                                        <i class="bi bi-cash-coin text-success"></i>
                                    </button>
                                }
                                <button class="ts-icon-btn" title="@L["Common_Edit"]" @onclick="()=>OpenEdit(l)"><i class="bi bi-pencil"></i></button>
                                <button class="ts-icon-btn ts-icon-btn--danger" title="@L["Lessons_Delete"]"
                                        @onclick="async () => await DeleteLesson(l)">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

<!-- Add/Edit lesson modal -->
@if (_showModal)
{
    <div class="ts-modal-backdrop" @onclick="CloseModal">
        <div class="ts-modal" @onclick:stopPropagation="true">
            <div class="ts-modal-header">
                <h2>@(_editingLesson == null ? L["Lessons_New"] : L["Lessons_Edit"])</h2>
                <button class="ts-modal-close" @onclick="CloseModal"><i class="bi bi-x-lg"></i></button>
            </div>
            <div class="ts-modal-body">
                <div class="row g-3">
                    <div class="col-12"><label class="form-label">@L["Common_Title"]</label>
                        <input class="form-control" @bind="_lf.Title" /></div>
                    <div class="col-6"><label class="form-label">@L["Common_Student"]</label>
                        <input class="form-control" @bind="_lf.Student" /></div>
                    <div class="col-6"><label class="form-label">@L["Lessons_SubjectRequired"]</label>
                        <input class="form-control" @bind="_lf.Subject" /></div>
                    <div class="col-6"><label class="form-label">@L["Lessons_DateRequired"]</label>
                        <input type="date" class="form-control" @bind="_lf.Date" disabled="@_dateLocked" /></div>
                    <div class="col-3"><label class="form-label">@L["Lessons_StartTime"]</label>
                        <input type="time" class="form-control" @bind="_lf.StartTime" disabled="@_dateLocked" /></div>
                    <div class="col-3"><label class="form-label">@L["Lessons_DurationHours"]</label>
                        <input type="number" step="0.5" class="form-control" @bind="_lf.Duration" disabled="@_dateLocked" /></div>
                    @if (_dateLocked)
                    {
                        <div class="col-12">
                            <div class="alert alert-warning py-2 mb-0">@L["Lessons_DateLocked24h"]</div>
                        </div>
                    }
                    <div class="col-6"><label class="form-label">@L["Common_Mode"]</label>
                        <select class="form-select" @bind="_lf.Mode">
                            <option value="En ligne">@L["Common_Online"]</option>
                            <option value="Présentiel">@L["Common_InPerson"]</option>
                        </select></div>
                    <div class="col-6"><label class="form-label">@L["Lessons_Type"]</label>
                        <select class="form-select" @bind="_lf.Type">
                            <option value="Individuel">@L["Lessons_Individual"]</option>
                            <option value="Collectif">@L["Lessons_Group"]</option>
                            <option value="Intensif">@L["Lessons_Intensive"]</option>
                        </select></div>
                    <div class="col-12">
                        <label class="form-label">@L["Lessons_Recurrence"]</label>
                        <select class="form-select" @bind="_lf.Recurrence">
                            <option value="none">@L["Lessons_Once"]</option>
                            <option value="weekly">@L["Lessons_Weekly"]</option>
                            <option value="biweekly">@L["Lessons_Biweekly"]</option>
                            <option value="monthly">@L["Lessons_Monthly"]</option>
                        </select>
                    </div>
                    @if (_lf.Recurrence != "none" && _editingLesson is null)
                    {
                        <div class="col-6">
                            <label class="form-label">@L["Lessons_Occurrences"]</label>
                            <input type="number" class="form-control" min="2" max="52" @bind="_lf.Occurrences" />
                        </div>
                        <div class="col-6">
                            <label class="form-label">@L["Lessons_Until"]</label>
                            <input type="date" class="form-control" @bind="_lf.UntilDate" />
                        </div>
                    }
                    <div class="col-12"><label class="form-label">@L["Lessons_Description"]</label>
                        <textarea class="form-control" rows="2" @bind="_lf.Description"></textarea></div>
                </div>
            </div>
            <div class="ts-modal-footer">
                <button class="btn btn-outline-secondary" @onclick="CloseModal">@L["Common_Cancel"]</button>
                <button class="btn btn-primary" @onclick="async () => await SaveLesson()">@L["Common_Save"]</button>
            </div>
        </div>
    </div>
}

@if (_showAttendance && _attendanceLesson is not null)
{
    <div class="ts-modal-backdrop" @onclick="CloseAttendance">
        <div class="ts-modal" @onclick:stopPropagation="true">
            <div class="ts-modal-header">
                <h2>@L["Lessons_Attendance"] — @_attendanceLesson.Title</h2>
                <button class="ts-modal-close" @onclick="CloseAttendance"><i class="bi bi-x-lg"></i></button>
            </div>
            <div class="ts-modal-body">
                <p class="text-muted small mb-3">@L["Lessons_AttendanceHelp"]</p>
                @if (_attendanceLoading)
                {
                    <div class="text-center py-3"><span class="spinner-border spinner-border-sm"></span></div>
                }
                else if (_attendances.Count == 0)
                {
                    <p class="text-muted">@L["Lessons_NoStudents"]</p>
                }
                else
                {
                    <ul class="list-unstyled mb-0">
                        @foreach (var a in _attendances)
                        {
                            <li class="d-flex align-items-center justify-content-between py-2 border-bottom">
                                <span>@a.StudentName</span>
                                <div class="form-check form-switch m-0">
                                    <input class="form-check-input" type="checkbox" checked="@a.IsPresent"
                                           @onchange="async e => await ToggleAttendance(a, (bool)(e.Value ?? false))" />
                                    <label class="form-check-label">@(a.IsPresent ? L["Lessons_Present"] : L["Lessons_Absent"])</label>
                                </div>
                            </li>
                        }
                    </ul>
                }
            </div>
            <div class="ts-modal-footer">
                <button class="btn btn-primary" @onclick="CloseAttendance">@L["Common_Close"]</button>
            </div>
        </div>
    </div>
}

@code {
    private const string RescheduleResolution = "reschedule";
    private const string RefundResolution = "refund";

    private string _search = "", _filterStatus = "", _filterMode = "";
    private bool _showModal;
    private bool _loading = true;
    private string _error = "";
    private LessonVM? _editingLesson;
    private LessonForm _lf = new();
    private bool _dateLocked;
    private bool _showAttendance;
    private bool _attendanceLoading;
    private LessonVM? _attendanceLesson;
    private List<LessonAttendanceDto> _attendances = [];

    private static string StatusBadge(string s) => s switch {
        "Terminé" or "Validé" => "ts-badge-success",
        "En cours" => "ts-badge-primary",
        "Annulé" => "ts-badge-danger",
        "Moniteur absent" => "ts-badge-warning",
        "Imputation réglée" => "ts-badge-neutral",
        _ => "ts-badge-neutral"
    };

    private IEnumerable<LessonVM> FilteredLessons => _lessons
        .Where(l => string.IsNullOrEmpty(_search) ||
            l.StudentName.Contains(_search, StringComparison.OrdinalIgnoreCase) ||
            l.Title.Contains(_search, StringComparison.OrdinalIgnoreCase) ||
            l.Subject.Contains(_search, StringComparison.OrdinalIgnoreCase))
        .Where(l => string.IsNullOrEmpty(_filterStatus) || l.Status == _filterStatus)
        .Where(l => string.IsNullOrEmpty(_filterMode) || l.Mode == _filterMode)
        .OrderByDescending(l => l.Date);

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var dtos = await LessonSvc.GetLessonsAsync();
            if (dtos.Count > 0)
                _lessons = dtos.Select(MapFromDto).ToList();
        }
        catch { /* keep empty */ }
        finally { _loading = false; }
    }

    private static LessonVM MapFromDto(LessonDto d) => new()
    {
        ApiId = d.Id,
        Title = d.Title,
        Subject = d.Subject ?? "",
        Date = d.StartTime.ToLocalTime(),
        EndTime = d.EndTime.ToLocalTime().ToString("HH:mm"),
        Duration = Math.Round((d.EndTime - d.StartTime).TotalHours, 1),
        Mode = LessonService.ModeToDisplay(d.Mode),
        Status = LessonService.DeriveStatus(d.StartTime, d.EndTime, d.SettlementStatus),
        SettlementStatus = d.SettlementStatus,
        SessionCounted = d.SessionCounted,
        TutorLiable = d.TutorLiable,
        AvatarColor = "#7c3aed"
    };

    private void OpenAdd() { _editingLesson = null; _lf = new(); _dateLocked = false; _showModal = true; }
    private void OpenEdit(LessonVM l)
    {
        _editingLesson = l;
        _lf = new LessonForm { Title=l.Title, Student=l.StudentName, Subject=l.Subject,
            Date=l.Date, StartTime=TimeOnly.FromDateTime(l.Date), Duration=l.Duration, Mode=l.Mode };
        var hoursLeft = l.Date.ToUniversalTime() - DateTime.UtcNow;
        _dateLocked = hoursLeft < TimeSpan.FromHours(24)
                      || l.SettlementStatus is "CancelledFree" or "TutorNoShow" or "LiabilityResolved";
        _showModal = true;
    }
    private void CloseModal() => _showModal = false;

    private async Task OpenAttendance(LessonVM lesson)
    {
        if (lesson.ApiId is null) return;
        _attendanceLesson = lesson;
        _showAttendance = true;
        _attendanceLoading = true;
        try
        {
            _attendances = await LessonSvc.GetAttendancesAsync(lesson.ApiId.Value);
        }
        catch { _attendances = []; }
        finally { _attendanceLoading = false; }
    }

    private void CloseAttendance()
    {
        _showAttendance = false;
        _attendanceLesson = null;
        _attendances = [];
    }

    private async Task ToggleAttendance(LessonAttendanceDto row, bool present)
    {
        if (_attendanceLesson?.ApiId is not Guid id) return;
        var updated = await LessonSvc.SetAttendanceAsync(id, row.StudentId, present);
        if (updated is null) return;
        var idx = _attendances.FindIndex(a => a.StudentId == row.StudentId);
        if (idx >= 0) _attendances[idx] = updated;
    }

    private async Task CancelLesson(LessonVM lesson)
    {
        if (lesson.ApiId is not Guid id) return;
        var confirmed = await JS.InvokeAsync<bool>("confirm", L["Lessons_CancelConfirm"].Value);
        if (!confirmed) return;
        var dto = await LessonSvc.CancelLessonAsync(id);
        if (dto is null) { _error = L["Lessons_CancelError"]; return; }
        ReplaceLesson(lesson, MapFromDto(dto));
        _error = "";
    }

    private async Task MarkTutorNoShow(LessonVM lesson)
    {
        if (lesson.ApiId is not Guid id) return;
        var confirmed = await JS.InvokeAsync<bool>("confirm", L["Lessons_TutorNoShowConfirm"].Value);
        if (!confirmed) return;
        var dto = await LessonSvc.MarkTutorNoShowAsync(id);
        if (dto is null) { _error = L["Lessons_TutorNoShowError"]; return; }
        ReplaceLesson(lesson, MapFromDto(dto));
        _error = "";
    }

    private async Task ResolveLiability(LessonVM lesson, string resolution)
    {
        if (lesson.ApiId is not Guid id) return;
        var dto = await LessonSvc.ResolveLiabilityAsync(id, resolution);
        if (dto is null) { _error = L["Lessons_ResolveError"]; return; }
        ReplaceLesson(lesson, MapFromDto(dto));
        _error = "";
    }

    private void ReplaceLesson(LessonVM old, LessonVM updated)
    {
        var idx = _lessons.IndexOf(old);
        if (idx >= 0) _lessons[idx] = updated;
    }

    private async Task DeleteLesson(LessonVM lesson)
    {
        var label = string.IsNullOrEmpty(lesson.StudentName) ? lesson.Title : lesson.StudentName;
        var confirmed = await JS.InvokeAsync<bool>(
            "confirm",
            string.Format(L["Lessons_CancelConfirmDetail"].Value, label, lesson.Date.ToString("dd/MM/yyyy")));
        if (!confirmed)
            return;

        if (lesson.ApiId is Guid id)
        {
            var dto = await LessonSvc.CancelLessonAsync(id, "Annulation");
            if (dto is null)
            {
                _error = L["Lessons_CancelError"];
                return;
            }
            ReplaceLesson(lesson, MapFromDto(dto));
        }
        else
        {
            _lessons.Remove(lesson);
        }
        _error = "";
    }

    private async Task SaveLesson()
    {
        if (string.IsNullOrWhiteSpace(_lf.Title) || string.IsNullOrWhiteSpace(_lf.Subject))
            return;

        var start = _lf.Date.Date.Add(_lf.StartTime.ToTimeSpan());
        var end   = start.AddHours(_lf.Duration);

        if (_editingLesson == null)
        {
            var recurrence = _lf.Recurrence;
            int? occurrences = null;
            DateTime? until = null;
            if (recurrence != "none")
            {
                if (_lf.UntilDate is { } u && u.Date >= _lf.Date.Date)
                    until = u.Date;
                else
                    occurrences = Math.Clamp(_lf.Occurrences, 2, 52);
            }

            var created = await LessonSvc.CreateLessonAsync(
                _lf.Title, _lf.Description, _lf.Subject,
                start.ToUniversalTime(), end.ToUniversalTime(), _lf.Mode,
                recurrenceFrequency: recurrence == "none" ? null : recurrence,
                recurrenceOccurrences: occurrences,
                recurrenceUntil: until?.ToUniversalTime());

            if (created.Count > 0)
            {
                foreach (var dto in created)
                    _lessons.Add(MapFromDto(dto));
            }
            else
            {
                _lessons.Add(new LessonVM
                {
                    Title          = _lf.Title,
                    StudentName    = _lf.Student,
                    Subject        = _lf.Subject,
                    Date           = start,
                    EndTime        = end.ToString("HH:mm"),
                    Duration       = _lf.Duration,
                    Mode           = _lf.Mode,
                    Status         = "Planifié",
                    AvatarColor    = "#7c3aed",
                    StudentInitials = string.Join("",
                        _lf.Student.Split(' ').Take(2).Select(x => x.Length > 0 ? x[0] : ' ')).Trim()
                });
            }
        }
        else if (_editingLesson.ApiId.HasValue)
        {
            var editStart = _dateLocked ? _editingLesson.Date : start;
            var editEnd = _dateLocked
                ? _editingLesson.Date.AddHours(_editingLesson.Duration)
                : end;
            var result = await LessonSvc.UpdateLessonWithErrorAsync(
                _editingLesson.ApiId.Value,
                _lf.Title, _lf.Description, _lf.Subject,
                editStart.ToUniversalTime(), editEnd.ToUniversalTime(), _lf.Mode);
            if (result.Error is not null)
            {
                _error = result.Error;
                return;
            }
            if (result.Value != null)
            {
                var updated = MapFromDto(result.Value);
                var idx = _lessons.IndexOf(_editingLesson);
                if (idx >= 0) _lessons[idx] = updated;
            }
            else
            {
                _editingLesson.Title   = _lf.Title;
                _editingLesson.Subject = _lf.Subject;
                if (!_dateLocked)
                {
                    _editingLesson.Date    = start;
                    _editingLesson.EndTime = end.ToString("HH:mm");
                    _editingLesson.Duration = _lf.Duration;
                }
                _editingLesson.Mode    = _lf.Mode;
            }
        }
        _error = "";
        _showModal = false;
    }

    private void StartLesson(LessonVM lesson)
    {
        lesson.Status = "En cours";
        Navigation.NavigateTo($"/tutor/classroom/{lesson.Id}?student={Uri.EscapeDataString(lesson.StudentName)}&initials={Uri.EscapeDataString(lesson.StudentInitials)}&title={Uri.EscapeDataString(lesson.Title)}&subject={Uri.EscapeDataString(lesson.Subject)}");
    }

    private class LessonForm
    {
        public string Title { get; set; } = "";
        public string Student { get; set; } = "";
        public string Subject { get; set; } = "";
        public DateTime Date { get; set; } = DateTime.Today;
        public TimeOnly StartTime { get; set; } = new TimeOnly(10, 0);
        public double Duration { get; set; } = 1;
        public string Mode { get; set; } = "En ligne";
        public string Type { get; set; } = "Individuel";
        public string Description { get; set; } = "";
        public string Recurrence { get; set; } = "none";
        public int Occurrences { get; set; } = 8;
        public DateTime? UntilDate { get; set; }
    }

    private class LessonVM
    {
        public Guid? ApiId { get; set; }
        public string Id { get; set; } = Guid.NewGuid().ToString("N")[..8];
        public string Title { get; set; } = "";
        public string StudentName { get; set; } = "";
        public string StudentInitials { get; set; } = "";
        public string Subject { get; set; } = "";
        public DateTime Date { get; set; }
        public string EndTime { get; set; } = "";
        public double Duration { get; set; }
        public string Mode { get; set; } = "";
        public string Status { get; set; } = "";
        public string? SettlementStatus { get; set; }
        public bool SessionCounted { get; set; }
        public bool TutorLiable { get; set; }
        public string AvatarColor { get; set; } = "#7c3aed";
    }

    private List<LessonVM> _lessons = [];
}
