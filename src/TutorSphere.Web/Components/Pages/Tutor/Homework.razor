@page "/tutor/homework"
@layout TutorLayout
@rendermode InteractiveServer
@inject IStringLocalizer<SharedResources> L
@inject HomeworkService HomeworkSvc

<PageTitle>@L["Homework_Title"] – TutorSphere</PageTitle>

<div class="ts-page-header">
    <div>
        <h1><i class="bi bi-journal-text me-2"></i>@L["Homework_Title"]</h1>
        <p class="ts-page-subtitle">@L["Homework_Subtitle"]</p>
    </div>
    <button class="btn btn-primary" @onclick="OpenAdd">
        <i class="bi bi-plus-lg me-1"></i>@L["Homework_New"]
    </button>
</div>

<!-- Quick filters -->
<div class="ts-toolbar">
    <div class="ts-search-box">
        <i class="bi bi-search ts-search-icon"></i>
        <input class="form-control" placeholder="@L["Homework_Search"]"
               @bind="_search" @bind:event="oninput" />
    </div>
    <select class="form-select w-auto" @bind="_filterStatus">
        <option value="">@L["Common_All"]</option>
        <option value="À rendre">@L["Homework_Due"]</option>
        <option value="Rendu">@L["Homework_Submitted"]</option>
        <option value="Corrigé">@L["Homework_Graded"]</option>
        <option value="En retard">@L["Homework_Late"]</option>
    </select>
    <select class="form-select w-auto" @bind="_filterSubject">
        <option value="">@L["Homework_AllSubjects"]</option>
        <option>Mathématiques</option><option>Physique</option><option>Chimie</option><option>Français</option>
    </select>
</div>

<!-- Homework cards -->
@if (_loading)
{
    <div class="ts-loading-state">
        <div class="spinner-border text-primary" role="status"></div>
        <span class="ms-3 text-muted">@L["Homework_Loading"]</span>
    </div>
}
else if (!string.IsNullOrEmpty(_error))
{
    <div class="alert alert-warning">
        <i class="bi bi-exclamation-triangle me-2"></i>@_error
    </div>
}
else
{
<div class="homework-grid">
    @foreach (var hw in FilteredHomework)
    {
        <div class="hw-card">
            <div class="hw-card-head">
                <span class="ts-badge @HwBadge(hw.Status)">@StatusLabel(hw.Status)</span>
                <span class="hw-due @(hw.IsOverdue ? "text-danger" : "text-muted")">
                    <i class="bi bi-calendar3 me-1"></i>@hw.DueDate.ToString("dd/MM")
                </span>
            </div>
            <h3 class="hw-title">@hw.Title</h3>
            <p class="hw-subject"><i class="bi bi-book me-1 text-muted"></i>@hw.Subject</p>
            <div class="hw-students">
                @foreach (var s in hw.Students)
                {
                    <span class="ts-badge ts-badge-neutral">@s</span>
                }
            </div>
            @if (!string.IsNullOrEmpty(hw.Description))
            {
                <p class="hw-desc">@hw.Description</p>
            }
            @if (hw.Status == "Corrigé" && hw.Grades.Any())
            {
                <div class="hw-grades">
                    @foreach (var g in hw.Grades)
                    {
                        <span class="hw-grade-chip">@g.Student : <strong>@g.Score/20</strong></span>
                    }
                </div>
            }
            <div class="hw-card-footer">
                <button class="ts-icon-btn" title="@L["Common_Edit"]" @onclick="()=>OpenEdit(hw)"><i class="bi bi-pencil"></i></button>
                @if (hw.Status == "Rendu")
                {
                    <button class="ts-icon-btn" title="@L["Homework_Grade"]" @onclick="()=>OpenGrade(hw)">
                        <i class="bi bi-check2-square text-success"></i>
                    </button>
                }
                <button class="ts-icon-btn ts-icon-btn--danger" title="@L["Common_Delete"]"
                        @onclick="async () => await DeleteHomework(hw)">
                    <i class="bi bi-trash"></i>
                </button>
            </div>
        </div>
    }
</div>
}

<!-- Add/Edit modal -->
@if (_showModal)
{
    <div class="ts-modal-backdrop" @onclick="CloseModal">
        <div class="ts-modal" @onclick:stopPropagation="true">
            <div class="ts-modal-header">
                <h2>@(_editing == null ? L["Homework_New"] : L["Homework_Edit"])</h2>
                <button class="ts-modal-close" @onclick="CloseModal"><i class="bi bi-x-lg"></i></button>
            </div>
            <div class="ts-modal-body">
                <div class="row g-3">
                    <div class="col-12"><label class="form-label">@L["Common_Title"] *</label>
                        <input class="form-control" @bind="_hf.Title" placeholder="@L["Homework_TitlePlaceholder"]" /></div>
                    <div class="col-6"><label class="form-label">@L["Common_Subject"]</label>
                        <input class="form-control" @bind="_hf.Subject" /></div>
                    <div class="col-6"><label class="form-label">@L["Homework_DueDate"] *</label>
                        <input type="date" class="form-control" @bind="_hf.DueDate" /></div>
                    <div class="col-12"><label class="form-label">@L["Common_Description"]</label>
                        <textarea class="form-control" rows="3" @bind="_hf.Description"
                            placeholder="@L["Homework_DescPlaceholder"]"></textarea></div>
                    <div class="col-12">
                        <label class="form-label">@L["Homework_Students"]</label>
                        <div class="d-flex flex-wrap gap-2">
                            @foreach (var s in _studentChoices)
                            {
                                var selected = _hf.Students.Contains(s);
                                <button type="button"
                                        class="ts-chip @(selected ? "active" : "")"
                                        @onclick="()=>{ if(selected) _hf.Students.Remove(s); else _hf.Students.Add(s); }">
                                    @s
                                </button>
                            }
                        </div>
                    </div>
                </div>
            </div>
            <div class="ts-modal-footer">
                <button class="btn btn-outline-secondary" @onclick="CloseModal">@L["Common_Cancel"]</button>
                <button class="btn btn-primary" @onclick="async () => await SaveHomework()">@L["Common_Save"]</button>
            </div>
        </div>
    </div>
}

<!-- Grade modal -->
@if (_grading != null)
{
    <div class="ts-modal-backdrop" @onclick="()=>_grading=null">
        <div class="ts-modal" @onclick:stopPropagation="true">
            <div class="ts-modal-header">
                <h2>@string.Format(L["Homework_GradeTitle"].Value, _grading.Title)</h2>
                <button class="ts-modal-close" @onclick="()=>_grading=null"><i class="bi bi-x-lg"></i></button>
            </div>
            <div class="ts-modal-body">
                @foreach (var s in _grading.Students)
                {
                    var existing = _grading.Grades.FirstOrDefault(g=>g.Student==s);
                    var score = existing?.Score ?? 0;
                    <div class="row align-items-center g-2 mb-2">
                        <div class="col-6"><strong>@s</strong></div>
                        <div class="col-4">
                            <div class="input-group input-group-sm">
                                <input type="number" min="0" max="20" class="form-control"
                                       value="@score"
                                       @onchange='e => SetGrade(_grading, s, int.Parse(e.Value?.ToString() ?? "0"))' />
                                <span class="input-group-text">/20</span>
                            </div>
                        </div>
                    </div>
                }
            </div>
            <div class="ts-modal-footer">
                <button class="btn btn-outline-secondary" @onclick="()=>_grading=null">@L["Common_Cancel"]</button>
                <button class="btn btn-primary" @onclick="MarkCorrected">@L["Homework_ValidateGrades"]</button>
            </div>
        </div>
    </div>
}

@code {
    private string _search = "", _filterStatus = "", _filterSubject = "";
    private bool _showModal;
    private bool _loading = true;
    private string _error = "";
    private HomeworkVM? _editing, _grading;
    private HomeworkForm _hf = new();

    private static string HwBadge(string s) => s switch {
        "Corrigé" => "ts-badge-success", "Rendu" => "ts-badge-primary",
        "En retard" => "ts-badge-danger", _ => "ts-badge-muted"
    };

    private string StatusLabel(string s) => s switch {
        "À rendre" => L["Homework_Due"],
        "Rendu" => L["Homework_Submitted"],
        "Corrigé" => L["Homework_Graded"],
        "En retard" => L["Homework_Late"],
        _ => s
    };

    private IEnumerable<HomeworkVM> FilteredHomework => _homeworks
        .Where(h => string.IsNullOrEmpty(_search) ||
            h.Title.Contains(_search, StringComparison.OrdinalIgnoreCase))
        .Where(h => string.IsNullOrEmpty(_filterStatus) || h.Status == _filterStatus)
        .Where(h => string.IsNullOrEmpty(_filterSubject) || h.Subject == _filterSubject)
        .OrderBy(h => h.DueDate);

    protected override async Task OnInitializedAsync()
    {
        try
        {
            // No tutor-scoped list endpoint exists yet; mock data kept as fallback.
            // Create/update/delete operations are wired to the real API below.
            await Task.CompletedTask;
        }
        catch { /* keep mock fallback */ }
        finally { _loading = false; }
    }

    private void OpenAdd() { _editing = null; _hf = new() { DueDate=DateTime.Today.AddDays(7) }; _showModal=true; }
    private void OpenEdit(HomeworkVM h) { _editing = h; _hf = new HomeworkForm { Title=h.Title, Subject=h.Subject, DueDate=h.DueDate, Description=h.Description, Students=[..h.Students] }; _showModal=true; }
    private void OpenGrade(HomeworkVM h) => _grading = h;
    private void CloseModal() => _showModal = false;
    private async Task MarkCorrected()
    {
        if (_grading is null) return;

        // Call grade API for each graded student if this homework has an ApiId
        if (_grading.ApiId.HasValue && _grading.Grades.Any())
        {
            var topGrade = _grading.Grades.OrderByDescending(g => g.Score).First();
            var req = new GradeHomeworkRequest(topGrade.Score, null);
            await HomeworkSvc.GradeHomeworkAsync(_grading.ApiId.Value, req);
        }

        _grading.Status = "Corrigé";
        _grading = null;
    }

    private void SetGrade(HomeworkVM hw, string student, int score)
    {
        var existing = hw.Grades.FirstOrDefault(g => g.Student == student);
        if (existing != null) existing.Score = score;
        else hw.Grades.Add(new GradeItem { Student = student, Score = score });
    }

    private async Task SaveHomework()
    {
        if (string.IsNullOrWhiteSpace(_hf.Title)) return;
        if (_editing == null)
        {
            // Create requires a real StudentId; store locally until student is linked.
            _homeworks.Add(new HomeworkVM
            {
                Title       = _hf.Title,
                Subject     = _hf.Subject,
                DueDate     = _hf.DueDate,
                Description = _hf.Description,
                Students    = [.._hf.Students],
                Status      = _hf.DueDate < DateTime.Today ? "En retard" : "À rendre"
            });
        }
        else
        {
            if (_editing.ApiId.HasValue)
            {
                var req = new UpdateHomeworkRequest(_hf.Title, _hf.Description, _hf.DueDate);
                await HomeworkSvc.UpdateHomeworkAsync(_editing.ApiId.Value, req);
            }
            _editing.Title       = _hf.Title;
            _editing.Subject     = _hf.Subject;
            _editing.DueDate     = _hf.DueDate;
            _editing.Description = _hf.Description;
        }
        _showModal = false;
    }

    private async Task DeleteHomework(HomeworkVM hw)
    {
        if (hw.ApiId.HasValue)
            await HomeworkSvc.DeleteHomeworkAsync(hw.ApiId.Value);
        _homeworks.Remove(hw);
    }

    private class HomeworkForm
    {
        public string Title { get; set; } = "";
        public string Subject { get; set; } = "";
        public DateTime DueDate { get; set; } = DateTime.Today.AddDays(7);
        public string Description { get; set; } = "";
        public List<string> Students { get; set; } = [];
    }
    private class GradeItem
    {
        public string Student { get; set; } = "";
        public int Score { get; set; }
    }
    private class HomeworkVM
    {
        public Guid? ApiId { get; set; }
        public string Title { get; set; } = "";
        public string Subject { get; set; } = "";
        public DateTime DueDate { get; set; }
        public string Description { get; set; } = "";
        public List<string> Students { get; set; } = [];
        public string Status { get; set; } = "À rendre";
        public List<GradeItem> Grades { get; set; } = [];
        public bool IsOverdue => Status == "En retard" || (DueDate < DateTime.Today && Status != "Corrigé");
    }

    private List<HomeworkVM> _homeworks = [];
    private readonly List<string> _studentChoices = [];
}
