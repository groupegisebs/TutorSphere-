@page "/tutor/homework"
@layout TutorLayout
@rendermode InteractiveServer
@inject IStringLocalizer<SharedResources> L
@inject HomeworkService HomeworkSvc
@inject ApiClient Api
@using TutorSphere.Application.DTOs.Homework
@using TutorSphere.Domain.Enums

<PageTitle>@L["Homework_Title"] – TutorSphere</PageTitle>

<div class="ts-page-header">
    <div>
        <h1><i class="bi bi-journal-text me-2"></i>@L["Homework_Title"]</h1>
        <p class="ts-page-subtitle">@L["Homework_Subtitle"]</p>
    </div>
    <button class="btn btn-primary" @onclick="OpenAdd">
        <i class="bi bi-plus-lg me-1"></i>@L["Homework_New"]
    </button>
</div>

<div class="ts-toolbar">
    <div class="ts-search-box">
        <i class="bi bi-search ts-search-icon"></i>
        <input class="form-control" placeholder="@L["Homework_Search"]"
               @bind="_search" @bind:event="oninput" />
    </div>
    <select class="form-select w-auto" @bind="_filterStatus">
        <option value="">@L["Common_All"]</option>
        <option value="À rendre">@L["Homework_Due"]</option>
        <option value="Rendu">@L["Homework_Submitted"]</option>
        <option value="Corrigé">@L["Homework_Graded"]</option>
        <option value="Brouillon">Brouillon</option>
    </select>
</div>

@if (_loading)
{
    <div class="ts-loading-state">
        <div class="spinner-border text-primary" role="status"></div>
        <span class="ms-3 text-muted">@L["Homework_Loading"]</span>
    </div>
}
else if (!string.IsNullOrEmpty(_error))
{
    <div class="alert alert-warning"><i class="bi bi-exclamation-triangle me-2"></i>@_error</div>
}
else if (!FilteredHomework.Any())
{
    <div class="ts-empty-state py-5 text-center text-muted">
        <i class="bi bi-journal-plus" style="font-size:2rem"></i>
        <p class="mt-2 mb-0">Aucun devoir pour le moment. Créez-en un avec texte, vidéo, fichiers…</p>
    </div>
}
else
{
    <div class="homework-grid">
        @foreach (var hw in FilteredHomework)
        {
            <div class="hw-card">
                <div class="hw-card-head">
                    <span class="ts-badge @HwBadge(hw.Status)">@StatusLabel(hw.Status)</span>
                    <span class="hw-due @(hw.IsOverdue ? "text-danger" : "text-muted")">
                        <i class="bi bi-calendar3 me-1"></i>@(hw.DueDate?.ToString("dd/MM") ?? "—")
                    </span>
                </div>
                <h3 class="hw-title">@hw.Title</h3>
                <p class="hw-subject"><i class="bi bi-book me-1 text-muted"></i>@(hw.Subject ?? "—")</p>
                <div class="hw-students">
                    @foreach (var s in hw.StudentNames)
                    {
                        <span class="ts-badge ts-badge-neutral">@s</span>
                    }
                </div>
                @if (hw.ContentCount > 0)
                {
                    <p class="hw-desc"><i class="bi bi-layers me-1"></i>@hw.ContentCount élément(s) de contenu</p>
                }
                <div class="hw-card-footer">
                    <button class="ts-icon-btn" title="@L["Common_Edit"]" @onclick="() => OpenEdit(hw)"><i class="bi bi-pencil"></i></button>
                    @if (hw.Status == "Rendu" && hw.ApiId.HasValue)
                    {
                        <button class="ts-icon-btn" title="@L["Homework_Grade"]" @onclick="() => OpenGrade(hw)">
                            <i class="bi bi-check2-square text-success"></i>
                        </button>
                    }
                    <button class="ts-icon-btn ts-icon-btn--danger" title="@L["Common_Delete"]"
                            @onclick="async () => await DeleteHomework(hw)">
                        <i class="bi bi-trash"></i>
                    </button>
                </div>
            </div>
        }
    </div>
}

@* ── Wizard création / édition ── *@
@if (_showModal)
{
    <div class="ts-modal-backdrop hw-wizard-backdrop" @onclick="CloseModal">
        <div class="ts-modal hw-wizard" @onclick:stopPropagation="true">
            <div class="hw-wizard-header">
                <div>
                    <h2><i class="bi bi-clipboard2-plus me-2"></i>@(_editing is null ? "Nouveau devoir" : "Modifier le devoir")</h2>
                    <p>Créez un devoir complet pour vos élèves</p>
                </div>
                <button type="button" class="ts-modal-close" @onclick="CloseModal"><i class="bi bi-x-lg"></i></button>
            </div>

            <div class="hw-wizard-steps">
                @for (var i = 0; i < _stepLabels.Length; i++)
                {
                    var idx = i;
                    <button type="button" class="hw-step @(_wizardStep == idx ? "active" : null) @(_wizardStep > idx ? "done" : null)"
                            @onclick="() => _wizardStep = idx">
                        <span class="hw-step-num">@(idx + 1)</span>
                        <span>@_stepLabels[idx]</span>
                    </button>
                }
            </div>

            <div class="hw-wizard-body">
                <div class="hw-wizard-main">
                    @if (_wizardStep == 0)
                    {
                        <section class="hw-section">
                            <h3>Informations générales</h3>
                            <div class="row g-3">
                                <div class="col-12">
                                    <label class="form-label">Titre du devoir *</label>
                                    <input class="form-control" @bind="_hf.Title" placeholder="Exercices chapitre 4 : Fractions" />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">Matière</label>
                                    <select class="form-select" @bind="_hf.Subject">
                                        <option value="">— Choisir —</option>
                                        @foreach (var s in _subjects)
                                        {
                                            <option value="@s">@s</option>
                                        }
                                    </select>
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label">Date limite *</label>
                                    <input type="date" class="form-control" @bind="_hf.DueDate" />
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label">Heure limite</label>
                                    <input type="time" class="form-control" @bind="_hf.DueTime" />
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label">Durée estimée</label>
                                    <div class="input-group">
                                        <input type="number" min="5" max="600" class="form-control" @bind="_hf.EstimatedMinutes" />
                                        <span class="input-group-text">minutes</span>
                                    </div>
                                </div>
                                <div class="col-12">
                                    <label class="form-label">Description</label>
                                    <textarea class="form-control" rows="3" maxlength="1000" @bind="_hf.Description"
                                              placeholder="Décrivez le but du devoir…"></textarea>
                                    <div class="form-text text-end">@(_hf.Description?.Length ?? 0)/1000</div>
                                </div>
                                <div class="col-12">
                                    <label class="form-label">Élèves concernés *</label>
                                    <div class="d-flex flex-wrap gap-2">
                                        @foreach (var s in _students)
                                        {
                                            var selected = _hf.StudentIds.Contains(s.Id);
                                            <button type="button" class="ts-chip @(selected ? "active" : null)"
                                                    @onclick="() => ToggleStudent(s.Id)">
                                                @s.FirstName @s.LastName
                                            </button>
                                        }
                                    </div>
                                    @if (_students.Count == 0)
                                    {
                                        <p class="text-muted small mb-0 mt-1">Aucun élève trouvé. Ajoutez des élèves dans votre école.</p>
                                    }
                                </div>
                            </div>
                        </section>
                    }
                    else if (_wizardStep == 1)
                    {
                        <section class="hw-section">
                            <h3>Contenu du devoir</h3>
                            <div class="hw-content-types">
                                @foreach (var t in _contentTypes)
                                {
                                    <button type="button" class="hw-ctype @(_hf.PendingContentType == t.Key ? "active" : null)"
                                            @onclick="() => _hf.PendingContentType = t.Key">
                                        <i class="bi @t.Icon"></i>@t.Label
                                    </button>
                                }
                            </div>

                            <div class="hw-add-block card border-0 bg-light mb-3">
                                <div class="card-body">
                                    <div class="mb-2">
                                        <label class="form-label">Titre (optionnel)</label>
                                        <input class="form-control form-control-sm" @bind="_hf.PendingTitle" placeholder="Ex. Rappels de cours" />
                                    </div>
                                    @if (_hf.PendingContentType is "text" or "form")
                                    {
                                        <label class="form-label">Contenu</label>
                                        <textarea class="form-control" rows="4" @bind="_hf.PendingBody"
                                                  placeholder="@(_hf.PendingContentType == "form" ? "Questions du formulaire…" : "Texte, consignes, formules…")"></textarea>
                                    }
                                    else if (_hf.PendingContentType == "file")
                                    {
                                        <label class="form-label">Fichier à joindre</label>
                                        <InputFile class="form-control" OnChange="OnHomeworkFileSelected"
                                                   accept=".pdf,.doc,.docx,.xls,.xlsx,.ppt,.pptx,.jpg,.jpeg,.png,.gif,.webp,.txt,.zip,.mp4,.mov" />
                                        @if (_uploadingFile)
                                        {
                                            <div class="form-text mt-1">
                                                <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                                                Envoi du fichier sur le serveur…
                                            </div>
                                        }
                                        @if (!string.IsNullOrEmpty(_fileUploadError))
                                        {
                                            <div class="text-danger small mt-1">@_fileUploadError</div>
                                        }
                                        <div class="form-text mt-2">Ou collez une URL externe (Drive, OneDrive…)</div>
                                        <input class="form-control mt-1" @bind="_hf.PendingUrl" placeholder="https://…" />
                                    }
                                    else
                                    {
                                        <label class="form-label">URL @(_hf.PendingContentType == "video" ? "vidéo" : "lien")</label>
                                        <input class="form-control" @bind="_hf.PendingUrl"
                                               placeholder="https://…" />
                                        <div class="form-text">Collez un lien YouTube, Drive, PDF, etc.</div>
                                    }
                                    <button type="button" class="btn btn-sm btn-primary mt-3"
                                            disabled="@(_uploadingFile || (_hf.PendingContentType == "file" && string.IsNullOrWhiteSpace(_hf.PendingUrl) && string.IsNullOrWhiteSpace(_hf.PendingBody)))"
                                            @onclick="AddContentBlock">
                                        <i class="bi bi-plus-lg me-1"></i>Ajouter cet élément
                                    </button>
                                </div>
                            </div>

                            @foreach (var block in _hf.Content)
                            {
                                <div class="hw-content-item" @key="block.Id">
                                    <div class="hw-content-item-head">
                                        <span class="ts-badge ts-badge-primary">@ContentTypeLabel(block.Type)</span>
                                        <strong>@(string.IsNullOrWhiteSpace(block.Title) ? "(Sans titre)" : block.Title)</strong>
                                        <button type="button" class="btn btn-link btn-sm text-danger ms-auto" @onclick="() => RemoveContent(block.Id)">Supprimer</button>
                                    </div>
                                    @if (!string.IsNullOrWhiteSpace(block.Body))
                                    {
                                        <p class="mb-0 small text-muted">@(block.Body.Length > 160 ? block.Body[..160] + "…" : block.Body)</p>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(block.Url))
                                    {
                                        @if (block.Type == "file")
                                        {
                                            <p class="mb-0 small text-muted">
                                                <i class="bi bi-paperclip me-1"></i>
                                                @(string.IsNullOrWhiteSpace(block.Title) ? "Fichier joint (serveur)" : block.Title)
                                                <span class="ms-1">— enregistré</span>
                                            </p>
                                        }
                                        else if (block.Url.StartsWith("http://", StringComparison.OrdinalIgnoreCase)
                                              || block.Url.StartsWith("https://", StringComparison.OrdinalIgnoreCase))
                                        {
                                            <a class="small" href="@block.Url" target="_blank" rel="noopener">@block.Url</a>
                                        }
                                        else
                                        {
                                            <span class="small text-muted">@block.Url</span>
                                        }
                                    }
                                </div>
                            }

                            @if (_hf.Content.Count == 0)
                            {
                                <p class="text-muted small">Ajoutez du texte, une vidéo, un fichier, un lien ou un formulaire.</p>
                            }
                        </section>
                    }
                    else if (_wizardStep == 2)
                    {
                        <section class="hw-section">
                            <h3>Consignes</h3>
                            <textarea class="form-control" rows="8" @bind="_hf.Instructions"
                                      placeholder="Précisez comment réaliser le devoir, le matériel requis, les critères attendus…"></textarea>
                        </section>
                    }
                    else if (_wizardStep == 3)
                    {
                        <section class="hw-section">
                            <h3>Remise du devoir</h3>
                            <p class="text-muted small">Choisissez comment les élèves peuvent rendre leur travail (plusieurs options possibles).</p>
                            <div class="hw-modes">
                                @foreach (var m in _submissionModes)
                                {
                                    var on = (_hf.SubmissionModes & m.Flag) != 0;
                                    <button type="button" class="hw-mode @(on ? "active" : null)" @onclick="() => ToggleMode(m.Flag)">
                                        <i class="bi @m.Icon"></i>
                                        <div>
                                            <strong>@m.Title</strong>
                                            <span>@m.Hint</span>
                                        </div>
                                        <i class="bi @(on ? "bi-check-circle-fill" : "bi-circle") hw-mode-check"></i>
                                    </button>
                                }
                            </div>
                        </section>
                    }
                    else
                    {
                        <section class="hw-section">
                            <h3>Options & critères</h3>
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <label class="form-label mb-0">Critères d'évaluation</label>
                                <button type="button" class="btn btn-sm btn-outline-primary" @onclick="AddCriterion">+ Ajouter un critère</button>
                            </div>
                            @foreach (var c in _hf.Criteria)
                            {
                                <div class="hw-criterion row g-2 align-items-center mb-2" @key="c.Key">
                                    <div class="col">
                                        <input class="form-control form-control-sm" @bind="c.Name" placeholder="Nom du critère" />
                                    </div>
                                    <div class="col-auto">
                                        <div class="input-group input-group-sm" style="width:7rem">
                                            <span class="input-group-text">/</span>
                                            <input type="number" min="1" max="100" class="form-control" @bind="c.Points" />
                                        </div>
                                    </div>
                                    <div class="col-auto">
                                        <button type="button" class="btn btn-sm btn-link text-danger" @onclick="() => _hf.Criteria.Remove(c)"><i class="bi bi-trash"></i></button>
                                    </div>
                                </div>
                            }
                            <p class="fw-semibold mt-2 mb-0">Total : / @_hf.Criteria.Sum(x => x.Points)</p>
                        </section>
                    }
                </div>

                <aside class="hw-wizard-side">
                    <div class="hw-side-card">
                        <h4>Aperçu</h4>
                        <ul class="hw-preview-list">
                            <li><span>Matière</span><strong>@(string.IsNullOrWhiteSpace(_hf.Subject) ? "—" : _hf.Subject)</strong></li>
                            <li><span>Échéance</span><strong>@_hf.DueDate.ToString("dd/MM/yyyy") @_hf.DueTime</strong></li>
                            <li><span>Durée</span><strong>@(_hf.EstimatedMinutes?.ToString() ?? "—") min</strong></li>
                            <li><span>Contenu</span><strong>@_hf.Content.Count élément(s)</strong></li>
                            <li><span>Élèves</span><strong>@_hf.StudentIds.Count</strong></li>
                            <li><span>Remise</span><strong>@ModesSummary()</strong></li>
                            <li><span>Points</span><strong>/ @_hf.Criteria.Sum(x => x.Points)</strong></li>
                        </ul>
                    </div>
                    @if (!string.IsNullOrEmpty(_saveError))
                    {
                        <div class="alert alert-danger py-2 small mb-0">@_saveError</div>
                    }
                </aside>
            </div>

            <div class="hw-wizard-footer">
                <button type="button" class="btn btn-outline-secondary" @onclick="CloseModal">Annuler</button>
                <div class="d-flex gap-2">
                    @if (_wizardStep > 0)
                    {
                        <button type="button" class="btn btn-outline-secondary" @onclick="() => _wizardStep--">Précédent</button>
                    }
                    <button type="button" class="btn btn-outline-primary" disabled="@_saving" @onclick="() => SaveAsync(draft: true)">
                        Enregistrer en brouillon
                    </button>
                    @if (_wizardStep < _stepLabels.Length - 1)
                    {
                        <button type="button" class="btn btn-primary" @onclick="NextStep">
                            Suivant <i class="bi bi-arrow-right ms-1"></i>
                        </button>
                    }
                    else
                    {
                        <button type="button" class="btn btn-primary" disabled="@_saving" @onclick="() => SaveAsync(draft: false)">
                            @(_saving ? "Enregistrement…" : "Publier le devoir")
                        </button>
                    }
                </div>
            </div>
        </div>
    </div>
}

@if (_grading is not null)
{
    <div class="ts-modal-backdrop" @onclick="() => _grading = null">
        <div class="ts-modal" @onclick:stopPropagation="true">
            <div class="ts-modal-header">
                <h2>@string.Format(L["Homework_GradeTitle"].Value, _grading.Title)</h2>
                <button class="ts-modal-close" @onclick="() => _grading = null"><i class="bi bi-x-lg"></i></button>
            </div>
            <div class="ts-modal-body">
                <div class="input-group mb-3">
                    <input type="number" min="0" max="100" class="form-control" @bind="_gradeValue" />
                    <span class="input-group-text">/100</span>
                </div>
                <textarea class="form-control" rows="3" @bind="_gradeFeedback" placeholder="Commentaire…"></textarea>
            </div>
            <div class="ts-modal-footer">
                <button class="btn btn-outline-secondary" @onclick="() => _grading = null">@L["Common_Cancel"]</button>
                <button class="btn btn-primary" @onclick="MarkCorrected">@L["Homework_ValidateGrades"]</button>
            </div>
        </div>
    </div>
}

@code {
    private static readonly string[] _stepLabels = ["Informations", "Contenu", "Consignes", "Remise", "Options"];
    private static readonly (string Key, string Label, string Icon)[] _contentTypes =
    [
        ("text", "Texte", "bi-type"),
        ("video", "Vidéo", "bi-camera-video"),
        ("file", "Fichier", "bi-file-earmark"),
        ("link", "Lien", "bi-link-45deg"),
        ("form", "Formulaire", "bi-ui-checks")
    ];
    private static readonly (HomeworkSubmissionMode Flag, string Title, string Hint, string Icon)[] _submissionModes =
    [
        (HomeworkSubmissionMode.Online, "Sur ordinateur", "Réponse en ligne directement sur la plateforme", "bi-laptop"),
        (HomeworkSubmissionMode.PaperScan, "Sur papier (à scanner)", "Scanner ou prendre une photo du devoir", "bi-phone"),
        (HomeworkSubmissionMode.Video, "Enregistrer une vidéo", "Filmer la résolution du devoir", "bi-camera-reels"),
        (HomeworkSubmissionMode.FileUpload, "Déposer un fichier", "Téléverser un fichier (PDF, image, doc…)", "bi-cloud-upload")
    ];
    private static readonly string[] _subjects =
        ["Mathématiques", "Physique", "Chimie", "Français", "Anglais", "Histoire", "Sciences", "Autre"];

    private string _search = "", _filterStatus = "";
    private bool _showModal, _loading = true, _saving, _uploadingFile;
    private string _error = "", _saveError = "", _fileUploadError = "";
    private int _wizardStep;
    private HomeworkVM? _editing, _grading;
    private HomeworkForm _hf = new();
    private List<HomeworkVM> _homeworks = [];
    private List<StudentChoice> _students = [];
    private decimal _gradeValue;
    private string? _gradeFeedback;

    private IEnumerable<HomeworkVM> FilteredHomework => _homeworks
        .Where(h => string.IsNullOrEmpty(_search) || h.Title.Contains(_search, StringComparison.OrdinalIgnoreCase))
        .Where(h => string.IsNullOrEmpty(_filterStatus) || h.Status == _filterStatus)
        .OrderBy(h => h.DueDate ?? DateTime.MaxValue);

    private static string HwBadge(string s) => s switch
    {
        "Corrigé" => "ts-badge-success",
        "Rendu" => "ts-badge-primary",
        "Brouillon" => "ts-badge-muted",
        "En retard" => "ts-badge-danger",
        _ => "ts-badge-muted"
    };

    private string StatusLabel(string s) => s switch
    {
        "À rendre" => L["Homework_Due"],
        "Rendu" => L["Homework_Submitted"],
        "Corrigé" => L["Homework_Graded"],
        "En retard" => L["Homework_Late"],
        "Brouillon" => "Brouillon",
        _ => s
    };

    private static string ContentTypeLabel(string t) => _contentTypes.FirstOrDefault(x => x.Key == t).Label ?? t;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var students = await Api.GetAsync<List<StudentDto>>("api/students") ?? [];
            _students = students
                .Select(s => new StudentChoice(s.Id, s.FirstName, s.LastName))
                .OrderBy(s => s.LastName)
                .ToList();

            await ReloadAsync();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally { _loading = false; }
    }

    private async Task ReloadAsync()
    {
        var list = await HomeworkSvc.GetAllAsync();
        var nameById = _students.ToDictionary(s => s.Id, s => $"{s.FirstName} {s.LastName}".Trim());

        _homeworks = list
            .GroupBy(h => h.AssignmentGroupId ?? h.Id)
            .Select(g =>
            {
                var first = g.OrderByDescending(x => x.CreatedAt).First();
                var status = first.IsDraft ? "Brouillon"
                    : first.IsGraded ? "Corrigé"
                    : first.SubmittedAt.HasValue ? "Rendu"
                    : first.DueDate < DateTime.UtcNow.Date ? "En retard"
                    : "À rendre";
                return new HomeworkVM
                {
                    ApiId = first.Id,
                    GroupId = first.AssignmentGroupId,
                    MemberIds = g.Select(x => x.Id).ToList(),
                    Members = g.Select(x => new HomeworkMember(x.Id, x.StudentId)).ToList(),
                    Title = first.Title,
                    Subject = first.Subject,
                    DueDate = first.DueDate,
                    Description = first.Description,
                    Instructions = first.Instructions,
                    EstimatedMinutes = first.EstimatedMinutes,
                    SubmissionModes = first.SubmissionModes,
                    Content = first.Content.ToList(),
                    Criteria = first.Criteria.Select(c => new CriterionRow { Name = c.Name, Points = c.Points }).ToList(),
                    StudentIds = g.Select(x => x.StudentId).Distinct().ToList(),
                    StudentNames = g.Select(x => nameById.GetValueOrDefault(x.StudentId, "Élève")).Distinct().ToList(),
                    Status = status,
                    IsDraft = first.IsDraft,
                    ContentCount = first.Content.Count
                };
            })
            .OrderByDescending(h => h.DueDate)
            .ToList();
    }

    private void OpenAdd()
    {
        _editing = null;
        _wizardStep = 0;
        _saveError = "";
        _hf = new HomeworkForm
        {
            DueDate = DateTime.Today.AddDays(7),
            DueTime = new TimeOnly(23, 59),
            EstimatedMinutes = 45,
            SubmissionModes = HomeworkSubmissionMode.Online | HomeworkSubmissionMode.PaperScan,
            Criteria = [new CriterionRow { Name = "Compréhension", Points = 10 }, new CriterionRow { Name = "Méthode", Points = 10 }]
        };
        _showModal = true;
    }

    private void OpenEdit(HomeworkVM h)
    {
        _editing = h;
        _wizardStep = 0;
        _saveError = "";
        var due = h.DueDate ?? DateTime.Today.AddDays(7);
        _hf = new HomeworkForm
        {
            Title = h.Title,
            Subject = h.Subject ?? "",
            DueDate = due.Date,
            DueTime = TimeOnly.FromDateTime(due),
            Description = h.Description ?? "",
            Instructions = h.Instructions ?? "",
            EstimatedMinutes = h.EstimatedMinutes ?? 45,
            SubmissionModes = h.SubmissionModes == HomeworkSubmissionMode.None
                ? HomeworkSubmissionMode.Online
                : h.SubmissionModes,
            StudentIds = [.. h.StudentIds],
            Content = h.Content.Select(c => new ContentBlock
            {
                Id = c.Id,
                Type = c.Type,
                Title = c.Title,
                Body = c.Body,
                Url = c.Url
            }).ToList(),
            Criteria = h.Criteria.Count > 0
                ? h.Criteria.Select(c => new CriterionRow { Name = c.Name, Points = c.Points }).ToList()
                : [new CriterionRow { Name = "Note globale", Points = 20 }]
        };
        _showModal = true;
    }

    private void OpenGrade(HomeworkVM h)
    {
        _grading = h;
        _gradeValue = 0;
        _gradeFeedback = null;
    }

    private void CloseModal() => _showModal = false;

    private void NextStep()
    {
        if (_wizardStep == 0 && string.IsNullOrWhiteSpace(_hf.Title))
        {
            _saveError = "Le titre est obligatoire.";
            return;
        }
        _saveError = "";
        if (_wizardStep < _stepLabels.Length - 1)
            _wizardStep++;
    }

    private void ToggleStudent(Guid id)
    {
        if (!_hf.StudentIds.Remove(id))
            _hf.StudentIds.Add(id);
    }

    private void ToggleMode(HomeworkSubmissionMode flag)
    {
        if ((_hf.SubmissionModes & flag) != 0)
            _hf.SubmissionModes &= ~flag;
        else
            _hf.SubmissionModes |= flag;
        if (_hf.SubmissionModes == HomeworkSubmissionMode.None)
            _hf.SubmissionModes = HomeworkSubmissionMode.Online;
    }

    private void AddContentBlock()
    {
        if (_hf.PendingContentType is "text" or "form")
        {
            if (string.IsNullOrWhiteSpace(_hf.PendingBody)) return;
        }
        else if (_hf.PendingContentType == "file")
        {
            // Upload auto-ajoute déjà un bloc ; ici on n’accepte qu’une URL externe.
            if (string.IsNullOrWhiteSpace(_hf.PendingUrl)) return;
        }
        else if (string.IsNullOrWhiteSpace(_hf.PendingUrl))
        {
            return;
        }

        _hf.Content.Add(new ContentBlock
        {
            Id = Guid.NewGuid().ToString("N"),
            Type = _hf.PendingContentType,
            Title = _hf.PendingTitle,
            Body = _hf.PendingBody,
            Url = _hf.PendingUrl
        });
        _hf.PendingTitle = "";
        _hf.PendingBody = "";
        _hf.PendingUrl = "";
        _fileUploadError = "";
    }

    private async Task OnHomeworkFileSelected(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file is null) return;

        _uploadingFile = true;
        _fileUploadError = "";
        try
        {
            const long maxSize = 50L * 1024 * 1024;
            await using var stream = file.OpenReadStream(maxSize);
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);

            using var content = new MultipartFormDataContent();
            var fileContent = new ByteArrayContent(ms.ToArray());
            fileContent.Headers.ContentType = new System.Net.Http.Headers.MediaTypeHeaderValue(
                string.IsNullOrWhiteSpace(file.ContentType) ? "application/octet-stream" : file.ContentType);
            content.Add(fileContent, "file", file.Name);
            content.Add(new StringContent("Devoirs"), "folder");
            if (_hf.StudentIds.Count == 1)
                content.Add(new StringContent(_hf.StudentIds[0].ToString()), "studentId");

            var result = await Api.PostMultipartAsync<HomeworkDocDto>("api/documents", content);
            if (result.Error is not null || result.Value is null)
            {
                _fileUploadError = result.Error ?? "Échec de l'envoi du fichier.";
                return;
            }

            var doc = result.Value;
            _hf.Content.Add(new ContentBlock
            {
                Id = Guid.NewGuid().ToString("N"),
                Type = "file",
                Title = string.IsNullOrWhiteSpace(_hf.PendingTitle) ? doc.FileName : _hf.PendingTitle.Trim(),
                Body = doc.Id.ToString("D"),
                Url = $"api/documents/{doc.Id}/file"
            });
            _hf.PendingTitle = "";
            _hf.PendingUrl = "";
        }
        catch (Exception ex)
        {
            _fileUploadError = ex.Message;
        }
        finally
        {
            _uploadingFile = false;
        }
    }

    private void RemoveContent(string id) =>
        _hf.Content.RemoveAll(c => c.Id == id);

    private void AddCriterion() =>
        _hf.Criteria.Add(new CriterionRow { Name = "Nouveau critère", Points = 5 });

    private string ModesSummary()
    {
        var labels = _submissionModes
            .Where(m => (_hf.SubmissionModes & m.Flag) != 0)
            .Select(m => m.Title)
            .ToList();
        return labels.Count == 0 ? "—" : string.Join(", ", labels);
    }

    private async Task SaveAsync(bool draft)
    {
        _saveError = "";
        if (string.IsNullOrWhiteSpace(_hf.Title))
        {
            _saveError = "Le titre est obligatoire.";
            _wizardStep = 0;
            return;
        }
        if (_hf.StudentIds.Count == 0)
        {
            _saveError = "Sélectionnez au moins un élève.";
            _wizardStep = 0;
            return;
        }

        _saving = true;
        try
        {
            var due = _hf.DueDate.Date.Add(_hf.DueTime.ToTimeSpan());
            var content = _hf.Content.Select(c =>
                new HomeworkContentBlockDto(c.Id, c.Type, c.Title, c.Body, c.Url)).ToList();
            var criteria = _hf.Criteria
                .Where(c => !string.IsNullOrWhiteSpace(c.Name))
                .Select(c => new HomeworkCriterionDto(c.Name.Trim(), c.Points))
                .ToList();

            var updateReq = new UpdateHomeworkRequest(
                _hf.Title.Trim(),
                _hf.Description,
                due,
                _hf.Subject,
                _hf.Instructions,
                _hf.EstimatedMinutes,
                _hf.SubmissionModes,
                content,
                criteria,
                draft);

            if (_editing is { Members.Count: > 0 })
            {
                var groupId = _editing.GroupId ?? Guid.NewGuid();
                var existingByStudent = _editing.Members
                    .GroupBy(m => m.StudentId)
                    .ToDictionary(g => g.Key, g => g.First().Id);

                foreach (var studentId in _hf.StudentIds.Distinct())
                {
                    if (existingByStudent.TryGetValue(studentId, out var homeworkId))
                    {
                        await HomeworkSvc.UpdateHomeworkAsync(homeworkId, updateReq);
                    }
                    else
                    {
                        await HomeworkSvc.CreateHomeworkAsync(new CreateHomeworkRequest(
                            studentId,
                            null,
                            _hf.Title.Trim(),
                            _hf.Description,
                            due,
                            _hf.Subject,
                            _hf.Instructions,
                            _hf.EstimatedMinutes,
                            _hf.SubmissionModes,
                            content,
                            criteria,
                            draft,
                            groupId));
                    }
                }

                foreach (var member in _editing.Members)
                {
                    if (!_hf.StudentIds.Contains(member.StudentId))
                        await HomeworkSvc.DeleteHomeworkAsync(member.Id);
                }
            }
            else
            {
                await HomeworkSvc.CreateBatchAsync(new CreateHomeworkBatchRequest(
                    _hf.StudentIds,
                    null,
                    _hf.Title.Trim(),
                    _hf.Description,
                    due,
                    _hf.Subject,
                    _hf.Instructions,
                    _hf.EstimatedMinutes,
                    _hf.SubmissionModes,
                    content,
                    criteria,
                    draft));
            }

            await ReloadAsync();
            _showModal = false;
        }
        catch (Exception ex)
        {
            _saveError = ex.Message;
        }
        finally { _saving = false; }
    }

    private async Task MarkCorrected()
    {
        if (_grading?.ApiId is not Guid id) return;
        await HomeworkSvc.GradeHomeworkAsync(id, new GradeHomeworkRequest(_gradeValue, _gradeFeedback));
        _grading = null;
        await ReloadAsync();
    }

    private async Task DeleteHomework(HomeworkVM hw)
    {
        var ids = hw.MemberIds.Count > 0
            ? hw.MemberIds
            : hw.ApiId is Guid singleId ? [singleId] : [];
        foreach (var homeworkId in ids)
            await HomeworkSvc.DeleteHomeworkAsync(homeworkId);
        await ReloadAsync();
    }

