@using System.Text.Json
@using System.Text.Json.Serialization
@page "/tutor/profile"
@layout TutorLayout
@rendermode InteractiveServer
@inject IStringLocalizer<SharedResources> L
@inject ApiClient Api
@inject AuthService Auth

<PageTitle>@L["Profile_Title"] – TutorSphere</PageTitle>

<div class="ts-page-header">
    <div>
        <h1><i class="bi bi-person-badge me-2"></i>@L["Profile_Title"]</h1>
        <p class="ts-page-subtitle">@L["Profile_Subtitle"]</p>
    </div>
    <div class="d-flex gap-2">
        <a href="/tutor/school" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-building me-1"></i>@L["Profile_MySchool"]
        </a>
        <button class="btn btn-primary" @onclick="SaveProfile" disabled="@_saving">
            @if (_saving) { <span class="spinner-border spinner-border-sm me-1"></span> }
            @L["Common_Save"]
        </button>
    </div>
</div>

@if (!string.IsNullOrEmpty(_error))
{
    <div class="alert alert-danger mb-4">
        <i class="bi bi-exclamation-circle me-2"></i>@_error
    </div>
}
@if (_saved)
{
    <div class="alert alert-success mb-4">
        <i class="bi bi-check-circle me-2"></i>@L["Profile_Updated"]
    </div>
}

<div class="ts-tabs-bar mb-4">
    <button class="ts-tab @(_tab=="presentation"?"active":"")" @onclick='()=>_tab="presentation"'>@L["Profile_TabPresentation"]</button>
    <button class="ts-tab @(_tab=="credentials"?"active":"")" @onclick='()=>_tab="credentials"'>@L["Profile_TabCredentials"]</button>
    <button class="ts-tab @(_tab=="subjects"?"active":"")" @onclick='()=>_tab="subjects"'>@L["Profile_TabSubjects"]</button>
    <button class="ts-tab @(_tab=="availability"?"active":"")" @onclick='()=>_tab="availability"'>@L["Profile_TabAvailability"]</button>
</div>

@if (_tab == "presentation")
{
    <div class="profile-card-layout">
        <div class="profile-avatar-card">
            <div class="profile-avatar-large" style="@(_photoDataUrl != null ? $"background:url({_photoDataUrl}) center/cover no-repeat;font-size:0" : "background:var(--ts-gradient-primary)")">
                @if (_photoDataUrl == null) { <text>@(_p.FirstName.Length > 0 ? _p.FirstName[0].ToString() : "")@(_p.LastName.Length > 0 ? _p.LastName[0].ToString() : "")</text> }
            </div>
            <label class="btn btn-outline-secondary btn-sm w-100 mt-2" style="cursor:pointer;margin:0">
                <i class="bi bi-camera me-1"></i>@L["Profile_ChangePhoto"]
                <InputFile OnChange="HandlePhotoChange" accept="image/*" style="display:none" />
            </label>
            <div class="profile-status mt-3">
                <label class="form-label">@L["Profile_Status"]</label>
                <select class="form-select form-select-sm" @bind="_p.Status">
                    <option value="Disponible">@L["Profile_StatusAvailable"]</option>
                    <option value="Complet">@L["Profile_StatusFull"]</option>
                    <option value="Inactif">@L["Profile_StatusInactive"]</option>
                </select>
            </div>
        </div>
        <div class="profile-info-card">
            <div class="row g-3">
                <div class="col-6"><label class="form-label">@L["Common_FirstName"] *</label>
                    <input class="form-control" @bind="_p.FirstName" /></div>
                <div class="col-6"><label class="form-label">@L["Common_LastName"] *</label>
                    <input class="form-control" @bind="_p.LastName" /></div>
                <div class="col-12"><label class="form-label">@L["Profile_Bio"]</label>
                    <textarea class="form-control" rows="3" @bind="_p.Bio"
                        placeholder="@L["Profile_BioPlaceholder"]"></textarea></div>
                <div class="col-md-4"><label class="form-label">@L["Profile_YearsExp"]</label>
                    <input type="number" class="form-control" @bind="_p.YearsExperience" /></div>
                <div class="col-md-4"><label class="form-label">@L["Profile_HourlyRate"]</label>
                    <input type="number" class="form-control" @bind="_p.HourlyRate" /></div>
                <div class="col-md-4"><label class="form-label">@L["Profile_Languages"]</label>
                    <input class="form-control" @bind="_p.Languages" placeholder="Français, Anglais" /></div>
                <div class="col-12"><label class="form-label">@L["Profile_FullCv"]</label>
                    <textarea class="form-control" rows="5" @bind="_p.FullBio"
                        placeholder="@L["Profile_FullCvPlaceholder"]"></textarea></div>
            </div>
        </div>
    </div>
}
else if (_tab == "credentials")
{
    <div class="section-card p-4">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h5 class="mb-0">@L["Profile_Diplomas"]</h5>
            @if (!_showDiplomaForm)
            {
                <button type="button" class="btn btn-sm btn-outline-primary" @onclick="OpenDiplomaForm">
                    <i class="bi bi-plus me-1"></i>@L["Common_Add"]
                </button>
            }
        </div>

        @if (_showDiplomaForm)
        {
            <div class="credential-form mb-3">
                <div class="row g-2">
                    <div class="col-md-5">
                        <label class="form-label">@L["Profile_TitleLabel"] *</label>
                        <input class="form-control" @bind="_diplomaDraft.Title" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">@L["Profile_Institution"] *</label>
                        <input class="form-control" @bind="_diplomaDraft.Institution" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">@L["Profile_Year"]</label>
                        <input class="form-control" @bind="_diplomaDraft.Year" placeholder="2020" />
                    </div>
                </div>
                @if (!string.IsNullOrEmpty(_credentialFormError))
                {
                    <div class="text-danger small mt-2">@_credentialFormError</div>
                }
                <div class="d-flex gap-2 mt-3">
                    <button type="button" class="btn btn-primary btn-sm" @onclick="ConfirmAddDiploma">@L["Profile_AddDiploma"]</button>
                    <button type="button" class="btn btn-outline-secondary btn-sm" @onclick="CancelDiplomaForm">@L["Common_Cancel"]</button>
                </div>
            </div>
        }

        @if (_p.Diplomas.Count == 0 && !_showDiplomaForm)
        {
            <p class="text-muted small mb-0">@L["Profile_NoDiplomas"]</p>
        }
        @foreach (var d in _p.Diplomas)
        {
            <div class="credential-item credential-item--editable">
                <i class="bi bi-mortarboard credential-icon"></i>
                <div class="credential-fields flex-grow-1">
                    <input class="form-control form-control-sm mb-1" @bind="d.Title" placeholder="@L["Profile_TitleLabel"]" />
                    <div class="d-flex gap-2">
                        <input class="form-control form-control-sm" @bind="d.Institution" placeholder="@L["Profile_Institution"]" />
                        <input class="form-control form-control-sm" style="max-width:6rem" @bind="d.Year" placeholder="@L["Profile_Year"]" />
                    </div>
                </div>
                <button type="button" class="ts-icon-btn ts-icon-btn--danger" title="@L["Common_Delete"]" @onclick="() => RemoveDiploma(d)">
                    <i class="bi bi-trash"></i>
                </button>
            </div>
        }

        <hr />

        <div class="d-flex justify-content-between align-items-center mb-3">
            <h5 class="mb-0">@L["Profile_Certifications"]</h5>
            @if (!_showCertForm)
            {
                <button type="button" class="btn btn-sm btn-outline-primary" @onclick="OpenCertForm">
                    <i class="bi bi-plus me-1"></i>@L["Common_Add"]
                </button>
            }
        </div>

        @if (_showCertForm)
        {
            <div class="credential-form mb-3">
                <div class="row g-2">
                    <div class="col-md-5">
                        <label class="form-label">@L["Profile_TitleLabel"] *</label>
                        <input class="form-control" @bind="_certDraft.Title" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">@L["Profile_Organization"] *</label>
                        <input class="form-control" @bind="_certDraft.Institution" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">@L["Profile_Year"]</label>
                        <input class="form-control" @bind="_certDraft.Year" placeholder="2023" />
                    </div>
                </div>
                @if (!string.IsNullOrEmpty(_credentialFormError))
                {
                    <div class="text-danger small mt-2">@_credentialFormError</div>
                }
                <div class="d-flex gap-2 mt-3">
                    <button type="button" class="btn btn-primary btn-sm" @onclick="ConfirmAddCert">@L["Profile_AddCert"]</button>
                    <button type="button" class="btn btn-outline-secondary btn-sm" @onclick="CancelCertForm">@L["Common_Cancel"]</button>
                </div>
            </div>
        }

        @if (_p.Certifications.Count == 0 && !_showCertForm)
        {
            <p class="text-muted small mb-0">@L["Profile_NoCerts"]</p>
        }
        @foreach (var c in _p.Certifications)
        {
            <div class="credential-item credential-item--editable">
                <i class="bi bi-award credential-icon text-warning"></i>
                <div class="credential-fields flex-grow-1">
                    <input class="form-control form-control-sm mb-1" @bind="c.Title" placeholder="@L["Profile_TitleLabel"]" />
                    <div class="d-flex gap-2">
                        <input class="form-control form-control-sm" @bind="c.Institution" placeholder="@L["Profile_Organization"]" />
                        <input class="form-control form-control-sm" style="max-width:6rem" @bind="c.Year" placeholder="@L["Profile_Year"]" />
                    </div>
                </div>
                <button type="button" class="ts-icon-btn ts-icon-btn--danger" title="@L["Common_Delete"]" @onclick="() => RemoveCert(c)">
                    <i class="bi bi-trash"></i>
                </button>
            </div>
        }
    </div>
}
else if (_tab == "subjects")
{
    <div class="section-card p-4">
        <p class="text-muted mb-3">@L["Profile_SubjectsHint"]</p>
        <div class="subject-chips">
            @foreach (var s in _allSubjects)
            {
                var active = _p.Subjects.Contains(s);
                <button type="button" class="ts-chip @(active?"active":"")"
                        @onclick="()=>{ if(active) _p.Subjects.Remove(s); else _p.Subjects.Add(s); }">
                    @s
                </button>
            }
        </div>

        <hr class="my-4" />
        <h5 class="mb-2">@L["Label_Level"]</h5>
        <p class="text-muted mb-3">@L["Profile_LevelsHint"]</p>
        <div class="subject-chips">
            @foreach (var level in _allLevels)
            {
                var active = _p.Levels.Contains(level);
                <button type="button" class="ts-chip @(active?"active":"")"
                        @onclick="()=>{ if(active) _p.Levels.Remove(level); else _p.Levels.Add(level); }">
                    @level
                </button>
            }
        </div>
    </div>
}
else if (_tab == "availability")
{
    <div class="section-card p-4">
        <p class="text-muted mb-3">@L["Profile_AvailabilityHint"]</p>
        <div class="availability-grid">
            @foreach (var day in _days)
            {
                <div class="avail-row">
                    <span class="avail-day">@day</span>
                    <div class="d-flex gap-2 flex-wrap">
                        @foreach (var slot in _timeSlots)
                        {
                            var key = $"{day}-{slot}";
                            var active = _p.Availability.Contains(key);
                            <button type="button" class="avail-chip @(active?"active":"")"
                                    @onclick="()=>{ if(active) _p.Availability.Remove(key); else _p.Availability.Add(key); }">
                                @slot
                            </button>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
}

@code {
    private string _tab = "presentation";
    private bool _saving, _saved;
    private string? _error;
    private string? _photoDataUrl;
    private bool _showDiplomaForm;
    private bool _showCertForm;
    private string? _credentialFormError;
    private Credential _diplomaDraft = new();
    private Credential _certDraft = new();

    private static readonly JsonSerializerOptions PortfolioJson = new()
    {
        PropertyNamingPolicy = JsonNamingPolicy.CamelCase,
        DefaultIgnoreCondition = JsonIgnoreCondition.WhenWritingNull
    };

    private async Task HandlePhotoChange(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file != null)
            _photoDataUrl = await ConvertToDataUrl(file);
    }

    private static async Task<string> ConvertToDataUrl(IBrowserFile file)
    {
        using var stream = file.OpenReadStream(maxAllowedSize: 5_000_000);
        using var ms = new MemoryStream();
        await stream.CopyToAsync(ms);
        return $"data:{file.ContentType};base64,{Convert.ToBase64String(ms.ToArray())}";
    }

    private static readonly string[] _allSubjects = ["Mathématiques","Physique","Chimie","Biologie","Français","Anglais","Espagnol","Histoire-Géo","Philosophie","Économie","Informatique","Comptabilité"];
    private static readonly string[] _allLevels =
    [
        "Primaire",
        "Secondaire 1",
        "Secondaire 2",
        "Secondaire 3",
        "Secondaire 4",
        "Secondaire 5",
        "Cégep",
        "Université"
    ];
    private static readonly string[] _days = ["Lundi","Mardi","Mercredi","Jeudi","Vendredi","Samedi","Dimanche"];
    private static readonly string[] _timeSlots = ["Matin","Après-midi","Soir"];

    protected override async Task OnInitializedAsync()
    {
        await Auth.EnsureSessionRestoredAsync();

        var me = await Api.GetAsync<UserProfileDto>("api/me/profile");
        if (me is not null)
        {
            _p.FirstName = me.FirstName;
            _p.LastName = me.LastName;
            _p.Bio = me.Bio ?? "";
            _p.Languages = me.PreferredLanguage switch
            {
                "en" => "Anglais",
                "fr" => "Français",
                _ => me.PreferredLanguage
            };
        }
        else
        {
            var authName = Auth.UserName;
            if (!string.IsNullOrWhiteSpace(authName))
            {
                var authParts = authName.Split(' ', 2, StringSplitOptions.RemoveEmptyEntries);
                _p.FirstName = authParts.Length > 0 ? authParts[0] : "";
                _p.LastName = authParts.Length > 1 ? authParts[1] : "";
            }
        }

        await LoadShowcaseAsync();
    }

    private async Task LoadShowcaseAsync()
    {
        if (Auth.TenantId is not Guid tenantId)
            return;

        var branding = await Api.GetAsync<BrandingDto>($"api/branding/tenant/{tenantId}");
        if (branding is null)
            return;

        if (!string.IsNullOrWhiteSpace(branding.Presentation))
            _p.FullBio = branding.Presentation;

        if (!string.IsNullOrWhiteSpace(branding.LogoUrl))
            _photoDataUrl = branding.LogoUrl;

        if (string.IsNullOrWhiteSpace(branding.Portfolio))
            return;

        try
        {
            var data = JsonSerializer.Deserialize<TutorShowcaseDto>(branding.Portfolio, PortfolioJson);
            if (data is null) return;

            _p.YearsExperience = data.YearsExperience;
            _p.HourlyRate = data.HourlyRate;
            _p.Status = string.IsNullOrWhiteSpace(data.Status) ? _p.Status : data.Status;
            _p.Diplomas = data.Diplomas?.Select(c => new Credential
            {
                Title = c.Title ?? "",
                Institution = c.Institution ?? "",
                Year = c.Year ?? ""
            }).ToList() ?? [];
            _p.Certifications = data.Certifications?.Select(c => new Credential
            {
                Title = c.Title ?? "",
                Institution = c.Institution ?? "",
                Year = c.Year ?? ""
            }).ToList() ?? [];
            _p.Subjects = data.Subjects?.ToList() ?? [];
            _p.Levels = data.Levels?.ToList() ?? [];
            _p.Availability = data.Availability is { Count: > 0 }
                ? new HashSet<string>(data.Availability)
                : [];
        }
        catch
        {
            /* ignore invalid portfolio json */
        }
    }

    private async Task SaveProfile()
    {
        if (string.IsNullOrWhiteSpace(_p.FirstName) || string.IsNullOrWhiteSpace(_p.LastName))
        {
            _error = "Prénom et nom sont obligatoires.";
            _saved = false;
            return;
        }

        _saving = true;
        _saved = false;
        _error = null;
        try
        {
            var result = await Api.PutWithErrorAsync<UserProfileDto>("api/me/profile", new
            {
                firstName = _p.FirstName.Trim(),
                lastName = _p.LastName.Trim(),
                bio = _p.Bio,
                preferredLanguage = _p.Languages
            });

            if (result.Error is not null)
            {
                _error = result.Error;
                return;
            }

            if (Auth.TenantId is Guid tenantId)
            {
                var showcase = new TutorShowcaseDto(
                    _p.YearsExperience,
                    _p.HourlyRate,
                    _p.Status,
                    _p.Diplomas.Select(c => new CredentialDto(c.Title, c.Institution, c.Year)).ToList(),
                    _p.Certifications.Select(c => new CredentialDto(c.Title, c.Institution, c.Year)).ToList(),
                    _p.Subjects.ToList(),
                    _p.Levels.ToList(),
                    _p.Availability.ToList());

                var brandingResult = await Api.PutWithErrorAsync<BrandingDto>($"api/branding/tenant/{tenantId}", new
                {
                    logoUrl = _photoDataUrl,
                    presentation = _p.FullBio,
                    portfolio = JsonSerializer.Serialize(showcase, PortfolioJson)
                });

                if (brandingResult.Error is not null)
                {
                    _error = brandingResult.Error;
                    return;
                }
            }

            var fullName = result.Value?.FullName ?? $"{_p.FirstName} {_p.LastName}".Trim();
            await Auth.UpdateLocalDisplayNameAsync(fullName);
            _saved = true;
        }
        finally
        {
            _saving = false;
        }
    }

    private record UserProfileDto(
        string Email, string FirstName, string LastName, string FullName,
        string? Phone, string? Bio, string PreferredLanguage, string TimeZone, string Role);

    private record BrandingDto(
        Guid Id, Guid TenantId, string? LogoUrl, string? BannerUrl,
        string PrimaryColor, string SecondaryColor, string? Presentation, string? Portfolio);

    private record CredentialDto(string? Title, string? Institution, string? Year);

    private record TutorShowcaseDto(
        int YearsExperience,
        decimal HourlyRate,
        string? Status,
        List<CredentialDto>? Diplomas,
        List<CredentialDto>? Certifications,
        List<string>? Subjects,
        List<string>? Levels,
        List<string>? Availability);

    private void OpenDiplomaForm()
    {
        _credentialFormError = null;
        _diplomaDraft = new Credential();
        _showDiplomaForm = true;
        _showCertForm = false;
    }

    private void CancelDiplomaForm()
    {
        _showDiplomaForm = false;
        _credentialFormError = null;
        _diplomaDraft = new Credential();
    }

    private void ConfirmAddDiploma()
    {
        if (string.IsNullOrWhiteSpace(_diplomaDraft.Title) || string.IsNullOrWhiteSpace(_diplomaDraft.Institution))
        {
            _credentialFormError = L["Profile_CredentialRequired"];
            return;
        }

        _p.Diplomas.Add(new Credential
        {
            Title = _diplomaDraft.Title.Trim(),
            Institution = _diplomaDraft.Institution.Trim(),
            Year = (_diplomaDraft.Year ?? "").Trim()
        });
        CancelDiplomaForm();
    }

    private void RemoveDiploma(Credential d) => _p.Diplomas.Remove(d);

    private void OpenCertForm()
    {
        _credentialFormError = null;
        _certDraft = new Credential();
        _showCertForm = true;
        _showDiplomaForm = false;
    }

    private void CancelCertForm()
    {
        _showCertForm = false;
        _credentialFormError = null;
        _certDraft = new Credential();
    }

    private void ConfirmAddCert()
    {
        if (string.IsNullOrWhiteSpace(_certDraft.Title) || string.IsNullOrWhiteSpace(_certDraft.Institution))
        {
            _credentialFormError = L["Profile_CredentialRequired"];
            return;
        }

        _p.Certifications.Add(new Credential
        {
            Title = _certDraft.Title.Trim(),
            Institution = _certDraft.Institution.Trim(),
            Year = (_certDraft.Year ?? "").Trim()
        });
        CancelCertForm();
    }

    private void RemoveCert(Credential c) => _p.Certifications.Remove(c);

    private class Credential
    {
        public string Title { get; set; } = "";
        public string Institution { get; set; } = "";
        public string Year { get; set; } = "";
    }

    private class ProfileVM
    {
        public string FirstName{get;set;}=""; public string LastName{get;set;}="";
        public string Bio{get;set;}="";
        public string FullBio{get;set;}="";
        public int YearsExperience{get;set;}=0; public decimal HourlyRate{get;set;}=0;
        public string Languages{get;set;}="Français"; public string Status{get;set;}="Disponible";
        public bool IsVerified{get;set;}=false;
        public List<Credential> Diplomas{get;set;}=[];
        public List<Credential> Certifications{get;set;}=[];
        public List<string> Subjects{get;set;}=[];
        public List<string> Levels{get;set;}=[];
        public HashSet<string> Availability{get;set;}=[];
    }
    private ProfileVM _p = new();
}
