@page "/tutor/premium"
@layout TutorLayout
@rendermode InteractiveServer
@inject AuthService AuthSvc
@inject ApiClient Api
@inject NavigationManager Navigation
@inject IStringLocalizer<SharedResources> L

<PageTitle>@L["Nav_Pricing"] – TutorSphere</PageTitle>

<div class="ts-page-header">
    <div>
        <h1><i class="bi bi-stars me-2" style="color:#5831E0"></i>@L["Nav_Pricing"]</h1>
        <p class="ts-page-subtitle">@L["Tutor_PricingDesc"]</p>
    </div>
    @if (_plan != null)
    {
        <span class="ts-badge @(_plan == "Active" ? "ts-badge-success" : "ts-badge-muted")" style="font-size:1rem;padding:.5rem 1rem">
            <i class="bi bi-patch-check-fill me-1"></i>
            @(_plan == "Active" ? "Plan Actif" : "Essai gratuit")
        </span>
    }
</div>

@if (_error != null)
{
    <div class="alert alert-danger mb-4">
        <i class="bi bi-exclamation-circle me-2"></i>@_error
    </div>
}

<PricingComparisonTable OnSubscribe="SubscribeAsync"
                        Subscribing="_subscribing"
                        SubscribingPlanId="_subscribingPlanId" />

<p class="text-center text-muted mb-5" style="font-size:.85rem">
    <i class="bi bi-shield-lock me-1"></i>@L["Tutor_PricingTrial"]
</p>

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="section-card p-4">
            <h3 class="mb-4 text-center" style="color:var(--ts-primary)">Questions fréquentes</h3>
            @foreach (var faq in _faqs)
            {
                <div class="premium-faq-item">
                    <button class="premium-faq-question"
                            @onclick="() => faq.Open = !faq.Open">
                        <span>@faq.Question</span>
                        <i class="bi @(faq.Open ? "bi-chevron-up" : "bi-chevron-down")"></i>
                    </button>
                    @if (faq.Open)
                    {
                        <div class="premium-faq-answer">@faq.Answer</div>
                    }
                </div>
            }
        </div>
    </div>
</div>

<style>
    .premium-faq-item { border-bottom: 1px solid var(--ts-border); }
    .premium-faq-item:last-child { border-bottom: none; }
    .premium-faq-question {
        display: flex;
        justify-content: space-between;
        align-items: center;
        width: 100%;
        background: none;
        border: none;
        padding: 1rem 0;
        font-weight: 600;
        font-size: .95rem;
        cursor: pointer;
        color: var(--ts-text);
        text-align: left;
    }
    .premium-faq-question:hover { color: var(--ts-primary); }
    .premium-faq-answer {
        padding: 0 0 1rem;
        color: var(--ts-muted);
        font-size: .9rem;
        line-height: 1.6;
    }
</style>

@code {
    private string? _plan;
    private bool _subscribing;
    private string? _subscribingPlanId;
    private string? _error;

    private class FaqItem { public string Question { get; set; } = ""; public string Answer { get; set; } = ""; public bool Open { get; set; } }

    private readonly List<FaqItem> _faqs =
    [
        new()
        {
            Question = "Puis-je annuler mon abonnement à tout moment ?",
            Answer = "Oui. Vous pouvez annuler votre abonnement depuis les paramètres de votre compte. L'accès reste actif jusqu'à la fin de la période déjà payée."
        },
        new()
        {
            Question = "Qu'est-ce qui se passe après l'essai gratuit ?",
            Answer = "Après 14 jours d'essai, votre carte sera débitée automatiquement selon le forfait choisi. Aucun frais pendant l'essai."
        },
        new()
        {
            Question = "Quel forfait choisir ?",
            Answer = "Le forfait Professional convient à la plupart des enseignants indépendants. Passez au Business si vous gérez plusieurs enseignants, ou contactez-nous pour Enterprise."
        },
        new()
        {
            Question = "La facturation est-elle sécurisée ?",
            Answer = "Oui. Tous les paiements sont traités par Stripe, leader mondial du paiement en ligne. Nous ne stockons jamais vos informations bancaires."
        },
    ];

    protected override void OnInitialized()
    {
        _plan = AuthSvc.IsAuthenticated ? "Trial" : null;
    }

    private async Task SubscribeAsync(string planId)
    {
        _error = null;
        _subscribingPlanId = planId;
        _subscribing = true;
        try
        {
            await Task.Delay(500);
            _error = "Pour vous abonner, veuillez contacter le support ou créer un abonnement élève dans l'onglet Abonnements, puis accéder au paiement.";
        }
        finally
        {
            _subscribing = false;
            _subscribingPlanId = null;
        }
    }
}
