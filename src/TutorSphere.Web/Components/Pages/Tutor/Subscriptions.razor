@page "/tutor/subscriptions"
@layout TutorLayout
@rendermode InteractiveServer
@inject IStringLocalizer<SharedResources> L
@inject ApiClient Api
@inject AuthService Auth

<PageTitle>@L["TutorSubs_Title"] – TutorSphere</PageTitle>

<div class="ts-page-header">
    <div>
        <h1><i class="bi bi-arrow-repeat me-2"></i>@L["TutorSubs_Title"]</h1>
        <p class="ts-page-subtitle">@L["TutorSubs_Subtitle"]</p>
    </div>
    <button class="btn btn-primary" @onclick="()=>_showPlanModal=true">
        <i class="bi bi-plus-lg me-1"></i>@L["TutorSubs_CreatePlan"]
    </button>
</div>

@if (!string.IsNullOrEmpty(_loadError))
{
    <div class="alert alert-warning mb-3" role="alert">@_loadError</div>
}
@if (!string.IsNullOrEmpty(_actionError))
{
    <div class="alert alert-danger mb-3" role="alert">@_actionError</div>
}
@if (!string.IsNullOrEmpty(_actionBanner))
{
    <div class="alert alert-success mb-3" role="alert">@_actionBanner</div>
}

<!-- KPIs -->
<div class="row g-3 mb-4">
    <div class="col-6 col-lg-3">
        <div class="ts-kpi-card ts-kpi-card--success">
            <span class="ts-kpi-val">@_subs.Count(s => IsActiveStatus(s.Status))</span>
            <span class="ts-kpi-label">@L["TutorSubs_Active"]</span>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="ts-kpi-card ts-kpi-card--warning">
            <span class="ts-kpi-val">@_subs.Count(s => IsActiveStatus(s.Status) && s.ExpiresAt <= DateTime.Today.AddDays(14))</span>
            <span class="ts-kpi-label">@L["TutorSubs_ExpiringSoon"]</span>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="ts-kpi-card">
            <span class="ts-kpi-val">@_subs.Where(s => IsActiveStatus(s.Status)).Sum(s => s.Amount).ToString("N0") $</span>
            <span class="ts-kpi-label">@L["TutorSubs_MRR"]</span>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="ts-kpi-card">
            <span class="ts-kpi-val">@AvgActiveAmount().ToString("N0") $</span>
            <span class="ts-kpi-label">@L["TutorSubs_AvgAmount"]</span>
        </div>
    </div>
</div>

<!-- Plans section -->
<div class="section-card mb-4">
    <div class="section-card-header">
        <h2>@L["TutorSubs_MyPlans"]</h2>
    </div>
    <div class="sub-plans-grid">
        @foreach (var plan in _plans)
        {
            <div class="sub-plan-card @(plan.Popular?"sub-plan-card--featured":"")">
                @if (plan.Popular) { <div class="sub-plan-badge">@L["TutorSubs_Popular"]</div> }
                <h3>@plan.Name</h3>
                <div class="sub-plan-price">
                    <span class="sub-plan-amount">@plan.Price $</span>
                    <span class="sub-plan-period">/ @plan.Period</span>
                </div>
                <ul class="sub-plan-features">
                    @foreach (var f in plan.Features)
                    {
                        <li><i class="bi bi-check-circle-fill text-success me-2"></i>@f</li>
                    }
                </ul>
                <div class="sub-plan-footer">
                    <span class="text-muted small">@string.Format(L["TutorSubs_Subscribers"].Value, _subs.Count(s => s.PlanName == plan.Name && IsActiveStatus(s.Status)))</span>
                    <div class="d-flex gap-1">
                        <button class="ts-icon-btn" title="@(plan.IsActive ? L["TutorSubs_Deactivate"] : L["TutorSubs_Activate"])"
                                @onclick="async () => await TogglePlan(plan)">
                            <i class="bi @(plan.IsActive ? "bi-toggle-on text-success" : "bi-toggle-off text-muted")"></i>
                        </button>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<!-- Subscribers table -->
<div class="section-card">
    <div class="section-card-header">
        <h2>@L["TutorSubs_SubscribersTitle"]</h2>
        <div class="d-flex gap-2">
            <select class="form-select form-select-sm w-auto" @bind="_filterSubStatus">
                <option value="">@L["Common_All"]</option>
                <option value="Pending">@L["TutorSubs_StatusPending"]</option>
                <option value="AwaitingPayment">@L["TutorSubs_StatusAwaitingPayment"]</option>
                <option value="Active">@L["TutorSubs_StatusActive"]</option>
                <option value="Paused">@L["TutorSubs_StatusSuspended"]</option>
                <option value="Rejected">@L["TutorSubs_StatusRejected"]</option>
                <option value="Cancelled">@L["TutorSubs_StatusCancelled"]</option>
            </select>
        </div>
    </div>
    @if (_loading)
    {
        <div class="d-flex align-items-center justify-content-center py-4">
            <span class="spinner-border text-primary me-2" role="status"></span>
            <span class="text-muted">@L["Common_Loading"]</span>
        </div>
    }
    else if (!FilteredSubs.Any())
    {
        <div class="text-center text-muted py-5">
            <i class="bi bi-people fs-1 d-block mb-2 opacity-50"></i>
            <p class="mb-0">@L["TutorSubs_NoSubscribers"]</p>
        </div>
    }
    else
    {
        <table class="table ts-table">
            <thead>
                <tr>
                    <th>@L["TutorSubs_StudentParent"]</th>
                    <th>@L["TutorSubs_Plan"]</th>
                    <th>@L["TutorSubs_Amount"]</th>
                    <th>@L["TutorSubs_Renewal"]</th>
                    <th>@L["Common_Status"]</th>
                    <th>@L["Common_Actions"]</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var s in FilteredSubs)
                {
                    <tr class="@(s.ExpiresAt <= DateTime.Today.AddDays(7) && IsActiveStatus(s.Status) ? "ts-row-warning" : "")">
                        <td>
                            <div><strong>@s.StudentName</strong></div>
                            <small class="text-muted">@(string.IsNullOrWhiteSpace(s.ParentName) ? "—" : s.ParentName)</small>
                        </td>
                        <td><span class="ts-badge ts-badge-neutral">@s.PlanName</span></td>
                        <td class="fw-semibold">@s.Amount.ToString("N2") $</td>
                        <td>@s.ExpiresAt.ToString("dd/MM/yyyy")
                            @if (s.ExpiresAt <= DateTime.Today.AddDays(14) && IsActiveStatus(s.Status))
                            {
                                <span class="text-warning ms-1"><i class="bi bi-exclamation-circle"></i></span>
                            }
                        </td>
                        <td><span class="ts-badge @SubBadge(s.Status)">@SubStatusLabel(s.Status)</span></td>
                        <td>
                            <div class="ts-action-group">
                                @if (s.Status == "Pending")
                                {
                                    <button class="btn btn-sm btn-success"
                                            disabled="@(_busyId == s.Id)"
                                            title="@L["TutorSubs_Accept"]"
                                            @onclick="async () => await AcceptAsync(s)">
                                        @if (_busyId == s.Id)
                                        {
                                            <span class="spinner-border spinner-border-sm"></span>
                                        }
                                        else
                                        {
                                            <i class="bi bi-check-lg me-1"></i>@L["TutorSubs_Accept"]
                                        }
                                    </button>
                                    <button class="btn btn-sm btn-outline-danger"
                                            disabled="@(_busyId == s.Id)"
                                            title="@L["TutorSubs_Refuse"]"
                                            @onclick="async () => await RejectAsync(s)">
                                        <i class="bi bi-x-lg me-1"></i>@L["TutorSubs_Refuse"]
                                    </button>
                                }
                                else if (s.Status == "Active")
                                {
                                    <button class="ts-icon-btn" title="@L["TutorSubs_Suspend"]" @onclick='() => s.Status = "Paused"'>
                                        <i class="bi bi-pause-circle text-warning"></i>
                                    </button>
                                }
                                else if (s.Status == "Paused")
                                {
                                    <button class="ts-icon-btn" title="@L["TutorSubs_Reactivate"]" @onclick='() => s.Status = "Active"'>
                                        <i class="bi bi-play-circle text-success"></i>
                                    </button>
                                }
                                <button class="ts-icon-btn" title="@L["TutorSubs_Invoice"]"><i class="bi bi-receipt"></i></button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

@if (_showPlanModal)
{
    <div class="ts-modal-backdrop" @onclick="()=>_showPlanModal=false">
        <div class="ts-modal" @onclick:stopPropagation="true">
            <div class="ts-modal-header">
                <h2>@L["TutorSubs_CreatePlanTitle"]</h2>
                <button class="ts-modal-close" @onclick="()=>_showPlanModal=false"><i class="bi bi-x-lg"></i></button>
            </div>
            <div class="ts-modal-body">
                <div class="row g-3">
                    <div class="col-12"><label class="form-label">@L["TutorSubs_PlanName"] *</label>
                        <input class="form-control" @bind="_pf.Name" /></div>
                    <div class="col-6"><label class="form-label">@L["TutorSubs_Price"] *</label>
                        <input type="number" class="form-control" @bind="_pf.Price" /></div>
                    <div class="col-6"><label class="form-label">@L["TutorSubs_Period"]</label>
                        <select class="form-select" @bind="_pf.Period">
                            <option value="mois">@L["TutorSubs_PeriodMonth"]</option>
                            <option value="trimestre">@L["TutorSubs_PeriodQuarter"]</option>
                            <option value="semestre">@L["TutorSubs_PeriodSemester"]</option>
                            <option value="an">@L["TutorSubs_PeriodYear"]</option>
                        </select></div>
                    <div class="col-12"><label class="form-label">@L["TutorSubs_Features"]</label>
                        <textarea class="form-control" rows="4" @bind="_pf.Features"></textarea></div>
                    <div class="col-12">
                        <div class="form-check form-switch">
                            <input class="form-check-input" type="checkbox" @bind="_pf.Popular" id="plan-popular" />
                            <label class="form-check-label" for="plan-popular">@L["TutorSubs_MarkPopular"]</label>
                        </div>
                    </div>
                </div>
            </div>
            <div class="ts-modal-footer">
                <button class="btn btn-outline-secondary" @onclick="()=>_showPlanModal=false">@L["Common_Cancel"]</button>
                <button class="btn btn-primary" @onclick="async () => await SavePlan()">@L["TutorSubs_Create"]</button>
            </div>
        </div>
    </div>
}

@code {
    private string _filterSubStatus = "";
    private bool _showPlanModal;
    private bool _loading = true;
    private bool _initialLoadDone;
    private string? _loadError;
    private string? _actionError;
    private string? _actionBanner;
    private Guid? _busyId;
    private PlanForm _pf = new();

    private static bool IsActiveStatus(string status) =>
        status is "Active" or "Actif";

    private decimal AvgActiveAmount()
    {
        var active = _subs.Where(s => IsActiveStatus(s.Status)).ToList();
        return active.Count > 0 ? Math.Round(active.Average(s => s.Amount), 0) : 0;
    }

    private static string SubBadge(string s) => s switch {
        "Active" or "Actif" => "ts-badge-success",
        "Paused" or "Suspendu" or "AwaitingPayment" or "Pending" => "ts-badge-warning",
        "Cancelled" or "Résilié" or "Rejected" => "ts-badge-danger",
        "Expired" => "ts-badge-neutral",
        _ => "ts-badge-neutral"
    };

    private string SubStatusLabel(string s) => s switch {
        "Active" or "Actif" => L["TutorSubs_StatusActive"],
        "Paused" or "Suspendu" => L["TutorSubs_StatusSuspended"],
        "Cancelled" or "Résilié" => L["TutorSubs_StatusCancelled"],
        "Pending" => L["TutorSubs_StatusPending"],
        "AwaitingPayment" => L["TutorSubs_StatusAwaitingPayment"],
        "Rejected" => L["TutorSubs_StatusRejected"],
        "Expired" => L["TutorSubs_StatusExpired"],
        _ => s
    };

    private IEnumerable<SubVM> FilteredSubs => _subs
        .Where(s => string.IsNullOrEmpty(_filterSubStatus) || s.Status == _filterSubStatus)
        .OrderBy(s => s.ExpiresAt);

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _initialLoadDone)
            return;

        _initialLoadDone = true;
        await Auth.EnsureSessionRestoredAsync(forceJs: true);
        await LoadAsync();
        StateHasChanged();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _loadError = null;
        try
        {
            var offeringsTask = Api.GetAsync<List<ApiOfferingDto>>("api/subscription-offerings");
            var subscribersTask = Api.GetAsync<List<ApiSubscriberDto>>("api/subscription-offerings/subscribers");
            await Task.WhenAll(offeringsTask, subscribersTask);

            var offerings = await offeringsTask ?? [];
            _plans.Clear();
            foreach (var o in offerings)
            {
                _plans.Add(new PlanVM
                {
                    ApiId = o.Id,
                    Name = o.Title,
                    Price = o.Price,
                    Period = "mois",
                    Popular = false,
                    IsActive = o.IsActive,
                    Features = string.IsNullOrEmpty(o.Description)
                        ? []
                        : o.Description.Split('\n').Where(f => !string.IsNullOrWhiteSpace(f)).ToList()
                });
            }

            var subscribers = await subscribersTask ?? [];
            _subs.Clear();
            _subs.AddRange(subscribers.Select(MapSubscriber));
        }
        catch (Exception ex)
        {
            _loadError = string.Format(L["TutorSubs_LoadError"].Value, ex.Message);
        }
        finally { _loading = false; }
    }

    private static SubVM MapSubscriber(ApiSubscriberDto s) => new()
    {
        Id = s.Id,
        StudentName = s.StudentName,
        ParentName = s.ParentName ?? "",
        PlanName = s.OfferingTitle,
        Amount = s.Price,
        ExpiresAt = s.EndDate.Kind == DateTimeKind.Utc ? s.EndDate.ToLocalTime().Date : s.EndDate.Date,
        Status = s.Status
    };

    private async Task AcceptAsync(SubVM sub)
    {
        _busyId = sub.Id;
        _actionError = null;
        _actionBanner = null;
        try
        {
            var result = await Api.PostWithErrorAsync<ApiSubscriberDto>(
                $"api/subscription-offerings/subscribers/{sub.Id}/accept",
                new { });
            if (result.Error is not null || result.Value is null)
            {
                _actionError = result.Error ?? L["TutorSubs_ActionFailed"];
                return;
            }

            ApplySubscriberUpdate(sub.Id, result.Value);
            _actionBanner = result.Value.Status == "Active"
                ? L["TutorSubs_AcceptActiveBanner"]
                : L["TutorSubs_AcceptPaymentBanner"];
        }
        catch (Exception ex)
        {
            _actionError = ex.Message;
        }
        finally { _busyId = null; }
    }

    private async Task RejectAsync(SubVM sub)
    {
        _busyId = sub.Id;
        _actionError = null;
        _actionBanner = null;
        try
        {
            var result = await Api.PostWithErrorAsync<ApiSubscriberDto>(
                $"api/subscription-offerings/subscribers/{sub.Id}/reject",
                new { });
            if (result.Error is not null || result.Value is null)
            {
                _actionError = result.Error ?? L["TutorSubs_ActionFailed"];
                return;
            }

            ApplySubscriberUpdate(sub.Id, result.Value);
            _actionBanner = L["TutorSubs_RejectBanner"];
        }
        catch (Exception ex)
        {
            _actionError = ex.Message;
        }
        finally { _busyId = null; }
    }

    private void ApplySubscriberUpdate(Guid id, ApiSubscriberDto dto)
    {
        var idx = _subs.FindIndex(s => s.Id == id);
        if (idx < 0) return;
        _subs[idx] = MapSubscriber(dto);
    }

    private async Task SavePlan()
    {
        if (string.IsNullOrWhiteSpace(_pf.Name)) return;

        var req = new
        {
            title = _pf.Name,
            description = _pf.Features,
            subject = (string?)null,
            price = _pf.Price,
            currency = "CAD",
            durationDays = 30,
            sessionCount = 4,
            frequency = _pf.Period
        };
        var created = await Api.PostAsync<ApiOfferingDto>("api/subscription-offerings", req);

        _plans.Add(new PlanVM
        {
            ApiId = created?.Id,
            Name = _pf.Name,
            Price = _pf.Price,
            Period = _pf.Period,
            Popular = _pf.Popular,
            IsActive = true,
            Features = _pf.Features.Split('\n').Where(f => !string.IsNullOrWhiteSpace(f)).ToList()
        });
        _showPlanModal = false;
        _pf = new();
    }

    private async Task TogglePlan(PlanVM plan)
    {
        if (plan.ApiId is null) { plan.IsActive = !plan.IsActive; return; }
        var endpoint = plan.IsActive
            ? $"api/subscription-offerings/{plan.ApiId}/deactivate"
            : $"api/subscription-offerings/{plan.ApiId}/activate";
        var result = await Api.PostAsync<ApiOfferingDto>(endpoint, new { });
        if (result is not null) plan.IsActive = result.IsActive;
        else plan.IsActive = !plan.IsActive;
    }

    private record ApiOfferingDto(
        Guid Id, string Title, string? Description, string? Subject,
        decimal Price, string Currency, int DurationDays, int SessionCount,
        string? Frequency, bool IsActive);

    private record ApiSubscriberDto(
        Guid Id,
        string StudentName,
        string? ParentName,
        string OfferingTitle,
        decimal Price,
        string Status,
        DateTime EndDate);

    private class PlanForm
    {
        public string Name { get; set; } = "";
        public decimal Price { get; set; } = 150;
        public string Period { get; set; } = "mois";
        public string Features { get; set; } = "";
        public bool Popular { get; set; }
    }
    private class PlanVM
    {
        public Guid? ApiId { get; set; }
        public string Name { get; set; } = "";
        public decimal Price { get; set; }
        public string Period { get; set; } = "";
        public bool Popular { get; set; }
        public bool IsActive { get; set; } = true;
        public List<string> Features { get; set; } = [];
    }
    private class SubVM
    {
        public Guid Id { get; set; }
        public string StudentName { get; set; } = "";
        public string ParentName { get; set; } = "";
        public string PlanName { get; set; } = "";
        public decimal Amount { get; set; }
        public DateTime ExpiresAt { get; set; }
        public string Status { get; set; } = "Active";
    }

    private readonly List<PlanVM> _plans = [];
    private readonly List<SubVM> _subs = [];
}
