@page "/tutor/parents"
@layout TutorLayout
@rendermode InteractiveServer
@inject IStringLocalizer<SharedResources> L
@inject ApiClient Api

<PageTitle>@L["Parents_Title"] – TutorSphere</PageTitle>

<div class="ts-page-header">
    <div>
        <h1><i class="bi bi-person-hearts me-2"></i>@L["Parents_Title"]</h1>
        <p class="ts-page-subtitle">@string.Format(L["Parents_Count"].Value, _parents.Count)</p>
    </div>
    <button class="btn btn-primary" @onclick="OpenAdd">
        <i class="bi bi-plus-lg me-1"></i>@L["Common_Add"]
    </button>
</div>

@if (!string.IsNullOrEmpty(_loadError))
{
    <div class="alert alert-danger">@_loadError</div>
}

<div class="ts-toolbar">
    <div class="ts-search-box">
        <i class="bi bi-search ts-search-icon"></i>
        <input class="form-control" placeholder="@L["Parents_Search"]"
               @bind="_search" @bind:event="oninput" />
    </div>
</div>

@if (_loading)
{
    <div class="ts-loading-state" style="padding:2rem;">
        <div class="spinner-border text-primary" role="status"></div>
        <span class="ms-2 text-muted">@L["Parents_Loading"]</span>
    </div>
}
else if (!FilteredParents.Any())
{
    <div class="ts-empty-card">
        <i class="bi bi-person-plus ts-empty-icon"></i>
        <p>@L["Parents_Empty"]</p>
    </div>
}
else
{
    <div class="ts-table-card">
        <table class="table ts-table">
            <thead>
                <tr>
                    <th>@L["Parents_Title"]</th>
                    <th>@L["Parents_Children"]</th>
                    <th>@L["Common_Phone"]</th>
                    <th>@L["Common_Email"]</th>
                    <th>@L["Common_Actions"]</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in FilteredParents)
                {
                    <tr>
                        <td>
                            <div class="ts-cell-user">
                                <div class="ts-avatar" style="background:@p.Color">@p.Initials</div>
                                <div><strong>@p.FullName</strong></div>
                            </div>
                        </td>
                        <td>
                            @if (p.Children.Count == 0)
                            {
                                <span class="text-muted">@p.ChildrenCount @L["Parents_ChildrenCount"]</span>
                            }
                            else
                            {
                                @foreach (var c in p.Children)
                                {
                                    <span class="ts-badge ts-badge-neutral me-1">@c</span>
                                }
                            }
                        </td>
                        <td>@(p.Phone ?? "—")</td>
                        <td>@p.Email</td>
                        <td>
                            <div class="ts-action-group">
                                <button class="ts-icon-btn" title="@L["Common_View"]" @onclick="() => OpenDetail(p)"><i class="bi bi-eye"></i></button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@if (_selected != null)
{
    <div class="ts-modal-backdrop" @onclick="() => _selected = null">
        <div class="ts-modal ts-modal-lg" @onclick:stopPropagation="true">
            <div class="ts-modal-header">
                <div class="ts-avatar ts-avatar-lg" style="background:@_selected.Color">@_selected.Initials</div>
                <div>
                    <h2>@_selected.FullName</h2>
                </div>
                <button class="ts-modal-close" @onclick="() => _selected = null"><i class="bi bi-x-lg"></i></button>
            </div>
            <div class="ts-modal-tabs">
                <button class="ts-tab @(_pTab == "info" ? "active" : "")" @onclick='() => _pTab = "info"'>@L["Parents_Info"]</button>
                <button class="ts-tab @(_pTab == "children" ? "active" : "")" @onclick='() => _pTab = "children"'>@L["Parents_Children"]</button>
            </div>
            <div class="ts-modal-body">
                @if (_pTab == "info")
                {
                    <div class="ts-form-grid">
                        <div class="ts-form-row"><label>@L["Parents_FullName"]</label><span>@_selected.FullName</span></div>
                        <div class="ts-form-row"><label>@L["Common_Phone"]</label><span>@(_selected.Phone ?? "—")</span></div>
                        <div class="ts-form-row"><label>@L["Common_Email"]</label><span>@_selected.Email</span></div>
                    </div>
                }
                else if (_pTab == "children")
                {
                    @if (_childrenLoading)
                    {
                        <div class="text-muted">@L["Common_Loading"]</div>
                    }
                    else if (_selected.Children.Count == 0)
                    {
                        <p class="ts-empty-inline">@L["Parents_NoChildren"]</p>
                    }
                    else
                    {
                        @foreach (var c in _selected.Children)
                        {
                            <div class="ts-list-item"><i class="bi bi-person me-2 text-primary"></i>@c</div>
                        }
                    }
                }
            </div>
        </div>
    </div>
}

@if (_showAdd)
{
    <div class="ts-modal-backdrop" @onclick="() => _showAdd = false">
        <div class="ts-modal" @onclick:stopPropagation="true">
            <div class="ts-modal-header">
                <h2>@L["Parents_Add"]</h2>
                <button class="ts-modal-close" @onclick="() => _showAdd = false"><i class="bi bi-x-lg"></i></button>
            </div>
            <div class="ts-modal-body">
                <div class="row g-3">
                    <div class="col-6"><label class="form-label">@L["Common_FirstName"] *</label>
                        <input class="form-control" @bind="_pForm.First" /></div>
                    <div class="col-6"><label class="form-label">@L["Common_LastName"] *</label>
                        <input class="form-control" @bind="_pForm.Last" /></div>
                    <div class="col-6"><label class="form-label">@L["Common_Phone"]</label>
                        <input class="form-control" @bind="_pForm.Phone" /></div>
                    <div class="col-6"><label class="form-label">@L["Common_Email"] *</label>
                        <input type="email" class="form-control" @bind="_pForm.Email" /></div>
                </div>
                @if (!string.IsNullOrEmpty(_addError))
                {
                    <div class="alert alert-danger mt-3">@_addError</div>
                }
            </div>
            <div class="ts-modal-footer">
                <button class="btn btn-outline-secondary" @onclick="() => _showAdd = false" disabled="@_saving">@L["Common_Cancel"]</button>
                <button class="btn btn-primary" @onclick="SaveParent" disabled="@_saving">
                    @(_saving ? L["Common_Saving"] : L["Common_Save"])
                </button>
            </div>
        </div>
    </div>
}

@code {
    private string _search = "";
    private ParentVM? _selected;
    private string _pTab = "info";
    private bool _showAdd;
    private bool _loading = true;
    private bool _saving;
    private bool _childrenLoading;
    private string _loadError = "";
    private string _addError = "";
    private ParentForm _pForm = new();
    private readonly List<ParentVM> _parents = [];
    private static readonly string[] Colors = ["#7c3aed", "#0ea5e9", "#10b981", "#f59e0b"];

    private void OpenAdd() { _pForm = new(); _addError = ""; _showAdd = true; }

    private IEnumerable<ParentVM> FilteredParents => _parents
        .Where(p => string.IsNullOrEmpty(_search) ||
            p.FullName.Contains(_search, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        _loadError = "";
        try
        {
            var result = await Api.GetWithErrorAsync<List<ApiParentDto>>("api/parents");
            if (result.Error is not null)
            {
                _loadError = result.Error;
                _parents.Clear();
                return;
            }

            _parents.Clear();
            var list = result.Value ?? [];
            for (var i = 0; i < list.Count; i++)
                _parents.Add(MapParent(list[i], i));
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task OpenDetail(ParentVM p)
    {
        _selected = p;
        _pTab = "info";
        _childrenLoading = true;
        try
        {
            var children = await Api.GetAsync<List<ApiChildDto>>($"api/parents/{p.Id}/children") ?? [];
            p.Children = children.Select(c => $"{c.FirstName} {c.LastName}").ToList();
        }
        finally
        {
            _childrenLoading = false;
        }
    }

    private async Task SaveParent()
    {
        if (string.IsNullOrWhiteSpace(_pForm.First) || string.IsNullOrWhiteSpace(_pForm.Last))
        {
            _addError = L["Parents_RequiredName"];
            return;
        }
        if (string.IsNullOrWhiteSpace(_pForm.Email))
        {
            _addError = L["Parents_RequiredEmail"];
            return;
        }

        _saving = true;
        _addError = "";
        try
        {
            var req = new
            {
                firstName = _pForm.First.Trim(),
                lastName = _pForm.Last.Trim(),
                email = _pForm.Email.Trim(),
                phone = string.IsNullOrWhiteSpace(_pForm.Phone) ? null : _pForm.Phone.Trim()
            };

            var result = await Api.PostWithErrorAsync<ApiParentDto>("api/parents", req);
            if (result.Error is not null || result.Value is null)
            {
                _addError = result.Error ?? L["Parents_CreateFailed"].Value;
                return;
            }

            _parents.Add(MapParent(result.Value, _parents.Count));
            _showAdd = false;
        }
        finally
        {
            _saving = false;
        }
    }

    private static ParentVM MapParent(ApiParentDto d, int index) => new()
    {
        Id = d.Id,
        FullName = $"{d.FirstName} {d.LastName}".Trim(),
        Phone = d.Phone,
        Email = d.Email,
        ChildrenCount = d.ChildrenCount,
        Children = [],
        Color = Colors[index % Colors.Length]
    };

    private record ApiParentDto(Guid Id, string FirstName, string LastName, string Email, string? Phone, int ChildrenCount);
    private record ApiChildDto(Guid Id, string FirstName, string LastName);

    private class ParentForm
    {
        public string First { get; set; } = "";
        public string Last { get; set; } = "";
        public string Phone { get; set; } = "";
        public string Email { get; set; } = "";
    }

    private class ParentVM
    {
        public Guid Id { get; set; }
        public string FullName { get; set; } = "";
        public string? Phone { get; set; }
        public string Email { get; set; } = "";
        public int ChildrenCount { get; set; }
        public List<string> Children { get; set; } = [];
        public string Color { get; set; } = "#7c3aed";
        public string Initials
        {
            get
            {
                var parts = FullName.Split(' ', StringSplitOptions.RemoveEmptyEntries);
                if (parts.Length >= 2) return $"{parts[0][0]}{parts[1][0]}".ToUpperInvariant();
                return FullName.Length > 0 ? FullName[..1].ToUpperInvariant() : "?";
            }
        }
    }
}
