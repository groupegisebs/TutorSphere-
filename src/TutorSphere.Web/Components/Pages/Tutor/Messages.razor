@page "/tutor/messages"
@layout TutorLayout
@rendermode InteractiveServer
@implements IDisposable
@inject IStringLocalizer<SharedResources> L
@inject MessageService MessageSvc
@inject AuthService Auth
@inject RealtimeMessagingClient Realtime
@inject MessagingNotificationState NotifyState

<PageTitle>@L["Messages_Title"] – TutorSphere</PageTitle>

<div class="ts-page-header">
    <div>
        <h1><i class="bi bi-chat-dots me-2"></i>@L["Messages_Title"]</h1>
    </div>
    <button class="btn btn-primary btn-sm" @onclick="NewConversation">
        <i class="bi bi-plus-lg me-1"></i>@L["Messages_New"]
    </button>
</div>

<div class="messages-layout">
    <aside class="messages-sidebar">
        <div class="messages-search">
            <i class="bi bi-search"></i>
            <input class="form-control form-control-sm" placeholder="@L["Messages_Search"]"
                   @bind="_msgSearch" @bind:event="oninput" />
        </div>
        <div class="conversation-list">
            @if (_loading)
            {
                <div class="ts-loading-state" style="padding: 1.5rem;">
                    <div class="spinner-border spinner-border-sm text-primary" role="status"></div>
                    <span class="ms-2 text-muted small">@L["Common_Loading"]</span>
                </div>
            }
            @foreach (var c in FilteredConversations)
            {
                <div class="conversation-item @(_active?.Id == c.Id ? "active" : "") @(c.Unread > 0 ? "unread" : "")"
                     @onclick="async () => await SelectConversation(c)">
                    <div class="conv-avatar" style="background:@c.Color">@c.Initials</div>
                    <div class="conv-info">
                        <div class="conv-name">@c.Name</div>
                        <div class="conv-last">@c.LastMessage</div>
                    </div>
                    <div class="conv-meta">
                        <span class="conv-time">@c.LastTime</span>
                        @if (c.Unread > 0)
                        {
                            <span class="conv-badge">@c.Unread</span>
                        }
                    </div>
                </div>
            }
        </div>
    </aside>

    @if (_active != null)
    {
        <section class="messages-chat">
            <div class="chat-header">
                <div class="ts-avatar" style="background:@_active.Color">@_active.Initials</div>
                <div>
                    <strong>@_active.Name</strong>
                    <span class="chat-role text-muted">@_active.Role</span>
                </div>
                <div class="ms-auto d-flex gap-2">
                    <button class="ts-icon-btn" title="@L["Messages_VideoCall"]"><i class="bi bi-camera-video"></i></button>
                    <button class="ts-icon-btn" title="@L["Messages_Call"]"><i class="bi bi-telephone"></i></button>
                </div>
            </div>

            <div class="chat-messages" id="chat-scroll">
                @foreach (var m in _active.Messages)
                {
                    <div class="chat-msg @(m.FromMe ? "chat-msg--me" : "chat-msg--them")">
                        <div class="chat-bubble">@m.Text</div>
                        <span class="chat-time">@m.Time</span>
                    </div>
                }
            </div>

            <div class="chat-input-area">
                <button class="ts-icon-btn" title="@L["Messages_Attachment"]"><i class="bi bi-paperclip"></i></button>
                <input class="form-control" placeholder="@L["Messages_Write"]"
                       @bind="_newMsg" @bind:event="oninput" @onkeydown="HandleKey" />
                <button class="btn btn-primary btn-sm" @onclick="async () => await SendMessage()"
                        disabled="@string.IsNullOrWhiteSpace(_newMsg)">
                    <i class="bi bi-send-fill"></i>
                </button>
            </div>
        </section>
    }
    else
    {
        <section class="messages-empty">
            <i class="bi bi-chat-dots messages-empty-icon"></i>
            <p>@L["Messages_SelectConversation"]</p>
        </section>
    }
</div>

@code {
    private string _msgSearch = "";
    private bool _loading = true;
    private ConversationVM? _active;
    private string _newMsg = "";
    private List<ConversationVM> _convs = [];

    private IEnumerable<ConversationVM> FilteredConversations => _convs
        .Where(c => string.IsNullOrEmpty(_msgSearch) ||
            c.Name.Contains(_msgSearch, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync()
    {
        Realtime.MessageReceived += OnRealtimeMessage;
        try
        {
            await Realtime.EnsureConnectedAsync();
            var dtos = await MessageSvc.GetConversationsAsync();
            if (dtos.Count > 0)
                _convs = dtos.Select((d, i) => MapConversation(d, i)).ToList();
            NotifyState.SetUnreadTotal(_convs.Sum(c => c.Unread));
        }
        catch { }
        finally { _loading = false; }
    }

    private void OnRealtimeMessage(MessageDto message) =>
        _ = InvokeAsync(() => ApplyIncomingMessage(message));

    private async Task ApplyIncomingMessage(MessageDto message)
    {
        var peerId = message.SenderUserId;
        var conv = _convs.FirstOrDefault(c => c.ApiUserId == peerId);
        if (conv is null)
        {
            conv = new ConversationVM
            {
                ApiUserId = peerId,
                Id = _convs.Count + 1,
                Name = peerId,
                Initials = "?",
                Color = "#7c3aed",
                LastMessage = message.Body,
                LastTime = FormatTime(message.CreatedAt),
                Unread = 1
            };
            _convs.Insert(0, conv);
        }
        else
        {
            conv.LastMessage = message.Body;
            conv.LastTime = FormatTime(message.CreatedAt);
            _convs.Remove(conv);
            _convs.Insert(0, conv);
        }

        if (_active?.ApiUserId == peerId)
        {
            if (conv.Messages.All(m => m.ApiId != message.Id))
            {
                conv.Messages.Add(new ChatMsg
                {
                    ApiId = message.Id,
                    Text = message.Body,
                    FromMe = false,
                    Time = FormatTime(message.CreatedAt)
                });
            }
            conv.Unread = 0;
            await MessageSvc.MarkConversationReadAsync(peerId);
        }
        else
        {
            conv.Unread++;
            if (!string.IsNullOrWhiteSpace(conv.Name) && conv.Name != peerId)
                NotifyState.ShowIncomingToast(conv.Name, message.Body);
        }

        StateHasChanged();
    }

    private static ConversationVM MapConversation(ConversationDto d, int index)
    {
        var colors = new[] { "#7c3aed", "#0ea5e9", "#10b981", "#ec4899", "#f59e0b" };
        var parts  = d.OtherUserName.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        var initials = parts.Length >= 2
            ? $"{parts[0][0]}{parts[^1][0]}"
            : d.OtherUserName.Length > 0 ? d.OtherUserName[..1] : "?";

        return new ConversationVM
        {
            ApiUserId   = d.OtherUserId,
            Id          = index + 1,
            Name        = d.OtherUserName,
            Initials    = initials.ToUpperInvariant(),
            Color       = colors[index % colors.Length],
            LastMessage = d.LastMessage?.Body ?? "",
            LastTime    = FormatTime(d.LastMessage?.CreatedAt),
            Unread      = d.UnreadCount
        };
    }

    private static string FormatTime(DateTime? dt)
    {
        if (dt is null) return "";
        var local = dt.Value.ToLocalTime();
        if (local.Date == DateTime.Today) return local.ToString("HH:mm");
        if (local.Date == DateTime.Today.AddDays(-1)) return "hier";
        return local.ToString("dd/MM");
    }

    private async Task SelectConversation(ConversationVM c)
    {
        var previousUnread = c.Unread;
        _active = c;
        NotifyState.ActiveConversationUserId = c.ApiUserId;
        c.Unread = 0;
        if (previousUnread > 0)
            NotifyState.AdjustUnread(-previousUnread);

        if (!string.IsNullOrEmpty(c.ApiUserId))
        {
            var msgs = await MessageSvc.GetMessagesAsync(c.ApiUserId);
            c.Messages = msgs.Select(m => new ChatMsg
            {
                ApiId  = m.Id,
                Text   = m.Body,
                FromMe = m.SenderUserId != c.ApiUserId,
                Time   = FormatTime(m.CreatedAt)
            }).ToList();
            await MessageSvc.MarkConversationReadAsync(c.ApiUserId);
        }
    }

    private void NewConversation() { }

    private async Task SendMessage()
    {
        if (_active == null || string.IsNullOrWhiteSpace(_newMsg)) return;
        var text = _newMsg;
        _newMsg = "";

        if (!string.IsNullOrEmpty(_active.ApiUserId))
        {
            var dto = await MessageSvc.SendMessageAsync(
                new SendMessageRequest(_active.ApiUserId, "(TutorSphere)", text));
            if (dto != null)
            {
                _active.Messages.Add(new ChatMsg
                {
                    ApiId  = dto.Id,
                    Text   = dto.Body,
                    FromMe = true,
                    Time   = FormatTime(dto.CreatedAt)
                });
                _active.LastMessage = dto.Body;
                _active.LastTime    = FormatTime(dto.CreatedAt);
                return;
            }
        }

        _active.Messages.Add(new ChatMsg { Text = text, FromMe = true, Time = DateTime.Now.ToString("HH:mm") });
        _active.LastMessage = text;
        _active.LastTime    = DateTime.Now.ToString("HH:mm");
    }

    private async Task HandleKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey) await SendMessage();
    }

    public void Dispose()
    {
        Realtime.MessageReceived -= OnRealtimeMessage;
        if (_active?.ApiUserId is { } id
            && string.Equals(NotifyState.ActiveConversationUserId, id, StringComparison.Ordinal))
            NotifyState.ActiveConversationUserId = null;
    }

    private class ChatMsg
    {
        public Guid? ApiId { get; set; }
        public string Text { get; set; } = "";
        public bool FromMe { get; set; }
        public string Time { get; set; } = "";
    }

    private class ConversationVM
    {
        public string? ApiUserId { get; set; }
        public int Id { get; set; }
        public string Name { get; set; } = "";
        public string Role { get; set; } = "";
        public string Initials { get; set; } = "";
        public string Color { get; set; } = "#7c3aed";
        public string LastMessage { get; set; } = "";
        public string LastTime { get; set; } = "";
        public int Unread { get; set; }
        public List<ChatMsg> Messages { get; set; } = [];
    }
}
