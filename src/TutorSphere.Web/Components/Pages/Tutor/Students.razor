@page "/tutor/students"
@layout TutorLayout
@rendermode InteractiveServer
@inject IStringLocalizer<SharedResources> L

<PageTitle>Mes Élèves – TutorSphere</PageTitle>

<div class="ts-page-header">
    <div>
        <h1><i class="bi bi-people me-2" aria-hidden="true"></i>Mes Élèves</h1>
        <p class="ts-page-subtitle">@_students.Count élève(s) dans votre école</p>
    </div>
    <button class="btn btn-primary" @onclick="OpenAddModal">
        <i class="bi bi-plus-lg me-1"></i>Ajouter un élève
    </button>
</div>

<!-- Search + filter bar -->
<div class="ts-toolbar">
    <div class="ts-search-box">
        <i class="bi bi-search ts-search-icon"></i>
        <input type="text" class="form-control" placeholder="Rechercher un élève…"
               @bind="_search" @bind:event="oninput" />
    </div>
    <select class="form-select w-auto" @bind="_filterLevel">
        <option value="">Tous les niveaux</option>
        <option>Primaire</option><option>Collège</option><option>Lycée</option><option>Université</option>
    </select>
    <select class="form-select w-auto" @bind="_filterStatus">
        <option value="">Tous les statuts</option>
        <option value="active">Actif</option><option value="inactive">Inactif</option>
    </select>
</div>

<!-- Students grid -->
@if (!Filtered.Any())
{
    <div class="ts-empty-card">
        <i class="bi bi-person-plus ts-empty-icon"></i>
        <p>Aucun élève trouvé. Ajoutez votre premier élève.</p>
    </div>
}
else
{
    <div class="students-grid">
        @foreach (var s in Filtered)
        {
            <div class="student-card" @onclick="() => OpenProfile(s)">
                <div class="student-card-avatar" style="background:@s.AvatarColor">@s.Initials</div>
                <div class="student-card-info">
                    <strong>@s.FirstName @s.LastName</strong>
                    <span class="student-card-level">@s.Level · @s.School</span>
                    <span class="student-card-sub @(s.IsActive ? "sub-active" : "sub-inactive")">
                        @(s.IsActive ? "Actif" : "Inactif")
                    </span>
                </div>
                <div class="student-card-meta">
                    <span class="ts-badge ts-badge-neutral">@s.Subject</span>
                    <span class="student-card-date">Depuis @s.SinceDate</span>
                </div>
                <div class="student-card-actions" @onclick:stopPropagation="true">
                    <button class="ts-icon-btn" title="Voir le profil" @onclick="() => OpenProfile(s)">
                        <i class="bi bi-eye"></i>
                    </button>
                    <button class="ts-icon-btn" title="Message" @onclick="() => {}">
                        <i class="bi bi-chat"></i>
                    </button>
                    <button class="ts-icon-btn" title="Rapport" @onclick="() => {}">
                        <i class="bi bi-file-earmark-text"></i>
                    </button>
                </div>
            </div>
        }
    </div>
}

<!-- ── Student Profile Modal ── -->
@if (_profileStudent != null)
{
    <div class="ts-modal-backdrop" @onclick="CloseProfile">
        <div class="ts-modal ts-modal-lg" @onclick:stopPropagation="true">
            <div class="ts-modal-header">
                <div class="ts-modal-avatar" style="background:@_profileStudent.AvatarColor">@_profileStudent.Initials</div>
                <div>
                    <h2>@_profileStudent.FirstName @_profileStudent.LastName</h2>
                    <span class="ts-badge @(_profileStudent.IsActive ? "ts-badge-success" : "ts-badge-muted")">
                        @(_profileStudent.IsActive ? "Actif" : "Inactif")
                    </span>
                </div>
                <button class="ts-modal-close" @onclick="CloseProfile"><i class="bi bi-x-lg"></i></button>
            </div>
            <div class="ts-modal-tabs">
                @foreach (var tab in new[] { "Informations", "Abonnements", "Présence", "Rapports", "Objectifs" })
                {
                    <button class="ts-tab @(_profileTab == tab ? "active" : "")" @onclick="() => _profileTab = tab">@tab</button>
                }
            </div>
            <div class="ts-modal-body">
                @if (_profileTab == "Informations")
                {
                    <div class="ts-form-grid">
                        <div class="ts-form-row"><label>Prénom</label><span>@_profileStudent.FirstName</span></div>
                        <div class="ts-form-row"><label>Nom</label><span>@_profileStudent.LastName</span></div>
                        <div class="ts-form-row">
                        <label>Date de naissance</label>
                        <span>
                            @_profileStudent.BirthDate
                            @if (_profileStudent.Age.HasValue)
                            {
                                <span class="ms-2 text-muted">(@_profileStudent.Age ans)</span>
                                if (_profileStudent.IsAutonomous)
                                {
                                    <span class="ts-badge ts-badge-neutral ms-2" title="Élève autonome — accès parental restreint">Autonome</span>
                                }
                            }
                        </span>
                    </div>
                        <div class="ts-form-row"><label>Sexe</label><span>@_profileStudent.Gender</span></div>
                        <div class="ts-form-row"><label>École</label><span>@_profileStudent.School</span></div>
                        <div class="ts-form-row"><label>Classe</label><span>@_profileStudent.Class</span></div>
                        <div class="ts-form-row"><label>Niveau</label><span>@_profileStudent.Level</span></div>
                        <div class="ts-form-row"><label>Téléphone</label><span>@_profileStudent.Phone</span></div>
                        <div class="ts-form-row"><label>Courriel</label><span>@_profileStudent.Email</span></div>
                        <div class="ts-form-row"><label>Parent</label><span>@_profileStudent.ParentName</span></div>
                        <div class="ts-form-row"><label>Matière</label><span>@_profileStudent.Subject</span></div>
                        <div class="ts-form-row"><label>Observations</label><span>@_profileStudent.Observations</span></div>
                    </div>
                }
                else if (_profileTab == "Présence")
                {
                    <div class="presence-stats">
                        <div class="presence-stat"><span class="presence-num text-success">@_profileStudent.Present</span><span>Présent</span></div>
                        <div class="presence-stat"><span class="presence-num text-danger">@_profileStudent.Absent</span><span>Absent</span></div>
                        <div class="presence-stat"><span class="presence-num text-warning">@_profileStudent.Late</span><span>Retard</span></div>
                        <div class="presence-stat"><span class="presence-num" style="color:var(--ts-primary)">@_profileStudent.AttendanceRate%</span><span>Taux</span></div>
                    </div>
                }
                else
                {
                    <p class="ts-empty-inline">Aucune donnée pour cet onglet.</p>
                }
            </div>
        </div>
    </div>
}

<!-- ── Add Student Modal ── -->
@if (_showAddModal)
{
    <div class="ts-modal-backdrop" @onclick="CloseAddModal">
        <div class="ts-modal" @onclick:stopPropagation="true">
            <div class="ts-modal-header">
                <h2>Ajouter un élève</h2>
                <button class="ts-modal-close" @onclick="CloseAddModal"><i class="bi bi-x-lg"></i></button>
            </div>
            <div class="ts-modal-body">
                <div class="row g-3">
                    <div class="col-6"><label class="form-label">Prénom *</label>
                        <input class="form-control" @bind="_form.FirstName" placeholder="Emma" /></div>
                    <div class="col-6"><label class="form-label">Nom *</label>
                        <input class="form-control" @bind="_form.LastName" placeholder="Johnson" /></div>
                    <div class="col-6"><label class="form-label">Date de naissance</label>
                        <input type="date" class="form-control" @bind="_form.BirthDate" /></div>
                    <div class="col-6"><label class="form-label">Sexe</label>
                        <select class="form-select" @bind="_form.Gender">
                            <option value="">—</option><option>Féminin</option><option>Masculin</option>
                        </select></div>
                    <div class="col-6"><label class="form-label">École</label>
                        <input class="form-control" @bind="_form.School" placeholder="Collège Victor Hugo" /></div>
                    <div class="col-6"><label class="form-label">Classe / Niveau</label>
                        <input class="form-control" @bind="_form.Class" placeholder="3ème" /></div>
                    <div class="col-6"><label class="form-label">Matière principale</label>
                        <input class="form-control" @bind="_form.Subject" placeholder="Mathématiques" /></div>
                    <div class="col-6"><label class="form-label">Courriel</label>
                        <input type="email" class="form-control" @bind="_form.Email" /></div>
                    <div class="col-12"><label class="form-label">Téléphone</label>
                        <input class="form-control" @bind="_form.Phone" /></div>
                    <div class="col-12"><label class="form-label">Observations</label>
                        <textarea class="form-control" rows="2" @bind="_form.Observations"></textarea></div>
                </div>
                @if (!string.IsNullOrEmpty(_addError))
                {
                    <div class="alert alert-danger mt-3">@_addError</div>
                }
            </div>
            <div class="ts-modal-footer">
                <button class="btn btn-outline-secondary" @onclick="CloseAddModal">Annuler</button>
                <button class="btn btn-primary" @onclick="SaveStudent">Enregistrer</button>
            </div>
        </div>
    </div>
}

@code {
    private string _search = "";
    private string _filterLevel = "";
    private string _filterStatus = "";
    private StudentViewModel? _profileStudent;
    private string _profileTab = "Informations";
    private bool _showAddModal;
    private string _addError = "";
    private StudentForm _form = new();

    private IEnumerable<StudentViewModel> Filtered => _students
        .Where(s => string.IsNullOrEmpty(_search) ||
            ($"{s.FirstName} {s.LastName}").Contains(_search, StringComparison.OrdinalIgnoreCase))
        .Where(s => string.IsNullOrEmpty(_filterLevel) || s.Level == _filterLevel)
        .Where(s => string.IsNullOrEmpty(_filterStatus) ||
            (_filterStatus == "active" && s.IsActive) ||
            (_filterStatus == "inactive" && !s.IsActive));

    private void OpenProfile(StudentViewModel s) { _profileStudent = s; _profileTab = "Informations"; }
    private void CloseProfile() => _profileStudent = null;
    private void OpenAddModal() { _form = new(); _addError = ""; _showAddModal = true; }
    private void CloseAddModal() => _showAddModal = false;

    private void SaveStudent()
    {
        if (string.IsNullOrWhiteSpace(_form.FirstName) || string.IsNullOrWhiteSpace(_form.LastName))
        { _addError = "Prénom et nom sont obligatoires."; return; }
        var colors = new[] { "#7c3aed","#0ea5e9","#10b981","#f59e0b","#ef4444","#ec4899" };
        var s = new StudentViewModel
        {
            FirstName = _form.FirstName, LastName = _form.LastName,
            BirthDate = _form.BirthDate?.ToString("dd/MM/yyyy") ?? "—",
            BirthDateParsed = _form.BirthDate,
            Gender = _form.Gender, School = _form.School, Class = _form.Class,
            Level = _form.Class, Subject = _form.Subject, Email = _form.Email,
            Phone = _form.Phone, Observations = _form.Observations,
            IsActive = true, SinceDate = DateTime.Now.ToString("MM/yyyy"),
            ParentName = "—", Present = 0, Absent = 0, Late = 0, AttendanceRate = 100,
            AvatarColor = colors[_students.Count % colors.Length]
        };
        _students.Add(s);
        _showAddModal = false;
    }

    private record StudentForm
    {
        public string FirstName { get; set; } = "";
        public string LastName { get; set; } = "";
        public DateTime? BirthDate { get; set; }
        public string Gender { get; set; } = "";
        public string School { get; set; } = "";
        public string Class { get; set; } = "";
        public string Subject { get; set; } = "";
        public string Email { get; set; } = "";
        public string Phone { get; set; } = "";
        public string Observations { get; set; } = "";
    }

    private class StudentViewModel
    {
        public string FirstName { get; set; } = "";
        public string LastName { get; set; } = "";
        public string BirthDate { get; set; } = "";
        public DateTime? BirthDateParsed { get; set; }
        public string Gender { get; set; } = "";
        public string School { get; set; } = "";
        public string Class { get; set; } = "";
        public string Level { get; set; } = "";
        public string Subject { get; set; } = "";
        public string Email { get; set; } = "";
        public string Phone { get; set; } = "";
        public string Observations { get; set; } = "";
        public string ParentName { get; set; } = "";
        public bool IsActive { get; set; }
        public string SinceDate { get; set; } = "";
        public string AvatarColor { get; set; } = "#7c3aed";
        public int Present { get; set; }
        public int Absent { get; set; }
        public int Late { get; set; }
        public int AttendanceRate { get; set; }
        public string Initials => $"{FirstName.FirstOrDefault()}{LastName.FirstOrDefault()}";
        public int? Age => BirthDateParsed.HasValue
            ? (int)((DateTime.Today - BirthDateParsed.Value).TotalDays / 365.25)
            : null;
        public bool IsAutonomous => Age.HasValue && Age >= 14;
    }

    private readonly List<StudentViewModel> _students =
    [
        new(){ FirstName="Emma", LastName="Johnson", BirthDate="12/03/2009", BirthDateParsed=new DateTime(2009,3,12), Gender="Féminin",
            School="Collège Victor Hugo", Class="4ème", Level="Collège", Subject="Mathématiques",
            Email="emma.j@email.com", Phone="06 12 34 56 78", ParentName="Marie Johnson",
            IsActive=true, SinceDate="09/2024", AvatarColor="#7c3aed",
            Present=18, Absent=2, Late=1, AttendanceRate=90, Observations="Bonne progression" },
        new(){ FirstName="Liam", LastName="Brown", BirthDate="05/07/2010", BirthDateParsed=new DateTime(2010,7,5), Gender="Masculin",
            School="Collège Jules Ferry", Class="5ème", Level="Collège", Subject="Physique",
            Email="liam.b@email.com", Phone="06 98 76 54 32", ParentName="David Brown",
            IsActive=true, SinceDate="10/2024", AvatarColor="#0ea5e9",
            Present=15, Absent=3, Late=2, AttendanceRate=83, Observations="Difficultés en électricité" },
        new(){ FirstName="Sophia", LastName="Davis", BirthDate="22/11/2007", BirthDateParsed=new DateTime(2007,11,22), Gender="Féminin",
            School="Lycée Pasteur", Class="Terminale", Level="Lycée", Subject="Chimie",
            Email="sophia.d@email.com", Phone="07 11 22 33 44", ParentName="Laura Davis",
            IsActive=true, SinceDate="01/2025", AvatarColor="#10b981",
            Present=12, Absent=0, Late=1, AttendanceRate=97, Observations="Très motivée" },
        new(){ FirstName="Noah", LastName="Wilson", BirthDate="14/06/2008", BirthDateParsed=new DateTime(2008,6,14), Gender="Masculin",
            School="Lycée Molière", Class="1ère", Level="Lycée", Subject="Mathématiques",
            Email="noah.w@email.com", Phone="06 55 44 33 22", ParentName="James Wilson",
            IsActive=false, SinceDate="06/2024", AvatarColor="#f59e0b",
            Present=8, Absent=5, Late=3, AttendanceRate=62, Observations="Départ famille" },
        new(){ FirstName="Olivia", LastName="Martinez", BirthDate="30/09/2011", BirthDateParsed=new DateTime(2011,9,30), Gender="Féminin",
            School="École Primaire Voltaire", Class="CM2", Level="Primaire", Subject="Français",
            Email="olivia.m@email.com", Phone="06 77 88 99 00", ParentName="Ana Martinez",
            IsActive=true, SinceDate="02/2025", AvatarColor="#ec4899",
            Present=20, Absent=1, Late=0, AttendanceRate=99, Observations="Excellent niveau" },
    ];
}
