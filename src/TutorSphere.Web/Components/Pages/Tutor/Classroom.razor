@page "/tutor/classroom/{lessonId}"
@layout TutorLayout
@rendermode InteractiveServer
@implements IDisposable
@inject IStringLocalizer<SharedResources> L
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject AuthService Auth

<PageTitle>@L["Classroom_Title"] – TutorSphere</PageTitle>

<div class="cr-page">

    <!-- ── Lesson header (light) ── -->
    <div class="cr-lesson-header">
        <div class="cr-lesson-meta">
            <div class="cr-lesson-icon">
                <i class="bi bi-mortarboard-fill"></i>
            </div>
            <div>
                <div class="cr-lesson-title">@_lesson.Title</div>
                <div class="cr-lesson-sub">@_lesson.Subject</div>
            </div>
            <span class="cr-badge-live">
                <i class="bi bi-circle-fill" style="font-size:0.45rem;vertical-align:middle;"></i>
                @L["Classroom_Live"]
            </span>
        </div>
        <div class="cr-lesson-actions">
            <a href="/tutor/dashboard" class="cr-school-link">
                @L["School_ViewPublic"] <i class="bi bi-box-arrow-up-right" style="font-size:0.75rem;"></i>
            </a>
            <span class="cr-elapsed-badge">
                <i class="bi bi-clock" style="font-size:0.75rem;margin-right:3px;"></i>
                @FormatElapsed(_elapsedSeconds)
            </span>
            <button class="cr-end-btn" @onclick="EndSession">
                <i class="bi bi-stop-fill me-1"></i>@L["Classroom_EndSession"]
            </button>
        </div>
    </div>

    <!-- ── Video gallery (dark) ── -->
    <div class="cr-video-section">
        <div class="cr-gallery-header">
            <span class="cr-gallery-label">
                <i class="bi bi-camera-video-fill me-1"></i>@L["Classroom_Title"]
            </span>
            <button class="cr-gallery-mode-btn">
                <i class="bi bi-grid me-1"></i>@L["Classroom_Gallery"]
            </button>
        </div>
        <div class="cr-gallery">
            <!-- Tutor tile (large) -->
            <div class="cr-tile-main">
                <div class="cr-tile-bg cr-tile-bg--tutor">
                    <video @ref="_localVideo"
                           class="cr-tile-video @(_showLocalVideo ? "" : "is-hidden")"
                           autoplay
                           playsinline
                           muted></video>
                    @if (!_showLocalVideo)
                    {
                        <i class="bi bi-person-fill cr-tile-placeholder-icon"></i>
                    }
                    @if (!string.IsNullOrEmpty(_mediaError))
                    {
                        <div class="cr-media-error" role="alert">
                            <i class="bi bi-exclamation-triangle-fill" aria-hidden="true"></i>
                            <span>@_mediaError</span>
                        </div>
                    }
                </div>
                <div class="cr-tile-label">
                    <div class="cr-tile-av" style="background:#5831E0;">JS</div>
                    <span class="cr-tile-name">@TutorDisplayName</span>
                    <span class="cr-tile-role">Tuteur</span>
                    <span class="cr-tile-media-icons">
                        <i class="bi @(_micOn ? "bi-mic-fill" : "bi-mic-mute-fill") @(_micOn ? "" : "cr-icon-off")"></i>
                        <i class="bi @(_camOn ? "bi-camera-video-fill" : "bi-camera-video-off-fill") @(_camOn ? "" : "cr-icon-off")"></i>
                    </span>
                </div>
            </div>
            <!-- Student tiles column -->
            <div class="cr-tiles-col">
                @foreach (var p in _participants.Where(x => x.Role != "Tuteur"))
                {
                    <div class="cr-tile-student">
                        <div class="cr-tile-bg cr-tile-bg--student">
                            <i class="bi bi-person-fill" style="font-size:1.25rem;color:rgba(255,255,255,0.15);"></i>
                        </div>
                        <div class="cr-tile-label cr-tile-label-sm">
                            <div class="cr-tile-av cr-tile-av-sm" style="background:@p.Color;">@p.Initials</div>
                            <span class="cr-tile-name">@p.Name</span>
                            <span class="cr-tile-media-icons">
                                <i class="bi @(p.MicOn ? "bi-mic-fill" : "bi-mic-mute-fill") @(p.MicOn ? "" : "cr-icon-off")"></i>
                                <i class="bi @(p.CamOn ? "bi-camera-video-fill" : "bi-camera-video-off-fill") @(p.CamOn ? "" : "cr-icon-off")"></i>
                            </span>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- ── Work area: whiteboard (left) + chat panel (right) ── -->
    <div class="cr-work-area">

        <!-- Whiteboard section -->
        <div class="cr-wb-section">
            <!-- Toolbar -->
            <div class="cr-wb-toolbar">
                <div class="cr-wb-tools">
                    <button class="cr-wb-tool @(_wbTool == "select" ? "active" : "")" @onclick='() => SetWbTool("select")' title="@L["Classroom_Select"]">
                        <i class="bi bi-cursor-fill"></i>
                    </button>
                    <button class="cr-wb-tool @(_wbTool == "pen" ? "active" : "")" @onclick='() => SetWbTool("pen")' title="@L["Classroom_Pen"]">
                        <i class="bi bi-pencil-fill"></i>
                    </button>
                    <button class="cr-wb-tool @(_wbTool == "eraser" ? "active" : "")" @onclick='() => SetWbTool("eraser")' title="@L["Classroom_Eraser"]">
                        <i class="bi bi-eraser-fill"></i>
                    </button>
                    <button class="cr-wb-tool @(_wbTool == "rect" ? "active" : "")" @onclick='() => SetWbTool("rect")' title="Rectangle">
                        <i class="bi bi-square"></i>
                    </button>
                    <button class="cr-wb-tool @(_wbTool == "text" ? "active" : "")" @onclick='() => SetWbTool("text")' title="Texte">
                        <i class="bi bi-fonts"></i>
                    </button>
                    <button class="cr-wb-tool @(_wbTool == "line" ? "active" : "")" @onclick='() => SetWbTool("line")' title="Ligne">
                        <i class="bi bi-slash-lg"></i>
                    </button>
                    <button class="cr-wb-tool" title="Image"><i class="bi bi-image"></i></button>
                    <button class="cr-wb-tool" title="Emoji"><i class="bi bi-emoji-smile"></i></button>
                    <button class="cr-wb-tool" title="Plus"><i class="bi bi-three-dots"></i></button>
                </div>
                <div class="cr-wb-sep"></div>
                <div class="cr-wb-colors">
                    @foreach (var clr in _wbColors)
                    {
                        <button class="cr-wb-color @(_wbColor == clr ? "active" : "")"
                                style="background:@clr;"
                                @onclick='() => SetWbColor(clr)'
                                title="@clr"></button>
                    }
                </div>
                <div class="cr-wb-sep"></div>
                <button class="cr-wb-size-btn @(_wbSize == "thin" ? "active" : "")" @onclick='() => SetWbSize("thin")' title="Fin">
                    <span class="cr-size-dot" style="width:3px;height:3px;"></span>
                </button>
                <button class="cr-wb-size-btn @(_wbSize == "medium" ? "active" : "")" @onclick='() => SetWbSize("medium")' title="Moyen">
                    <span class="cr-size-dot" style="width:7px;height:7px;"></span>
                </button>
                <button class="cr-wb-size-btn @(_wbSize == "thick" ? "active" : "")" @onclick='() => SetWbSize("thick")' title="Épais">
                    <span class="cr-size-dot" style="width:12px;height:12px;"></span>
                </button>
                <div class="cr-wb-sep"></div>
                <button class="cr-wb-tool" @onclick="ClearWhiteboard" title="@L["Classroom_ClearAll"]">
                    <i class="bi bi-trash3"></i>
                </button>
            </div>

            <!-- Canvas -->
            <div class="cr-canvas-wrapper">
                <canvas @ref="_canvasRef" class="cr-canvas"></canvas>
            </div>

            <!-- Footer: page nav + zoom -->
            <div class="cr-wb-footer">
                <button class="cr-wb-foot-btn" @onclick="PrevPage" title="Page précédente">
                    <i class="bi bi-chevron-left"></i>
                </button>
                <span class="cr-wb-page-info">@_wbPage / @_wbTotalPages</span>
                <button class="cr-wb-foot-btn" @onclick="NextPage" title="Page suivante">
                    <i class="bi bi-chevron-right"></i>
                </button>
                <div style="flex:1;"></div>
                <button class="cr-wb-foot-btn" @onclick="ZoomOut" title="Zoom arrière">−</button>
                <span class="cr-wb-zoom-label">@_wbZoom%</span>
                <button class="cr-wb-foot-btn" @onclick="ZoomIn" title="Zoom avant">+</button>
                <button class="cr-wb-foot-btn ms-2" title="Plein écran">
                    <i class="bi bi-fullscreen"></i>
                </button>
            </div>
        </div>

        <!-- Right panel: Chat / Participants / Documents -->
        <div class="cr-panel">
            <div class="cr-panel-tabs">
                <button class="cr-panel-tab @(_activeTab == "Chat" ? "active" : "")" @onclick='() => _activeTab = "Chat"'>
                    @L["Classroom_Chat"]
                </button>
                <button class="cr-panel-tab @(_activeTab == "Participants" ? "active" : "")" @onclick='() => _activeTab = "Participants"'>
                    @L["Classroom_Participants"] <span class="cr-tab-count">@_participants.Count</span>
                </button>
                <button class="cr-panel-tab @(_activeTab == "Documents" ? "active" : "")" @onclick='() => _activeTab = "Documents"'>
                    @L["Classroom_Documents"]
                </button>
            </div>

            <div class="cr-panel-body">
                @if (_activeTab == "Chat")
                {
                    <div class="cr-chat-messages" id="cr-chat-scroll">
                        <div class="cr-chat-date-sep">Aujourd'hui</div>
                        @foreach (var msg in _chatMessages)
                        {
                            @if (msg.IsMe)
                            {
                                <div class="cr-msg-row cr-msg-me">
                                    <div class="cr-msg-bubble cr-msg-bubble-me">@msg.Text</div>
                                    <div class="cr-msg-time-me">@msg.Time</div>
                                </div>
                            }
                            else
                            {
                                <div class="cr-msg-row cr-msg-them">
                                    <div class="cr-msg-av-sm" style="background:@GetSenderColor(msg.Sender);">
                                        @GetSenderInitials(msg.Sender)
                                    </div>
                                    <div class="cr-msg-body">
                                        <div class="cr-msg-header">
                                            <span class="cr-msg-sender">@msg.Sender</span>
                                            <span class="cr-msg-time">@msg.Time</span>
                                        </div>
                                        <div class="cr-msg-bubble cr-msg-bubble-them">@msg.Text</div>
                                    </div>
                                </div>
                            }
                        }
                    </div>
                    <div class="cr-chat-input-bar">
                        <button class="cr-chat-icon-btn" title="Emoji">
                            <i class="bi bi-emoji-smile"></i>
                        </button>
                        <input class="cr-chat-input"
                               placeholder="@L["Classroom_TypeMessage"]"
                               @bind="_newMessage"
                               @bind:event="oninput"
                               @onkeydown="OnChatKeyDown" />
                        <button class="cr-chat-icon-btn" title="Pièce jointe">
                            <i class="bi bi-paperclip"></i>
                        </button>
                        <button class="cr-chat-send-btn" @onclick="SendMessage" title="Envoyer">
                            <i class="bi bi-send-fill"></i>
                        </button>
                    </div>
                }
                else if (_activeTab == "Participants")
                {
                    <div class="cr-participants-list">
                        @foreach (var p in _participants)
                        {
                            <div class="cr-participant-row">
                                <div class="cr-p-avatar" style="background:@p.Color;">@p.Initials</div>
                                <div class="cr-p-info">
                                    <div class="cr-p-name">@p.Name</div>
                                    <div class="cr-p-role">@p.Role</div>
                                </div>
                                <div class="cr-p-media">
                                    <span class="@(p.MicOn ? "cr-p-icon-on" : "cr-p-icon-off")">
                                        <i class="bi @(p.MicOn ? "bi-mic-fill" : "bi-mic-mute-fill")"></i>
                                    </span>
                                    <span class="@(p.CamOn ? "cr-p-icon-on" : "cr-p-icon-off")">
                                        <i class="bi @(p.CamOn ? "bi-camera-video-fill" : "bi-camera-video-off-fill")"></i>
                                    </span>
                                </div>
                            </div>
                        }
                    </div>
                }
                else if (_activeTab == "Documents")
                {
                    <div class="cr-docs-list">
                        <button class="cr-upload-btn">
                            <i class="bi bi-upload me-1"></i>@L["Classroom_Share"]
                        </button>
                        @foreach (var doc in _documents)
                        {
                            <div class="cr-doc-row">
                                <i class="bi bi-file-earmark-pdf cr-doc-icon"></i>
                                <div class="cr-doc-meta">
                                    <div class="cr-doc-name">@doc.Name</div>
                                    <div class="cr-doc-size">@doc.Size</div>
                                </div>
                                <button class="cr-doc-dl-btn" title="@L["Common_Download"]">
                                    <i class="bi bi-download"></i>
                                </button>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- ── Bottom toolbar (dark) ── -->
    <div class="cr-toolbar">
        <div class="cr-tool-item">
            <button class="cr-tool-btn @(_micOn ? "" : "cr-tool-btn--muted")" @onclick="ToggleMic"
                    title="@L["Classroom_Mic"]">
                <i class="bi @(_micOn ? "bi-mic-fill" : "bi-mic-mute-fill")"></i>
            </button>
            <span class="cr-tool-lbl">@L["Classroom_Mic"]</span>
        </div>
        <div class="cr-tool-item">
            <button class="cr-tool-btn @(_camOn ? "" : "cr-tool-btn--muted")" @onclick="ToggleCam"
                    title="@L["Classroom_Camera"]">
                <i class="bi @(_camOn ? "bi-camera-video-fill" : "bi-camera-video-off-fill")"></i>
            </button>
            <span class="cr-tool-lbl">@L["Classroom_Camera"]</span>
        </div>
        <div class="cr-tool-item">
            <button class="cr-tool-btn @(_sharing ? "cr-tool-btn--active" : "")" @onclick="ToggleShare" title="@L["Classroom_ShareScreen"]">
                <i class="bi bi-display"></i>
            </button>
            <span class="cr-tool-lbl">@L["Classroom_Share"]</span>
        </div>
        <div class="cr-tool-item">
            <button class="cr-tool-btn" title="@L["Classroom_Whiteboard"]">
                <i class="bi bi-easel"></i>
            </button>
            <span class="cr-tool-lbl">@L["Classroom_Whiteboard"]</span>
        </div>
        <div class="cr-tool-item">
            <button class="cr-tool-btn" @onclick='() => _activeTab = "Participants"' title="@L["Classroom_Participants"]">
                <i class="bi bi-people-fill"></i>
            </button>
            <span class="cr-tool-lbl">@L["Classroom_Participants"]</span>
        </div>
        <div class="cr-tool-item">
            <button class="cr-tool-btn" title="@L["Classroom_Poll"]">
                <i class="bi bi-bar-chart-fill"></i>
            </button>
            <span class="cr-tool-lbl">@L["Classroom_Poll"]</span>
        </div>
        <div class="cr-tool-item">
            <button class="cr-tool-btn @(_recording ? "cr-tool-btn--danger" : "")" @onclick="ToggleRecording"
                    title="@L["Classroom_Record"]">
                <i class="bi @(_recording ? "bi-stop-circle-fill" : "bi-record-circle")"></i>
            </button>
            <span class="cr-tool-lbl">@L["Classroom_Record"]</span>
        </div>
        <div class="cr-tool-sep"></div>
        <div class="cr-tool-item">
            <button class="cr-tool-btn cr-tool-btn--quit" @onclick="GoBack" title="@L["Classroom_Leave"]">
                <i class="bi bi-box-arrow-right"></i>
            </button>
            <span class="cr-tool-lbl">@L["Classroom_Leave"]</span>
        </div>
    </div>
</div>

@code {
    [Parameter] public string LessonId { get; set; } = "";

    [SupplyParameterFromQuery] public string? Student   { get; set; }
    [SupplyParameterFromQuery] public string? Initials  { get; set; }
    [SupplyParameterFromQuery] public string? Title     { get; set; }
    [SupplyParameterFromQuery] public string? Subject   { get; set; }

    private int _elapsedSeconds;
    private System.Threading.Timer? _timer;

    private bool _micOn      = true;
    private bool _camOn      = true;
    private bool _sharing    = false;
    private bool _recording  = false;
    private bool _mediaReady = false;
    private bool _mediaStarted;
    private string? _mediaError;

    private ElementReference _localVideo;
    private bool _showLocalVideo => _sharing || (_camOn && _mediaReady);

    private string _activeTab  = "Chat";
    private string _newMessage = "";

    private ClassroomLesson _lesson = new();

    // Whiteboard state
    private ElementReference _canvasRef;
    private bool   _wbReady = false;
    private string _wbTool  = "pen";
    private string _wbColor = "#000000";
    private string _wbSize  = "medium";
    private int    _wbPage  = 3;
    private int    _wbTotalPages = 12;
    private int    _wbZoom  = 100;

    private readonly string[] _wbColors =
        ["#ef4444", "#b91c1c", "#22c55e", "#3b82f6", "#000000", "#f97316", "#a855f7", "#eab308"];

    private string TutorDisplayName =>
        string.IsNullOrWhiteSpace(Auth.UserName) ? "Tuteur" : Auth.UserName!;

    private string TutorInitials
    {
        get
        {
            var parts = TutorDisplayName.Split([' ', '@'], StringSplitOptions.RemoveEmptyEntries);
            if (parts.Length >= 2)
                return $"{char.ToUpperInvariant(parts[0][0])}{char.ToUpperInvariant(parts[1][0])}";
            return TutorDisplayName.Length > 0 ? char.ToUpperInvariant(TutorDisplayName[0]).ToString() : "T";
        }
    }

    protected override void OnInitialized()
    {
        _lesson = new ClassroomLesson
        {
            Title           = string.IsNullOrWhiteSpace(Title)    ? "Mathématiques – Chapitre 3" : Title,
            StudentName     = string.IsNullOrWhiteSpace(Student)  ? "Élève"                      : Student,
            StudentInitials = string.IsNullOrWhiteSpace(Initials) ? "EL"                         : Initials,
            Subject         = string.IsNullOrWhiteSpace(Subject)  ? "Équations du 2ᵉ degré"      : Subject,
            AvatarColor     = "#7c3aed",
        };

        _participants =
        [
            new() { Name = TutorDisplayName, Initials = TutorInitials, Color = "#5831E0", Role = "Tuteur",
                    MicOn = _micOn, CamOn = _camOn },
            new() { Name = _lesson.StudentName, Initials = _lesson.StudentInitials,
                    Color = _lesson.AvatarColor, Role = "Élève", MicOn = true, CamOn = false },
        ];

        InitChatMessages();

        _timer = new System.Threading.Timer(_ =>
        {
            _elapsedSeconds++;
            InvokeAsync(StateHasChanged);
        }, null, 1000, 1000);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!_wbReady)
        {
            try
            {
                await JS.InvokeVoidAsync("whiteboard.init", _canvasRef);
                _wbReady = true;
            }
            catch { /* prerender phase — JS not yet available */ }
        }

        if (firstRender && !_mediaStarted)
        {
            _mediaStarted = true;
            await StartLocalMediaAsync();
        }
    }

    public void Dispose()
    {
        _timer?.Dispose();
        _ = StopLocalMediaAsync();
    }

    private static string FormatElapsed(int s)
    {
        var h = s / 3600;
        var m = (s % 3600) / 60;
        var sec = s % 60;
        return h > 0 ? $"{h}:{m:D2}:{sec:D2}" : $"{m:D2}:{sec:D2}";
    }

    private async Task GoBack()
    {
        await StopLocalMediaAsync();
        Navigation.NavigateTo("/tutor/lessons");
    }

    private async Task EndSession()
    {
        await StopLocalMediaAsync();
        Navigation.NavigateTo("/tutor/lessons");
    }

    private async Task StartLocalMediaAsync()
    {
        _mediaError = null;
        try
        {
            var result = await JS.InvokeAsync<MediaStartResult>(
                "classroomMedia.start", _localVideo, new { video = true, audio = true });

            if (result is null || !result.Ok)
            {
                _mediaReady = false;
                _camOn = false;
                _micOn = false;
                _mediaError = result?.Error ?? "Impossible d'activer la caméra.";
                SyncTutorMediaFlags();
                StateHasChanged();
                return;
            }

            _mediaReady = true;
            _camOn = result.Video;
            _micOn = result.Audio;
            SyncTutorMediaFlags();
            StateHasChanged();
        }
        catch (JSException ex)
        {
            _mediaReady = false;
            _camOn = false;
            _micOn = false;
            _mediaError = ex.Message;
            SyncTutorMediaFlags();
            StateHasChanged();
        }
        catch (InvalidOperationException)
        {
            // Prerender — retry not needed; button will start media.
        }
    }

    private async Task StopLocalMediaAsync()
    {
        try { await JS.InvokeVoidAsync("classroomMedia.stop", _localVideo); }
        catch { }
        _mediaReady = false;
    }

    private void SyncTutorMediaFlags()
    {
        if (_participants.Count > 0)
        {
            _participants[0].MicOn = _micOn;
            _participants[0].CamOn = _camOn;
        }
    }

    private async Task ToggleMic()
    {
        if (!_mediaReady)
        {
            await StartLocalMediaAsync();
            return;
        }

        _micOn = !_micOn;
        try { await JS.InvokeVoidAsync("classroomMedia.setAudioEnabled", _micOn); }
        catch { }
        SyncTutorMediaFlags();
    }

    private async Task ToggleCam()
    {
        if (!_mediaReady)
        {
            await StartLocalMediaAsync();
            return;
        }

        _camOn = !_camOn;
        try { await JS.InvokeVoidAsync("classroomMedia.setVideoEnabled", _camOn); }
        catch { }
        if (_camOn) _mediaError = null;
        SyncTutorMediaFlags();
    }

    private async Task ToggleShare()
    {
        if (_sharing)
        {
            try { await JS.InvokeVoidAsync("classroomMedia.stopScreenShare", _localVideo); }
            catch { }
            _sharing = false;
            return;
        }

        try
        {
            var result = await JS.InvokeAsync<MediaStartResult>("classroomMedia.startScreenShare", _localVideo);
            if (result is null || !result.Ok)
            {
                _mediaError = result?.Error ?? "Partage d'écran impossible.";
                return;
            }
            _sharing = true;
            _mediaError = null;
        }
        catch (JSException ex)
        {
            _mediaError = ex.Message;
        }
    }

    private void ToggleRecording() => _recording = !_recording;

    private void OnChatKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey) SendMessage();
    }

    private void SendMessage()
    {
        var text = _newMessage.Trim();
        if (string.IsNullOrEmpty(text)) return;
        _chatMessages.Add(new ChatMsg
        {
            Text   = text,
            IsMe   = true,
            Sender = TutorDisplayName,
            Time   = DateTime.Now.ToString("HH:mm"),
        });
        _newMessage = "";
    }

    private async Task SetWbTool(string tool)
    {
        _wbTool = tool;
        try { await JS.InvokeVoidAsync("whiteboard.setTool", tool); } catch { }
    }

    private async Task SetWbColor(string color)
    {
        _wbColor = color;
        _wbTool  = "pen";
        try { await JS.InvokeVoidAsync("whiteboard.setColor", color); } catch { }
    }

    private async Task SetWbSize(string size)
    {
        _wbSize = size;
        try { await JS.InvokeVoidAsync("whiteboard.setSize", size); } catch { }
    }

    private async Task ClearWhiteboard()
    {
        try { await JS.InvokeVoidAsync("whiteboard.clear"); } catch { }
    }

    private void PrevPage() { if (_wbPage > 1)             _wbPage--; }
    private void NextPage() { if (_wbPage < _wbTotalPages) _wbPage++; }
    private void ZoomOut()  { if (_wbZoom > 25)  _wbZoom = Math.Max(25,  _wbZoom - 25); }
    private void ZoomIn()   { if (_wbZoom < 200) _wbZoom = Math.Min(200, _wbZoom + 25); }

    private static string GetSenderColor(string sender) =>
        sender.StartsWith("É", StringComparison.OrdinalIgnoreCase) ? "#7c3aed" : "#5831E0";

    private static string GetSenderInitials(string sender) =>
        sender.Length >= 2 ? sender[..2].ToUpper() : sender.ToUpper();

