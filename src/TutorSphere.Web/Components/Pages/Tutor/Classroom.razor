@page "/tutor/classroom/{lessonId}"
@layout TutorLayout
@rendermode InteractiveServer
@implements IDisposable
@inject IStringLocalizer<SharedResources> L
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject AuthService Auth
@inject ApiClient Api
@inject LessonService LessonSvc
@inject IHttpClientFactory HttpFactory
@inject RealtimeClassroomClient ClassroomRt

<PageTitle>@L["Classroom_Title"] – TutorSphere</PageTitle>

<div class="cr-pro @(_wbCollapsed ? "cr-pro--wb-min" : null)">
    <header class="cr-pro-header">
        <div class="cr-pro-header-left">
            <div style="min-width:0">
                <h1 class="cr-pro-course-title">@_lesson.Title</h1>
                <div class="cr-pro-meta-row">
                    @if (!string.IsNullOrWhiteSpace(_lesson.Subject))
                    {
                        <span class="cr-pro-chip"><i class="bi bi-journal-bookmark"></i>@_lesson.Subject</span>
                    }
                    <span class="cr-pro-chip"><i class="bi bi-bullseye"></i>@L["ClassroomPro_SessionGoal"]</span>
                    <span class="cr-pro-chip cr-pro-chip--live">
                        <i class="bi bi-circle-fill"></i>@L["Classroom_Live"]
                    </span>
                    @if (_recording)
                    {
                        <span class="cr-pro-chip" style="color:#b91c1c;background:#fee2e2;border-color:#fecaca">
                            <i class="bi bi-record-circle-fill"></i>@L["Classroom_Record"]
                        </span>
                    }
                </div>
                <div class="cr-pro-progress" title='@L["ClassroomPro_Progress"]'>
                    <div class="cr-pro-progress-meta">
                        <span>@L["ClassroomPro_SessionProgress"]</span>
                        <span>@SessionProgressPercent%</span>
                    </div>
                    <div class="cr-pro-progress-bar" aria-hidden="true"><span style="width:@SessionProgressPercent%"></span></div>
                </div>
            </div>
        </div>

        <div class="cr-pro-stats">
            <div class="cr-pro-stat">
                <span class="cr-pro-stat-label">@L["ClassroomPro_Duration"]</span>
                <span class="cr-pro-stat-value"><i class="bi bi-clock"></i>@FormatElapsed(_elapsedSeconds)</span>
            </div>
            <div class="cr-pro-stat">
                <span class="cr-pro-stat-label">@L["ClassroomPro_Network"]</span>
                <span class="cr-pro-stat-value">
                    <span class="cr-pro-net-bars is-good" aria-hidden="true"><span></span><span></span><span></span><span></span></span>
                    @L["ClassroomPro_NetworkExcellent"]
                </span>
            </div>
            <div class="cr-pro-stat">
                <span class="cr-pro-stat-label">@L["ClassroomPro_Participants"]</span>
                <span class="cr-pro-stat-value"><i class="bi bi-people"></i>@_participants.Count</span>
            </div>
            <button type="button" class="cr-pro-stat" style="cursor:pointer;border:1px solid var(--crp-border)" @onclick='() => OpenSide("Holo")' title="Holo">
                <span class="cr-pro-stat-label">Holo</span>
                <span class="cr-pro-stat-value" style="color:var(--crp-ai)"><i class="bi bi-stars"></i>IA</span>
            </button>
        </div>

        <div class="cr-pro-header-right">
            <a class="cr-pro-link" href="/tutor/school">@L["School_ViewPublic"] <i class="bi bi-box-arrow-up-right"></i></a>
            <button type="button" class="cr-pro-icon-btn" title='@L["Nav_Settings"]' @onclick='() => PushToast(L["ClassroomPro_SettingsSoon"])'>
                <i class="bi bi-gear"></i>
            </button>
            <button type="button" class="cr-pro-icon-btn" title='@L["Nav_Notifications"]' @onclick='() => PushToast(L["ClassroomPro_NoNotifications"])'>
                <i class="bi bi-bell"></i>
            </button>
            <span class="cr-pro-avatar" title="@TutorDisplayName">@TutorInitials</span>
            <button type="button" class="cr-pro-end-btn" @onclick="EndSession">
                <i class="bi bi-stop-fill"></i>@L["Classroom_EndSession"]
            </button>
        </div>
    </header>

    <div class="cr-pro-body @(_panelOpen ? "is-panel-open" : null) @(_panelCollapsed ? "is-panel-collapsed" : null)">
        <div class="cr-pro-panel-scrim" @onclick="() => _panelOpen = false"></div>

        <div class="cr-pro-center @(_wbCollapsed ? "is-wb-collapsed" : "is-wb-foreground")">
            @if (_pendingShareRequests.Count > 0)
            {
                <div class="cr-pro-share-requests">
                    @foreach (var req in _pendingShareRequests.ToList())
                    {
                        <div class="cr-pro-share-request" @key="req.RequesterConnectionId">
                            <i class="bi bi-display"></i>
                            <span>
                                <strong>@req.RequesterDisplayName</strong>
                                @(req.Kind == "whiteboard" ? " demande à partager son tableau" : " demande à partager son écran")
                            </span>
                            <button type="button" class="ok" @onclick="() => RespondShareAsync(req, true)">Autoriser</button>
                            <button type="button" class="stop" @onclick="() => RespondShareAsync(req, false)">Refuser</button>
                        </div>
                    }
                </div>
            }

            @if (_sharing)
            {
                <div class="cr-pro-sharebar">
                    <i class="bi bi-broadcast"></i>
                    <span>@(_sharingWhiteboard ? "Vous partagez le tableau avec la classe" : L["ClassroomPro_SharingScreen"])</span>
                    <button type="button" class="ghost" @onclick='() => PushToast(L["ClassroomPro_PauseSoon"])'>@L["ClassroomPro_Pause"]</button>
                    <button type="button" class="ghost" @onclick="ToggleWhiteboardForeground">@L["ClassroomPro_Annotate"]</button>
                    <button type="button" class="stop" @onclick="StopTutorShareAsync">@L["ClassroomPro_StopShare"]</button>
                </div>
            }

            <section class="cr-pro-video @ViewModeClass @(_viewFullscreen ? "is-fullscreen" : null)">
                <div class="cr-pro-video-top">
                    <button type="button" class="cr-pro-view-btn" @onclick="() => _showViewMenu = !_showViewMenu">
                        <i class="bi bi-grid-3x3-gap"></i>@ViewModeLabel
                    </button>
                </div>
                @if (_showViewMenu)
                {
                    <div class="cr-pro-view-menu">
                        <button type="button" class="@(_viewMode == "speaker" ? "active" : null)" @onclick='() => SetViewMode("speaker")'>@L["ClassroomPro_ViewSpeaker"]</button>
                        <button type="button" class="@(_viewMode == "gallery" ? "active" : null)" @onclick='() => SetViewMode("gallery")'>@L["ClassroomPro_ViewGallery"]</button>
                        <button type="button" class="@(_viewMode == "presenter" ? "active" : null)" @onclick='() => SetViewMode("presenter")'>@L["ClassroomPro_ViewPresenter"]</button>
                        <button type="button" class="@(_viewMode == "mosaic" ? "active" : null)" @onclick='() => SetViewMode("mosaic")'>@L["ClassroomPro_ViewMosaic"]</button>
                        <button type="button" class="@(_viewMode == "vertical" ? "active" : null)" @onclick='() => SetViewMode("vertical")'>@L["ClassroomPro_ViewVertical"]</button>
                        <button type="button" @onclick="ToggleFullscreenView">@L["ClassroomPro_ViewFullscreen"]</button>
                    </div>
                }

                <div class="cr-pro-stage">
                    <div class="cr-pro-stage-bg"></div>
                    <video data-rtc-main
                           class="@(_showRemoteMain ? "" : "is-hidden")"
                           autoplay playsinline></video>
                    <video data-rtc-local-stage
                           class="@(_showLocalVideo && !_showRemoteMain ? "" : "is-hidden")"
                           autoplay playsinline muted></video>
                    @if (!_showLocalVideo && !_showRemoteMain)
                    {
                        <div class="cr-pro-placeholder"><i class="bi bi-person-fill"></i></div>
                    }
                    @if (!string.IsNullOrEmpty(_mediaError) && !_showRemoteMain)
                    {
                        <div class="cr-pro-media-error" role="alert">
                            <i class="bi bi-exclamation-triangle-fill"></i>
                            <span>@_mediaError</span>
                        </div>
                    }
                    <div class="cr-pro-stage-label">
                        @if (_showRemoteMain && _focusedPeer is not null)
                        {
                            <span class="cr-pro-stage-av" style="background:@_focusedPeer.Color">@_focusedPeer.Initials</span>
                            <span>@_focusedPeer.Name</span>
                            <i class="bi @(_focusedPeer.MicOn ? "bi-mic-fill" : "bi-mic-mute-fill")"></i>
                        }
                        else
                        {
                            <span class="cr-pro-stage-av">@TutorInitials</span>
                            <span>@TutorDisplayName</span>
                            <i class="bi @(_micOn ? "bi-mic-fill" : "bi-mic-mute-fill")"></i>
                        }
                    </div>
                </div>

                <div class="cr-pro-strip">
                    <div class="cr-pro-thumb is-self @(_showLocalVideo ? "has-video" : null)" title="@TutorDisplayName">
                        <video @ref="_localVideo"
                               data-rtc-local
                               class="@(_showLocalVideo ? "" : "is-hidden")"
                               autoplay playsinline muted></video>
                        @if (!_showLocalVideo)
                        {
                            <div class="cr-pro-placeholder cr-pro-placeholder--av" style="--av:#1e3a5f">
                                <span>@TutorInitials</span>
                            </div>
                        }
                        <div class="cr-pro-thumb-chrome">
                            <span class="cr-pro-thumb-live"><i class="bi bi-circle-fill"></i>LIVE</span>
                            @if (_sharing) { <span class="cr-pro-thumb-react" title='@L["Classroom_ShareScreen"]'>🖥️</span> }
                            @if (_handRaised) { <span class="cr-pro-thumb-react">✋</span> }
                        </div>
                        <div class="cr-pro-thumb-label">
                            <span>@TutorDisplayName (@L["ClassroomPro_You"])</span>
                        </div>
                        <div class="cr-pro-thumb-telemetry">
                            <i class="bi @(_micOn ? "bi-mic-fill" : "bi-mic-mute-fill") @(_micOn ? null : "is-off")"></i>
                            <i class="bi @(_camOn ? "bi-camera-video-fill" : "bi-camera-video-off-fill") @(_camOn ? null : "is-off")"></i>
                            <i class="bi bi-wifi"></i>
                            <span>@L["ClassroomPro_NetworkExcellent"]</span>
                            <span class="ping">~24ms</span>
                        </div>
                    </div>
                    @foreach (var p in VisibleStudentTiles)
                    {
                        <div @key="p.ConnectionId ?? p.Name"
                             class="cr-pro-thumb @(p.IsOnline ? null : "is-offline") @(p.IsSpeaking || (p.CamOn && p.HasRemoteVideo) ? "is-speaking" : null) @(p.CamOn && p.HasRemoteVideo ? "has-video" : null)"
                             @onclick="() => FocusPeer(p)" title="@p.Name">
                            @if (!string.IsNullOrEmpty(p.ConnectionId) && p.IsOnline)
                            {
                                <video data-rtc-peer="@p.ConnectionId"
                                       autoplay playsinline></video>
                            }
                            @if (!(p.CamOn && p.HasRemoteVideo && p.IsOnline) || string.IsNullOrEmpty(p.ConnectionId))
                            {
                                <div class="cr-pro-placeholder cr-pro-placeholder--av" style="--av:@p.Color">
                                    <span>@p.Initials</span>
                                </div>
                            }
                            <div class="cr-pro-thumb-chrome">
                                @if (p.IsOnline)
                                {
                                    <span class="cr-pro-thumb-live"><i class="bi bi-circle-fill"></i>LIVE</span>
                                }
                                else
                                {
                                    <span class="cr-pro-thumb-offline">@L["ClassroomPro_Absent"]</span>
                                }
                                @if (p.HandRaised) { <span class="cr-pro-thumb-react">✋</span> }
                            </div>
                            <div class="cr-pro-thumb-label">
                                <span>@p.Name</span>
                            </div>
                            <div class="cr-pro-thumb-telemetry">
                                <i class="bi @(p.MicOn && p.IsOnline ? "bi-mic-fill" : "bi-mic-mute-fill") @(p.MicOn && p.IsOnline ? null : "is-off")"></i>
                                <i class="bi @(p.CamOn && p.IsOnline ? "bi-camera-video-fill" : "bi-camera-video-off-fill") @(p.CamOn && p.IsOnline ? null : "is-off")"></i>
                                <i class="bi bi-wifi"></i>
                                <span>@(p.IsOnline ? L["ClassroomPro_NetworkExcellent"] : "—")</span>
                                <span class="ping">@(p.IsOnline ? "~32ms" : "—")</span>
                            </div>
                        </div>
                    }
                    @if (HiddenStudentCount > 0)
                    {
                        <button type="button" class="cr-pro-thumb cr-pro-thumb--more" @onclick='() => OpenSide("Participants")'>
                            +@HiddenStudentCount @L["ClassroomPro_MoreStudents"]
                        </button>
                    }
                </div>
            </section>

            <div class="cr-pro-dock-wrap">
                <div class="cr-pro-dock" role="toolbar" aria-label="@L["Classroom_Title"]">
                    <button type="button" class="cr-pro-dock-btn @(!_micOn ? "is-off" : null)" @onclick="ToggleMic" title='@L["Classroom_Mic"]'>
                        <i class="bi @(_micOn ? "bi-mic-fill" : "bi-mic-mute-fill")"></i>
                    </button>
                    <button type="button" class="cr-pro-dock-btn @(!_camOn ? "is-off" : null)" @onclick="ToggleCam" title='@L["Classroom_Camera"]'>
                        <i class="bi @(_camOn ? "bi-camera-video-fill" : "bi-camera-video-off-fill")"></i>
                    </button>
                    <button type="button" class="cr-pro-dock-btn @(_sharing && !_sharingWhiteboard ? "is-on" : null)" @onclick="ToggleShare" title='@L["Classroom_ShareScreen"]'>
                        <i class="bi bi-display"></i>
                    </button>
                    <button type="button" class="cr-pro-dock-btn @(_handRaised ? "is-on" : null)" @onclick="ToggleHand" title='@L["ClassroomPro_RaiseHand"]'>
                        <i class="bi bi-hand-index-thumb"></i>
                    </button>
                    <button type="button" class="cr-pro-dock-btn" @onclick='() => OpenSide("Chat")' title='@L["Classroom_Chat"]'>
                        <i class="bi bi-chat-dots-fill"></i>
                    </button>
                    <button type="button" class="cr-pro-dock-btn" @onclick='() => OpenSide("Participants")' title='@L["Classroom_Participants"]'>
                        <i class="bi bi-people-fill"></i>
                        <span class="cr-pro-dock-badge">@_participants.Count</span>
                    </button>
                    <button type="button" class="cr-pro-dock-btn @(_recording ? "is-rec" : null)" @onclick="ToggleRecording" title='@L["Classroom_Record"]'>
                        <i class="bi @(_recording ? "bi-stop-circle-fill" : "bi-record-circle")"></i>
                    </button>
                    <button type="button" class="cr-pro-dock-btn @(!_wbCollapsed ? "is-on" : null)" @onclick="ToggleWbCollapsed" title='@L["Classroom_Whiteboard"]'>
                        <i class="bi bi-easel"></i>
                    </button>
                    <button type="button" class="cr-pro-dock-btn" @onclick='() => OpenSide("Documents")' title='@L["Classroom_Documents"]'>
                        <i class="bi bi-folder2-open"></i>
                    </button>
                    <div style="position:relative">
                        <button type="button" class="cr-pro-dock-btn @(_showBgMenu ? "is-on" : null)" @onclick="() => _showBgMenu = !_showBgMenu" title='@L["Classroom_Background"]'>
                            <i class="bi bi-magic"></i>
                        </button>
                    </div>
                    <button type="button" class="cr-pro-dock-btn" @onclick="() => _showMoreMenu = !_showMoreMenu" title='@L["ClassroomPro_More"]'>
                        <i class="bi bi-three-dots"></i>
                    </button>
                    <span class="cr-pro-dock-sep"></span>
                    <button type="button" class="cr-pro-dock-btn cr-pro-dock-btn--quit" @onclick="GoBack" title='@L["Classroom_Leave"]'>
                        <i class="bi bi-telephone-x-fill"></i>
                    </button>
                </div>
            </div>

            @if (_showBgMenu)
            {
                <div class="cr-pro-bg-menu">
                    <button type="button" class="cr-pro-bg-opt @(_bgMode == "none" ? "active" : "")" @onclick='() => SetBackgroundAsync("none")'>@L["Classroom_BgNone"]</button>
                    <button type="button" class="cr-pro-bg-opt @(_bgMode == "blur" ? "active" : "")" @onclick='() => SetBackgroundAsync("blur")'>@L["Classroom_BgBlur"]</button>
                    <button type="button" class="cr-pro-bg-opt" @onclick='() => SetBackgroundAsync("image", "library")'>@L["Classroom_BgLibrary"]</button>
                    <button type="button" class="cr-pro-bg-opt" @onclick='() => SetBackgroundAsync("image", "classroom")'>@L["Classroom_BgClassroom"]</button>
                    <label class="cr-pro-bg-opt" style="cursor:pointer">
                        @L["Classroom_BgCustom"]
                        <InputFile OnChange="OnBackgroundFileAsync" accept="image/*" style="display:none" />
                    </label>
                </div>
            }

            <section class="cr-pro-board @(_wbCollapsed ? "is-peek" : null) @(!string.IsNullOrEmpty(_watchingBoardShareFrom) ? "is-remote-share" : null)" @onclick="OnBoardPeekClick">
                <button type="button" class="cr-pro-wb-peek" @onclick="ExpandBoardFromPeek" @onclick:stopPropagation="true">
                    <span class="cr-pro-wb-peek-icon"><i class="bi bi-easel"></i></span>
                    <span class="cr-pro-wb-peek-copy">
                        <strong>@L["Classroom_Whiteboard"]</strong>
                        <span>@(!string.IsNullOrEmpty(_watchingBoardShareName) ? $"Tableau de {_watchingBoardShareName}" : (_boardDocName ?? L["ClassroomPro_WbPeekHint"].Value))</span>
                    </span>
                    <span class="cr-pro-wb-peek-cta">@L["ClassroomPro_WbExpand"] <i class="bi bi-chevron-up"></i></span>
                </button>
                @if (!string.IsNullOrEmpty(_watchingBoardShareFrom))
                {
                    <div class="cr-pro-board-share-banner" @onclick:stopPropagation="true">
                        <i class="bi bi-easel"></i>
                        <span>
                            @if (_watchingBoardShareIsOwn)
                            {
                                <text>Vous partagez le tableau avec la classe</text>
                            }
                            else if (_boardSharePublishedToClass)
                            {
                                <text>Tableau de @_watchingBoardShareName — visible par la classe</text>
                            }
                            else
                            {
                                <text>Tableau de @_watchingBoardShareName — visible par vous seul</text>
                            }
                        </span>
                        @if (!_watchingBoardShareIsOwn && !_boardSharePublishedToClass)
                        {
                            <button type="button" class="cr-pro-board-share-publish" @onclick="PublishWatchedBoardToClassAsync">
                                Partager avec la classe
                            </button>
                        }
                    </div>
                }
                <div class="cr-pro-board-toolbar" @onclick:stopPropagation="true">
                    <button type="button" class="cr-pro-wb-btn @(_wbTool == "select" ? "active" : "")" @onclick='() => SetWbTool("select")' title='@L["Classroom_Select"]'><i class="bi bi-cursor-fill"></i></button>
                    <button type="button" class="cr-pro-wb-btn @(_wbTool == "pen" ? "active" : "")" @onclick='() => SetWbTool("pen")' title='@L["Classroom_Pen"]'><i class="bi bi-pencil-fill"></i></button>
                    <button type="button" class="cr-pro-wb-btn @(_wbTool == "highlighter" ? "active" : "")" @onclick='() => SetWbTool("highlighter")' title='@L["ClassroomPro_Highlighter"]'><i class="bi bi-highlighter"></i></button>
                    <button type="button" class="cr-pro-wb-btn @(_wbTool == "eraser" ? "active" : "")" @onclick='() => SetWbTool("eraser")' title='@L["Classroom_Eraser"]'><i class="bi bi-eraser-fill"></i></button>
                    <button type="button" class="cr-pro-wb-btn @(_wbTool == "text" ? "active" : "")" @onclick='() => SetWbTool("text")' title='@L["ClassroomPro_Text"]'><i class="bi bi-fonts"></i></button>
                    <button type="button" class="cr-pro-wb-btn @(_wbTool == "rect" ? "active" : "")" @onclick='() => SetWbTool("rect")' title='@L["ClassroomPro_Rect"]'><i class="bi bi-square"></i></button>
                    <button type="button" class="cr-pro-wb-btn @(_wbTool == "ellipse" ? "active" : "")" @onclick='() => SetWbTool("ellipse")' title='@L["ClassroomPro_Circle"]'><i class="bi bi-circle"></i></button>
                    <button type="button" class="cr-pro-wb-btn @(_wbTool == "line" ? "active" : "")" @onclick='() => SetWbTool("line")' title='@L["ClassroomPro_Arrow"]'><i class="bi bi-arrow-up-right"></i></button>
                    <button type="button" class="cr-pro-wb-btn" @onclick='() => PushToast(L["ClassroomPro_ImageSoon"])' title='@L["ClassroomPro_Image"]'><i class="bi bi-image"></i></button>
                    <button type="button" class="cr-pro-wb-btn" @onclick='() => PushToast(L["ClassroomPro_StickySoon"])' title='@L["ClassroomPro_Sticky"]'><i class="bi bi-sticky"></i></button>
                    <button type="button" class="cr-pro-wb-btn @(_wbTool == "laser" ? "active" : "")" @onclick='() => SetWbTool("laser")' title='@L["ClassroomPro_Laser"]'><i class="bi bi-bullseye"></i></button>
                    <span class="cr-pro-wb-sep"></span>
                    @foreach (var clr in _wbColors)
                    {
                        <button type="button" class="cr-pro-wb-color @(_wbColor == clr ? "active" : "")" style="background:@clr" @onclick="() => SetWbColor(clr)"></button>
                    }
                    <span class="cr-pro-wb-sep"></span>
                    <button type="button" class="cr-pro-wb-size @(_wbSize == "thin" ? "active" : "")" @onclick='() => SetWbSize("thin")'><span class="cr-pro-wb-dot" style="width:3px;height:3px"></span></button>
                    <button type="button" class="cr-pro-wb-size @(_wbSize == "medium" ? "active" : "")" @onclick='() => SetWbSize("medium")'><span class="cr-pro-wb-dot" style="width:7px;height:7px"></span></button>
                    <button type="button" class="cr-pro-wb-size @(_wbSize == "thick" ? "active" : "")" @onclick='() => SetWbSize("thick")'><span class="cr-pro-wb-dot" style="width:11px;height:11px"></span></button>
                    <span class="cr-pro-wb-sep"></span>
                    <button type="button" class="cr-pro-wb-btn" @onclick='() => PushToast(L["ClassroomPro_UndoSoon"])' title='@L["ClassroomPro_Undo"]'><i class="bi bi-arrow-counterclockwise"></i></button>
                    <button type="button" class="cr-pro-wb-btn" @onclick='() => PushToast(L["ClassroomPro_RedoSoon"])' title='@L["ClassroomPro_Redo"]'><i class="bi bi-arrow-clockwise"></i></button>
                    <button type="button" class="cr-pro-wb-btn" @onclick="ClearWhiteboard" title='@L["Classroom_ClearAll"]'><i class="bi bi-trash3"></i></button>
                    <button type="button" class="cr-pro-wb-btn" @onclick='() => PushToast(L["ClassroomPro_ExportSoon"])' title="PDF"><i class="bi bi-filetype-pdf"></i></button>
                    <button type="button" class="cr-pro-wb-btn" @onclick='() => PushToast(L["ClassroomPro_ExportSoon"])' title="PNG"><i class="bi bi-filetype-png"></i></button>
                    <span style="flex:1"></span>
                    <button type="button" class="cr-pro-wb-btn" @onclick="ToggleWbCollapsed" title='@L["ClassroomPro_CollapseBoard"]'><i class="bi bi-chevron-down"></i></button>
                </div>
                <div class="cr-pro-board-canvas-wrap" @onclick:stopPropagation="true">
                    @if (!string.IsNullOrEmpty(_boardDocName) && string.IsNullOrEmpty(_watchingBoardShareFrom))
                    {
                        <div class="cr-pro-board-doc"><i class="bi bi-image me-1"></i>@_boardDocName — @L["Classroom_AnnotateHint"]</div>
                    }
                    <video data-rtc-board-share
                           class="cr-pro-board-remote is-hidden"
                           autoplay playsinline muted></video>
                    <canvas @ref="_canvasRef" class="cr-canvas"></canvas>
                </div>
                <div class="cr-pro-board-footer" @onclick:stopPropagation="true">
                    <button type="button" class="cr-pro-wb-btn" @onclick="PrevPage"><i class="bi bi-chevron-left"></i></button>
                    <span>@_wbPage / @_wbTotalPages</span>
                    <button type="button" class="cr-pro-wb-btn" @onclick="NextPage"><i class="bi bi-chevron-right"></i></button>
                    <span style="flex:1"></span>
                    <button type="button" class="cr-pro-wb-btn" @onclick="ZoomOut">−</button>
                    <span>@_wbZoom%</span>
                    <button type="button" class="cr-pro-wb-btn" @onclick="ZoomIn">+</button>
                    <button type="button" class="cr-pro-wb-btn @(_wbForeground ? "active" : "")" @onclick="ToggleWhiteboardForeground" title='@L["Classroom_WbForeground"]'>
                        <i class="bi @(_wbForeground ? "bi-fullscreen-exit" : "bi-fullscreen")"></i>
                    </button>
                    <button type="button" class="cr-pro-wb-btn @(_sharingWhiteboard ? "active" : "")" @onclick="ToggleWhiteboardShare" title='@L["Classroom_Whiteboard"]'>
                        <i class="bi bi-cast"></i>
                    </button>
                </div>
            </section>
        </div>

        <aside class="cr-pro-side">
            <div class="cr-pro-side-tabs">
                <button type="button" class="cr-pro-side-tab @(_sideRail == "People" ? "active" : null)" @onclick='() => _sideRail = "People"'><i class="bi bi-people"></i>@L["Classroom_Participants"]</button>
                <button type="button" class="cr-pro-side-tab @(_sideRail == "Chat" ? "active" : null)" @onclick='() => { _sideRail = "Chat"; _activeTab = "Chat"; }'><i class="bi bi-chat"></i>@L["Classroom_Chat"]</button>
                <button type="button" class="cr-pro-side-tab is-ai @(_sideRail == "Holo" ? "active" : null)" @onclick='() => _sideRail = "Holo"'><i class="bi bi-stars"></i>Holo</button>
                <button type="button" class="cr-pro-side-tab @(_sideRail == "Docs" ? "active" : null)" @onclick='() => { _sideRail = "Docs"; _activeTab = "Documents"; }'><i class="bi bi-folder"></i>@L["Classroom_Documents"]</button>
                <button type="button" class="cr-pro-side-tab @(_sideRail == "Quiz" ? "active" : null)" @onclick='() => _sideRail = "Quiz"'><i class="bi bi-question-circle"></i>Quiz</button>
                <button type="button" class="cr-pro-side-tab @(_sideRail == "Notes" ? "active" : null)" @onclick='() => _sideRail = "Notes"'><i class="bi bi-journal-text"></i>@L["ClassroomPro_AiNotes"]</button>
            </div>

            @if (_sideRail == "People")
            {
                <div class="cr-pro-side-card" style="border:none;box-shadow:none">
                    <div class="cr-pro-side-head">
                        <h3>@L["Classroom_Participants"] (@_participants.Count)</h3>
                        <button type="button" class="cr-pro-invite" @onclick='() => PushToast(L["ClassroomPro_InviteSoon"])'>
                            <i class="bi bi-person-plus"></i> @L["ClassroomPro_Invite"]
                        </button>
                    </div>
                    <div class="cr-pro-search">
                        <i class="bi bi-search"></i>
                        <input @bind="_participantFilter" @bind:event="oninput" placeholder='@L["ClassroomPro_SearchParticipant"]' />
                    </div>
                    <div class="cr-pro-plist">
                        @foreach (var p in FilteredParticipants)
                        {
                            <div class="cr-pro-prow @(p.Role == "Tuteur" ? "is-self" : null)">
                                <div class="cr-pro-prow-av" style="background:@p.Color">@p.Initials</div>
                                <div>
                                    <div class="cr-pro-prow-name">@p.Name</div>
                                    <div class="cr-pro-prow-role">
                                        @p.Role
                                        · @(p.IsOnline || p.Role == "Tuteur" ? L["ClassroomPro_Present"] : L["ClassroomPro_Absent"])
                                    </div>
                                </div>
                                <div class="cr-pro-prow-icons">
                                    @if (p.HandRaised) { <i class="bi bi-hand-index-thumb-fill is-hand"></i> }
                                    <i class="bi @(p.MicOn ? "bi-mic-fill" : "bi-mic-mute-fill") @(p.MicOn ? "" : "is-off")"></i>
                                    <i class="bi @(p.CamOn || p.HasRemoteVideo ? "bi-camera-video-fill" : "bi-camera-video-off-fill") @(p.CamOn || p.HasRemoteVideo ? "" : "is-off")"></i>
                                    @if (p.Role != "Tuteur")
                                    {
                                        <button type="button" class="cr-pro-icon-btn" style="width:28px;height:28px;border:none" title='@L["ClassroomPro_Mute"]'
                                                @onclick="() => MuteParticipant(p)"><i class="bi bi-mic-mute"></i></button>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }
            else if (_sideRail == "Holo")
            {
                <div class="cr-pro-holo-panel">
                    <div class="cr-pro-holo-insight">
                        <strong>Holo</strong> — @L["ClassroomPro_HoloInsight"]
                    </div>
                    <div class="cr-pro-holo-actions">
                        <button type="button" @onclick='() => RunAi("explain")'><i class="bi bi-lightbulb"></i>@L["ClassroomPro_AiExplain"]</button>
                        <button type="button" @onclick='() => RunAi("hint")'><i class="bi bi-magic"></i>@L["ClassroomPro_HoloHint"]</button>
                        <button type="button" @onclick='() => RunAi("draw")'><i class="bi bi-brush"></i>@L["ClassroomPro_HoloDraw"]</button>
                        <button type="button" @onclick='() => RunAi("exercises")'><i class="bi bi-journal-plus"></i>@L["ClassroomPro_AiExercises"]</button>
                        <button type="button" @onclick='() => RunAi("quiz")'><i class="bi bi-question-circle"></i>@L["ClassroomPro_AiQuiz"]</button>
                        <button type="button" @onclick='() => RunAi("correct")'><i class="bi bi-check2-circle"></i>@L["ClassroomPro_AiCorrect"]</button>
                        <button type="button" @onclick='() => RunAi("translate")'><i class="bi bi-translate"></i>@L["ClassroomPro_AiTranslate"]</button>
                        <button type="button" @onclick='() => RunAi("summary")'><i class="bi bi-stars"></i>@L["ClassroomPro_AiSummary"]</button>
                        <button type="button" @onclick='() => RunAi("voice")'><i class="bi bi-soundwave"></i>@L["ClassroomPro_AiVoice"]</button>
                        <button type="button" @onclick='() => RunAi("adapt")'><i class="bi bi-sliders"></i>@L["ClassroomPro_HoloAdapt"]</button>
                    </div>
                </div>
            }
            else if (_sideRail == "Docs")
            {
                <div class="cr-pro-plist" style="padding:0.75rem">
                    <label class="cr-pro-invite" style="display:inline-flex;cursor:pointer;margin-bottom:0.75rem">
                        <i class="bi bi-upload me-1"></i>@L["ClassroomPro_Upload"]
                        <InputFile OnChange="OnDocSelected" style="display:none" />
                    </label>
                    @foreach (var doc in _documents)
                    {
                        <div class="cr-pro-prow">
                            <i class="bi bi-file-earmark" style="color:var(--crp-violet)"></i>
                            <div>
                                <div class="cr-pro-prow-name">@doc.Name</div>
                                <div class="cr-pro-prow-role">@doc.Size</div>
                            </div>
                            @if (doc.IsImage)
                            {
                                <button type="button" class="cr-pro-invite" @onclick="() => OpenDocumentOnBoardAsync(doc)" title='@L["Classroom_AnnotateHint"]'>
                                    <i class="bi bi-share me-1"></i>@L["Classroom_ShareDocAction"]
                                </button>
                            }
                        </div>
                    }
                    @if (_documents.Count == 0)
                    {
                        <p class="text-muted small mb-0">@L["ClassroomPro_NoDocuments"]</p>
                    }
                </div>
            }
            else if (_sideRail is "Quiz" or "Notes")
            {
                <div class="cr-pro-side-empty">
                    @(_sideRail == "Quiz" ? L["ClassroomPro_QuizSoon"] : L["ClassroomPro_NotesSoon"])
                </div>
            }
            else
            {
                <div class="cr-pro-side-card" style="border:none;box-shadow:none;display:flex;flex-direction:column;min-height:0;flex:1">
                    <div class="cr-pro-chat">
                        @foreach (var m in _chatMessages)
                        {
                            <div class="cr-pro-msg @(m.IsMe ? "is-me" : null)">
                                <div class="cr-pro-msg-av" style="background:@(m.IsMe ? "#1e3a5f" : GetSenderColor(m.Sender))">@GetSenderInitials(m.Sender)</div>
                                <div>
                                    <div class="cr-pro-bubble">
                                        <div class="cr-pro-msg-meta">
                                            <strong>@m.Sender</strong>
                                            <span>@m.Time</span>
                                        </div>
                                        <div class="cr-pro-msg-text">@m.Text</div>
                                    </div>
                                    <div class="cr-pro-msg-actions">
                                        <button type="button" style="border:none;background:transparent;color:inherit;font-size:0.7rem" @onclick='() => PushToast(L["ClassroomPro_ReactSoon"])'>👍</button>
                                        <button type="button" style="border:none;background:transparent;color:inherit;font-size:0.7rem" @onclick="() => ReplyTo(m)">@L["ClassroomPro_Reply"]</button>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                    <div class="cr-pro-chat-input">
                        <button type="button" class="cr-pro-icon-btn" style="border:none" @onclick='() => PushToast(L["ClassroomPro_AttachSoon"])'><i class="bi bi-paperclip"></i></button>
                        <button type="button" class="cr-pro-icon-btn" style="border:none" @onclick='() => PushToast(L["ClassroomPro_EmojiSoon"])'><i class="bi bi-emoji-smile"></i></button>
                        <input @bind="_newMessage" @onkeydown="OnChatKeyDown" placeholder='@L["Classroom_TypeMessage"]' />
                        <button type="button" class="cr-pro-send" @onclick="SendMessageAsync"><i class="bi bi-send-fill"></i></button>
                    </div>
                </div>
            }
        </aside>
    </div>

    <div class="cr-pro-toasts">
        @foreach (var t in _toasts)
        {
            <div class="cr-pro-toast">@t</div>
        }
    </div>

    <button type="button" class="cr-pro-ai-fab" @onclick='() => OpenSide("Holo")'>
        <i class="bi bi-stars"></i> Holo
    </button>
    @if (_showAiDrawer)
    {
        <div class="cr-pro-ai-drawer">
            <header>
                <h4><i class="bi bi-stars me-1"></i> Holo</h4>
                <button type="button" class="cr-pro-icon-btn" style="background:rgba(255,255,255,.15);color:#fff;border:none" @onclick="() => _showAiDrawer = false"><i class="bi bi-x-lg"></i></button>
            </header>
            <div class="cr-pro-holo-panel">
                <div class="cr-pro-holo-insight">@L["ClassroomPro_HoloInsight"]</div>
                <div class="cr-pro-holo-actions">
                    <button type="button" @onclick='() => RunAi("explain")'><i class="bi bi-lightbulb"></i>@L["ClassroomPro_AiExplain"]</button>
                    <button type="button" @onclick='() => RunAi("hint")'><i class="bi bi-magic"></i>@L["ClassroomPro_HoloHint"]</button>
                    <button type="button" @onclick='() => RunAi("draw")'><i class="bi bi-brush"></i>@L["ClassroomPro_HoloDraw"]</button>
                    <button type="button" @onclick='() => RunAi("exercises")'><i class="bi bi-journal-plus"></i>@L["ClassroomPro_AiExercises"]</button>
                    <button type="button" @onclick='() => RunAi("quiz")'><i class="bi bi-question-circle"></i>@L["ClassroomPro_AiQuiz"]</button>
                    <button type="button" @onclick='() => RunAi("correct")'><i class="bi bi-check2-circle"></i>@L["ClassroomPro_AiCorrect"]</button>
                    <button type="button" @onclick='() => RunAi("translate")'><i class="bi bi-translate"></i>@L["ClassroomPro_AiTranslate"]</button>
                    <button type="button" @onclick='() => RunAi("summary")'><i class="bi bi-stars"></i>@L["ClassroomPro_AiSummary"]</button>
                </div>
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public string LessonId { get; set; } = "";

    [SupplyParameterFromQuery] public string? Student   { get; set; }
    [SupplyParameterFromQuery] public string? Initials  { get; set; }
    [SupplyParameterFromQuery] public string? Title     { get; set; }
    [SupplyParameterFromQuery] public string? Subject   { get; set; }

    private int _elapsedSeconds;
    private System.Threading.Timer? _timer;

    private bool _micOn      = true;
    private bool _camOn      = true;
    private bool _privacyPaused;
    private bool _micBeforePrivacy = true;
    private bool _camBeforePrivacy = true;
    private bool _cameraAvailable = true;
    private int _cameraCount;
    private bool _sharing    = false;
    private bool _sharingWhiteboard = false;
    private string? _watchingBoardShareFrom;
    private string? _watchingBoardShareName;
    private string _watchingBoardShareKind = "whiteboard";
    private bool _boardSharePublishedToClass;
    private bool _watchingBoardShareIsOwn =>
        !string.IsNullOrEmpty(_watchingBoardShareFrom)
        && _watchingBoardShareFrom == ClassroomRt.ConnectionId;
    private readonly List<ClassroomShareRequestDto> _pendingShareRequests = [];
    private bool _recording  = false;
    private bool _mediaReady = false;
    private bool _mediaStarted;
    private bool _docsLoading;
    private string? _mediaError;
    private DotNetObjectReference<Classroom>? _jsRef;
    private bool _showBgMenu;
    private string _bgMode = "none";
    private string? _bgPreset;
    private bool _wbForeground;
    private bool _wbCollapsed = true;
    private bool _panelOpen;
    /// <summary>Replié au démarrage pour maximiser vidéo / tableau ; rouvert via le dock.</summary>
    private bool _panelCollapsed = true;
    private bool _handRaised;
    private bool _showAiDrawer;
    private bool _showViewMenu;
    private bool _showMoreMenu;
    private bool _viewFullscreen;
    private bool _needRtcRemount;
    private string _viewMode = "gallery";
    private string _participantFilter = "";
    private readonly List<string> _toasts = [];
    private System.Threading.Timer? _toastTimer;

    private ElementReference _localVideo;
    private bool _showLocalVideo => _sharing || (_camOn && _mediaReady);
    private ParticipantVM? _focusedPeer;
    private bool _showRemoteMain =>
        _focusedPeer is { CamOn: true, ConnectionId: not null and not "" };

    private async Task FocusPeer(ParticipantVM peer)
    {
        if (!peer.IsOnline || string.IsNullOrEmpty(peer.ConnectionId))
            return;

        peer.IsSpeaking = true;
        foreach (var other in _participants.Where(x => x != peer))
            other.IsSpeaking = false;

        if (_focusedPeer?.ConnectionId == peer.ConnectionId && _showRemoteMain)
        {
            _focusedPeer = null;
            peer.IsSpeaking = false;
            try { await JS.InvokeVoidAsync("classroomRtc.clearMain"); } catch { }
            try { await JS.InvokeVoidAsync("classroomRtc.remountAll"); } catch { }
            return;
        }

        _focusedPeer = peer;
        if (peer.CamOn)
        {
            try { await JS.InvokeVoidAsync("classroomRtc.focusRemote", peer.ConnectionId); } catch { }
        }
    }

    private IEnumerable<ParticipantVM> StudentParticipants =>
        _participants.Where(x => x.Role != "Tuteur");

    private bool ShowAllPanelistTiles =>
        !_wbCollapsed || _viewMode is "gallery" or "mosaic";

    /// <summary>
    /// Galerie / tableau en avant : tous les panélistes. Autres vues : présents d'abord.
    /// </summary>
    private IEnumerable<ParticipantVM> VisibleStudentTiles
    {
        get
        {
            var take = ShowAllPanelistTiles ? 50 : 5;
            var source = ShowAllPanelistTiles
                ? StudentParticipants
                : StudentParticipants.Where(x => x.IsOnline);
            return source
                .OrderByDescending(x => x.IsOnline)
                .ThenBy(x => x.Name, StringComparer.OrdinalIgnoreCase)
                .Take(take);
        }
    }

    private int HiddenStudentCount =>
        Math.Max(0, (ShowAllPanelistTiles
            ? StudentParticipants.Count()
            : StudentParticipants.Count(x => x.IsOnline)) - (ShowAllPanelistTiles ? 50 : 5));

    private IEnumerable<ParticipantVM> FilteredParticipants =>
        _participants.Where(p =>
            string.IsNullOrWhiteSpace(_participantFilter)
            || p.Name.Contains(_participantFilter, StringComparison.OrdinalIgnoreCase));

    private string ViewModeClass => _viewMode switch
    {
        "gallery" => "is-gallery",
        "presenter" => "is-presenter",
        "mosaic" => "is-mosaic",
        "vertical" => "is-vertical",
        _ => ""
    };

    private string ViewModeLabel => _viewMode switch
    {
        "gallery" => L["ClassroomPro_ViewGallery"],
        "presenter" => L["ClassroomPro_ViewPresenter"],
        "mosaic" => L["ClassroomPro_ViewMosaic"],
        "vertical" => L["ClassroomPro_ViewVertical"],
        _ => L["ClassroomPro_ViewSpeaker"]
    };

    private void SetViewMode(string mode)
    {
        _viewMode = mode;
        _showViewMenu = false;
        if (mode != "fullscreen")
            _viewFullscreen = false;
        if (mode is "gallery" or "mosaic")
        {
            try { _ = JS.InvokeVoidAsync("classroomRtc.clearMain"); } catch { }
            _focusedPeer = null;
        }
        _needRtcRemount = true;
    }

    private void ToggleFullscreenView()
    {
        _viewFullscreen = !_viewFullscreen;
        _showViewMenu = false;
    }

    private void ToggleWbCollapsed()
    {
        _wbCollapsed = !_wbCollapsed;
        // Ouvrir tableau/document = panélistes à gauche + board en grand (local).
        _wbForeground = !_wbCollapsed;
        _needRtcRemount = true;
    }

    private void ToggleHand()
    {
        _handRaised = !_handRaised;
        var me = _participants.FirstOrDefault(p => p.Role == "Tuteur");
        if (me is not null) me.HandRaised = _handRaised;
        PushToast(_handRaised ? L["ClassroomPro_HandRaised"] : L["ClassroomPro_HandLowered"]);
    }

    private void OpenSide(string tab)
    {
        _panelOpen = true;
        _panelCollapsed = false;
        _showAiDrawer = false;
        switch (tab)
        {
            case "Participants":
            case "People":
                _sideRail = "People";
                break;
            case "Documents":
                _sideRail = "Docs";
                _activeTab = "Documents";
                break;
            case "Holo":
                _sideRail = "Holo";
                break;
            default:
                _sideRail = "Chat";
                _activeTab = "Chat";
                break;
        }
    }

    private int SessionProgressPercent =>
        Math.Clamp(_elapsedSeconds * 100 / Math.Max(1, 55 * 60), 4, 99);

    private void ExpandBoardFromPeek()
    {
        _wbCollapsed = false;
        _wbForeground = true;
        _needRtcRemount = true;
    }

    private void OnBoardPeekClick()
    {
        if (_wbCollapsed)
            ExpandBoardFromPeek();
    }

    private void MuteParticipant(ParticipantVM p)
    {
        p.MicOn = false;
        PushToast(string.Format(L["ClassroomPro_MutedFmt"].Value, p.Name));
    }

    private void ReplyTo(ChatMsg m)
    {
        _newMessage = $"@{m.Sender} ";
        OpenSide("Chat");
    }

    private void RunAi(string action)
    {
        _showAiDrawer = false;
        _sideRail = "Holo";
        _panelOpen = true;
        _panelCollapsed = false;
        PushToast(string.Format(L["ClassroomPro_AiStartedFmt"].Value, action));
    }

    private void PushToast(string message)
    {
        _toasts.Insert(0, message);
        if (_toasts.Count > 4)
            _toasts.RemoveAt(_toasts.Count - 1);
        _toastTimer?.Dispose();
        _toastTimer = new System.Threading.Timer(_ =>
        {
            _ = InvokeAsync(() =>
            {
                if (_toasts.Count > 0)
                    _toasts.RemoveAt(_toasts.Count - 1);
                StateHasChanged();
            });
        }, null, 3500, Timeout.Infinite);
    }

    private string _activeTab  = "Chat";
    private string _sideRail = "People";
    private string _newMessage = "";

    private ClassroomLesson _lesson = new();

    // Whiteboard state
    private ElementReference _canvasRef;
    private bool   _wbReady = false;
    private string _wbTool  = "pen";
    private string _wbColor = "#000000";
    private string _wbSize  = "medium";
    private int    _wbPage  = 3;
    private int    _wbTotalPages = 12;
    private int    _wbZoom  = 100;

    private readonly string[] _wbColors =
        ["#ef4444", "#b91c1c", "#22c55e", "#3b82f6", "#000000", "#f97316", "#a855f7", "#eab308"];

    private string TutorDisplayName =>
        string.IsNullOrWhiteSpace(Auth.UserName) ? "Tuteur" : Auth.UserName!;

    private string TutorInitials
    {
        get
        {
            var parts = TutorDisplayName.Split([' ', '@'], StringSplitOptions.RemoveEmptyEntries);
            if (parts.Length >= 2)
                return $"{char.ToUpperInvariant(parts[0][0])}{char.ToUpperInvariant(parts[1][0])}";
            return TutorDisplayName.Length > 0 ? char.ToUpperInvariant(TutorDisplayName[0]).ToString() : "T";
        }
    }

    protected override async Task OnInitializedAsync()
    {
        var colors = new[] { "#7c3aed", "#0ea5e9", "#10b981", "#ec4899", "#f59e0b", "#f97316" };

        _lesson = new ClassroomLesson
        {
            Title           = string.IsNullOrWhiteSpace(Title) ? "Séance" : Title!,
            StudentName     = string.IsNullOrWhiteSpace(Student) ? "" : Student!,
            StudentInitials = string.IsNullOrWhiteSpace(Initials) ? "" : Initials!,
            Subject         = string.IsNullOrWhiteSpace(Subject) ? "" : Subject!,
            AvatarColor     = "#7c3aed",
        };

        _participants =
        [
            new() { Name = TutorDisplayName, Initials = TutorInitials, Color = "#5831E0", Role = "Tuteur",
                    MicOn = _micOn, CamOn = _camOn },
        ];

        if (Guid.TryParse(LessonId, out var lessonGuid))
        {
            try
            {
                var dto = await Api.GetAsync<LessonDto>($"api/lessons/{lessonGuid}");
                if (dto is not null)
                {
                    if (string.IsNullOrWhiteSpace(Title)) _lesson.Title = dto.Title;
                    if (string.IsNullOrWhiteSpace(Subject)) _lesson.Subject = dto.Subject ?? "";
                }
            }
            catch { /* keep query defaults */ }

            try
            {
                var attendances = await LessonSvc.GetAttendancesAsync(lessonGuid);
                var i = 0;
                foreach (var a in attendances)
                {
                    var name = string.IsNullOrWhiteSpace(a.StudentName) ? "Élève" : a.StudentName.Trim();
                    _participants.Add(new ParticipantVM
                    {
                        Name = name,
                        Initials = InitialsFrom(name),
                        Color = colors[i % colors.Length],
                        Role = "Élève",
                        MicOn = true,
                        CamOn = false
                    });
                    i++;
                }

                if (_participants.Count > 1)
                {
                    var studentNames = _participants.Where(p => p.Role == "Élève").Select(p => p.Name).ToList();
                    if (studentNames.Count > 0)
                    {
                        _lesson.StudentName = string.Join(", ", studentNames);
                        _lesson.StudentInitials = InitialsFrom(studentNames[0]);
                    }
                }
                else if (_participants.Count == 1 && !string.IsNullOrWhiteSpace(_lesson.StudentName))
                {
                    _participants.Add(new ParticipantVM
                    {
                        Name = _lesson.StudentName,
                        Initials = string.IsNullOrWhiteSpace(_lesson.StudentInitials)
                            ? InitialsFrom(_lesson.StudentName)
                            : _lesson.StudentInitials,
                        Color = _lesson.AvatarColor,
                        Role = "Élève",
                        MicOn = true,
                        CamOn = false
                    });
                }
            }
            catch { /* roster fallback below */ }

            try { await LessonSvc.NotifyLessonStartedAsync(lessonGuid); }
            catch { /* best-effort */ }

            await LoadDocumentsAsync(lessonGuid);
        }

        if (_participants.Count == 1)
        {
            var fallback = string.IsNullOrWhiteSpace(_lesson.StudentName) ? "Élève" : _lesson.StudentName;
            _participants.Add(new ParticipantVM
            {
                Name = fallback,
                Initials = InitialsFrom(fallback),
                Color = "#7c3aed",
                Role = "Élève",
                MicOn = true,
                CamOn = false
            });
        }

        InitChatMessages();

        _timer = new System.Threading.Timer(_ =>
        {
            _elapsedSeconds++;
            InvokeAsync(StateHasChanged);
        }, null, 1000, 1000);
    }

    private async Task LoadDocumentsAsync(Guid lessonId)
    {
        _docsLoading = true;
        try
        {
            var docs = await Api.GetAsync<List<ApiDocDto>>($"api/documents?lessonId={lessonId}") ?? [];
            _documents = docs.Select(d => new DocumentVM
            {
                Id = d.Id,
                Name = d.FileName,
                Size = FormatSize(d.FileSize),
                Url = d.Url,
                ContentType = d.ContentType
            }).ToList();
        }
        catch { _documents = []; }
        finally { _docsLoading = false; }
    }

    private static string InitialsFrom(string name)
    {
        var parts = name.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length >= 2)
            return $"{char.ToUpperInvariant(parts[0][0])}{char.ToUpperInvariant(parts[^1][0])}";
        return name.Length > 0 ? name[..Math.Min(2, name.Length)].ToUpperInvariant() : "?";
    }

    private static string FormatSize(long bytes) =>
        bytes < 1024 ? $"{bytes} o"
        : bytes < 1024 * 1024 ? $"{bytes / 1024.0:0.#} Ko"
        : $"{bytes / (1024.0 * 1024):0.#} Mo";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!_wbReady)
        {
            try
            {
                await JS.InvokeVoidAsync("whiteboard.init", _canvasRef);
                _wbReady = true;
            }
            catch { /* prerender */ }
        }

        if (firstRender && !_mediaStarted)
        {
            _mediaStarted = true;
            _jsRef = DotNetObjectReference.Create(this);
            try { await JS.InvokeVoidAsync("classroomMedia.setEndedCallback", _jsRef); } catch { }
            try { await JS.InvokeVoidAsync("whiteboard.setStrokeDotNetRef", _jsRef); } catch { }
            // Hub / chat d'abord — ne pas bloquer la salle sur getUserMedia.
            await ConnectCollaborativeBoardAsync();
            _needRtcRemount = true;
            _ = BootstrapLocalMediaAsync();
        }

        if (_needRtcRemount)
        {
            _needRtcRemount = false;
            try { await JS.InvokeVoidAsync("classroomRtc.remountAll"); } catch { }
            try { await JS.InvokeVoidAsync("classroomRtc.unlockAudio"); } catch { }
        }
    }

    private async Task BootstrapLocalMediaAsync()
    {
        try
        {
            await StartLocalMediaAsync();
            await RefreshRtcTracksAsync();
            await BroadcastOwnMediaStateAsync();
            _needRtcRemount = true;
            await InvokeAsync(StateHasChanged);
        }
        catch { /* permission deny / no device — chat reste live */ }
    }

    public void Dispose()
    {
        _timer?.Dispose();
        _toastTimer?.Dispose();
        ClassroomRt.StrokeReceived -= OnRemoteStroke;
        ClassroomRt.BoardCleared -= OnRemoteBoardCleared;
        ClassroomRt.BackgroundChanged -= OnRemoteBackground;
        ClassroomRt.PeerListReceived -= OnPeerList;
        ClassroomRt.PeerJoined -= OnPeerJoined;
        ClassroomRt.PeerLeft -= OnPeerLeft;
        ClassroomRt.PeerMediaStateChanged -= OnPeerMediaState;
        ClassroomRt.MediaSyncRequested -= OnMediaSyncRequested;
        ClassroomRt.RtcSignalReceived -= OnRtcSignal;
        ClassroomRt.ChatMessageReceived -= OnChatMessage;
        ClassroomRt.ChatHistoryReceived -= OnChatHistory;
        ClassroomRt.ShareRequestReceived -= OnShareRequest;
        ClassroomRt.ShareLiveStartedReceived -= OnShareLiveStarted;
        ClassroomRt.ShareLiveEndedReceived -= OnShareLiveEnded;
        _ = ClassroomRt.LeaveAsync();
        try { _ = JS.InvokeVoidAsync("classroomRtc.stop"); } catch { }
        _jsRef?.Dispose();
        _ = StopLocalMediaAsync();
    }

    private Guid? _lessonGuid;

    private async Task ConnectCollaborativeBoardAsync()
    {
        if (!Guid.TryParse(LessonId, out var lid)) return;
        _lessonGuid = lid;
        ClassroomRt.StrokeReceived += OnRemoteStroke;
        ClassroomRt.BoardCleared += OnRemoteBoardCleared;
        ClassroomRt.BackgroundChanged += OnRemoteBackground;
        ClassroomRt.PeerListReceived += OnPeerList;
        ClassroomRt.PeerJoined += OnPeerJoined;
        ClassroomRt.PeerLeft += OnPeerLeft;
        ClassroomRt.PeerMediaStateChanged += OnPeerMediaState;
        ClassroomRt.MediaSyncRequested += OnMediaSyncRequested;
        ClassroomRt.RtcSignalReceived += OnRtcSignal;
        ClassroomRt.ChatMessageReceived += OnChatMessage;
        ClassroomRt.ChatHistoryReceived += OnChatHistory;
        ClassroomRt.ShareRequestReceived += OnShareRequest;
        ClassroomRt.ShareLiveStartedReceived += OnShareLiveStarted;
        ClassroomRt.ShareLiveEndedReceived += OnShareLiveEnded;

        // Connect hub first so ConnectionId is known before PeerList arrives.
        await ClassroomRt.EnsureHubReadyAsync();

        if (_jsRef is not null)
        {
            try
            {
                await JS.InvokeVoidAsync("classroomRtc.init", _jsRef, new
                {
                    selfConnectionId = ClassroomRt.ConnectionId
                });
            }
            catch { }
        }

        if (!string.IsNullOrEmpty(ClassroomRt.ConnectionId))
        {
            try { await JS.InvokeVoidAsync("classroomRtc.setSelfId", ClassroomRt.ConnectionId); }
            catch { }
        }

        await ClassroomRt.JoinLessonAsync(lid, TutorDisplayName, "Tuteur", micOn: false, camOn: false);
        await BroadcastOwnMediaStateAsync();
    }

    private void OnPeerList(Guid lessonId, IReadOnlyList<ClassroomPeerDto> peers) =>
        _ = InvokeAsync(() =>
        {
            if (_lessonGuid != lessonId) return;
            var selfId = ClassroomRt.ConnectionId ?? "";
            foreach (var peer in peers)
            {
                UpsertLivePeer(peer);
                var shouldOffer = !string.IsNullOrEmpty(selfId)
                    && string.CompareOrdinal(selfId, peer.ConnectionId) < 0;
                // Ne pas await : libérer le circuit pour le chat pendant la négociation WebRTC.
                _ = JS.InvokeVoidAsync("classroomRtc.connect", peer.ConnectionId, shouldOffer);
            }
            _needRtcRemount = true;
            StateHasChanged();
        });

    private void OnPeerJoined(Guid lessonId, ClassroomPeerDto peer) =>
        _ = InvokeAsync(() =>
        {
            if (_lessonGuid != lessonId) return;
            UpsertLivePeer(peer);
            PushToast(string.Format(L["ClassroomPro_JoinedFmt"].Value, peer.DisplayName));
            var selfId = ClassroomRt.ConnectionId ?? "";
            var shouldOffer = !string.IsNullOrEmpty(selfId)
                && string.CompareOrdinal(selfId, peer.ConnectionId) < 0;
            _ = JS.InvokeVoidAsync("classroomRtc.connect", peer.ConnectionId, shouldOffer);
            _needRtcRemount = true;
            StateHasChanged();
        });

    private void OnPeerLeft(Guid lessonId, string connectionId) =>
        _ = InvokeAsync(async () =>
        {
            if (_lessonGuid != lessonId) return;
            try { await JS.InvokeVoidAsync("classroomRtc.closePeer", connectionId); } catch { }
            var p = _participants.FirstOrDefault(x => x.ConnectionId == connectionId);
            if (p is not null)
            {
                var name = p.Name;
                p.ConnectionId = null;
                p.IsOnline = false;
                p.HasRemoteVideo = false;
                p.CamOn = false;
                p.MicOn = false;
                PushToast(string.Format(L["ClassroomPro_LeftFmt"].Value, name));
            }
            if (_focusedPeer?.ConnectionId == connectionId)
            {
                _focusedPeer = null;
                try { await JS.InvokeVoidAsync("classroomRtc.clearMain"); } catch { }
            }
            StateHasChanged();
        });

    private void OnPeerMediaState(Guid lessonId, string connectionId, bool micOn, bool camOn) =>
        _ = InvokeAsync(async () =>
        {
            if (_lessonGuid != lessonId) return;
            var p = _participants.FirstOrDefault(x => x.ConnectionId == connectionId);
            if (p is null) return;
            p.MicOn = micOn;
            p.CamOn = camOn;
            // Masquage immédiat ; affichage vidéo seulement si flux déjà reçu.
            if (!camOn)
                p.HasRemoteVideo = false;
            else
            {
                // Partage écran / caméra réactivés : réévaluer le flux (replaceTrack ne refire pas ontrack).
                try { await JS.InvokeVoidAsync("classroomRtc.probeRemoteMedia", connectionId); } catch { }
                try { await JS.InvokeVoidAsync("classroomRtc.remount", connectionId); } catch { }
            }
            try { await JS.InvokeVoidAsync("classroomRtc.setRemoteMediaVisible", connectionId, camOn); }
            catch { }
            if (camOn && _viewMode is "speaker" or "presenter"
                && (_focusedPeer is null || _focusedPeer.ConnectionId == connectionId))
            {
                _focusedPeer = p;
                try { await JS.InvokeVoidAsync("classroomRtc.focusRemote", connectionId); } catch { }
            }
            if (!camOn && _focusedPeer?.ConnectionId == connectionId)
            {
                _focusedPeer = null;
                try { await JS.InvokeVoidAsync("classroomRtc.clearMain"); } catch { }
            }
            StateHasChanged();
        });

    private void OnMediaSyncRequested(Guid lessonId) =>
        _ = InvokeAsync(async () =>
        {
            if (_lessonGuid != lessonId) return;
            await BroadcastOwnMediaStateAsync();
        });

    private void OnRtcSignal(Guid lessonId, string fromConnectionId, string type, string payload)
    {
        if (_lessonGuid != lessonId) return;
        // Fire-and-forget : ne pas monopoliser le circuit Blazor pendant SDP/ICE.
        _ = InvokeAsync(() =>
        {
            _ = JS.InvokeVoidAsync("classroomRtc.handleSignal", fromConnectionId, type, payload);
        });
    }

    private void UpsertLivePeer(ClassroomPeerDto peer)
    {
        var match = _participants.FirstOrDefault(p =>
            !string.IsNullOrEmpty(p.ConnectionId) && p.ConnectionId == peer.ConnectionId)
            ?? _participants.FirstOrDefault(p =>
                p.Role != "Tuteur"
                && string.IsNullOrEmpty(p.ConnectionId)
                && string.Equals(p.Name, peer.DisplayName, StringComparison.OrdinalIgnoreCase))
            ?? _participants.FirstOrDefault(p =>
                p.Role != "Tuteur" && string.IsNullOrEmpty(p.ConnectionId) && !p.IsOnline);

        if (match is null)
        {
            match = new ParticipantVM
            {
                Name = peer.DisplayName,
                Initials = InitialsFrom(peer.DisplayName),
                Color = "#7c3aed",
                Role = string.IsNullOrWhiteSpace(peer.Role) || peer.Role == "Participant" ? "Élève" : peer.Role,
            };
            _participants.Add(match);
        }

        match.ConnectionId = peer.ConnectionId;
        match.IsOnline = true;
        match.MicOn = peer.MicOn;
        match.CamOn = peer.CamOn;
        // Ne pas forcer HasRemoteVideo=true : attendre ontrack (évite tuile noire).
        if (!peer.CamOn)
            match.HasRemoteVideo = false;
        if (string.IsNullOrWhiteSpace(match.Name))
            match.Name = peer.DisplayName;
    }

