    [JSInvokable]
    public Task OnRtcRemoteMedia(string connectionId, bool hasVideo, bool hasAudio) =>
        InvokeAsync(async () =>
        {
            var p = _participants.FirstOrDefault(x => x.ConnectionId == connectionId);
            if (p is null) return;
            p.IsOnline = true;
            // Flux reçu = vrai affichage vidéo (indépendamment de l'intention CamOn SignalR).
            p.HasRemoteVideo = hasVideo;
            if (hasVideo) p.CamOn = true;
            if (hasAudio) p.MicOn = true;
            if (hasAudio) p.IsSpeaking = true;

            // En vue galerie : tous voient/entendent via la vignette. En grand : monter aussi sur la scène.
            if (hasVideo && _watchingBoardShareFrom == connectionId)
            {
                try { await JS.InvokeVoidAsync("classroomRtc.focusBoardShare", connectionId); } catch { }
            }
            else if (hasVideo && _viewMode is "speaker" or "presenter"
                && (_focusedPeer is null || _focusedPeer.ConnectionId == connectionId))
            {
                _focusedPeer = p;
                try { await JS.InvokeVoidAsync("classroomRtc.focusRemote", connectionId); } catch { }
            }
            StateHasChanged();
            _needRtcRemount = true;
            try { await JS.InvokeVoidAsync("classroomRtc.setRemoteMediaVisible", connectionId, p.CamOn && hasVideo); } catch { }
            try { await JS.InvokeVoidAsync("classroomRtc.unlockAudio"); } catch { }
        });

    [JSInvokable]
    public Task OnRtcConnectionState(string connectionId, string state) =>
        InvokeAsync(() =>
        {
            var p = _participants.FirstOrDefault(x => x.ConnectionId == connectionId);
            if (p is null) return Task.CompletedTask;
            // disconnected = souvent transitoire (réseau) — ne pas tuer la tuile (effet « vidéo figée »).
            if (state == "closed")
            {
                p.HasRemoteVideo = false;
                p.IsOnline = false;
                StateHasChanged();
            }
            else if (state == "failed")
            {
                p.HasRemoteVideo = false;
                StateHasChanged();
            }
            else if (state == "connected")
            {
                p.IsOnline = true;
                StateHasChanged();
            }
            return Task.CompletedTask;
        });

    private async Task BroadcastOwnMediaStateAsync()
    {
        if (_lessonGuid is null) return;
        if (_privacyPaused)
        {
            await ClassroomRt.BroadcastMediaStateAsync(_lessonGuid.Value, false, false);
            return;
        }
        await ClassroomRt.BroadcastMediaStateAsync(_lessonGuid.Value, _micOn, _camOn || _sharing);
    }

    /// <summary>
    /// Ordinateur verrouillé / onglet masqué : micro + caméra coupés côté JS ;
    /// on synchronise les pairs puis on restaure à la reprise.
    /// </summary>
    [JSInvokable]
    public Task OnMediaPrivacyPause(bool paused) =>
        InvokeAsync(async () =>
        {
            if (paused)
            {
                if (_privacyPaused) return;
                _privacyPaused = true;
                _micBeforePrivacy = _micOn;
                _camBeforePrivacy = _camOn;
                await BroadcastOwnMediaStateAsync();
                StateHasChanged();
                return;
            }

            if (!_privacyPaused) return;
            _privacyPaused = false;
            _micOn = _micBeforePrivacy;
            _camOn = _camBeforePrivacy;
            try { await JS.InvokeVoidAsync("classroomMedia.setAudioEnabled", _micOn); } catch { }
            try { await JS.InvokeVoidAsync("classroomMedia.setVideoEnabled", _camOn); } catch { }
            await RefreshRtcTracksAsync();
            SyncTutorMediaFlags();
            await BroadcastOwnMediaStateAsync();
            try { await JS.InvokeVoidAsync("classroomRtc.unlockAudio"); } catch { }
            _needRtcRemount = true;
            StateHasChanged();
        });

