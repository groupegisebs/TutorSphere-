    [JSInvokable]
    public async Task OnMediaDevicesChanged(MediaDevicesInfo info)
    {
        _cameraCount = info.Cameras;
        var wasAvailable = _cameraAvailable;
        _cameraAvailable = info.Cameras > 0;

        if (!_cameraAvailable)
        {
            _camOn = false;
            if (string.IsNullOrEmpty(_mediaError))
                _mediaError = L["Classroom_NoCamera"].Value;
        }
        else if (!wasAvailable && !_camOn)
        {
            _mediaError = L["Classroom_CameraDetected"].Value;
        }

        SyncTutorMediaFlags();
        await InvokeAsync(StateHasChanged);
    }

    private static string FormatElapsed(int s)
    {
        var h = s / 3600;
        var m = (s % 3600) / 60;
        var sec = s % 60;
        return h > 0 ? $"{h}:{m:D2}:{sec:D2}" : $"{m:D2}:{sec:D2}";
    }

