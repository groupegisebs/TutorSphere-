@page "/tutor/classroom/{lessonId}"
@layout TutorLayout
@rendermode InteractiveServer
@implements IDisposable
@inject NavigationManager Navigation

<PageTitle>Salle de classe – TutorSphere</PageTitle>

<div class="classroom-layout">
    <!-- Top bar -->
    <div class="classroom-topbar">
        <button class="classroom-tool-btn" title="Retour" @onclick="GoBack">
            <i class="bi bi-arrow-left"></i>
        </button>
        <div style="flex:1">
            <div style="font-weight:600;font-size:1rem;">@_lesson.Title</div>
            <div style="font-size:0.75rem;color:rgba(255,255,255,0.5);">@_lesson.StudentName · @_lesson.Subject</div>
        </div>
        <span class="classroom-elapsed">
            <i class="bi bi-circle-fill text-danger me-1" style="font-size:0.5rem;animation:pulse 1s infinite;"></i>
            @FormatElapsed(_elapsedSeconds)
        </span>
        <button class="btn btn-sm" style="background:#ef4444;color:white;border:none;padding:0.4rem 1rem;border-radius:8px;"
                @onclick="EndSession">
            <i class="bi bi-stop-fill me-1"></i>Terminer la séance
        </button>
    </div>

    <!-- Main area -->
    <div class="classroom-main">
        <!-- Video area (75%) -->
        <div class="classroom-video-area">
            <div class="classroom-video-placeholder">
                <div style="width:96px;height:96px;border-radius:50%;background:rgba(255,255,255,0.08);display:flex;align-items:center;justify-content:center;font-size:2.5rem;">
                    <i class="bi bi-camera-video"></i>
                </div>
                <div style="font-size:1.25rem;font-weight:600;color:rgba(255,255,255,0.6);">@_lesson.StudentName</div>
                <div style="font-size:0.875rem;color:rgba(255,255,255,0.3);">En attente de connexion vidéo…</div>
            </div>
            <!-- Local camera preview -->
            <div class="classroom-local-cam">
                <div style="text-align:center;color:rgba(255,255,255,0.4);">
                    <i class="bi bi-person-fill" style="font-size:1.5rem;"></i>
                    <div style="font-size:0.625rem;margin-top:4px;">Vous</div>
                </div>
            </div>
        </div>

        <!-- Right panel (25%) -->
        <div class="classroom-panel">
            <!-- Tab headers -->
            <div style="display:flex;border-bottom:1px solid rgba(255,255,255,0.1);">
                @foreach (var tab in _tabs)
                {
                    <button class="classroom-tab-btn @(_activeTab == tab ? "active" : "")"
                            @onclick="() => _activeTab = tab">
                        @tab
                    </button>
                }
            </div>

            <!-- Tab content -->
            <div style="flex:1;overflow:hidden;display:flex;flex-direction:column;">
                @if (_activeTab == "Chat")
                {
                    <!-- Chat messages -->
                    <div class="classroom-chat-messages">
                        @foreach (var msg in _chatMessages)
                        {
                            <div class="classroom-chat-msg @(msg.IsMe ? "me" : "them")">
                                @if (!msg.IsMe)
                                {
                                    <div style="font-size:0.7rem;color:rgba(255,255,255,0.4);margin-bottom:2px;">@msg.Sender</div>
                                }
                                <div class="classroom-bubble">@msg.Text</div>
                                <div style="font-size:0.65rem;color:rgba(255,255,255,0.3);margin-top:2px;text-align:@(msg.IsMe?"right":"left")">@msg.Time</div>
                            </div>
                        }
                    </div>
                    <!-- Chat input -->
                    <div style="padding:0.75rem;border-top:1px solid rgba(255,255,255,0.1);display:flex;gap:0.5rem;">
                        <input class="classroom-chat-input" placeholder="Message…"
                               @bind="_newMessage" @bind:event="oninput"
                               @onkeydown="OnChatKeyDown" />
                        <button class="classroom-tool-btn" @onclick="SendMessage" title="Envoyer">
                            <i class="bi bi-send-fill"></i>
                        </button>
                    </div>
                }
                else if (_activeTab == "Participants")
                {
                    <div style="padding:1rem;overflow-y:auto;flex:1;">
                        @foreach (var p in _participants)
                        {
                            <div style="display:flex;align-items:center;gap:0.75rem;padding:0.5rem 0;border-bottom:1px solid rgba(255,255,255,0.06);">
                                <div style="width:36px;height:36px;border-radius:50%;background:@p.Color;display:flex;align-items:center;justify-content:center;font-size:0.875rem;font-weight:600;">
                                    @p.Initials
                                </div>
                                <div style="flex:1;">
                                    <div style="font-size:0.875rem;font-weight:500;">@p.Name</div>
                                    <div style="font-size:0.75rem;color:rgba(255,255,255,0.4);">@p.Role</div>
                                </div>
                                <span title="Micro" style="color:@(p.MicOn ? "rgba(255,255,255,0.6)" : "#ef4444");font-size:0.875rem;">
                                    <i class="bi @(p.MicOn ? "bi-mic-fill" : "bi-mic-mute-fill")"></i>
                                </span>
                                <span title="Caméra" style="color:@(p.CamOn ? "rgba(255,255,255,0.6)" : "#ef4444");font-size:0.875rem;">
                                    <i class="bi @(p.CamOn ? "bi-camera-video-fill" : "bi-camera-video-off-fill")"></i>
                                </span>
                            </div>
                        }
                    </div>
                }
                else if (_activeTab == "Documents")
                {
                    <div style="padding:1rem;overflow-y:auto;flex:1;display:flex;flex-direction:column;gap:0.5rem;">
                        <button class="btn btn-sm" style="background:rgba(255,255,255,0.1);color:white;border:none;border-radius:8px;width:100%;padding:0.5rem;">
                            <i class="bi bi-upload me-1"></i>Partager un fichier
                        </button>
                        @foreach (var doc in _documents)
                        {
                            <div style="display:flex;align-items:center;gap:0.75rem;padding:0.5rem;background:rgba(255,255,255,0.05);border-radius:8px;">
                                <i class="bi bi-file-earmark-text" style="color:rgba(255,255,255,0.5);font-size:1.25rem;"></i>
                                <div style="flex:1;overflow:hidden;">
                                    <div style="font-size:0.8rem;font-weight:500;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">@doc.Name</div>
                                    <div style="font-size:0.7rem;color:rgba(255,255,255,0.4);">@doc.Size</div>
                                </div>
                                <button class="classroom-tool-btn" style="width:30px;height:30px;font-size:0.8rem;" title="Télécharger">
                                    <i class="bi bi-download"></i>
                                </button>
                            </div>
                        }
                    </div>
                }
                else if (_activeTab == "Tableau blanc")
                {
                    <div style="flex:1;display:flex;align-items:center;justify-content:center;flex-direction:column;gap:1rem;color:rgba(255,255,255,0.3);">
                        <i class="bi bi-easel" style="font-size:3rem;"></i>
                        <div style="font-size:0.875rem;">Tableau blanc interactif</div>
                        <div style="font-size:0.75rem;text-align:center;max-width:180px;">Disponible prochainement dans la version complète</div>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Bottom toolbar -->
    <div class="classroom-toolbar">
        <div style="display:flex;gap:0.5rem;align-items:center;">
            <button class="classroom-tool-btn @(_micOn ? "active" : "muted")"
                    title="@(_micOn ? "Couper le micro" : "Activer le micro")"
                    @onclick="ToggleMic">
                <i class="bi @(_micOn ? "bi-mic-fill" : "bi-mic-mute-fill")"></i>
            </button>
            <span style="font-size:0.65rem;color:rgba(255,255,255,0.4);text-align:center;display:block;margin-top:-0.25rem;">Micro</span>
        </div>
        <div style="display:flex;flex-direction:column;align-items:center;gap:2px;">
            <button class="classroom-tool-btn @(_camOn ? "active" : "muted")"
                    title="@(_camOn ? "Couper la caméra" : "Activer la caméra")"
                    @onclick="ToggleCam">
                <i class="bi @(_camOn ? "bi-camera-video-fill" : "bi-camera-video-off-fill")"></i>
            </button>
            <span style="font-size:0.65rem;color:rgba(255,255,255,0.4);">Caméra</span>
        </div>
        <div style="display:flex;flex-direction:column;align-items:center;gap:2px;">
            <button class="classroom-tool-btn @(_sharing ? "active" : "")"
                    title="Partage d'écran" @onclick="ToggleShare">
                <i class="bi bi-display"></i>
            </button>
            <span style="font-size:0.65rem;color:rgba(255,255,255,0.4);">Partage écran</span>
        </div>
        <div style="display:flex;flex-direction:column;align-items:center;gap:2px;">
            <button class="classroom-tool-btn" title="Tableau blanc" @onclick='() => _activeTab = "Tableau blanc"'>
                <i class="bi bi-easel"></i>
            </button>
            <span style="font-size:0.65rem;color:rgba(255,255,255,0.4);">Tableau blanc</span>
        </div>
        <div style="display:flex;flex-direction:column;align-items:center;gap:2px;">
            <button class="classroom-tool-btn" title="Sondage">
                <i class="bi bi-bar-chart-fill"></i>
            </button>
            <span style="font-size:0.65rem;color:rgba(255,255,255,0.4);">Sondage</span>
        </div>
        <div style="display:flex;flex-direction:column;align-items:center;gap:2px;">
            <button class="classroom-tool-btn @(_recording ? "danger" : "")"
                    title="@(_recording ? "Arrêter l'enregistrement" : "Démarrer l'enregistrement")"
                    @onclick="ToggleRecording">
                <i class="bi @(_recording ? "bi-stop-circle-fill" : "bi-record-circle")"></i>
            </button>
            <span style="font-size:0.65rem;color:rgba(255,255,255,0.4);">Enregistrement</span>
        </div>
        <div style="width:1px;height:36px;background:rgba(255,255,255,0.1);margin:0 0.5rem;"></div>
        <div style="display:flex;flex-direction:column;align-items:center;gap:2px;">
            <button class="classroom-tool-btn danger" title="Quitter" @onclick="GoBack">
                <i class="bi bi-box-arrow-right"></i>
            </button>
            <span style="font-size:0.65rem;color:rgba(255,255,255,0.4);">Quitter</span>
        </div>
    </div>
</div>

@code {
    [Parameter] public string LessonId { get; set; } = "";

    [SupplyParameterFromQuery] public string? Student { get; set; }
    [SupplyParameterFromQuery] public string? Initials { get; set; }
    [SupplyParameterFromQuery] public string? Title { get; set; }
    [SupplyParameterFromQuery] public string? Subject { get; set; }

    private int _elapsedSeconds = 0;
    private System.Threading.Timer? _timer;

    private bool _micOn = true;
    private bool _camOn = true;
    private bool _sharing = false;
    private bool _recording = false;

    private string _activeTab = "Chat";
    private readonly string[] _tabs = ["Chat", "Participants", "Documents", "Tableau blanc"];
    private string _newMessage = "";

    private ClassroomLesson _lesson = new();

    protected override void OnInitialized()
    {
        _lesson = new ClassroomLesson
        {
            Title       = string.IsNullOrWhiteSpace(Title)    ? "Séance en cours" : Title,
            StudentName = string.IsNullOrWhiteSpace(Student)  ? "Élève"           : Student,
            StudentInitials = string.IsNullOrWhiteSpace(Initials) ? "EL"          : Initials,
            Subject     = string.IsNullOrWhiteSpace(Subject)  ? "—"               : Subject,
            AvatarColor = "#7c3aed",
        };
        _participants = [
            new() { Name = "Vous (tuteur)", Initials = "MT", Color = "#5831E0", Role = "Tuteur", MicOn = _micOn, CamOn = _camOn },
            new() { Name = _lesson.StudentName, Initials = _lesson.StudentInitials, Color = _lesson.AvatarColor, Role = "Élève", MicOn = true, CamOn = false },
        ];
        _timer = new System.Threading.Timer(_ =>
        {
            _elapsedSeconds++;
            InvokeAsync(StateHasChanged);
        }, null, 1000, 1000);
    }

    public void Dispose()
    {
        _timer?.Dispose();
    }

    private static string FormatElapsed(int seconds)
    {
        var h = seconds / 3600;
        var m = (seconds % 3600) / 60;
        var s = seconds % 60;
        return h > 0
            ? $"{h}:{m:D2}:{s:D2}"
            : $"{m:D2}:{s:D2}";
    }

    private void GoBack() => Navigation.NavigateTo("/tutor/lessons");
    private void EndSession() => Navigation.NavigateTo("/tutor/lessons");

    private void ToggleMic()
    {
        _micOn = !_micOn;
        if (_participants.Count > 0) _participants[0].MicOn = _micOn;
    }

    private void ToggleCam()
    {
        _camOn = !_camOn;
        if (_participants.Count > 0) _participants[0].CamOn = _camOn;
    }

    private void ToggleShare() => _sharing = !_sharing;
    private void ToggleRecording() => _recording = !_recording;

    private void OnChatKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey) SendMessage();
    }

    private void SendMessage()
    {
        var text = _newMessage.Trim();
        if (string.IsNullOrEmpty(text)) return;
        _chatMessages.Add(new ChatMsg { Text = text, IsMe = true, Sender = "Vous", Time = DateTime.Now.ToString("HH:mm") });
        _newMessage = "";
    }

    private List<ParticipantVM> _participants = [];

    private readonly List<ChatMsg> _chatMessages =
    [
        new() { Text = "Bonjour ! Je suis prêt(e).", IsMe = false, Sender = "Élève", Time = DateTime.Now.AddMinutes(-2).ToString("HH:mm") },
        new() { Text = "Parfait, on commence par les exercices du chapitre 3.", IsMe = true, Sender = "Vous", Time = DateTime.Now.AddMinutes(-1).ToString("HH:mm") },
    ];

    private readonly List<DocumentVM> _documents =
    [
        new() { Name = "Exercices_Chapitre3.pdf", Size = "1.2 Mo" },
        new() { Name = "Cours_Fonctions.pdf", Size = "840 Ko" },
    ];

    private class ClassroomLesson
    {
        public string Title { get; set; } = "";
        public string StudentName { get; set; } = "";
        public string StudentInitials { get; set; } = "";
        public string Subject { get; set; } = "";
        public string AvatarColor { get; set; } = "#7c3aed";
    }

    private class ParticipantVM
    {
        public string Name { get; set; } = "";
        public string Initials { get; set; } = "";
        public string Color { get; set; } = "";
        public string Role { get; set; } = "";
        public bool MicOn { get; set; } = true;
        public bool CamOn { get; set; } = true;
    }

    private class ChatMsg
    {
        public string Text { get; set; } = "";
        public bool IsMe { get; set; }
        public string Sender { get; set; } = "";
        public string Time { get; set; } = "";
    }

    private class DocumentVM
    {
        public string Name { get; set; } = "";
        public string Size { get; set; } = "";
    }
}
