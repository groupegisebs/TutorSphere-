    private async Task StartLocalMediaAsync()
    {
        _mediaError = null;
        try
        {
            var result = await JS.InvokeAsync<MediaStartResult>(
                "classroomMedia.start", _localVideo, new { video = true, audio = true });

            if (result is null || !result.Ok)
            {
                _mediaReady = false;
                _camOn = false;
                _micOn = false;
                _cameraAvailable = (result?.Cameras ?? 0) > 0;
                _cameraCount = result?.Cameras ?? 0;
                _mediaError = result?.Error
                    ?? (_cameraAvailable ? "Impossible d'activer la caméra." : L["Classroom_NoCamera"].Value);
                SyncTutorMediaFlags();
                await BroadcastOwnMediaStateAsync();
                StateHasChanged();
                return;
            }

            _mediaReady = true;
            _camOn = result.Video;
            _micOn = result.Audio;
            _cameraCount = result.Cameras;
            _cameraAvailable = result.Cameras > 0 || result.Video;
            if (!string.IsNullOrWhiteSpace(result.Warning))
                _mediaError = result.Warning;
            SyncTutorMediaFlags();
            await RefreshRtcTracksAsync();
            await BroadcastOwnMediaStateAsync();
            try { await JS.InvokeVoidAsync("classroomRtc.unlockAudio"); } catch { }
            _needRtcRemount = true;
            StateHasChanged();
        }
        catch (JSException ex)
        {
            _mediaReady = false;
            _camOn = false;
            _micOn = false;
            _cameraAvailable = false;
            _mediaError = ex.Message;
            SyncTutorMediaFlags();
            await BroadcastOwnMediaStateAsync();
            StateHasChanged();
        }
        catch (InvalidOperationException)
        {
            // Prerender — retry not needed; button will start media.
        }
    }

    private async Task StopLocalMediaAsync()
    {
        try { await JS.InvokeVoidAsync("classroomMedia.stop", _localVideo); }
        catch { }
        _mediaReady = false;
    }

    private void SyncTutorMediaFlags()
    {
        var me = _participants.FirstOrDefault(p => p.Role == "Tuteur");
        if (me is null) return;
        me.MicOn = _micOn;
        me.CamOn = _camOn || _sharing;
    }

    private async Task ToggleMic()
    {
        if (!_mediaReady)
        {
            await StartLocalMediaAsync();
            return;
        }

        // Réactiver : s'assurer qu'une piste micro existe et est publiée à tous.
        if (!_micOn)
        {
            var hasAudio = false;
            try { hasAudio = await JS.InvokeAsync<bool>("classroomMedia.hasAudioTrack"); }
            catch { }

            if (!hasAudio)
            {
                try
                {
                    var result = await JS.InvokeAsync<MediaStartResult>("classroomMedia.enableMicrophone");
                    if (result is null || !result.Ok)
                    {
                        _micOn = false;
                        _mediaError = result?.Error ?? "Aucun microphone détecté.";
                        SyncTutorMediaFlags();
                        await BroadcastOwnMediaStateAsync();
                        return;
                    }
                }
                catch (JSException ex)
                {
                    _micOn = false;
                    _mediaError = ex.Message;
                    SyncTutorMediaFlags();
                    await BroadcastOwnMediaStateAsync();
                    return;
                }
            }

            _micOn = true;
            try { await JS.InvokeVoidAsync("classroomMedia.setAudioEnabled", true); }
            catch { }
            SyncTutorMediaFlags();
            await RefreshRtcTracksAsync();
            await BroadcastOwnMediaStateAsync();
            try { await JS.InvokeVoidAsync("classroomRtc.unlockAudio"); } catch { }
            _needRtcRemount = true;
            return;
        }

        _micOn = false;
        try { await JS.InvokeVoidAsync("classroomMedia.setAudioEnabled", false); }
        catch { }
        SyncTutorMediaFlags();
        await BroadcastOwnMediaStateAsync();
    }

    private async Task ToggleCam()
    {
        if (!_mediaReady)
        {
            await StartLocalMediaAsync();
            return;
        }

        // Activer la caméra alors qu'aucune piste vidéo n'existe encore (ex. branchée après).
        if (!_camOn)
        {
            var hasTrack = false;
            try { hasTrack = await JS.InvokeAsync<bool>("classroomMedia.hasVideoTrack"); }
            catch { }

            if (!hasTrack)
            {
                try
                {
                    var result = await JS.InvokeAsync<MediaStartResult>("classroomMedia.enableCamera", _localVideo);
                    _cameraCount = result?.Cameras ?? _cameraCount;
                    _cameraAvailable = (result?.Cameras ?? 0) > 0 || (result?.Video ?? false);
                    if (result is null || !result.Ok)
                    {
                        _camOn = false;
                        _mediaError = result?.Error ?? L["Classroom_NoCamera"].Value;
                        SyncTutorMediaFlags();
                        return;
                    }
                    _camOn = result.Video;
                    _mediaError = _camOn ? null : L["Classroom_NoCamera"].Value;
                    SyncTutorMediaFlags();
                    await RefreshRtcTracksAsync();
                    await BroadcastOwnMediaStateAsync();
                    _needRtcRemount = true;
                    return;
                }
                catch (JSException ex)
                {
                    _camOn = false;
                    _mediaError = ex.Message;
                    SyncTutorMediaFlags();
                    return;
                }
            }
        }

        if (!_cameraAvailable && !_camOn)
        {
            _mediaError = L["Classroom_NoCamera"].Value;
            return;
        }

        _camOn = !_camOn;
        try
        {
            var ok = await JS.InvokeAsync<bool>("classroomMedia.setVideoEnabled", _camOn);
            if (_camOn && !ok)
            {
                _camOn = false;
                _mediaError = L["Classroom_NoCamera"].Value;
            }
            else if (_camOn)
                _mediaError = null;
        }
        catch { }
        SyncTutorMediaFlags();
        await RefreshRtcTracksAsync();
        await BroadcastOwnMediaStateAsync();
    }

