    private async Task StartLocalMediaAsync()
    {
        _mediaError = null;
        try
        {
            var result = await JS.InvokeAsync<MediaStartResult>(
                "classroomMedia.start", _localVideo, new { video = true, audio = true });

            if (result is null || !result.Ok)
            {
                _mediaReady = false;
                _camOn = false;
                _micOn = false;
                _cameraAvailable = (result?.Cameras ?? 0) > 0;
                _cameraCount = result?.Cameras ?? 0;
                _mediaError = result?.Error
                    ?? (_cameraAvailable ? "Impossible d'activer la caméra." : L["Classroom_NoCamera"].Value);
                SyncTutorMediaFlags();
                await BroadcastOwnMediaStateAsync();
                StateHasChanged();
                return;
            }

            _mediaReady = true;
            _camOn = result.Video;
            _micOn = result.Audio;
            _cameraCount = result.Cameras;
            _cameraAvailable = result.Cameras > 0 || result.Video;
            if (!string.IsNullOrWhiteSpace(result.Warning))
                _mediaError = result.Warning;
            SyncTutorMediaFlags();
            await RefreshRtcTracksAsync();
            await BroadcastOwnMediaStateAsync();
            try { await JS.InvokeVoidAsync("classroomRtc.unlockAudio"); } catch { }
            _needRtcRemount = true;
            StateHasChanged();
        }
        catch (JSException ex)
        {
            _mediaReady = false;
            _camOn = false;
            _micOn = false;
            _cameraAvailable = false;
            _mediaError = ex.Message;
            SyncTutorMediaFlags();
            await BroadcastOwnMediaStateAsync();
            StateHasChanged();
        }
        catch (InvalidOperationException)
        {
            // Prerender — retry not needed; button will start media.
        }
    }

    private async Task StopLocalMediaAsync()
    {
        try { await JS.InvokeVoidAsync("classroomMedia.stop", _localVideo); }
        catch { }
        _mediaReady = false;
    }

    private void SyncTutorMediaFlags()
    {
        var me = _participants.FirstOrDefault(p => p.Role == "Tuteur");
        if (me is null) return;
        me.MicOn = _micOn;
        me.CamOn = _camOn || _sharing;
    }

    private async Task ToggleMic()
    {
        if (!_mediaReady)
        {
            await StartLocalMediaAsync();
            return;
        }

        // Réactiver : s'assurer qu'une piste micro existe et est publiée à tous.
        if (!_micOn)
        {
            var hasAudio = false;
            try { hasAudio = await JS.InvokeAsync<bool>("classroomMedia.hasAudioTrack"); }
            catch { }

            if (!hasAudio)
            {
                try
                {
                    var result = await JS.InvokeAsync<MediaStartResult>("classroomMedia.enableMicrophone");
                    if (result is null || !result.Ok)
                    {
                        _micOn = false;
                        _mediaError = result?.Error ?? "Aucun microphone détecté.";
                        SyncTutorMediaFlags();
                        await BroadcastOwnMediaStateAsync();
                        return;
                    }
                }
                catch (JSException ex)
                {
                    _micOn = false;
                    _mediaError = ex.Message;
                    SyncTutorMediaFlags();
                    await BroadcastOwnMediaStateAsync();
                    return;
                }
            }

            _micOn = true;
            try { await JS.InvokeVoidAsync("classroomMedia.setAudioEnabled", true); }
            catch { }
            SyncTutorMediaFlags();
            await RefreshRtcTracksAsync();
            await BroadcastOwnMediaStateAsync();
            try { await JS.InvokeVoidAsync("classroomRtc.unlockAudio"); } catch { }
            _needRtcRemount = true;
            return;
        }

        _micOn = false;
        try { await JS.InvokeVoidAsync("classroomMedia.setAudioEnabled", false); }
        catch { }
        SyncTutorMediaFlags();
        await BroadcastOwnMediaStateAsync();
    }

    private async Task ToggleCam()
    {
        if (!_mediaReady)
        {
            await StartLocalMediaAsync();
            return;
        }

        // Activer la caméra alors qu'aucune piste vidéo n'existe encore (ex. branchée après).
        if (!_camOn)
        {
            var hasTrack = false;
            try { hasTrack = await JS.InvokeAsync<bool>("classroomMedia.hasVideoTrack"); }
            catch { }

            if (!hasTrack)
            {
                try
                {
                    var result = await JS.InvokeAsync<MediaStartResult>("classroomMedia.enableCamera", _localVideo);
                    _cameraCount = result?.Cameras ?? _cameraCount;
                    _cameraAvailable = (result?.Cameras ?? 0) > 0 || (result?.Video ?? false);
                    if (result is null || !result.Ok)
                    {
                        _camOn = false;
                        _mediaError = result?.Error ?? L["Classroom_NoCamera"].Value;
                        SyncTutorMediaFlags();
                        return;
                    }
                    _camOn = result.Video;
                    _mediaError = _camOn ? null : L["Classroom_NoCamera"].Value;
                    SyncTutorMediaFlags();
                    await RefreshRtcTracksAsync();
                    await BroadcastOwnMediaStateAsync();
                    _needRtcRemount = true;
                    return;
                }
                catch (JSException ex)
                {
                    _camOn = false;
                    _mediaError = ex.Message;
                    SyncTutorMediaFlags();
                    return;
                }
            }
        }

        if (!_cameraAvailable && !_camOn)
        {
            _mediaError = L["Classroom_NoCamera"].Value;
            return;
        }

        _camOn = !_camOn;
        try
        {
            var ok = await JS.InvokeAsync<bool>("classroomMedia.setVideoEnabled", _camOn);
            if (_camOn && !ok)
            {
                _camOn = false;
                _mediaError = L["Classroom_NoCamera"].Value;
            }
            else if (_camOn)
                _mediaError = null;
        }
        catch { }
        SyncTutorMediaFlags();
        await RefreshRtcTracksAsync();
        await BroadcastOwnMediaStateAsync();
    }

    private void ToggleWhiteboardForeground()
    {
        // En avant ↔ galerie : pas de tableau « ouvert en bas » avec panélistes encore en grand.
        if (!_wbCollapsed)
        {
            _wbCollapsed = true;
            _wbForeground = false;
        }
        else
        {
            _wbCollapsed = false;
            _wbForeground = true;
        }
        _showBgMenu = false;
        _needRtcRemount = true;
    }

    private async Task SetBackgroundAsync(string mode, string? preset = null, string? imageUrl = null)
    {
        _showBgMenu = false;
        if (!_mediaReady || !_camOn)
        {
            _mediaError = L["Classroom_BgNeedCamera"].Value;
            return;
        }

        try
        {
            var result = await JS.InvokeAsync<MediaStartResult>(
                "classroomMedia.setBackgroundEffect",
                _localVideo,
                new { mode, preset, imageUrl });

            if (result is null || !result.Ok)
            {
                _mediaError = result?.Error ?? L["Classroom_BgFailed"].Value;
                return;
            }

            _bgMode = mode;
            _bgPreset = mode == "image" ? preset : null;
            _mediaError = null;
        }
        catch (JSException ex)
        {
            _mediaError = ex.Message;
        }
    }

    private async Task OnBackgroundFileAsync(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file is null) return;
        try
        {
            await using var stream = file.OpenReadStream(maxAllowedSize: 4 * 1024 * 1024);
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);
            var b64 = Convert.ToBase64String(ms.ToArray());
            var mime = string.IsNullOrWhiteSpace(file.ContentType) ? "image/jpeg" : file.ContentType;
            await SetBackgroundAsync("image", null, $"data:{mime};base64,{b64}");
            _bgPreset = "custom";
        }
        catch (Exception ex)
        {
            _mediaError = ex.Message;
        }
    }

    private async Task ToggleShare()
    {
        if (_sharing && !_sharingWhiteboard)
        {
            await StopTutorShareAsync();
            return;
        }

        try
        {
            var result = await JS.InvokeAsync<MediaStartResult>("classroomMedia.startScreenShare", _localVideo);
            if (result is null || !result.Ok)
            {
                _mediaError = result?.Error ?? "Partage d'écran impossible.";
                return;
            }
            _sharing = true;
            _sharingWhiteboard = false;
            _mediaError = null;
            await RefreshRtcTracksAsync();
            await BroadcastOwnMediaStateAsync();
            if (_lessonGuid is not null)
                await ClassroomRt.AnnounceTutorShareAsync(_lessonGuid.Value, "screen");
            try { await JS.InvokeVoidAsync("classroomRtc.unlockAudio"); } catch { }
        }
        catch (JSException ex)
        {
            _mediaError = ex.Message;
        }
    }

    private async Task ToggleWhiteboardShare()
    {
        if (_sharingWhiteboard)
        {
            await StopTutorShareAsync();
            return;
        }

        try
        {
            // Agrandir le tableau avant captureStream pour que toute la classe voie un flux utilisable.
            _wbCollapsed = false;
            _wbForeground = true;
            await InvokeAsync(StateHasChanged);
            await Task.Delay(120);

            if (!_wbReady)
                await JS.InvokeVoidAsync("whiteboard.init", _canvasRef);

            var result = await JS.InvokeAsync<MediaStartResult>(
                "classroomMedia.startWhiteboardShare", _localVideo, _canvasRef);
            if (result is null || !result.Ok)
            {
                _mediaError = result?.Error ?? "Partage du tableau impossible.";
                return;
            }
            _sharing = true;
            _sharingWhiteboard = true;
            _mediaError = null;
            await RefreshRtcTracksAsync();
            await BroadcastOwnMediaStateAsync();
            if (_lessonGuid is not null)
                await ClassroomRt.AnnounceTutorShareAsync(_lessonGuid.Value, "whiteboard");
            PushToast("Tableau partagé avec la classe.");
            try { await JS.InvokeVoidAsync("classroomRtc.unlockAudio"); } catch { }
        }
        catch (JSException ex)
        {
            _mediaError = ex.Message;
        }
    }

    private async Task StopTutorShareAsync()
    {
        try { await JS.InvokeVoidAsync("classroomMedia.stopScreenShare", _localVideo); } catch { }
        _sharing = false;
        _sharingWhiteboard = false;
        await RefreshRtcTracksAsync();
        await BroadcastOwnMediaStateAsync();
        if (_lessonGuid is not null)
            await ClassroomRt.NotifyShareEndedAsync(_lessonGuid.Value);
    }

    private void OnShareRequest(ClassroomShareRequestDto req) =>
        _ = InvokeAsync(() =>
        {
            if (_lessonGuid is null || req.LessonId != _lessonGuid.Value) return;
            _pendingShareRequests.RemoveAll(r => r.RequesterConnectionId == req.RequesterConnectionId);
            _pendingShareRequests.Add(req);
            PushToast($"{req.RequesterDisplayName} demande à partager.");
            StateHasChanged();
        });

    private async Task RespondShareAsync(ClassroomShareRequestDto req, bool approved)
    {
        if (_lessonGuid is null) return;
        _pendingShareRequests.RemoveAll(r => r.RequesterConnectionId == req.RequesterConnectionId);
        await ClassroomRt.RespondShareAsync(_lessonGuid.Value, req.RequesterConnectionId, approved, req.Kind);
        PushToast(approved
            ? $"Partage de {req.RequesterDisplayName} autorisé."
            : $"Partage de {req.RequesterDisplayName} refusé.");
    }

    private void OnShareLiveStarted(Guid lessonId, string connectionId, string displayName, string kind) =>
        _ = InvokeAsync(async () =>
        {
            if (_lessonGuid != lessonId) return;
            if (connectionId == ClassroomRt.ConnectionId) return;
            _pendingShareRequests.RemoveAll(r => r.RequesterConnectionId == connectionId);
            var p = _participants.FirstOrDefault(x => x.ConnectionId == connectionId);
            if (p is not null)
            {
                p.CamOn = true;
                p.HasRemoteVideo = true;
                _focusedPeer = p;
            }

            if (string.Equals(kind, "whiteboard", StringComparison.OrdinalIgnoreCase))
            {
                var alreadyWatching = _watchingBoardShareFrom == connectionId;
                _watchingBoardShareFrom = connectionId;
                _watchingBoardShareName = displayName;
                _watchingBoardShareKind = "whiteboard";
                // Nouveau board élève → revue privée ; 2e event (PublishShareToClass) → classe.
                _boardSharePublishedToClass = alreadyWatching;
                _wbCollapsed = false;
                _wbForeground = true;
                await InvokeAsync(StateHasChanged);
                await Task.Delay(80);
                try { await JS.InvokeVoidAsync("classroomRtc.focusBoardShare", connectionId); } catch { }
                PushToast(alreadyWatching
                    ? $"Tableau de {displayName} partagé avec la classe."
                    : $"{displayName} partage son tableau (visible par vous).");
            }
            else
            {
                _viewMode = "speaker";
                try { await JS.InvokeVoidAsync("classroomRtc.focusRemote", connectionId); } catch { }
                PushToast($"{displayName} partage maintenant avec la classe.");
            }
            StateHasChanged();
        });

    private async Task PublishWatchedBoardToClassAsync()
    {
        if (_lessonGuid is null || string.IsNullOrEmpty(_watchingBoardShareFrom)) return;
        if (_boardSharePublishedToClass) return;
        await ClassroomRt.PublishShareToClassAsync(
            _lessonGuid.Value,
            _watchingBoardShareFrom,
            _watchingBoardShareKind);
        _boardSharePublishedToClass = true;
        PushToast($"Tableau de {_watchingBoardShareName} partagé avec la classe.");
    }

    private void OnShareLiveEnded(Guid lessonId, string connectionId) =>
        _ = InvokeAsync(async () =>
        {
            if (_lessonGuid != lessonId) return;
            _pendingShareRequests.RemoveAll(r => r.RequesterConnectionId == connectionId);
            if (_watchingBoardShareFrom == connectionId)
            {
                _watchingBoardShareFrom = null;
                _watchingBoardShareName = null;
                _boardSharePublishedToClass = false;
                try { await JS.InvokeVoidAsync("classroomRtc.clearBoardShare"); } catch { }
            }
            if (_focusedPeer?.ConnectionId == connectionId)
            {
                _focusedPeer = null;
                try { await JS.InvokeVoidAsync("classroomRtc.clearMain"); } catch { }
            }
            StateHasChanged();
        });

    private async Task OnDocSelected(InputFileChangeEventArgs e)
    {
        if (!Guid.TryParse(LessonId, out var lessonId)) return;
        var file = e.File;
        if (file is null) return;

        try
        {
            await using var stream = file.OpenReadStream(20 * 1024 * 1024);
            using var content = new MultipartFormDataContent();
            var streamContent = new StreamContent(stream);
            streamContent.Headers.ContentType = new System.Net.Http.Headers.MediaTypeHeaderValue(
                string.IsNullOrWhiteSpace(file.ContentType) ? "application/octet-stream" : file.ContentType);
            content.Add(streamContent, "file", file.Name);
            content.Add(new StringContent(lessonId.ToString()), "lessonId");

            var http = HttpFactory.CreateClient("TutorSphereApi");
            http.DefaultRequestHeaders.Authorization =
                new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", Auth.Token);
            using var resp = await http.PostAsync("api/documents", content);
            if (resp.IsSuccessStatusCode)
                await LoadDocumentsAsync(lessonId);
            else
                _mediaError = "Échec de l'envoi du document.";
        }
        catch (Exception ex)
        {
            _mediaError = ex.Message;
        }
    }

    private void ToggleRecording() => _recording = !_recording;

    private void OnChatKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey)
            _ = SendMessageAsync();
    }

    private async Task SendMessageAsync()
    {
        var text = _newMessage.Trim();
        if (string.IsNullOrEmpty(text) || _lessonGuid is null) return;
        _newMessage = "";

        var sentAt = DateTime.UtcNow;
        var selfId = ClassroomRt.ConnectionId ?? "";
        _chatMessages.Add(new ChatMsg
        {
            Text = text,
            IsMe = true,
            Sender = TutorDisplayName,
            Time = sentAt.ToLocalTime().ToString("HH:mm"),
            ConnectionId = selfId,
            SentAtUtc = sentAt
        });

        await ClassroomRt.SendChatMessageAsync(_lessonGuid.Value, text);
    }

    private void OnChatMessage(ClassroomChatMessageDto msg) =>
        _ = InvokeAsync(() =>
        {
            if (_lessonGuid is null || msg.LessonId != _lessonGuid.Value) return;
            AppendChatMessage(msg);
            StateHasChanged();
        });

    private void OnChatHistory(Guid lessonId, IReadOnlyList<ClassroomChatMessageDto> messages) =>
        _ = InvokeAsync(() =>
        {
            if (_lessonGuid != lessonId) return;
            _chatMessages.Clear();
            foreach (var msg in messages)
                AppendChatMessage(msg);
            StateHasChanged();
        });

    private void AppendChatMessage(ClassroomChatMessageDto msg)
    {
        var selfId = ClassroomRt.ConnectionId ?? "";
        // Déduplique l'UI optimiste (même texte, même connexion, fenêtre courte).
        if (!string.IsNullOrEmpty(selfId) && msg.SenderConnectionId == selfId)
        {
            var pending = _chatMessages.LastOrDefault(m =>
                m.IsMe
                && m.Text == msg.Text
                && Math.Abs((m.SentAtUtc - msg.SentAtUtc).TotalSeconds) < 8);
            if (pending is not null)
            {
                pending.ConnectionId = msg.SenderConnectionId;
                pending.SentAtUtc = msg.SentAtUtc;
                pending.Time = msg.SentAtUtc.ToLocalTime().ToString("HH:mm");
                return;
            }
        }

        _chatMessages.Add(new ChatMsg
        {
            Text = msg.Text,
            IsMe = !string.IsNullOrEmpty(selfId) && msg.SenderConnectionId == selfId,
            Sender = msg.SenderDisplayName,
            Time = msg.SentAtUtc.ToLocalTime().ToString("HH:mm"),
            ConnectionId = msg.SenderConnectionId,
            SentAtUtc = msg.SentAtUtc
        });
    }

