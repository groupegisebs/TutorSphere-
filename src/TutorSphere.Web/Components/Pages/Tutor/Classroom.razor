    private async Task SetBackgroundAsync(string mode, string? preset = null, string? imageUrl = null)
    {
        _showBgMenu = false;
        if (!_mediaReady || !_camOn)
        {
            _mediaError = L["Classroom_BgNeedCamera"].Value;
            return;
        }

        try
        {
            var result = await JS.InvokeAsync<MediaStartResult>(
                "classroomMedia.setBackgroundEffect",
                _localVideo,
                new { mode, preset, imageUrl });

            if (result is null || !result.Ok)
            {
                _mediaError = result?.Error ?? L["Classroom_BgFailed"].Value;
                return;
            }

            _bgMode = mode;
            _bgPreset = mode == "image" ? preset : null;
            _mediaError = null;
        }
        catch (JSException ex)
        {
            _mediaError = ex.Message;
        }
    }

    private async Task OnBackgroundFileAsync(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file is null) return;
        try
        {
            await using var stream = file.OpenReadStream(maxAllowedSize: 4 * 1024 * 1024);
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);
            var b64 = Convert.ToBase64String(ms.ToArray());
            var mime = string.IsNullOrWhiteSpace(file.ContentType) ? "image/jpeg" : file.ContentType;
            await SetBackgroundAsync("image", null, $"data:{mime};base64,{b64}");
            _bgPreset = "custom";
        }
        catch (Exception ex)
        {
            _mediaError = ex.Message;
        }
    }

    private async Task ToggleShare()
    {
        if (_sharing && !_sharingWhiteboard)
        {
            try { await JS.InvokeVoidAsync("classroomMedia.stopScreenShare", _localVideo); } catch { }
            _sharing = false;
            _sharingWhiteboard = false;
            await RefreshRtcTracksAsync();
            await BroadcastOwnMediaStateAsync();
            return;
        }

        try
        {
            var result = await JS.InvokeAsync<MediaStartResult>("classroomMedia.startScreenShare", _localVideo);
            if (result is null || !result.Ok)
            {
                _mediaError = result?.Error ?? "Partage d'écran impossible.";
                return;
            }
            _sharing = true;
            _sharingWhiteboard = false;
            _mediaError = null;
            await RefreshRtcTracksAsync();
            await BroadcastOwnMediaStateAsync();
            try { await JS.InvokeVoidAsync("classroomRtc.unlockAudio"); } catch { }
        }
        catch (JSException ex)
        {
            _mediaError = ex.Message;
        }
    }

    private async Task ToggleWhiteboardShare()
    {
        if (_sharingWhiteboard)
        {
            try { await JS.InvokeVoidAsync("classroomMedia.stopScreenShare", _localVideo); } catch { }
            _sharing = false;
            _sharingWhiteboard = false;
            await RefreshRtcTracksAsync();
            await BroadcastOwnMediaStateAsync();
            return;
        }

        try
        {
            if (!_wbReady)
                await JS.InvokeVoidAsync("whiteboard.init", _canvasRef);

            var result = await JS.InvokeAsync<MediaStartResult>(
                "classroomMedia.startWhiteboardShare", _localVideo, _canvasRef);
            if (result is null || !result.Ok)
            {
                _mediaError = result?.Error ?? "Partage du tableau impossible.";
                return;
            }
            _sharing = true;
            _sharingWhiteboard = true;
            _mediaError = null;
            await RefreshRtcTracksAsync();
            await BroadcastOwnMediaStateAsync();
            try { await JS.InvokeVoidAsync("classroomRtc.unlockAudio"); } catch { }
        }
        catch (JSException ex)
        {
            _mediaError = ex.Message;
        }
    }

    private async Task OnDocSelected(InputFileChangeEventArgs e)
    {
        if (!Guid.TryParse(LessonId, out var lessonId)) return;
        var file = e.File;
        if (file is null) return;

        try
        {
            await using var stream = file.OpenReadStream(20 * 1024 * 1024);
            using var content = new MultipartFormDataContent();
            var streamContent = new StreamContent(stream);
            streamContent.Headers.ContentType = new System.Net.Http.Headers.MediaTypeHeaderValue(
                string.IsNullOrWhiteSpace(file.ContentType) ? "application/octet-stream" : file.ContentType);
            content.Add(streamContent, "file", file.Name);
            content.Add(new StringContent(lessonId.ToString()), "lessonId");

            var http = HttpFactory.CreateClient("TutorSphereApi");
            http.DefaultRequestHeaders.Authorization =
                new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", Auth.Token);
            using var resp = await http.PostAsync("api/documents", content);
            if (resp.IsSuccessStatusCode)
                await LoadDocumentsAsync(lessonId);
            else
                _mediaError = "Échec de l'envoi du document.";
        }
        catch (Exception ex)
        {
            _mediaError = ex.Message;
        }
    }

