    private void ZoomOut()  { if (_wbZoom > 25)  _wbZoom = Math.Max(25,  _wbZoom - 25); }
    private void ZoomIn()   { if (_wbZoom < 200) _wbZoom = Math.Min(200, _wbZoom + 25); }

    private string GetSenderColor(string sender)
    {
        var match = _participants.FirstOrDefault(p =>
            string.Equals(p.Name, sender, StringComparison.OrdinalIgnoreCase));
        if (match is not null)
            return match.Color;
        return string.Equals(sender, TutorDisplayName, StringComparison.OrdinalIgnoreCase)
            ? "#5831E0"
            : "#7c3aed";
    }

    private static string GetSenderInitials(string sender) => InitialsFrom(sender);

    private List<ParticipantVM> _participants = [];

    private List<ChatMsg> _chatMessages = [];

    private void InitChatMessages()
    {
        var students = _participants.Where(p => p.Role == "Élève").ToList();
        if (students.Count == 0)
        {
            _chatMessages = [];
            return;
        }

        // Démo : chaque message d'élève utilise un vrai nom (rotation si plusieurs).
        var first = students[0].Name;
        var second = students.Count > 1 ? students[1].Name : first;
        _chatMessages =
        [
            new() { Text = "Bonjour ! Je suis prêt(e).",
                    IsMe = false, Sender = first,
                    Time = DateTime.Now.AddMinutes(-5).ToString("HH:mm") },
            new() { Text = "Parfait, on commence par les exercices du chapitre 3.",
                    IsMe = true,  Sender = TutorDisplayName,
                    Time = DateTime.Now.AddMinutes(-4).ToString("HH:mm") },
            new() { Text = "D'accord, j'ai mon cahier ouvert.",
                    IsMe = false, Sender = second,
                    Time = DateTime.Now.AddMinutes(-2).ToString("HH:mm") },
        ];
    }

