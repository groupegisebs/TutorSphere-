@page "/tutor/offers"
@layout TutorLayout
@rendermode InteractiveServer
@inject IStringLocalizer<SharedResources> L
@inject ApiClient Api

<PageTitle>@L["Offers_Title"] – TutorSphere</PageTitle>

<div class="ts-page-header">
    <div>
        <h1><i class="bi bi-tags me-2"></i>@L["Offers_Title"]</h1>
        <p class="ts-page-subtitle">@L["Offers_Subtitle"]</p>
    </div>
    <div class="d-flex gap-2">
        <a href="/tutor/offers/create" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-eye me-1"></i>@L["Offers_PublicCatalog"]
        </a>
        <button class="btn btn-primary" @onclick="OpenAdd">
            <i class="bi bi-plus-lg me-1"></i>@L["Offers_New"]
        </button>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-sm-6 col-lg-3">
        <div class="ts-kpi-card"><span class="ts-kpi-val">@_offers.Count</span><span class="ts-kpi-label">@L["Offers_Created"]</span></div>
    </div>
    <div class="col-sm-6 col-lg-3">
        <div class="ts-kpi-card"><span class="ts-kpi-val">@_offers.Count(o=>o.IsPublished)</span><span class="ts-kpi-label">@L["Offers_PublishedCount"]</span></div>
    </div>
    <div class="col-sm-6 col-lg-3">
        <div class="ts-kpi-card"><span class="ts-kpi-val">@_offers.Sum(o=>o.Subscribers)</span><span class="ts-kpi-label">@L["Offers_ActiveSubscribers"]</span></div>
    </div>
    <div class="col-sm-6 col-lg-3">
        <div class="ts-kpi-card"><span class="ts-kpi-val">@_offers.Sum(o=>o.MonthlyRevenue) $</span><span class="ts-kpi-label">@L["Offers_MonthlyRevenue"]</span></div>
    </div>
</div>

<div class="offers-list">
    @foreach (var offer in _offers)
    {
        <div class="offer-card @(offer.IsPublished ? "" : "offer-card--draft")">
            <div class="offer-card-header">
                <div>
                    <h3 class="offer-card-title">@offer.Name</h3>
                    <p class="offer-card-desc">@offer.Description</p>
                </div>
                <span class="ts-badge @(offer.IsPublished ? "ts-badge-success" : "ts-badge-muted")">
                    @(offer.IsPublished ? L["Offers_Published"] : L["Offers_Draft"])
                </span>
            </div>
            <div class="offer-card-meta">
                <div class="offer-meta-item"><i class="bi bi-currency-dollar"></i><strong>@offer.Price @offer.Currency</strong> @string.Format(L["Offers_PerPeriod"].Value, PeriodLabel(offer.Period))</div>
                @if (offer.HourlyRate is > 0)
                {
                    <div class="offer-meta-item"><i class="bi bi-cash-coin"></i>@offer.HourlyRate.Value.ToString("0.##") $/h</div>
                }
                <div class="offer-meta-item"><i class="bi bi-calendar3"></i>@offer.SessionsPerMonth @L["Offers_Sessions"]</div>
                <div class="offer-meta-item"><i class="bi bi-clock"></i>@offer.SessionDuration min</div>
                <div class="offer-meta-item"><i class="bi bi-book"></i>@offer.Subject@(string.IsNullOrWhiteSpace(offer.Level) ? "" : $" · {LevelLabel(offer.Level)}")</div>
                <div class="offer-meta-item"><i class="bi @(offer.Mode=="En ligne"?"bi-camera-video":"bi-geo-alt")"></i>@ModeLabel(offer.Mode)</div>
            </div>
            @{
                var scheduleText = FormatScheduleSummary(offer);
            }
            @if (!string.IsNullOrWhiteSpace(scheduleText))
            {
                <div class="offer-schedule-summary">
                    <i class="bi bi-calendar-week me-1"></i>@scheduleText
                </div>
            }
            <div class="offer-card-footer">
                <div class="offer-card-stats">
                    <span><i class="bi bi-people me-1"></i>@offer.Subscribers @L["Offers_Subscribers"]</span>
                    <span><i class="bi bi-graph-up me-1"></i>@offer.MonthlyRevenue $ @string.Format(L["Offers_PerPeriod"].Value, PeriodLabel("mois"))</span>
                </div>
                <div class="ts-action-group">
                    <button class="ts-icon-btn" title="@L["Common_Edit"]" @onclick="() => OpenEdit(offer)"><i class="bi bi-pencil"></i></button>
                    <button class="ts-icon-btn" title="@(offer.IsPublished ? L["Offers_Unpublish"] : L["Offers_Publish"])"
                            @onclick="async () => await TogglePublish(offer)">
                        <i class="bi @(offer.IsPublished?"bi-eye-slash":"bi-eye")"></i>
                    </button>
                    <button class="ts-icon-btn ts-icon-btn--danger" title="@L["Common_Delete"]"
                            @onclick="async () => await DeleteOffer(offer)">
                        <i class="bi bi-trash"></i>
                    </button>
                </div>
            </div>
        </div>
    }
</div>

@if (_showModal)
{
    <div class="ts-modal-backdrop" @onclick="CloseModal">
        <div class="ts-modal ts-modal-lg" @onclick:stopPropagation="true">
            <div class="ts-modal-header">
                <h2>@(_editing == null ? L["Offers_New"] : L["Offers_EditTitle"])</h2>
                <button class="ts-modal-close" @onclick="CloseModal"><i class="bi bi-x-lg"></i></button>
            </div>
            <div class="ts-modal-body">
                <div class="row g-3">
                    <div class="col-12"><label class="form-label">@L["Offers_NameRequired"]</label>
                        <input class="form-control" @bind="_mf.Name" /></div>
                    <div class="col-12"><label class="form-label">@L["Common_Description"]</label>
                        <textarea class="form-control" rows="2" @bind="_mf.Description"></textarea></div>

                    <div class="col-3"><label class="form-label">@L["Offers_PackagePrice"]</label>
                        <input type="number" class="form-control" @bind="_mf.Price" /></div>
                    <div class="col-3"><label class="form-label">@L["Offers_HourlyRate"]</label>
                        <input type="number" step="0.01" min="0" class="form-control" @bind="_mf.HourlyRate"
                               @bind:after="SuggestPackagePrice" /></div>
                    <div class="col-3"><label class="form-label">@L["Offers_Currency"]</label>
                        <select class="form-select" @bind="_mf.Currency">
                            <option>CAD</option><option>EUR</option><option>USD</option>
                        </select></div>
                    <div class="col-3"><label class="form-label">@L["Offers_BillingPeriod"]</label>
                        <select class="form-select" @bind="_mf.Period" @bind:after="RecalcSessions">
                            <option value="semaine">@L["Offers_Week"]</option>
                            <option value="mois">@L["Offers_Month"]</option>
                            <option value="trimestre">@L["Offers_PeriodQuarter"]</option>
                            <option value="semestre">@L["Offers_PeriodSemester"]</option>
                            <option value="an">@L["Offers_PeriodYear"]</option>
                        </select></div>

                    <div class="col-6"><label class="form-label">@L["Offers_Cadence"]</label>
                        <select class="form-select" @bind="_mf.Cadence" @bind:after="RecalcSessions">
                            <option value="weekly">@L["Lessons_Weekly"]</option>
                            <option value="biweekly">@L["Lessons_Biweekly"]</option>
                        </select></div>
                    <div class="col-3"><label class="form-label">@L["Offers_DurationMin"]</label>
                        <input type="number" class="form-control" min="15" step="15"
                               @bind="_mf.SessionDuration" @bind:after="SuggestPackagePrice" /></div>
                    <div class="col-3"><label class="form-label">@L["Offers_SessionsPerPeriod"]</label>
                        <input type="number" class="form-control" min="1" @bind="_mf.SessionsPerMonth" />
                        <small class="text-muted">@L["Offers_SessionsHint"]</small></div>

                    <div class="col-12">
                        <label class="form-label">@L["Offers_DaysTimes"]</label>
                        <p class="text-muted small mb-2">@L["Offers_DaysHint"]</p>
                        <div class="offer-day-grid">
                            @foreach (var day in _days)
                            {
                                var slot = _mf.DaySlots[day];
                                <div class="offer-day-row @(slot.Enabled ? "is-on" : null)">
                                    <label class="offer-day-check">
                                        <input type="checkbox" checked="@slot.Enabled"
                                               @onchange="e => OnDayToggle(day, e)" />
                                        <span>@DayFullLabel(day)</span>
                                    </label>
                                    <input type="time" class="form-control form-control-sm offer-day-time"
                                           disabled="@(!slot.Enabled)"
                                           value="@slot.Time"
                                           @onchange="e => SetDayTime(day, e.Value?.ToString())" />
                                </div>
                            }
                        </div>
                    </div>

                    <div class="col-4"><label class="form-label">@L["Offers_Mode"]</label>
                        <select class="form-select" @bind="_mf.Mode">
                            <option value="En ligne">@L["Offers_Online"]</option>
                            <option value="Présentiel">@L["Offers_InPerson"]</option>
                            <option value="Hybride">@L["Offers_Hybrid"]</option>
                        </select></div>
                    <div class="col-4"><label class="form-label">@L["Common_Subject"]</label>
                        <input class="form-control" @bind="_mf.Subject" /></div>
                    <div class="col-4"><label class="form-label">@L["Students_Level"]</label>
                        <select class="form-select" @bind="_mf.Level">
                            <option value="Tous niveaux">@L["Offers_AllLevels"]</option>
                            <option value="Primaire">@L["Level_Primary"]</option>
                            <option value="Collège">@L["Level_Middle"]</option>
                            <option value="Lycée">@L["Level_High"]</option>
                            <option value="Université">@L["Level_University"]</option>
                        </select></div>
                    <div class="col-12"><label class="form-label">@L["Offers_CancellationPolicy"]</label>
                        <textarea class="form-control" rows="2" @bind="_mf.CancellationPolicy"></textarea></div>
                </div>
                @if (!string.IsNullOrEmpty(_modalError))
                {
                    <div class="alert alert-danger mt-3">@_modalError</div>
                }
            </div>
            <div class="ts-modal-footer">
                <button class="btn btn-outline-secondary" @onclick="CloseModal">@L["Common_Cancel"]</button>
                <button class="btn btn-primary" @onclick="SaveOffer">
                    @(_editing == null ? L["Offers_CreateOffer"] : L["Common_Save"])
                </button>
            </div>
        </div>
    </div>
}

@code {
    private static readonly string[] _days =
        ["Lundi", "Mardi", "Mercredi", "Jeudi", "Vendredi", "Samedi", "Dimanche"];

    private string DayFullLabel(string day) => day switch {
        "Lundi" => L["Day_Monday"],
        "Mardi" => L["Day_Tuesday"],
        "Mercredi" => L["Day_Wednesday"],
        "Jeudi" => L["Day_Thursday"],
        "Vendredi" => L["Day_Friday"],
        "Samedi" => L["Day_Saturday"],
        "Dimanche" => L["Day_Sunday"],
        _ => day
    };

    private string ModeLabel(string? mode) => mode switch {
        "En ligne" => L["Offers_Online"],
        "Présentiel" => L["Offers_InPerson"],
        _ => mode ?? ""
    };

    private string PeriodLabel(string? period) => NormalizePeriod(period) switch {
        "semaine" => L["Offers_Week"],
        "trimestre" => L["Offers_PeriodQuarter"],
        "semestre" => L["Offers_PeriodSemester"],
        "an" => L["Offers_PeriodYear"],
        _ => L["Offers_Month"]
    };

    private string LevelLabel(string? level) => level switch {
        "Tous niveaux" => L["Offers_AllLevels"],
        "Primaire" => L["Level_Primary"],
        "Collège" => L["Level_Middle"],
        "Lycée" => L["Level_High"],
        "Université" => L["Level_University"],
        _ => level ?? ""
    };

    private string DayAbbrev(string day) => day.Trim().ToLowerInvariant() switch {
        "lundi" or "lun" or "monday" or "mon" => L["Day_Mon_Short"],
        "mardi" or "mar" or "tuesday" or "tue" => L["Day_Tue_Short"],
        "mercredi" or "mer" or "wednesday" or "wed" => L["Day_Wed_Short"],
        "jeudi" or "jeu" or "thursday" or "thu" => L["Day_Thu_Short"],
        "vendredi" or "ven" or "friday" or "fri" => L["Day_Fri_Short"],
        "samedi" or "sam" or "saturday" or "sat" => L["Day_Sat_Short"],
        "dimanche" or "dim" or "sunday" or "sun" => L["Day_Sun_Short"],
        _ => day.Length <= 3 ? day : day[..3]
    };

    private static string FormatTime(string time)
    {
        if (TimeSpan.TryParse(time, out var ts))
            return ts.ToString(@"hh\:mm");
        if (time.Length >= 5 && time.Contains(':'))
            return time[..5];
        return time;
    }

    private string FormatScheduleSummary(OfferVM offer)
    {
        if (offer.Slots.Count > 0)
        {
            var cadence = offer.Cadence is "biweekly" or "fortnightly"
                ? L["Lessons_Biweekly"]
                : L["Lessons_Weekly"];
            var days = string.Join(", ", offer.Slots.Select(s => $"{DayAbbrev(s.Day)} {FormatTime(s.Time)}"));
            return $"{PeriodLabel(offer.Period)} · {cadence} · {days}";
        }

        // Fallback: translate known FR tokens in stored Frequency string
        var raw = offer.ScheduleSummary;
        if (string.IsNullOrWhiteSpace(raw)) return "";
        return raw
            .Replace("Chaque semaine", L["Lessons_Weekly"], StringComparison.OrdinalIgnoreCase)
            .Replace("Toutes les 2 semaines", L["Lessons_Biweekly"], StringComparison.OrdinalIgnoreCase)
            .Replace("mois", PeriodLabel("mois"), StringComparison.OrdinalIgnoreCase)
            .Replace("semaine", PeriodLabel("semaine"), StringComparison.OrdinalIgnoreCase);
    }

    private bool _showModal;
    private OfferVM? _editing;
    private string _modalError = "";
    private OfferForm _mf = new();
    private readonly List<OfferVM> _offers = [];

    protected override async Task OnInitializedAsync()
    {
        var offerings = await Api.GetAsync<List<ApiOfferingDto>>("api/subscription-offerings") ?? [];
        _offers.Clear();
        _offers.AddRange(offerings.Select(MapOffer));
    }

    private void OpenAdd()
    {
        _editing = null;
        _mf = new OfferForm();
        _modalError = "";
        RecalcSessions();
        _showModal = true;
    }

    private void OpenEdit(OfferVM o)
    {
        _editing = o;
        _mf = new OfferForm
        {
            Name = o.Name,
            Description = o.Description,
            Price = o.Price,
            HourlyRate = o.HourlyRate ?? 0,
            Currency = o.Currency,
            Period = NormalizePeriod(o.Period),
            Cadence = o.Cadence,
            SessionsPerMonth = o.SessionsPerMonth,
            SessionDuration = o.SessionDuration,
            Mode = string.IsNullOrWhiteSpace(o.Mode) ? "En ligne" : o.Mode,
            Subject = o.Subject,
            Level = string.IsNullOrWhiteSpace(o.Level) ? "Tous niveaux" : o.Level,
            CancellationPolicy = o.CancellationPolicy
        };

        foreach (var day in _days)
            _mf.DaySlots[day] = new DaySlot();

        foreach (var s in o.Slots)
        {
            if (_mf.DaySlots.ContainsKey(s.Day))
                _mf.DaySlots[s.Day] = new DaySlot { Enabled = true, Time = s.Time };
        }

        _modalError = "";
        _showModal = true;
    }

    private void CloseModal() => _showModal = false;

    private void OnDayToggle(string day, ChangeEventArgs e)
    {
        var enabled = e.Value switch
        {
            bool b => b,
            string s => s is "true" or "on",
            _ => false
        };
        ToggleDay(day, enabled);
    }

    private void ToggleDay(string day, bool enabled)
    {
        _mf.DaySlots[day].Enabled = enabled;
        if (enabled && string.IsNullOrWhiteSpace(_mf.DaySlots[day].Time))
            _mf.DaySlots[day].Time = "16:00";
        RecalcSessions();
    }

    private void SetDayTime(string day, string? time)
    {
        _mf.DaySlots[day].Time = string.IsNullOrWhiteSpace(time) ? "16:00" : time;
    }

    private void RecalcSessions()
    {
        var slotCount = _mf.DaySlots.Values.Count(s => s.Enabled);
        if (slotCount == 0)
            return;

        var weeks = _mf.Period switch
        {
            "semaine" => 1,
            "trimestre" => 12,
            "semestre" => 26,
            "an" => 52,
            _ => 4
        };
        if (_mf.Cadence == "biweekly")
            weeks = Math.Max(1, weeks / 2);

        _mf.SessionsPerMonth = weeks * slotCount;
        SuggestPackagePrice();
    }

    private void SuggestPackagePrice()
    {
        if (_mf.HourlyRate <= 0 || _mf.SessionsPerMonth <= 0 || _mf.SessionDuration <= 0)
            return;

        var hoursPerSession = _mf.SessionDuration / 60m;
        _mf.Price = Math.Round(_mf.HourlyRate * hoursPerSession * _mf.SessionsPerMonth, 2);
    }

    private async Task SaveOffer()
    {
        if (string.IsNullOrWhiteSpace(_mf.Name))
        {
            _modalError = L["Offers_NameRequiredError"];
            return;
        }

        var slots = _mf.DaySlots
            .Where(kv => kv.Value.Enabled)
            .Select(kv => new { day = kv.Key, time = kv.Value.Time })
            .ToList();

        if (slots.Count == 0)
        {
            _modalError = L["Offers_DaysRequiredError"];
            return;
        }

        var durationDays = _mf.Period switch
        {
            "semaine" => 7,
            "trimestre" => 90,
            "semestre" => 180,
            "an" => 365,
            _ => 30
        };

        var schedule = new
        {
            billingPeriod = _mf.Period,
            cadence = _mf.Cadence,
            sessionDurationMin = _mf.SessionDuration,
            hourlyRate = _mf.HourlyRate > 0 ? (decimal?)_mf.HourlyRate : null,
            level = _mf.Level,
            cancellationPolicy = string.IsNullOrWhiteSpace(_mf.CancellationPolicy) ? null : _mf.CancellationPolicy.Trim(),
            slots
        };

        var req = new
        {
            title = _mf.Name.Trim(),
            description = _mf.Description,
            subject = string.IsNullOrWhiteSpace(_mf.Subject) ? null : _mf.Subject.Trim(),
            price = _mf.Price,
            currency = _mf.Currency,
            durationDays,
            sessionCount = Math.Max(1, _mf.SessionsPerMonth),
            frequency = _mf.Period,
            mode = _mf.Mode,
            schedule
        };

        if (_editing is null)
        {
            var created = await Api.PostWithErrorAsync<ApiOfferingDto>("api/subscription-offerings", req);
            if (created.Error is not null || created.Value is null)
            {
                _modalError = created.Error ?? L["Offers_CreateFailed"].Value;
                return;
            }
            _offers.Add(MapOffer(created.Value));
        }
        else if (_editing.Id.HasValue)
        {
            var updated = await Api.PutWithErrorAsync<ApiOfferingDto>($"api/subscription-offerings/{_editing.Id}", req);
            if (updated.Error is not null || updated.Value is null)
            {
                _modalError = updated.Error ?? L["Offers_UpdateFailed"].Value;
                return;
            }
            var mapped = MapOffer(updated.Value);
            var idx = _offers.FindIndex(o => o.Id == mapped.Id);
            if (idx >= 0) _offers[idx] = mapped;
        }

        _showModal = false;
    }

    private async Task TogglePublish(OfferVM offer)
    {
        if (offer.Id is null) return;
        var endpoint = offer.IsPublished
            ? $"api/subscription-offerings/{offer.Id}/deactivate"
            : $"api/subscription-offerings/{offer.Id}/activate";
        var result = await Api.PostAsync<ApiOfferingDto>(endpoint, new { });
        if (result is not null) offer.IsPublished = result.IsActive;
    }

    private async Task DeleteOffer(OfferVM offer)
    {
        if (offer.Id is not null)
            await Api.DeleteAsync($"api/subscription-offerings/{offer.Id}");
        _offers.Remove(offer);
    }

    private static string NormalizePeriod(string? period)
    {
        var p = (period ?? "mois").ToLowerInvariant();
        if (p.Contains("semaine")) return "semaine";
        if (p.Contains("trimestre")) return "trimestre";
        if (p.Contains("semestre")) return "semestre";
        if (p.Contains("an")) return "an";
        if (p.Contains("mois") || p is "month") return "mois";
        return "mois";
    }

    private static OfferVM MapOffer(ApiOfferingDto o)
    {
        var schedule = o.Schedule;
        var slots = schedule?.Slots?.Select(s => (s.Day, s.Time)).ToList() ?? [];
        var period = schedule?.BillingPeriod ?? NormalizePeriod(o.Frequency);
        var cadence = schedule?.Cadence ?? "weekly";

        return new OfferVM
        {
            Id = o.Id,
            Name = o.Title,
            Description = o.Description ?? "",
            Price = o.Price,
            HourlyRate = schedule?.HourlyRate,
            Currency = o.Currency,
            Period = period,
            Cadence = cadence,
            SessionsPerMonth = o.SessionCount,
            SessionDuration = schedule?.SessionDurationMin > 0 ? schedule.SessionDurationMin : 60,
            Mode = string.IsNullOrWhiteSpace(o.Mode) ? "En ligne" : o.Mode,
            Subject = o.Subject ?? "",
            Level = schedule?.Level ?? "",
            CancellationPolicy = schedule?.CancellationPolicy ?? "",
            ScheduleSummary = o.Frequency,
            Slots = slots,
            IsPublished = o.IsActive,
            Subscribers = 0,
            MonthlyRevenue = 0
        };
    }

    private record ApiSlotDto(string Day, string Time);
    private record ApiScheduleDto(
        string BillingPeriod, string Cadence, int SessionDurationMin,
        string? Level, string? CancellationPolicy, List<ApiSlotDto>? Slots,
        decimal? HourlyRate);
    private record ApiOfferingDto(
        Guid Id, string Title, string? Description, string? Subject,
        decimal Price, string Currency, int DurationDays, int SessionCount,
        string? Frequency, bool IsActive, string? Mode, string? Conditions,
        ApiScheduleDto? Schedule);

    private class DaySlot
    {
        public bool Enabled { get; set; }
        public string Time { get; set; } = "16:00";
    }

    private class OfferForm
    {
        public string Name { get; set; } = "";
        public string Description { get; set; } = "";
        public decimal Price { get; set; } = 150;
        public decimal HourlyRate { get; set; }
        public string Currency { get; set; } = "CAD";
        public string Period { get; set; } = "mois";
        public string Cadence { get; set; } = "weekly";
        public int SessionsPerMonth { get; set; } = 4;
        public int SessionDuration { get; set; } = 60;
        public string Mode { get; set; } = "En ligne";
        public string Subject { get; set; } = "";
        public string Level { get; set; } = "Tous niveaux";
        public string CancellationPolicy { get; set; } = "";
        public Dictionary<string, DaySlot> DaySlots { get; set; } =
            _days.ToDictionary(d => d, _ => new DaySlot());
    }

    private class OfferVM
    {
        public Guid? Id { get; set; }
        public string Name { get; set; } = "";
        public string Description { get; set; } = "";
        public decimal Price { get; set; }
        public decimal? HourlyRate { get; set; }
        public string Currency { get; set; } = "CAD";
        public string Period { get; set; } = "mois";
        public string Cadence { get; set; } = "weekly";
        public int SessionsPerMonth { get; set; }
        public int SessionDuration { get; set; }
        public string Mode { get; set; } = "";
        public string Subject { get; set; } = "";
        public string Level { get; set; } = "";
        public string CancellationPolicy { get; set; } = "";
        public string? ScheduleSummary { get; set; }
        public List<(string Day, string Time)>Slots { get; set; } = [];
        public bool IsPublished { get; set; }
        public int Subscribers { get; set; }
        public decimal MonthlyRevenue { get; set; }
    }
}
