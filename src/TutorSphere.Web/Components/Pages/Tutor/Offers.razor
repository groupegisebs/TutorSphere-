@page "/tutor/offers"
@layout TutorLayout
@rendermode InteractiveServer
@inject IStringLocalizer<SharedResources> L
@inject ApiClient Api

<PageTitle>Mes Offres – TutorSphere</PageTitle>

<div class="ts-page-header">
    <div>
        <h1><i class="bi bi-tags me-2"></i>Mes Offres</h1>
        <p class="ts-page-subtitle">Gérez vos formules et tarifs</p>
    </div>
    <div class="d-flex gap-2">
        <a href="/tutor/offers/create" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-eye me-1"></i>Catalogue public
        </a>
        <button class="btn btn-primary" @onclick="OpenAdd">
            <i class="bi bi-plus-lg me-1"></i>Nouvelle offre
        </button>
    </div>
</div>

<!-- Stats row -->
<div class="row g-3 mb-4">
    <div class="col-sm-6 col-lg-3">
        <div class="ts-kpi-card"><span class="ts-kpi-val">@_offers.Count</span><span class="ts-kpi-label">Offres créées</span></div>
    </div>
    <div class="col-sm-6 col-lg-3">
        <div class="ts-kpi-card"><span class="ts-kpi-val">@_offers.Count(o=>o.IsPublished)</span><span class="ts-kpi-label">Publiées</span></div>
    </div>
    <div class="col-sm-6 col-lg-3">
        <div class="ts-kpi-card"><span class="ts-kpi-val">@_offers.Sum(o=>o.Subscribers)</span><span class="ts-kpi-label">Abonnés actifs</span></div>
    </div>
    <div class="col-sm-6 col-lg-3">
        <div class="ts-kpi-card"><span class="ts-kpi-val">@_offers.Sum(o=>o.MonthlyRevenue) $</span><span class="ts-kpi-label">Revenus / mois</span></div>
    </div>
</div>

<!-- Offers list -->
<div class="offers-list">
    @foreach (var offer in _offers)
    {
        <div class="offer-card @(offer.IsPublished ? "" : "offer-card--draft")">
            <div class="offer-card-header">
                <div>
                    <h3 class="offer-card-title">@offer.Name</h3>
                    <p class="offer-card-desc">@offer.Description</p>
                </div>
                <span class="ts-badge @(offer.IsPublished ? "ts-badge-success" : "ts-badge-muted")">
                    @(offer.IsPublished ? "Publié" : "Brouillon")
                </span>
            </div>
            <div class="offer-card-meta">
                <div class="offer-meta-item"><i class="bi bi-currency-dollar"></i><strong>@offer.Price @offer.Currency</strong> / @offer.Period</div>
                <div class="offer-meta-item"><i class="bi bi-calendar3"></i>@offer.SessionsPerMonth séances/mois</div>
                <div class="offer-meta-item"><i class="bi bi-clock"></i>@offer.SessionDuration min</div>
                <div class="offer-meta-item"><i class="bi bi-book"></i>@offer.Subject · @offer.Level</div>
                <div class="offer-meta-item"><i class="bi @(offer.Mode=="En ligne"?"bi-camera-video":"bi-geo-alt")"></i>@offer.Mode</div>
            </div>
            @if (offer.Variants.Any())
            {
                <div class="offer-variants">
                    @foreach (var v in offer.Variants)
                    {
                        <span class="offer-variant-chip">@v.Label — @v.Price $</span>
                    }
                </div>
            }
            <div class="offer-card-footer">
                <div class="offer-card-stats">
                    <span><i class="bi bi-people me-1"></i>@offer.Subscribers abonné(s)</span>
                    <span><i class="bi bi-graph-up me-1"></i>@offer.MonthlyRevenue $ / mois</span>
                </div>
                <div class="ts-action-group">
                    <button class="ts-icon-btn" title="Modifier" @onclick="() => OpenEdit(offer)"><i class="bi bi-pencil"></i></button>
                    <button class="ts-icon-btn" title="@(offer.IsPublished?"Dépublier":"Publier")"
                            @onclick="async () => await TogglePublish(offer)">
                        <i class="bi @(offer.IsPublished?"bi-eye-slash":"bi-eye")"></i>
                    </button>
                    <button class="ts-icon-btn ts-icon-btn--danger" title="Supprimer"
                            @onclick="async () => await DeleteOffer(offer)">
                        <i class="bi bi-trash"></i>
                    </button>
                </div>
            </div>
        </div>
    }
</div>

<!-- Add/Edit Modal -->
@if (_showModal)
{
    <div class="ts-modal-backdrop" @onclick="CloseModal">
        <div class="ts-modal ts-modal-lg" @onclick:stopPropagation="true">
            <div class="ts-modal-header">
                <h2>@(_editing == null ? "Nouvelle offre" : "Modifier l'offre")</h2>
                <button class="ts-modal-close" @onclick="CloseModal"><i class="bi bi-x-lg"></i></button>
            </div>
            <div class="ts-modal-body">
                <div class="row g-3">
                    <div class="col-12"><label class="form-label">Nom de l'offre *</label>
                        <input class="form-control" @bind="_mf.Name" placeholder="Ex: Cours de maths intensif" /></div>
                    <div class="col-12"><label class="form-label">Description</label>
                        <textarea class="form-control" rows="2" @bind="_mf.Description"></textarea></div>
                    <div class="col-4"><label class="form-label">Prix *</label>
                        <input type="number" class="form-control" @bind="_mf.Price" /></div>
                    <div class="col-4"><label class="form-label">Devise</label>
                        <select class="form-select" @bind="_mf.Currency">
                            <option>CAD</option><option>EUR</option><option>USD</option>
                        </select></div>
                    <div class="col-4"><label class="form-label">Période</label>
                        <select class="form-select" @bind="_mf.Period">
                            <option>mois</option><option>trimestre</option><option>semestre</option><option>an</option>
                        </select></div>
                    <div class="col-4"><label class="form-label">Séances / mois</label>
                        <input type="number" class="form-control" @bind="_mf.SessionsPerMonth" /></div>
                    <div class="col-4"><label class="form-label">Durée (min)</label>
                        <input type="number" class="form-control" @bind="_mf.SessionDuration" /></div>
                    <div class="col-4"><label class="form-label">Mode</label>
                        <select class="form-select" @bind="_mf.Mode">
                            <option>En ligne</option><option>Présentiel</option><option>Hybride</option>
                        </select></div>
                    <div class="col-6"><label class="form-label">Matière</label>
                        <input class="form-control" @bind="_mf.Subject" placeholder="Mathématiques" /></div>
                    <div class="col-6"><label class="form-label">Niveau</label>
                        <select class="form-select" @bind="_mf.Level">
                            <option>Tous niveaux</option><option>Primaire</option>
                            <option>Collège</option><option>Lycée</option><option>Université</option>
                        </select></div>
                    <div class="col-12"><label class="form-label">Politique d'annulation</label>
                        <textarea class="form-control" rows="2" @bind="_mf.CancellationPolicy"
                            placeholder="Ex: Annulation gratuite 24h avant la séance"></textarea></div>
                </div>
                @if (!string.IsNullOrEmpty(_modalError))
                {
                    <div class="alert alert-danger mt-3">@_modalError</div>
                }
            </div>
            <div class="ts-modal-footer">
                <button class="btn btn-outline-secondary" @onclick="CloseModal">Annuler</button>
                <button class="btn btn-primary" @onclick="SaveOffer">
                    @(_editing == null ? "Créer l'offre" : "Enregistrer")
                </button>
            </div>
        </div>
    </div>
}

@code {
    private bool _showModal;
    private bool _loading = true;
    private OfferVM? _editing;
    private string _modalError = "";
    private OfferForm _mf = new();
    private readonly List<OfferVM> _offers = [];

    protected override async Task OnInitializedAsync()
    {
        var offerings = await Api.GetAsync<List<ApiOfferingDto>>("api/subscription-offerings") ?? [];
        _offers.Clear();
        _offers.AddRange(offerings.Select(MapOffer));
        _loading = false;
    }

    private void OpenAdd() { _editing = null; _mf = new(); _modalError = ""; _showModal = true; }
    private void OpenEdit(OfferVM o)
    {
        _editing = o;
        _mf = new OfferForm
        {
            Name = o.Name, Description = o.Description, Price = o.Price,
            Currency = o.Currency, Period = o.Period, SessionsPerMonth = o.SessionsPerMonth,
            Subject = o.Subject
        };
        _modalError = "";
        _showModal = true;
    }
    private void CloseModal() => _showModal = false;

    private async Task SaveOffer()
    {
        if (string.IsNullOrWhiteSpace(_mf.Name)) { _modalError = "Le nom est obligatoire."; return; }

        var durationDays = _mf.Period switch
        {
            "trimestre" => 90,
            "semestre" => 180,
            "an" => 365,
            _ => 30
        };

        if (_editing is null)
        {
            var req = new
            {
                title = _mf.Name.Trim(),
                description = _mf.Description,
                subject = string.IsNullOrWhiteSpace(_mf.Subject) ? null : _mf.Subject.Trim(),
                price = _mf.Price,
                currency = _mf.Currency,
                durationDays,
                sessionCount = _mf.SessionsPerMonth,
                frequency = _mf.Period
            };
            var created = await Api.PostWithErrorAsync<ApiOfferingDto>("api/subscription-offerings", req);
            if (created.Error is not null || created.Value is null)
            {
                _modalError = created.Error ?? "Création impossible.";
                return;
            }
            _offers.Add(MapOffer(created.Value));
        }
        else if (_editing.Id.HasValue)
        {
            var req = new
            {
                title = _mf.Name.Trim(),
                description = _mf.Description,
                subject = string.IsNullOrWhiteSpace(_mf.Subject) ? null : _mf.Subject.Trim(),
                price = _mf.Price,
                currency = _mf.Currency,
                durationDays,
                sessionCount = _mf.SessionsPerMonth,
                frequency = _mf.Period
            };
            var updated = await Api.PutWithErrorAsync<ApiOfferingDto>($"api/subscription-offerings/{_editing.Id}", req);
            if (updated.Error is not null || updated.Value is null)
            {
                _modalError = updated.Error ?? "Mise à jour impossible.";
                return;
            }
            var mapped = MapOffer(updated.Value);
            var idx = _offers.FindIndex(o => o.Id == mapped.Id);
            if (idx >= 0) _offers[idx] = mapped;
        }

        _showModal = false;
    }

    private async Task TogglePublish(OfferVM offer)
    {
        if (offer.Id is null) return;
        var endpoint = offer.IsPublished
            ? $"api/subscription-offerings/{offer.Id}/deactivate"
            : $"api/subscription-offerings/{offer.Id}/activate";
        var result = await Api.PostAsync<ApiOfferingDto>(endpoint, new { });
        if (result is not null) offer.IsPublished = result.IsActive;
    }

    private async Task DeleteOffer(OfferVM offer)
    {
        if (offer.Id is not null)
            await Api.DeleteAsync($"api/subscription-offerings/{offer.Id}");
        _offers.Remove(offer);
    }

    private static OfferVM MapOffer(ApiOfferingDto o) => new()
    {
        Id = o.Id,
        Name = o.Title,
        Description = o.Description ?? "",
        Price = o.Price,
        Currency = o.Currency,
        Period = o.Frequency ?? "mois",
        SessionsPerMonth = o.SessionCount,
        SessionDuration = 60,
        Mode = "En ligne",
        Subject = o.Subject ?? "",
        Level = "",
        IsPublished = o.IsActive,
        Subscribers = 0,
        MonthlyRevenue = 0,
        Variants = []
    };

    private record ApiOfferingDto(
        Guid Id, string Title, string? Description, string? Subject,
        decimal Price, string Currency, int DurationDays, int SessionCount,
        string? Frequency, bool IsActive);

    private class OfferForm
    {
        public string Name { get; set; } = "";
        public string Description { get; set; } = "";
        public decimal Price { get; set; } = 150;
        public string Currency { get; set; } = "CAD";
        public string Period { get; set; } = "mois";
        public int SessionsPerMonth { get; set; } = 4;
        public int SessionDuration { get; set; } = 60;
        public string Mode { get; set; } = "En ligne";
        public string Subject { get; set; } = "";
        public string Level { get; set; } = "Tous niveaux";
        public string CancellationPolicy { get; set; } = "";
    }

    private class OfferVM
    {
        public Guid? Id { get; set; }
        public string Name { get; set; } = "";
        public string Description { get; set; } = "";
        public decimal Price { get; set; }
        public string Currency { get; set; } = "CAD";
        public string Period { get; set; } = "mois";
        public int SessionsPerMonth { get; set; }
        public int SessionDuration { get; set; }
        public string Mode { get; set; } = "";
        public string Subject { get; set; } = "";
        public string Level { get; set; } = "";
        public string CancellationPolicy { get; set; } = "";
        public bool IsPublished { get; set; }
        public int Subscribers { get; set; }
        public decimal MonthlyRevenue { get; set; }
        public List<(string Label, decimal Price)> Variants { get; set; } = [];
    }
}
