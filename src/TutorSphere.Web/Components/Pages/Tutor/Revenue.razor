@page "/tutor/revenue"
@layout TutorLayout
@rendermode InteractiveServer
@inject IStringLocalizer<SharedResources> L

<PageTitle>Revenus – TutorSphere</PageTitle>

<div class="ts-page-header">
    <div>
        <h1><i class="bi bi-graph-up me-2"></i>Revenus</h1>
        <p class="ts-page-subtitle">Analyse financière de votre activité</p>
    </div>
    <div class="d-flex gap-2">
        <select class="form-select form-select-sm w-auto" @bind="_period">
            <option value="week">Cette semaine</option>
            <option value="month" selected>Ce mois</option>
            <option value="quarter">Ce trimestre</option>
            <option value="year">Cette année</option>
        </select>
        <button class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-download me-1"></i>Exporter
        </button>
    </div>
</div>

<!-- KPI row -->
<div class="row g-3 mb-4">
    <div class="col-6 col-lg-3">
        <div class="ts-kpi-card ts-kpi-card--success">
            <span class="ts-kpi-val">2 450 $</span>
            <span class="ts-kpi-label">Encaissé @PeriodLabel</span>
            <span class="ts-kpi-trend text-success"><i class="bi bi-arrow-up-short"></i>+12%</span>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="ts-kpi-card">
            <span class="ts-kpi-val">29 400 $</span>
            <span class="ts-kpi-label">Revenus annuels</span>
            <span class="ts-kpi-trend text-success"><i class="bi bi-arrow-up-short"></i>+23%</span>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="ts-kpi-card ts-kpi-card--warning">
            <span class="ts-kpi-val">260 $</span>
            <span class="ts-kpi-label">En attente</span>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="ts-kpi-card">
            <span class="ts-kpi-val">204 $</span>
            <span class="ts-kpi-label">Revenu / élève moyen</span>
        </div>
    </div>
</div>

<div class="row g-4 mb-4">
    <!-- Revenue chart -->
    <div class="col-lg-8">
        <div class="section-card h-100">
            <div class="section-card-header">
                <h2>Évolution des revenus</h2>
                <span class="text-muted small">@PeriodLabel</span>
            </div>
            <div class="chart-area">
                <svg viewBox="0 0 560 160" preserveAspectRatio="none" class="revenue-chart-svg">
                    <defs>
                        <linearGradient id="rev-fill" x1="0" y1="0" x2="0" y2="1">
                            <stop offset="0%" stop-color="var(--ts-primary)" stop-opacity="0.2"/>
                            <stop offset="100%" stop-color="var(--ts-primary)" stop-opacity="0"/>
                        </linearGradient>
                    </defs>
                    <path d="@AreaPath" fill="url(#rev-fill)"/>
                    <path d="@LinePath" fill="none" stroke="var(--ts-primary)" stroke-width="2.5" stroke-linejoin="round"/>
                    @foreach (var (x,y) in _chartPoints)
                    {
                        <circle cx="@x" cy="@y" r="4" fill="white" stroke="var(--ts-primary)" stroke-width="2"/>
                    }
                </svg>
                <div class="chart-x-labels">
                    @foreach (var l in _chartLabels)
                    {
                        <span>@l</span>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Breakdown by subject -->
    <div class="col-lg-4">
        <div class="section-card h-100">
            <div class="section-card-header"><h2>Par matière</h2></div>
            @foreach (var s in _bySubject)
            {
                <div class="revenue-row">
                    <div class="revenue-row-label">
                        <span class="revenue-dot" style="background:@s.Color"></span>
                        @s.Subject
                    </div>
                    <div class="revenue-row-bar">
                        <div class="revenue-bar-fill" style="width:@s.Pct%;background:@s.Color"></div>
                    </div>
                    <span class="revenue-row-val">@s.Amount $</span>
                </div>
            }
        </div>
    </div>
</div>

<div class="row g-4">
    <!-- By student -->
    <div class="col-md-6">
        <div class="section-card">
            <div class="section-card-header"><h2>Par élève</h2></div>
            <table class="table ts-table">
                <thead><tr><th>Élève</th><th>Séances</th><th>Total</th></tr></thead>
                <tbody>
                    @foreach (var s in _byStudent)
                    {
                        <tr>
                            <td>
                                <div class="ts-cell-user">
                                    <div class="ts-avatar ts-avatar-sm" style="background:@s.Color">@s.Initials</div>
                                    @s.Name
                                </div>
                            </td>
                            <td>@s.Sessions</td>
                            <td class="fw-semibold">@s.Total $</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Recent transactions -->
    <div class="col-md-6">
        <div class="section-card">
            <div class="section-card-header"><h2>Dernières transactions</h2></div>
            @foreach (var t in _recentTransactions)
            {
                <div class="transaction-item">
                    <div class="transaction-icon @(t.Amount > 0 ? "transaction-icon--in" : "transaction-icon--out")">
                        <i class="bi @(t.Amount > 0 ? "bi-arrow-down-left" : "bi-arrow-up-right")"></i>
                    </div>
                    <div class="transaction-info">
                        <strong>@t.Description</strong>
                        <span class="text-muted small">@t.Date</span>
                    </div>
                    <span class="@(t.Amount > 0 ? "text-success" : "text-danger") fw-semibold">
                        @(t.Amount > 0 ? "+" : "")@t.Amount $
                    </span>
                </div>
            }
        </div>
    </div>
</div>

@code {
    private string _period = "month";
    private string PeriodLabel => _period switch { "week"=>"cette semaine","month"=>"ce mois","quarter"=>"ce trimestre","year"=>"cette année",_=>"" };

    private static readonly (double X, double Y)[] _chartPoints =
        [(40,120),(100,95),(160,78),(220,85),(280,60),(340,45),(400,52),(460,30),(520,38)];

    private string LinePath => $"M{string.Join(" L", _chartPoints.Select(p=>$"{p.X},{p.Y}"))}";
    private string AreaPath => $"M{string.Join(" L", _chartPoints.Select(p=>$"{p.X},{p.Y}"))} L{_chartPoints.Last().X},160 L{_chartPoints.First().X},160 Z";

    private static readonly string[] _chartLabels = ["1 Juin","5","10","15","20","25","30 Juin"];

    private record SubjectRevenue(string Subject, decimal Amount, string Color)
    {
        public double Pct => Math.Min(100, (double)(Amount / 2450m * 100));
    }
    private static readonly SubjectRevenue[] _bySubject =
    [
        new("Mathématiques", 1400, "#7c3aed"),
        new("Physique-Chimie", 700, "#0ea5e9"),
        new("Français", 350, "#10b981"),
    ];

    private record StudentRevenue(string Name, string Initials, string Color, int Sessions, decimal Total);
    private static readonly StudentRevenue[] _byStudent =
    [
        new("Sophia Davis","SD","#10b981",8,660),
        new("Emma Johnson","EJ","#7c3aed",8,600),
        new("Liam Brown","LB","#0ea5e9",6,420),
        new("Olivia Martinez","OM","#ec4899",4,480),
        new("Noah Wilson","NW","#f59e0b",3,290),
    ];

    private record Transaction(string Description, string Date, decimal Amount);
    private static readonly Transaction[] _recentTransactions =
    [
        new("Abonnement – Emma Johnson","25/06/2026",200),
        new("Abonnement – Sophia Davis","24/06/2026",350),
        new("Paiement manuel – Liam Brown","22/06/2026",120),
        new("Remboursement – Noah Wilson","20/06/2026",-200),
        new("Abonnement – Olivia Martinez","18/06/2026",120),
    ];
}
