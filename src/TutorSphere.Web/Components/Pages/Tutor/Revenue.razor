@page "/tutor/revenue"
@layout TutorLayout
@rendermode InteractiveServer
@inject IStringLocalizer<SharedResources> L
@inject ApiClient Api
@inject AuthService AuthSvc

<PageTitle>@L["Revenue_Title"] – TutorSphere</PageTitle>

<div class="ts-page-header">
    <div>
        <h1><i class="bi bi-graph-up me-2"></i>@L["Revenue_Title"]</h1>
        <p class="ts-page-subtitle">@L["Revenue_Subtitle"]</p>
    </div>
    <div class="d-flex gap-2">
        <select class="form-select form-select-sm w-auto" @bind="_period">
            <option value="week">@L["Common_ThisWeek"]</option>
            <option value="month">@L["Common_ThisMonth"]</option>
            <option value="quarter">@L["Revenue_ThisQuarter"]</option>
            <option value="year">@L["Revenue_ThisYear"]</option>
        </select>
        <button class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-download me-1"></i>@L["Common_Export"]
        </button>
    </div>
</div>

<!-- KPI row -->
<div class="row g-3 mb-4">
    <div class="col-6 col-lg-3">
        <div class="ts-kpi-card ts-kpi-card--success">
            @if (_statsLoading)
            {
                <span class="ts-kpi-val"><span class="spinner-border spinner-border-sm"></span></span>
            }
            else
            {
                <span class="ts-kpi-val">@_monthlyRevenue.ToString("N0") $</span>
            }
            <span class="ts-kpi-label">@L["Payments_CollectedThisMonth"]</span>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="ts-kpi-card">
            <span class="ts-kpi-val">@_activeSubscriptions</span>
            <span class="ts-kpi-label">@L["Revenue_ActiveSubscriptions"]</span>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="ts-kpi-card ts-kpi-card--warning">
            <span class="ts-kpi-val">@_pendingPayments</span>
            <span class="ts-kpi-label">@L["Revenue_PendingPayments"]</span>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="ts-kpi-card">
            <span class="ts-kpi-val">@_activeStudents</span>
            <span class="ts-kpi-label">@L["Revenue_ActiveStudents"]</span>
        </div>
    </div>
</div>

<div class="row g-4 mb-4">
    <!-- Revenue chart -->
    <div class="col-lg-8">
        <div class="section-card h-100">
            <div class="section-card-header">
                <h2>@L["Revenue_Evolution"]</h2>
                <span class="text-muted small">@PeriodLabel</span>
            </div>
            <div class="chart-area">
                <svg viewBox="0 0 560 160" preserveAspectRatio="none" class="revenue-chart-svg">
                    <defs>
                        <linearGradient id="rev-fill" x1="0" y1="0" x2="0" y2="1">
                            <stop offset="0%" stop-color="var(--ts-primary)" stop-opacity="0.2"/>
                            <stop offset="100%" stop-color="var(--ts-primary)" stop-opacity="0"/>
                        </linearGradient>
                    </defs>
                    <path d="@AreaPath" fill="url(#rev-fill)"/>
                    <path d="@LinePath" fill="none" stroke="var(--ts-primary)" stroke-width="2.5" stroke-linejoin="round"/>
                    @foreach (var (x,y) in _chartPoints)
                    {
                        <circle cx="@x" cy="@y" r="4" fill="white" stroke="var(--ts-primary)" stroke-width="2"/>
                    }
                </svg>
                <div class="chart-x-labels">
                    @foreach (var l in ChartLabels)
                    {
                        <span>@l</span>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Breakdown by subject -->
    <div class="col-lg-4">
        <div class="section-card h-100">
            <div class="section-card-header"><h2>@L["Revenue_BySubject"]</h2></div>
            @foreach (var s in _bySubject)
            {
                <div class="revenue-row">
                    <div class="revenue-row-label">
                        <span class="revenue-dot" style="background:@s.Color"></span>
                        @s.Subject
                    </div>
                    <div class="revenue-row-bar">
                        <div class="revenue-bar-fill" style="width:@s.Pct%;background:@s.Color"></div>
                    </div>
                    <span class="revenue-row-val">@s.Amount $</span>
                </div>
            }
        </div>
    </div>
</div>

<div class="row g-4">
    <!-- By student -->
    <div class="col-md-6">
        <div class="section-card">
            <div class="section-card-header"><h2>@L["Revenue_ByStudent"]</h2></div>
            <table class="table ts-table">
                <thead><tr><th>@L["Common_Student"]</th><th>@L["Revenue_Sessions"]</th><th>@L["Revenue_Total"]</th></tr></thead>
                <tbody>
                    @foreach (var s in _byStudent)
                    {
                        <tr>
                            <td>
                                <div class="ts-cell-user">
                                    <div class="ts-avatar ts-avatar-sm" style="background:@s.Color">@s.Initials</div>
                                    @s.Name
                                </div>
                            </td>
                            <td>@s.Sessions</td>
                            <td class="fw-semibold">@s.Total $</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Recent transactions -->
    <div class="col-md-6">
        <div class="section-card">
            <div class="section-card-header"><h2>@L["Revenue_RecentTransactions"]</h2></div>
            @foreach (var t in _recentTransactions)
            {
                <div class="transaction-item">
                    <div class="transaction-icon @(t.Amount > 0 ? "transaction-icon--in" : "transaction-icon--out")">
                        <i class="bi @(t.Amount > 0 ? "bi-arrow-down-left" : "bi-arrow-up-right")"></i>
                    </div>
                    <div class="transaction-info">
                        <strong>@t.Description</strong>
                        <span class="text-muted small">@t.Date</span>
                    </div>
                    <span class="@(t.Amount > 0 ? "text-success" : "text-danger") fw-semibold">
                        @(t.Amount > 0 ? "+" : "")@t.Amount $
                    </span>
                </div>
            }
        </div>
    </div>
</div>

@code {
    private string _period = "month";
    private string PeriodLabel => _period switch
    {
        "week" => L["Revenue_ThisWeek"],
        "month" => L["Revenue_ThisMonthShort"],
        "quarter" => L["Revenue_ThisQuarterShort"],
        "year" => L["Revenue_ThisYearShort"],
        _ => ""
    };

    private bool _statsLoading = true;
    private decimal _monthlyRevenue;
    private int _activeStudents;
    private int _activeSubscriptions;
    private int _upcomingLessons;
    private int _pendingPayments;

    private record DashboardDto(
        decimal MonthlyRevenue, int ActiveStudents,
        int ActiveSubscriptions, int UpcomingLessons, int PendingPayments);

    protected override async Task OnInitializedAsync()
    {
        var tenantId = AuthSvc.TenantId;
        if (tenantId is not null)
        {
            var stats = await Api.GetAsync<DashboardDto>($"api/tenants/{tenantId}/dashboard");
            if (stats is not null)
            {
                _monthlyRevenue      = stats.MonthlyRevenue;
                _activeStudents      = stats.ActiveStudents;
                _activeSubscriptions = stats.ActiveSubscriptions;
                _upcomingLessons     = stats.UpcomingLessons;
                _pendingPayments     = stats.PendingPayments;
            }
        }
        _statsLoading = false;
    }

    private static readonly (double X, double Y)[] _chartPoints =
        [(40,120),(100,95),(160,78),(220,85),(280,60),(340,45),(400,52),(460,30),(520,38)];

    private string LinePath => $"M{string.Join(" L", _chartPoints.Select(p=>$"{p.X},{p.Y}"))}";
    private string AreaPath => $"M{string.Join(" L", _chartPoints.Select(p=>$"{p.X},{p.Y}"))} L{_chartPoints.Last().X},160 L{_chartPoints.First().X},160 Z";

    private string[] ChartLabels
    {
        get
        {
            var culture = System.Globalization.CultureInfo.CurrentUICulture;
            var now = DateTime.Today;
            var lastDay = DateTime.DaysInMonth(now.Year, now.Month);
            var month = culture.DateTimeFormat.GetAbbreviatedMonthName(now.Month);
            return [$"1 {month}", "5", "10", "15", "20", "25", $"{lastDay} {month}"];
        }
    }

    private record SubjectRevenue(string Subject, decimal Amount, string Color)
    {
        public double Pct => Amount <= 0 ? 0 : 100;
    }
    private static readonly SubjectRevenue[] _bySubject = [];

    private record StudentRevenue(string Name, string Initials, string Color, int Sessions, decimal Total);
    private static readonly StudentRevenue[] _byStudent = [];

    private record Transaction(string Description, string Date, decimal Amount);
    private static readonly Transaction[] _recentTransactions = [];
}
