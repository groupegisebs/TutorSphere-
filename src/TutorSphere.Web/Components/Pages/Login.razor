@page "/login"
@layout LoginLayout
@inject IStringLocalizer<SharedResources> L

<PageTitle>@L["PageTitle_Login"]</PageTitle>

<div class="login-page">
    <div class="login-illustration">
        <div class="login-illustration-content">
            <div class="login-illustration-scene" aria-hidden="true">
                <i class="bi bi-laptop login-scene-icon login-scene-icon--laptop"></i>
                <i class="bi bi-lightbulb login-scene-icon login-scene-icon--lamp"></i>
                <i class="bi bi-flower1 login-scene-icon login-scene-icon--plant"></i>
                <i class="bi bi-book login-scene-icon login-scene-icon--book"></i>
            </div>
            <p class="login-illustration-tagline">@L["Login_IllustrationTagline"]</p>
        </div>
    </div>

    <div class="login-form-panel">
        <div class="login-form-inner">
            <div class="login-brand">
                <img src="images/tutorsphere-logo.png" alt="@L["AppName"]" class="login-logo" />
                <span class="login-brand-name">@L["AppName"]</span>
            </div>

            <h1>@L["Login_Title"]</h1>
            <p class="login-subtitle">@L["Login_Subtitle"]</p>

            <form class="login-form" @onsubmit:preventDefault="true">
                <div class="mb-3">
                    <label class="form-label" for="email">@L["Label_EmailAddress"]</label>
                    <input type="email" id="email" class="form-control" placeholder="@L["Placeholder_Email"]" />
                </div>
                <div class="mb-3">
                    <label class="form-label" for="password">@L["Label_Password"]</label>
                    <input type="password" id="password" class="form-control" placeholder="••••••••" />
                </div>
                <div class="login-options mb-4">
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="remember" />
                        <label class="form-check-label" for="remember">@L["Login_RememberMe"]</label>
                    </div>
                    <a href="#" class="login-forgot">@L["Login_ForgotPassword"]</a>
                </div>
                <button type="submit" class="btn btn-primary btn-lg w-100 mb-4">@L["Login_SignIn"]</button>
            </form>

            <div class="login-divider"><span>@L["Login_OrContinueWith"]</span></div>

            <div class="login-social row g-2 mb-4">
                <div class="col-6">
                    <button type="button" class="btn btn-outline-secondary w-100 login-social-btn">
                        <i class="bi bi-google"></i> Google
                    </button>
                </div>
                <div class="col-6">
                    <button type="button" class="btn btn-outline-secondary w-100 login-social-btn">
                        <i class="bi bi-apple"></i> Apple
                    </button>
                </div>
            </div>

            <p class="login-footer text-center">
                @L["Login_NoAccount"] <a href="tutor/register">@L["Login_CreateAccount"]</a>
            </p>

            <div class="login-lang mt-3">
                <LanguageSelector />
            </div>
        </div>
    </div>
</div>
