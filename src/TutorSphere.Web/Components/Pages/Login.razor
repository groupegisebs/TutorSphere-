@page "/login"
@layout LoginLayout
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<SharedResources> L

@* Static SSR — no InteractiveServer circuit required for first paint (avoids blank /login until refresh). *@

<PageTitle>TutorSphere — Connexion</PageTitle>

<div class="login-selector-page">
    <div class="login-selector-header">
        <img src="images/tutorsphere-logo-full.png" alt="TutorSphere" class="app-logo-full login-logo" />
    </div>

    <div class="login-selector-hero">
        <h1>@L["Login_Welcome"]</h1>
        <p>@L["Login_ChooseSpace"]</p>
    </div>

    <div class="login-role-grid">

        <!-- Tuteur -->
        <a href="/login/tuteur" class="login-role-card login-role-tutor" data-enhance-nav="false">
            <div class="login-role-icon">
                <i class="bi bi-person-workspace"></i>
            </div>
            <h2>@L["Login_Tutor_Title"]</h2>
            <p>@L["Login_Tutor_Desc"]</p>
            <span class="login-role-btn">@L["Login_Connect"] <i class="bi bi-arrow-right"></i></span>
        </a>

        <!-- Parent -->
        <a href="/login/parent" class="login-role-card login-role-parent" data-enhance-nav="false">
            <span class="login-free-badge">@L["Badge_Free"]</span>
            <div class="login-role-icon">
                <i class="bi bi-house-heart"></i>
            </div>
            <h2>@L["Login_Parent_Title"]</h2>
            <p>@L["Login_Parent_Desc"]</p>
            <span class="login-role-btn">@L["Login_Connect"] <i class="bi bi-arrow-right"></i></span>
        </a>

        <!-- Élève -->
        <a href="/login/eleve" class="login-role-card login-role-eleve" data-enhance-nav="false">
            <span class="login-free-badge">@L["Badge_Free"]</span>
            <div class="login-role-icon">
                <i class="bi bi-backpack"></i>
            </div>
            <h2>@L["Login_Student_Title"]</h2>
            <p>@L["Login_Student_Desc"]</p>
            <span class="login-role-btn">@L["Login_Connect"] <i class="bi bi-arrow-right"></i></span>
        </a>

    </div>

    <div class="login-selector-footer">
        <a href="/login/admin" class="login-admin-link" data-enhance-nav="false">
            <i class="bi bi-shield-lock me-1"></i>@L["Login_SuperAdmin"]
        </a>
    </div>
</div>
