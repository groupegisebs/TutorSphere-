@page "/login"
@layout LoginLayout
@rendermode InteractiveServer
@inject NavigationManager Navigation

<PageTitle>TutorSphere — Connexion</PageTitle>

<div class="login-selector-page">
    <div class="login-selector-header">
        <img src="images/tutorsphere-logo.png" alt="TutorSphere" class="login-logo" />
        <div>
            <span class="login-brand-name">TutorSphere</span>
            <p class="login-brand-tagline">Plateforme éducative intelligente</p>
        </div>
    </div>

    <div class="login-selector-hero">
        <h1>Bienvenue sur <span>TutorSphere</span></h1>
        <p>Choisissez votre espace de connexion</p>
    </div>

    <div class="login-role-grid">

        <!-- Tuteur -->
        <div class="login-role-card login-role-tutor" @onclick='() => Navigation.NavigateTo("/login/tuteur")'>
            <div class="login-role-icon">
                <i class="bi bi-person-workspace"></i>
            </div>
            <h2>Tuteur / Enseignant</h2>
            <p>Gérez vos cours, élèves et sessions</p>
            <button class="login-role-btn">Se connecter <i class="bi bi-arrow-right"></i></button>
        </div>

        <!-- Parent -->
        <div class="login-role-card login-role-parent" @onclick='() => Navigation.NavigateTo("/login/parent")'>
            <div class="login-role-icon">
                <i class="bi bi-house-heart"></i>
            </div>
            <h2>Parent</h2>
            <p>Suivez la progression de vos enfants</p>
            <button class="login-role-btn">Se connecter <i class="bi bi-arrow-right"></i></button>
        </div>

        <!-- Élève -->
        <div class="login-role-card login-role-eleve" @onclick='() => Navigation.NavigateTo("/login/eleve")'>
            <div class="login-role-icon">
                <i class="bi bi-backpack"></i>
            </div>
            <h2>Élève</h2>
            <p>Accédez à vos cours et devoirs</p>
            <button class="login-role-btn">Se connecter <i class="bi bi-arrow-right"></i></button>
        </div>

    </div>

    <div class="login-selector-footer">
        <a href="/login/admin" class="login-admin-link">
            <i class="bi bi-shield-lock me-1"></i>Super Admin
        </a>
    </div>
</div>
