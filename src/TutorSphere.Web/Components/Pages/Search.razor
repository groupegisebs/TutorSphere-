@page "/search"
@inject HttpClient Http
@inject IStringLocalizer<SharedResources> L

<PageTitle>@L["PageTitle_Search"]</PageTitle>

<div class="search-page">
    <div class="search-page-header page-header">
        <h1>@L["Search_Title"]</h1>
        <p class="page-subtitle">@L["Search_Subtitle"]</p>
    </div>

    <div class="search-layout">
        <aside class="search-filters">
            <h2><i class="bi bi-sliders"></i> @L["Search_Filters"]</h2>
            <div class="mb-3">
                <label class="form-label">@L["Label_Subject"]</label>
                <input class="form-control" @bind="Filters.Subject" placeholder="@L["Placeholder_Subject"]" />
            </div>
            <div class="mb-3">
                <label class="form-label">@L["Label_City"]</label>
                <input class="form-control" @bind="Filters.City" placeholder="@L["Placeholder_City"]" />
            </div>
            <div class="mb-3">
                <label class="form-label">@L["Label_Language"]</label>
                <select class="form-select" @bind="Filters.Language">
                    <option value="">@L["Filter_All"]</option>
                    <option value="@SupportedLanguageCodes.French">@L["Lang_French"]</option>
                    <option value="@SupportedLanguageCodes.English">@L["Lang_English"]</option>
                    <option value="@SupportedLanguageCodes.Spanish">@L["Lang_Spanish"]</option>
                    <option value="@SupportedLanguageCodes.German">@L["Lang_German"]</option>
                    <option value="@SupportedLanguageCodes.Portuguese">@L["Lang_Portuguese"]</option>
                    <option value="@SupportedLanguageCodes.MandarinChinese">@L["Lang_Mandarin"]</option>
                    <option value="@SupportedLanguageCodes.Arabic">@L["Lang_Arabic"]</option>
                </select>
            </div>
            <div class="row g-2 mb-3">
                <div class="col-6">
                    <label class="form-label">@L["Label_MinPrice"]</label>
                    <input type="number" class="form-control" @bind="Filters.MinPrice" min="0" step="1" />
                </div>
                <div class="col-6">
                    <label class="form-label">@L["Label_MaxPrice"]</label>
                    <input type="number" class="form-control" @bind="Filters.MaxPrice" min="0" step="1" />
                </div>
            </div>
            <div class="mb-3">
                <label class="form-label">@L["Label_Level"]</label>
                <input class="form-control" @bind="Filters.Level" placeholder="@L["Placeholder_Level"]" />
            </div>
            <div class="mb-3">
                <label class="form-label">@L["Label_Mode"]</label>
                <select class="form-select" @bind="SelectedMode">
                    <option value="">@L["Filter_All"]</option>
                    <option value="0">@L["Filter_Mode_InPerson"]</option>
                    <option value="1">@L["Filter_Mode_Online"]</option>
                    <option value="2">@L["Filter_Mode_Hybrid"]</option>
                </select>
            </div>
            <div class="mb-3">
                <label class="form-label">@L["Label_MinRating"]</label>
                <input type="number" class="form-control" @bind="Filters.MinRating" min="0" max="5" step="0.5" disabled />
                <small class="form-hint">@L["Hint_RatingsComingSoon"]</small>
            </div>
            <button class="btn btn-primary w-100" @onclick="SearchAsync" disabled="@IsLoading">
                @if (IsLoading)
                {
                    <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                }
                @(IsLoading ? L["Button_Searching"] : L["Button_Search"])
            </button>
        </aside>

        <section class="search-results">
            @if (!string.IsNullOrEmpty(ErrorMessage))
            {
                <div class="alert alert-danger">
                    <i class="bi bi-exclamation-circle me-2"></i>@ErrorMessage
                </div>
            }
            else if (IsLoading)
            {
                <div class="loading-state">
                    <div class="loading-spinner"></div>
                    <span>@L["Search_Loading"]</span>
                </div>
            }
            else if (Results.Count == 0)
            {
                <div class="empty-state">
                    <div class="empty-state-icon"><i class="bi bi-search"></i></div>
                    <h2 class="h5">@L["Search_NoResults_Title"]</h2>
                    <p class="text-muted mb-0">@L["Search_NoResults_Description"]</p>
                </div>
            }
            else
            {
            <p class="results-count"><i class="bi bi-people me-1"></i>@L["Search_ResultsCount", Results.Count]</p>
                <div class="results-grid">
                    @foreach (var tutor in Results)
                    {
                        <TutorSearchCard Tutor="tutor" ProfileHref="@($"/tutor/{tutor.Slug}")" />
                    }
                </div>
            }
        </section>
    </div>
</div>

@code {
    private SearchFiltersModel Filters { get; set; } = new();
    private string SelectedMode { get; set; } = "";
    private List<TutorSearchResultDto> Results { get; set; } = [];
    private bool IsLoading { get; set; }
    private string? ErrorMessage { get; set; }

    protected override async Task OnInitializedAsync()
    {
        await SearchAsync();
    }

    private async Task SearchAsync()
    {
        IsLoading = true;
        ErrorMessage = null;

        try
        {
            var query = BuildQueryString();
            var response = await Http.GetFromJsonAsync<List<TutorSearchResultDto>>($"api/search/tutors{query}");
            Results = response ?? [];
        }
        catch (Exception)
        {
            ErrorMessage = L["Search_Error_Load"];
            Results = [];
        }
        finally
        {
            IsLoading = false;
        }
    }

    private string BuildQueryString()
    {
        var parts = new List<string>();

        AddQuery(parts, "subject", Filters.Subject);
        AddQuery(parts, "city", Filters.City);
        AddQuery(parts, "language", Filters.Language);
        AddQuery(parts, "level", Filters.Level);

        if (Filters.MinPrice.HasValue)
            parts.Add($"minPrice={Filters.MinPrice.Value}");
        if (Filters.MaxPrice.HasValue)
            parts.Add($"maxPrice={Filters.MaxPrice.Value}");
        if (!string.IsNullOrWhiteSpace(SelectedMode))
            parts.Add($"mode={SelectedMode}");

        return parts.Count == 0 ? "" : "?" + string.Join("&", parts);
    }

    private static void AddQuery(List<string> parts, string key, string? value)
    {
        if (!string.IsNullOrWhiteSpace(value))
            parts.Add($"{key}={Uri.EscapeDataString(value.Trim())}");
    }

    private sealed class SearchFiltersModel
    {
        public string Subject { get; set; } = "";
        public string City { get; set; } = "";
        public string Language { get; set; } = "";
        public decimal? MinPrice { get; set; }
        public decimal? MaxPrice { get; set; }
        public string Level { get; set; } = "";
        public decimal? MinRating { get; set; }
    }
}
