@page "/tutor/dashboard"
@inject IStringLocalizer<SharedResources> L

<PageTitle>@L["PageTitle_TutorDashboard"]</PageTitle>

<h1>@L["TutorDashboard_Title"]</h1>
<p class="text-muted">@L["TutorDashboard_Subtitle"]</p>

<div class="row g-3 mt-2">
    <div class="col-md-3">
        <div class="stat-card">
            <span class="stat-label">@L["Stat_MonthlyRevenue"]</span>
            <span class="stat-value">0,00 $</span>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card">
            <span class="stat-label">@L["Stat_ActiveStudents"]</span>
            <span class="stat-value">0</span>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card">
            <span class="stat-label">@L["Stat_ActiveSubscriptions"]</span>
            <span class="stat-value">0</span>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card">
            <span class="stat-label">@L["Stat_UpcomingLessons"]</span>
            <span class="stat-value">0</span>
        </div>
    </div>
</div>

<div class="mt-4">
    <h2>@L["Modules_Title"]</h2>
    <ul>
        <li>@L["Module_StudentsParents"]</li>
        <li>@L["Module_Subscriptions"]</li>
        <li>@L["Module_Calendar"]</li>
        <li>@L["Module_Homework"]</li>
        <li>@L["Module_Revenue"]</li>
    </ul>
</div>
