@page "/tutor/dashboard"
@inject IStringLocalizer<SharedResources> L

<PageTitle>@L["PageTitle_TutorDashboard"]</PageTitle>

<div class="page-header">
    <h1>@L["TutorDashboard_Title"]</h1>
    <p class="page-subtitle">@L["TutorDashboard_Subtitle"]</p>
</div>

<div class="row g-3">
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card stat-card--revenue">
            <div class="stat-card-icon"><i class="bi bi-currency-dollar"></i></div>
            <div class="stat-card-body">
                <span class="stat-label">@L["Stat_MonthlyRevenue"]</span>
                <span class="stat-value">0,00 $</span>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card stat-card--students">
            <div class="stat-card-icon"><i class="bi bi-people"></i></div>
            <div class="stat-card-body">
                <span class="stat-label">@L["Stat_ActiveStudents"]</span>
                <span class="stat-value">0</span>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card stat-card--subscriptions">
            <div class="stat-card-icon"><i class="bi bi-credit-card"></i></div>
            <div class="stat-card-body">
                <span class="stat-label">@L["Stat_ActiveSubscriptions"]</span>
                <span class="stat-value">0</span>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card stat-card--lessons">
            <div class="stat-card-icon"><i class="bi bi-calendar-check"></i></div>
            <div class="stat-card-body">
                <span class="stat-label">@L["Stat_UpcomingLessons"]</span>
                <span class="stat-value">0</span>
            </div>
        </div>
    </div>
</div>

<div class="section-card mt-4">
    <h2><i class="bi bi-grid me-2"></i>@L["Modules_Title"]</h2>
    <div class="module-grid">
        <div class="module-item">
            <i class="bi bi-person-lines-fill"></i>
            <span>@L["Module_StudentsParents"]</span>
        </div>
        <div class="module-item">
            <i class="bi bi-arrow-repeat"></i>
            <span>@L["Module_Subscriptions"]</span>
        </div>
        <div class="module-item">
            <i class="bi bi-calendar3"></i>
            <span>@L["Module_Calendar"]</span>
        </div>
        <div class="module-item">
            <i class="bi bi-journal-text"></i>
            <span>@L["Module_Homework"]</span>
        </div>
        <div class="module-item">
            <i class="bi bi-graph-up-arrow"></i>
            <span>@L["Module_Revenue"]</span>
        </div>
    </div>
</div>
