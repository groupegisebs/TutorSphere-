@page "/tutor/dashboard"
@layout TutorLayout
@rendermode InteractiveServer
@inject IStringLocalizer<SharedResources> L
@inject LessonService LessonSvc
@inject MessageService MessageSvc
@inject AuthService Auth
@inject ApiClient Api

<PageTitle>@L["PageTitle_TutorDashboard"]</PageTitle>

<div class="dashboard-header">
    <div>
        <h1 class="dashboard-greeting">@L["TutorDashboard_Title"]</h1>
        <p class="dashboard-date">@L["TutorDashboard_Subtitle_Welcome", DisplayName]</p>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-sm-6 col-xl">
        <StatCard Label="@L["Stat_MonthlyRevenue"]" Value="@FormatMoney(_monthlyRevenue)" Icon="bi-currency-dollar" Variant="revenue" />
    </div>
    <div class="col-sm-6 col-xl">
        <StatCard Label="@L["Stat_ActiveSubscriptions"]" Value="@_activeSubscriptions.ToString()" Icon="bi-arrow-repeat" Variant="subscriptions" />
    </div>
    <div class="col-sm-6 col-xl">
        <StatCard Label="@L["Stat_UpcomingLessons"]" Value="@_upcomingLessonsCount.ToString()" Icon="bi-calendar-check" Variant="lessons" Change="@L["Stat_Today"]" ChangeVariant="neutral" />
    </div>
    <div class="col-sm-6 col-xl">
        <StatCard Label="@L["Stat_ActiveStudents"]" Value="@_activeStudents.ToString()" Icon="bi-people" Variant="students" />
    </div>
    <div class="col-sm-6 col-xl">
        <StatCard Label="@L["Stat_PendingPayments"]" Value="@FormatMoney(_pendingPayments)" Icon="bi-hourglass-split" Variant="payments" ChangeVariant="negative" />
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-lg-7">
        <div class="section-card h-100">
            <div class="section-card-header">
                <div>
                    <h2>@L["TutorDashboard_RevenueChart"]</h2>
                    <p class="dashboard-amount">@FormatMoney(_monthlyRevenue)</p>
                </div>
            </div>
            <div class="chart-placeholder chart-placeholder--line" aria-hidden="true">
                <p class="text-muted px-3 py-4 mb-0">@L["TutorDashboard_RevenueHint"]</p>
            </div>
        </div>
    </div>
    <div class="col-lg-5">
        <div class="section-card h-100">
            <div class="section-card-header">
                <h2>@L["Stat_UpcomingLessons"]</h2>
                <a href="tutor/calendar" class="btn btn-sm btn-link">@L["Button_ViewAll"]</a>
            </div>
            @if (_lessonsLoading)
            {
                <div class="ts-loading-state" style="padding: 1.5rem;">
                    <div class="spinner-border spinner-border-sm text-primary" role="status"></div>
                    <span class="ms-2 text-muted">@L["Common_Loading"]</span>
                </div>
            }
            else if (UpcomingLessons.Count == 0)
            {
                <p class="ts-empty-inline px-3 py-3">@L["TutorDashboard_NoUpcomingLessons"]</p>
            }
            else
            {
                <ul class="lesson-list">
                    @foreach (var lesson in UpcomingLessons)
                    {
                        <li class="lesson-list-item">
                            <span class="lesson-time-left">@lesson.Time</span>
                            <div class="lesson-avatar">@lesson.Initials</div>
                            <div class="lesson-info">
                                <strong>@lesson.Student</strong>
                                <span>@lesson.Subject</span>
                            </div>
                            <span class="lesson-mode-badge lesson-mode-badge--@lesson.ModeClass">@lesson.Mode</span>
                        </li>
                    }
                </ul>
            }
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-4">
        <div class="section-card">
            <div class="section-card-header">
                <h2>@L["TutorDashboard_UnreadMessages"]</h2>
                <a href="tutor/messages" class="btn btn-sm btn-link">@L["Button_ViewAll"]</a>
            </div>
            <p class="dashboard-big-stat">@_unreadMessages</p>
            <p class="dashboard-big-stat-label">
                <span class="dot dot--primary"></span> @L["TutorDashboard_NewMessages"]
            </p>
        </div>
    </div>
    <div class="col-lg-8">
        <div class="section-card h-100">
            <div class="section-card-header">
                <h2>@L["TutorDashboard_RecentActivity"]</h2>
                <a href="tutor/students" class="btn btn-sm btn-link">@L["Button_ViewAll"]</a>
            </div>
            @if (RecentActivity.Count == 0)
            {
                <p class="ts-empty-inline px-3 py-3">@L["TutorDashboard_NoRecentActivity"]</p>
            }
            else
            {
                <ul class="activity-feed">
                    @foreach (var item in RecentActivity)
                    {
                        <li class="activity-item">
                            <div class="activity-icon activity-icon--@item.IconVariant">
                                <i class="bi @item.Icon" aria-hidden="true"></i>
                            </div>
                            <div class="activity-content">
                                <strong class="activity-title">@item.Title</strong>
                                <span class="activity-description">@item.Description</span>
                            </div>
                            <span class="activity-time">@item.Time</span>
                        </li>
                    }
                </ul>
            }
        </div>
    </div>
</div>

@code {
    private record LessonItem(string Student, string Subject, string Time, string Initials, string Mode, string ModeClass);
    private record ActivityItem(string Title, string Description, string Time, string Icon, string IconVariant);
    private record DashboardDto(decimal MonthlyRevenue, int ActiveStudents, int ActiveSubscriptions, int UpcomingLessons, int PendingPayments);

    private bool _lessonsLoading = true;
    private decimal _monthlyRevenue;
    private int _activeStudents;
    private int _activeSubscriptions;
    private int _upcomingLessonsCount;
    private decimal _pendingPayments;
    private int _unreadMessages;
    private List<LessonItem> UpcomingLessons = [];
    private List<ActivityItem> RecentActivity = [];

    private string DisplayName
    {
        get
        {
            var name = Auth.UserName;
            if (string.IsNullOrWhiteSpace(name)) return "Tuteur";
            var first = name.Split(' ', StringSplitOptions.RemoveEmptyEntries).FirstOrDefault();
            return first ?? name;
        }
    }

    private static string FormatMoney(decimal amount) =>
        amount.ToString("N0", System.Globalization.CultureInfo.GetCultureInfo("fr-CA")) + " $";

    protected override async Task OnInitializedAsync()
    {
        var tenantId = Auth.TenantId;
        if (tenantId is not null)
        {
            var stats = await Api.GetAsync<DashboardDto>($"api/tenants/{tenantId}/dashboard");
            if (stats is not null)
            {
                _monthlyRevenue = stats.MonthlyRevenue;
                _activeStudents = stats.ActiveStudents;
                _activeSubscriptions = stats.ActiveSubscriptions;
                _upcomingLessonsCount = stats.UpcomingLessons;
                _pendingPayments = stats.PendingPayments;
            }
        }

        try
        {
            var conversations = await MessageSvc.GetConversationsAsync();
            _unreadMessages = conversations.Sum(c => c.UnreadCount);
        }
        catch { /* keep 0 */ }

        try
        {
            var dtos = await LessonSvc.GetLessonsAsync();
            var upcoming = dtos
                .Where(d => d.StartTime >= DateTime.UtcNow)
                .OrderBy(d => d.StartTime)
                .Take(5)
                .ToList();

            if (tenantId is null)
                _upcomingLessonsCount = upcoming.Count;

            UpcomingLessons = upcoming.Select(d =>
            {
                var local = d.StartTime.ToLocalTime();
                var mode = LessonService.ModeToDisplay(d.Mode);
                var modeClass = d.Mode == "InPerson" ? "inperson" : "online";
                return new LessonItem(
                    d.Title,
                    d.Subject ?? "",
                    local.ToString("HH:mm"),
                    d.Title.Length > 0 ? d.Title[..1].ToUpperInvariant() : "?",
                    mode,
                    modeClass);
            }).ToList();

            RecentActivity = dtos
                .OrderByDescending(d => d.UpdatedAt ?? d.CreatedAt)
                .Take(5)
                .Select(d => new ActivityItem(
                    d.Title,
                    d.Subject ?? LessonService.ModeToDisplay(d.Mode),
                    (d.UpdatedAt ?? d.CreatedAt).ToLocalTime().ToString("dd/MM HH:mm"),
                    "bi-calendar-event",
                    "primary"))
                .ToList();
        }
        catch { /* empty until API available */ }
        finally { _lessonsLoading = false; }
    }
}
