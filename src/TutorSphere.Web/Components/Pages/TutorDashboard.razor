@page "/tutor/dashboard"
@inject IStringLocalizer<SharedResources> L

<PageTitle>@L["PageTitle_TutorDashboard"]</PageTitle>

<PageHeader Title="@L["TutorDashboard_Title"]" Subtitle="@L["TutorDashboard_Subtitle"]" />

<div class="row g-3">
    <div class="col-sm-6 col-xl-4">
        <StatCard Label="@L["Stat_MonthlyRevenue"]" Value="0,00 $" Icon="bi-currency-dollar" Variant="revenue" />
    </div>
    <div class="col-sm-6 col-xl-4">
        <StatCard Label="@L["Stat_ActiveSubscriptions"]" Value="0" Icon="bi-credit-card" Variant="subscriptions" />
    </div>
    <div class="col-sm-6 col-xl-4">
        <StatCard Label="@L["Stat_UpcomingLessons"]" Value="0" Icon="bi-calendar-check" Variant="lessons" />
    </div>
    <div class="col-sm-6 col-xl-4">
        <StatCard Label="@L["Stat_ActiveStudents"]" Value="0" Icon="bi-people" Variant="students" />
    </div>
    <div class="col-sm-6 col-xl-4">
        <StatCard Label="@L["Stat_PendingPayments"]" Value="0" Icon="bi-hourglass-split" Variant="payments" />
    </div>
    <div class="col-sm-6 col-xl-4">
        <StatCard Label="@L["Stat_Notifications"]" Value="0" Icon="bi-bell" Variant="notifications" />
    </div>
</div>

<div class="section-card mt-4">
    <h2><i class="bi bi-grid me-2"></i>@L["Modules_Title"]</h2>
    <div class="module-grid">
        <div class="module-item"><i class="bi bi-person-lines-fill"></i><span>@L["Module_StudentsParents"]</span></div>
        <div class="module-item"><i class="bi bi-arrow-repeat"></i><span>@L["Module_Subscriptions"]</span></div>
        <div class="module-item"><i class="bi bi-calendar3"></i><span>@L["Module_Calendar"]</span></div>
        <div class="module-item"><i class="bi bi-journal-text"></i><span>@L["Module_Homework"]</span></div>
        <div class="module-item"><i class="bi bi-graph-up-arrow"></i><span>@L["Module_Revenue"]</span></div>
    </div>
</div>
