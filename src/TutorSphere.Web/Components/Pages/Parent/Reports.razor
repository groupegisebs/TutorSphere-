@page "/parent/reports"
@layout ParentLayout
@rendermode InteractiveServer
@inject IStringLocalizer<SharedResources> L
@inject ApiClient Api

<PageTitle>Rapports – TutorSphere</PageTitle>

<div class="ts-page-header">
    <div>
        <h1><i class="bi bi-file-earmark-text me-2"></i>Rapports de séance</h1>
        <p class="ts-page-subtitle">Suivez les comptes-rendus de chaque cours</p>
    </div>
</div>

<div class="ts-toolbar">
    <div class="ts-search-box">
        <i class="bi bi-search ts-search-icon"></i>
        <input class="form-control" placeholder="Chercher…" @bind="_search" @bind:event="oninput" />
    </div>
    <select class="form-select w-auto" @bind="_childFilter">
        <option value="">Tous les enfants</option>
        @foreach (var name in _childNames)
        {
            <option>@name</option>
        }
    </select>
</div>

@if (_loading)
{
    <div class="d-flex align-items-center justify-content-center py-5">
        <span class="spinner-border text-primary me-3" role="status"></span>
        <span class="text-muted">Chargement des rapports…</span>
    </div>
}
else
{
    <div class="ts-table-card">
        <table class="table ts-table">
            <thead><tr><th>Date</th><th>Matière</th><th>Points forts</th><th>Devoir</th><th>Actions</th></tr></thead>
            <tbody>
                @foreach (var r in FilteredReports)
                {
                    <tr>
                        <td>@r.CreatedAt.ToString("dd/MM/yyyy")</td>
                        <td>@(r.TopicsStudied ?? "—")</td>
                        <td>@(r.Strengths ?? "—")</td>
                        <td>@(r.HomeworkAssigned ?? "—")</td>
                        <td>
                            <button class="ts-icon-btn" title="Voir" @onclick="() => _selected = r">
                                <i class="bi bi-eye"></i>
                            </button>
                        </td>
                    </tr>
                }
                @if (!FilteredReports.Any())
                {
                    <tr><td colspan="5" class="text-center text-muted py-4">Aucun rapport disponible.</td></tr>
                }
            </tbody>
        </table>
    </div>
}

@if (_selected != null)
{
    <div class="ts-modal-backdrop" @onclick="() => _selected = null">
        <div class="ts-modal ts-modal-lg" @onclick:stopPropagation="true">
            <div class="ts-modal-header">
                <h2>Rapport – @_selected.CreatedAt.ToString("dd/MM/yyyy")</h2>
                <button class="ts-modal-close" @onclick="() => _selected = null"><i class="bi bi-x-lg"></i></button>
            </div>
            <div class="ts-modal-body">
                <div class="ts-form-grid">
                    <div class="ts-form-row"><label>Date</label><span>@_selected.CreatedAt.ToString("dd/MM/yyyy HH:mm")</span></div>
                    <div class="ts-form-row"><label>Travail effectué</label><span>@(_selected.TopicsStudied ?? "—")</span></div>
                    <div class="ts-form-row"><label>Participation</label><span>@(_selected.Participation ?? "—")</span></div>
                    <div class="ts-form-row"><label>Points forts</label><span>@(_selected.Strengths ?? "—")</span></div>
                    <div class="ts-form-row"><label>À améliorer</label><span>@(_selected.Weaknesses ?? "—")</span></div>
                    <div class="ts-form-row"><label>Devoir</label><span>@(_selected.HomeworkAssigned ?? "—")</span></div>
                    <div class="ts-form-row"><label>Observations</label><span>@(_selected.Observations ?? "—")</span></div>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private string _search = "", _childFilter = "";
    private bool _loading = true;
    private LessonReportDto? _selected;
    private List<LessonReportDto> _reports = [];
    private List<string> _childNames = [];

    private IEnumerable<LessonReportDto> FilteredReports => _reports
        .Where(r => string.IsNullOrEmpty(_search) ||
            (r.TopicsStudied ?? "").Contains(_search, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var students = await Api.GetAsync<List<StudentSummaryDto>>("api/students") ?? [];
            foreach (var s in students)
            {
                _childNames.Add($"{s.FirstName} {s.LastName}".Trim());
                var reps = await Api.GetAsync<List<LessonReportDto>>($"api/lessonreports/student/{s.Id}") ?? [];
                _reports.AddRange(reps);
            }
            _reports = [.. _reports.OrderByDescending(r => r.CreatedAt)];
        }
        catch { }
        finally { _loading = false; }
    }

    private record StudentSummaryDto(Guid Id, string FirstName, string LastName);
    private record LessonReportDto(
        Guid Id, Guid TenantId, Guid LessonId, Guid StudentId,
        string? TopicsStudied, string? Participation, string? Strengths,
        string? Weaknesses, string? HomeworkAssigned, string? Observations,
        bool SentToParent, DateTime? SentAt, DateTime CreatedAt, DateTime? UpdatedAt);
}
