@page "/parent/payments"
@layout ParentLayout
@rendermode InteractiveServer
@inject IStringLocalizer<SharedResources> L

<PageTitle>Mes Paiements – TutorSphere</PageTitle>

<div class="ts-page-header">
    <div>
        <h1><i class="bi bi-credit-card me-2"></i>Mes Paiements</h1>
        <p class="ts-page-subtitle">Historique de vos paiements et factures</p>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-6 col-lg-3">
        <div class="ts-kpi-card ts-kpi-card--success">
            <span class="ts-kpi-val">@_payments.Where(p=>p.Status=="Payé").Sum(p=>p.Amount).ToString("N0") $</span>
            <span class="ts-kpi-label">Total payé</span>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="ts-kpi-card ts-kpi-card--warning">
            <span class="ts-kpi-val">@_payments.Where(p=>p.Status=="En attente").Sum(p=>p.Amount).ToString("N0") $</span>
            <span class="ts-kpi-label">En attente</span>
        </div>
    </div>
</div>

<div class="ts-table-card">
    <table class="table ts-table">
        <thead><tr><th>Date</th><th>Description</th><th>Enfant</th><th>Montant</th><th>Statut</th><th></th></tr></thead>
        <tbody>
            @foreach (var p in _payments)
            {
                <tr>
                    <td>@p.Date.ToString("dd/MM/yyyy")</td>
                    <td>@p.Description</td>
                    <td><span class="ts-badge ts-badge-neutral">@p.Child</span></td>
                    <td class="fw-semibold">@p.Amount $ CAD</td>
                    <td>
                        <span class="ts-badge @(p.Status=="Payé"?"ts-badge-success":p.Status=="En attente"?"ts-badge-warning":"ts-badge-danger")">
                            @p.Status
                        </span>
                    </td>
                    <td>
                        <button class="ts-icon-btn" title="Facture PDF"><i class="bi bi-file-pdf"></i></button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@code {
    private record PaymentVM(DateTime Date, string Description, string Child, decimal Amount, string Status);
    private static readonly List<PaymentVM> _payments =
    [
        new(DateTime.Today.AddDays(-2), "Cours de Maths – Juin", "Emma Johnson", 200, "Payé"),
        new(DateTime.Today.AddDays(-2), "Cours de Français – Juin", "Lucas Johnson", 160, "Payé"),
        new(DateTime.Today, "Cours de Maths – Juillet", "Emma Johnson", 200, "En attente"),
        new(DateTime.Today.AddDays(-32), "Cours de Maths – Mai", "Emma Johnson", 200, "Payé"),
        new(DateTime.Today.AddDays(-32), "Cours de Français – Mai", "Lucas Johnson", 160, "Payé"),
    ];
}
