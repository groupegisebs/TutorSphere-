@page "/parent/children"
@layout ParentLayout
@rendermode InteractiveServer
@using System.ComponentModel.DataAnnotations
@using TutorSphere.Application.DTOs.Students
@inject IStringLocalizer<SharedResources> L
@inject ApiClient Api
@inject AuthService Auth
<PageTitle>@L["Children_Title"] – TutorSphere</PageTitle>

<div class="ts-page-header">
    <div>
        <h1><i class="bi bi-people-fill me-2"></i>@L["Children_Title"]</h1>
        <p class="ts-page-subtitle">@L["Nav_Parent_Children"]</p>
    </div>
    <button type="button" class="btn btn-primary" @onclick="OpenAddModal">
        <i class="bi bi-plus-lg me-1"></i>@L["Children_Add"]
    </button>
</div>

@if (!string.IsNullOrEmpty(_loadError))
{
    <div class="alert alert-warning mb-3 d-flex flex-wrap align-items-center gap-2" role="alert">
        <i class="bi bi-exclamation-triangle me-2"></i>
        <span class="flex-grow-1">@_loadError</span>
        @if (_sessionExpired)
        {
            <a class="btn btn-sm btn-outline-dark" href="/login/parent">@L["Common_Login"]</a>
        }
    </div>
}

@if (_loading)
{
    <div class="d-flex align-items-center justify-content-center py-5">
        <span class="spinner-border text-primary me-3" role="status"></span>
        <span class="text-muted">@L["Common_Loading"]</span>
    </div>
}
else
{
    @if (_children.Count > 0 && _children.All(c => c.IsAutonomous))
    {
        <div class="autonomous-notice mb-3">
            <i class="bi bi-info-circle-fill"></i>
            <span>Tous vos enfants ont atteint l'autonomie (14 ans et plus). Vous pouvez toujours consulter leur planning et les informations générales.</span>
        </div>
    }

    <div class="children-grid">
        @foreach (var child in _children)
        {
            <div class="child-card @(_active?.Id == child.Id ? "active" : "")" @onclick="() => _active = child">
                <div class="child-card-header">
                    <div class="ts-avatar ts-avatar-lg" style="background:@child.Color">@child.Initials</div>
                    <div>
                        <h3>
                            @child.Name
                            @if (child.Age.HasValue)
                            {
                                <span class="text-muted ms-2" style="font-size:0.85rem;font-weight:400">(@child.Age ans)</span>
                            }
                        </h3>
                        <span class="text-muted">@(child.Level ?? "—") · @(child.School ?? "—")</span>
                    </div>
                    <span class="ts-badge @(child.IsActive ? "ts-badge-success" : "ts-badge-muted") ms-auto">
                        @(child.IsActive ? L["Common_Active"] : L["Common_Inactive"])
                    </span>
                </div>
                @if (child.IsAutonomous)
                {
                    <div class="autonomous-notice">
                        <i class="bi bi-info-circle-fill"></i>
                        <span>Votre enfant a @child.Age ans ou plus. Conformément à notre politique de confidentialité, certaines informations (rapports détaillés, messages, devoirs) ne sont pas accessibles aux parents pour les élèves autonomes.</span>
                    </div>
                }
                <div class="child-subjects">
                    @foreach (var s in child.Subjects)
                    {
                        <span class="ts-badge ts-badge-neutral">@s</span>
                    }
                </div>
            </div>
        }
        @if (_children.Count == 0)
        {
            <div class="text-center py-5 text-muted col-span-full">
                <i class="bi bi-people fs-1 d-block mb-3 opacity-50"></i>
                <p class="mb-3">Aucun enfant enregistré.</p>
                <button type="button" class="btn btn-outline-primary" @onclick="OpenAddModal">
                    <i class="bi bi-plus-lg me-1"></i>Ajouter votre premier enfant
                </button>
            </div>
        }
    </div>

    @if (_active != null)
    {
        <div class="section-card mt-4">
            <div class="section-card-header">
                <h2>
                    Détail — @_active.Name
                    @if (_active.Age.HasValue)
                    {
                        <span class="text-muted ms-2" style="font-size:0.9rem;font-weight:400">(@_active.Age ans)</span>
                    }
                </h2>
            </div>
            @if (_active.IsAutonomous)
            {
                <div style="padding:1rem 1.5rem 0">
                    <div class="autonomous-notice">
                        <i class="bi bi-info-circle-fill"></i>
                        <span>Votre enfant a @_active.Age ans ou plus. Conformément à notre politique de confidentialité, certaines informations (rapports détaillés, messages, devoirs) ne sont pas accessibles aux parents pour les élèves autonomes.</span>
                    </div>
                </div>
            }
            <div style="padding:1.5rem">
                <div class="d-flex gap-2 mb-3">
                    <button type="button" class="btn btn-outline-primary btn-sm" @onclick="OpenEditModal">
                        <i class="bi bi-pencil me-1"></i>Modifier
                    </button>
                    <button type="button" class="btn btn-outline-danger btn-sm" disabled="@_deleting" @onclick="DeleteChildAsync">
                        @if (_deleting)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                        }
                        <i class="bi bi-trash me-1"></i>Supprimer
                    </button>
                </div>
                @if (!string.IsNullOrEmpty(_detailError))
                {
                    <div class="alert alert-danger mb-3" role="alert">@_detailError</div>
                }
                <div class="ts-form-grid">
                    <div class="ts-form-row"><label>Prénom</label><span>@_active.FirstName</span></div>
                    <div class="ts-form-row"><label>Nom</label><span>@_active.LastName</span></div>
                    <div class="ts-form-row"><label>Âge</label><span>@(_active.Age.HasValue ? $"{_active.Age} ans" : "—")</span></div>
                    <div class="ts-form-row"><label>Niveau</label><span>@(_active.Level ?? "—")</span></div>
                    <div class="ts-form-row"><label>École</label><span>@(_active.School ?? "—")</span></div>
                    <div class="ts-form-row"><label>Matières</label><span>@(string.Join(", ", _active.Subjects))</span></div>
                    @if (!string.IsNullOrWhiteSpace(_active.Email))
                    {
                        <div class="ts-form-row"><label>Courriel</label><span>@_active.Email</span></div>
                    }
                </div>
            </div>
        </div>
    }
}

@if (_showEditModal && _active != null)
{
    <div class="ts-modal-backdrop" @onclick="CloseEditModal">
        <div class="ts-modal ts-modal-lg" @onclick:stopPropagation="true">
            <div class="ts-modal-header">
                <h2><i class="bi bi-pencil me-2"></i>Modifier — @_active.Name</h2>
                <button type="button" class="ts-modal-close" @onclick="CloseEditModal"><i class="bi bi-x-lg"></i></button>
            </div>
            <div class="ts-modal-body">
                @if (!string.IsNullOrEmpty(_formError))
                {
                    <div class="alert alert-danger mb-3" role="alert">@_formError</div>
                }
                @ChildFormFields(_form)
            </div>
            <div class="ts-modal-footer">
                <button type="button" class="btn btn-outline-secondary" @onclick="CloseEditModal">Annuler</button>
                <button type="button" class="btn btn-primary" disabled="@_saving" @onclick="UpdateChildAsync">
                    @if (_saving)
                    {
                        <span class="spinner-border spinner-border-sm me-2"></span>
                    }
                    Enregistrer
                </button>
            </div>
        </div>
    </div>
}

@if (_showAddModal)
{
    <div class="ts-modal-backdrop" @onclick="CloseAddModal">
        <div class="ts-modal ts-modal-lg" @onclick:stopPropagation="true">
            <div class="ts-modal-header">
                <h2><i class="bi bi-person-plus me-2"></i>Ajouter un enfant</h2>
                <button type="button" class="ts-modal-close" @onclick="CloseAddModal"><i class="bi bi-x-lg"></i></button>
            </div>
            <div class="ts-modal-body">
                @if (!string.IsNullOrEmpty(_formError))
                {
                    <div class="alert alert-danger mb-3" role="alert">@_formError</div>
                }
                @ChildFormFields(_form)
                @if (_form.Age.HasValue && _form.Age >= 14)
                {
                    <div class="autonomous-notice mt-3">
                        <i class="bi bi-info-circle-fill"></i>
                        <span>Cet enfant a @_form.Age ans ou plus — il sera considéré comme autonome et certaines informations ne seront plus visibles dans votre espace parent.</span>
                    </div>
                }
            </div>
            <div class="ts-modal-footer">
                <button type="button" class="btn btn-outline-secondary" @onclick="CloseAddModal">Annuler</button>
                <button type="button" class="btn btn-primary" disabled="@_saving" @onclick="SaveChildAsync">
                    @if (_saving)
                    {
                        <span class="spinner-border spinner-border-sm me-2"></span>
                    }
                    Enregistrer
                </button>
            </div>
        </div>
    </div>
}

@code {
    private bool _loading = true;
    private bool _showAddModal;
    private bool _showEditModal;
    private bool _saving;
    private bool _deleting;
    private string? _formError;
    private string? _loadError;
    private string? _detailError;
    private bool _sessionExpired;
    private ChildVM? _active;
    private List<ChildVM> _children = [];
    private ChildForm _form = new();

    private static readonly string[] Colors = ["#7c3aed", "#0ea5e9", "#10b981", "#ec4899", "#f59e0b"];

    private bool _initialLoadDone;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _initialLoadDone)
            return;

        _initialLoadDone = true;
        await Auth.EnsureSessionRestoredAsync(forceJs: true);
        await LoadChildrenAsync();
        StateHasChanged();
    }

    private async Task LoadChildrenAsync()
    {
        _loading = true;
        _loadError = null;
        _sessionExpired = false;
        try
        {
            await Auth.EnsureSessionRestoredAsync(forceJs: true);

            if (string.IsNullOrEmpty(Auth.Token))
            {
                if (Auth.IsSessionExpired)
                {
                    _sessionExpired = true;
                    _loadError = ApiClient.SessionExpiredMessage;
                }

                _children = [];
                return;
            }

            var result = await Api.GetWithErrorAsync<List<StudentDto>>("api/parent/children");
            if (!result.IsSuccess)
            {
                if (result.Error == ApiClient.SessionExpiredMessage)
                {
                    _sessionExpired = true;
                    _loadError = result.Error;
                    _children = [];
                    return;
                }

                _loadError = result.Error ?? "Impossible de charger la liste des enfants.";
                _children = [];
                return;
            }

            _children = (result.Value ?? []).Select((s, i) => MapToChild(s, i)).ToList();
            _active = _children.FirstOrDefault(c => _active is null || c.Id == _active.Id) ?? _children.FirstOrDefault();
        }
        catch (Exception ex)
        {
            _loadError = $"Erreur lors du chargement : {ex.Message}";
            _children = [];
        }
        finally { _loading = false; }
    }

    private void OpenAddModal()
    {
        _form = new ChildForm();
        _formError = null;
        _showAddModal = true;
        _showEditModal = false;
    }

    private void OpenEditModal()
    {
        if (_active is null) return;

        _form = new ChildForm
        {
            FirstName = _active.FirstName,
            LastName = _active.LastName,
            Email = _active.Email,
            DateOfBirth = _active.DateOfBirth,
            SchoolLevel = _active.Level,
            SchoolName = _active.School,
            Subjects = _active.Subjects.Count > 0 ? string.Join(", ", _active.Subjects) : null
        };
        _formError = null;
        _detailError = null;
        _showEditModal = true;
        _showAddModal = false;
    }

    private void CloseAddModal()
    {
        _showAddModal = false;
        _formError = null;
    }

    private void CloseEditModal()
    {
        _showEditModal = false;
        _formError = null;
    }

    private async Task SaveChildAsync()
    {
        if (!ValidateForm(out var payload))
            return;

        _saving = true;
        try
        {
            var result = await Api.PostWithErrorAsync<StudentDto>("api/parent/children", payload);
            if (!HandleApiFailure(result.Error))
                return;

            CloseAddModal();
            await LoadChildrenAsync();
        }
        finally { _saving = false; }
    }

    private async Task UpdateChildAsync()
    {
        if (_active is null || !ValidateForm(out var payload))
            return;

        _saving = true;
        try
        {
            var result = await Api.PutWithErrorAsync<StudentDto>($"api/parent/children/{_active.Id}", payload);
            if (!HandleApiFailure(result.Error))
                return;

            CloseEditModal();
            await LoadChildrenAsync();
        }
        finally { _saving = false; }
    }

    private async Task DeleteChildAsync()
    {
        if (_active is null)
            return;

        _deleting = true;
        _detailError = null;
        try
        {
            await Auth.EnsureSessionRestoredAsync();
            var result = await Api.DeleteWithErrorAsync($"api/parent/children/{_active.Id}");
            if (result.Error == ApiClient.SessionExpiredMessage)
            {
                _sessionExpired = true;
                _loadError = result.Error;
                return;
            }

            if (result.Error is not null)
            {
                _detailError = result.Error;
                return;
            }

            _active = null;
            await LoadChildrenAsync();
        }
        finally { _deleting = false; }
    }

    private bool ValidateForm(out object payload)
    {
        _formError = null;
        payload = new { };

        if (string.IsNullOrWhiteSpace(_form.FirstName) || string.IsNullOrWhiteSpace(_form.LastName))
        {
            _formError = "Le prénom et le nom sont obligatoires.";
            return false;
        }

        if (_form.DateOfBirth is null)
        {
            _formError = "La date de naissance est obligatoire.";
            return false;
        }

        var dob = _form.DateOfBirth.Value.Date;
        if (dob > DateTime.Today)
        {
            _formError = "La date de naissance ne peut pas être dans le futur.";
            return false;
        }

        if (!string.IsNullOrWhiteSpace(_form.Email) && !new EmailAddressAttribute().IsValid(_form.Email.Trim()))
        {
            _formError = "L'adresse courriel n'est pas valide.";
            return false;
        }

        payload = new
        {
            firstName = _form.FirstName.Trim(),
            lastName = _form.LastName.Trim(),
            dateOfBirth = dob,
            email = string.IsNullOrWhiteSpace(_form.Email) ? null : _form.Email.Trim(),
            schoolLevel = string.IsNullOrWhiteSpace(_form.SchoolLevel) ? null : _form.SchoolLevel.Trim(),
            schoolName = string.IsNullOrWhiteSpace(_form.SchoolName) ? null : _form.SchoolName.Trim(),
            subjects = string.IsNullOrWhiteSpace(_form.Subjects) ? null : _form.Subjects.Trim()
        };

        return true;
    }

    private bool HandleApiFailure(string? error)
    {
        if (error is null)
            return true;

        if (error == ApiClient.SessionExpiredMessage)
        {
            _sessionExpired = true;
            _loadError = error;
            return false;
        }

        _formError = error;
        return false;
    }

    private RenderFragment ChildFormFields(ChildForm form) => __builder =>
    {
        <div class="row g-3">
            <div class="col-md-6">
                <label class="form-label">Prénom *</label>
                <input class="form-control" @bind="form.FirstName" />
            </div>
            <div class="col-md-6">
                <label class="form-label">Nom *</label>
                <input class="form-control" @bind="form.LastName" />
            </div>
            <div class="col-md-6">
                <label class="form-label">Date de naissance *</label>
                <input type="date" class="form-control" @bind="form.DateOfBirth" />
            </div>
            <div class="col-md-6">
                <label class="form-label">Courriel (optionnel)</label>
                <input type="email" class="form-control" @bind="form.Email" placeholder="enfant@exemple.com" />
            </div>
            <div class="col-md-6">
                <label class="form-label">Niveau scolaire</label>
                <input class="form-control" @bind="form.SchoolLevel" placeholder="Ex. Secondaire 3" />
            </div>
            <div class="col-md-6">
                <label class="form-label">École</label>
                <input class="form-control" @bind="form.SchoolName" placeholder="Nom de l'établissement" />
            </div>
            <div class="col-12">
                <label class="form-label">Matières suivies</label>
                <input class="form-control" @bind="form.Subjects" placeholder="Mathématiques, Français, Sciences (séparées par des virgules)" />
            </div>
        </div>
    };
    private ChildVM MapToChild(StudentDto s, int index = -1)
    {
        if (index < 0)
            index = _children.FindIndex(c => c.Id == s.Id);

        if (index < 0)
            index = _children.Count;
        var name = $"{s.FirstName} {s.LastName}".Trim();
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        var initials = parts.Length >= 2
            ? $"{parts[0][0]}{parts[^1][0]}".ToUpperInvariant()
            : name.Length > 0 ? name[..1].ToUpperInvariant() : "?";

        return new ChildVM
        {
            Id = s.Id,
            FirstName = s.FirstName,
            LastName = s.LastName,
            Name = name,
            Initials = initials,
            Color = Colors[index % Colors.Length],
            IsActive = true,
            Level = s.SchoolLevel,
            School = s.SchoolName,
            Subjects = s.Subjects?.ToList() ?? [],
            DateOfBirth = s.DateOfBirth,
            Email = s.Email
        };
    }

    private class ChildForm
    {
        public string FirstName { get; set; } = "";
        public string LastName { get; set; } = "";
        public string? Email { get; set; }
        public DateTime? DateOfBirth { get; set; }
        public string? SchoolLevel { get; set; }
        public string? SchoolName { get; set; }
        public string? Subjects { get; set; }
        public int? Age => DateOfBirth.HasValue
            ? (int)((DateTime.Today - DateOfBirth.Value.Date).TotalDays / 365.25)
            : null;
    }

    private class ChildVM
    {
        public Guid Id { get; set; }
        public string FirstName { get; set; } = "";
        public string LastName { get; set; } = "";
        public string Name { get; set; } = "";
        public string Initials { get; set; } = "";
        public string Color { get; set; } = "#7c3aed";
        public bool IsActive { get; set; }
        public string? Level { get; set; }
        public string? School { get; set; }
        public string? Email { get; set; }
        public List<string> Subjects { get; set; } = [];
        public DateTime? DateOfBirth { get; set; }
        public int? Age => DateOfBirth.HasValue
            ? (int)((DateTime.Today - DateOfBirth.Value.Date).TotalDays / 365.25)
            : null;
        public bool IsAutonomous => Age.HasValue && Age >= 14;
    }
}