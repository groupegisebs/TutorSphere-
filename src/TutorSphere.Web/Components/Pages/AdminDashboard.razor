@page "/admin/dashboard"
@layout AdminLayout
@inject IStringLocalizer<SharedResources> L

<PageTitle>@L["PageTitle_AdminDashboard"]</PageTitle>

<PageHeader Title="@L["AdminDashboard_Title"]" Subtitle="@L["AdminDashboard_Subtitle"]" />

<div class="row g-3 mb-4">
    <div class="col-sm-6 col-xl-3">
        <StatCard Label="@L["Admin_Stat_Tutors"]" Value="1 245" Icon="bi-person-badge" Variant="students" Change="@L["Stat_Change_Positive", "+42"]" />
    </div>
    <div class="col-sm-6 col-xl-3">
        <StatCard Label="@L["Admin_Stat_Parents"]" Value="3 562" Icon="bi-people" Variant="subscriptions" Change="@L["Stat_Change_Positive", "+128"]" />
    </div>
    <div class="col-sm-6 col-xl-3">
        <StatCard Label="@L["Admin_Stat_Students"]" Value="5 894" Icon="bi-mortarboard" Variant="lessons" Change="@L["Stat_Change_Positive", "+256"]" />
    </div>
    <div class="col-sm-6 col-xl-3">
        <StatCard Label="@L["Admin_Stat_Revenue"]" Value="12 450 $" Icon="bi-currency-dollar" Variant="revenue" Change="@L["Stat_Change_Positive", "+8%"]" />
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-lg-7">
        <div class="section-card h-100">
            <div class="section-card-header">
                <h2>@L["Admin_RevenueChart"]</h2>
            </div>
            <div class="chart-placeholder chart-placeholder--line" aria-hidden="true">
                <svg viewBox="0 0 400 120" preserveAspectRatio="none">
                    <polyline points="0,100 60,85 120,70 180,75 240,50 300,45 360,30 400,20" fill="none" stroke="currentColor" stroke-width="2.5" />
                </svg>
            </div>
        </div>
    </div>
    <div class="col-lg-5">
        <div class="section-card h-100">
            <div class="section-card-header">
                <h2>@L["Admin_RevenueBreakdown"]</h2>
            </div>
            <div class="chart-placeholder chart-placeholder--donut" aria-hidden="true">
                <div class="donut-chart">
                    <div class="donut-hole"></div>
                </div>
                <ul class="donut-legend">
                    <li><span class="donut-legend-color donut-legend-color--primary"></span>@L["Admin_Revenue_Subscriptions"]</li>
                    <li><span class="donut-legend-color donut-legend-color--accent"></span>@L["Admin_Revenue_Commissions"]</li>
                    <li><span class="donut-legend-color donut-legend-color--muted"></span>@L["Admin_Revenue_Other"]</li>
                </ul>
            </div>
        </div>
    </div>
</div>

<div class="row g-3">
    <div class="col-sm-6 col-xl-3">
        <div class="mini-stat-card">
            <i class="bi bi-arrow-repeat mini-stat-icon mini-stat-icon--info"></i>
            <div>
                <span class="mini-stat-label">@L["Admin_Mini_ActiveSubs"]</span>
                <span class="mini-stat-value">892</span>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="mini-stat-card">
            <i class="bi bi-x-circle mini-stat-icon mini-stat-icon--warning"></i>
            <div>
                <span class="mini-stat-label">@L["Admin_Mini_FailedPayments"]</span>
                <span class="mini-stat-value">12</span>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="mini-stat-card">
            <i class="bi bi-exclamation-triangle mini-stat-icon mini-stat-icon--danger"></i>
            <div>
                <span class="mini-stat-label">@L["Admin_Mini_Disputes"]</span>
                <span class="mini-stat-value">3</span>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="mini-stat-card">
            <i class="bi bi-person-plus mini-stat-icon mini-stat-icon--success"></i>
            <div>
                <span class="mini-stat-label">@L["Admin_Mini_NewSignups"]</span>
                <span class="mini-stat-value">47</span>
            </div>
        </div>
    </div>
</div>
