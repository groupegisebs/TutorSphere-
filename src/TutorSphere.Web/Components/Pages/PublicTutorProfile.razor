@page "/tutor/{Slug}/public"
@layout PublicLayout
@rendermode InteractiveServer
@using TutorSphere.Application.DTOs.Branding
@inject IStringLocalizer<SharedResources> L
@inject ApiClient Api

<PageTitle>@L["PageTitle_PublicProfile", Profile?.TutorFullName ?? Profile?.SchoolName ?? Slug]</PageTitle>

@if (_loading)
{
    <div class="school-loading">
        <p>@L["Loading"]</p>
    </div>
}
else if (_notFound || Profile is null)
{
    <div class="school-not-found container py-5">
        <h1>Profil introuvable</h1>
        <p class="text-muted">Cet enseignant n’est pas disponible ou son profil n’est pas public.</p>
        <a class="btn btn-primary" href="/">@L["BackToHome"]</a>
    </div>
}
else if (!string.IsNullOrEmpty(_error))
{
    <div class="container py-5">
        <div class="alert alert-danger">@_error</div>
    </div>
}
else
{
    <div class="container public-profile-content tutor-detail-public">
        <TutorDetailView Profile="Profile" SubscribeHref="/login/parent" />
    </div>
}

@code {
    [Parameter] public string Slug { get; set; } = "";

    private PublicTutorDetailDto? Profile { get; set; }
    private bool _loading = true;
    private bool _notFound;
    private string? _error;

    protected override async Task OnParametersSetAsync()
    {
        _loading = true;
        _error = null;
        _notFound = false;
        Profile = null;

        try
        {
            Profile = await Api.GetAsync<PublicTutorDetailDto>($"api/branding/{Uri.EscapeDataString(Slug)}/tutor");
            _notFound = Profile is null;
        }
        catch
        {
            _error = L["Search_Error_Load"];
        }
        finally
        {
            _loading = false;
        }
    }
}
