@page "/student/dashboard"
@layout StudentLayout
@rendermode InteractiveServer
@using TutorSphere.Application.DTOs.Lessons
@inject IStringLocalizer<SharedResources> L
@inject LessonService LessonSvc
@inject ApiClient Api

<PageTitle>@L["PageTitle_StudentDashboard"]</PageTitle>

<div class="dashboard-header">
    <div>
        <h1 class="dashboard-greeting">@L["StudentDashboard_Welcome", _studentName]</h1>
        <p class="dashboard-date">@DateTime.Now.ToString("dddd d MMMM yyyy")</p>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-sm-6 col-xl-3">
        <StatCard Label="@L["StudentDashboard_CoursesThisWeek"]" Value="@_weekLessons.ToString()" Icon="bi-book" Variant="lessons" Change="@L["Stat_Today"]" ChangeVariant="neutral" />
    </div>
    <div class="col-sm-6 col-xl-3">
        <StatCard Label="@L["StudentDashboard_HomeworkDue"]" Value="@_pendingHomework.ToString()" Icon="bi-pencil-square" Variant="payments" Change="@L["StudentDashboard_DueToday"]" ChangeVariant="negative" />
    </div>
    <div class="col-sm-6 col-xl-3">
        <StatCard Label="@L["StudentDashboard_AverageGrade"]" Value="—" Icon="bi-graph-up" Variant="revenue" Change="" ChangeVariant="neutral" />
    </div>
    <div class="col-sm-6 col-xl-3">
        <StatCard Label="@L["StudentDashboard_UnreadMessages"]" Value="—" Icon="bi-chat-dots" Variant="notifications" Change="" ChangeVariant="neutral" />
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-lg-7">
        <div class="section-card h-100">
            <div class="section-card-header">
                <h2>@L["StudentDashboard_UpcomingCourses"]</h2>
                <a href="student/courses" class="btn btn-sm btn-link">@L["Button_ViewAll"]</a>
            </div>
            @if (_lessonsLoading)
            {
                <div class="d-flex align-items-center gap-2 p-3">
                    <span class="spinner-border spinner-border-sm text-primary"></span>
                    <span class="text-muted small">Chargement…</span>
                </div>
            }
            else if (_upcomingLessons.Count == 0)
            {
                <p class="text-muted small p-3">Aucune séance à venir.</p>
            }
            else
            {
                <ul class="lesson-list">
                    @foreach (var lesson in _upcomingLessons)
                    {
                        <li class="lesson-list-item">
                            <div class="lesson-avatar" style="background: var(--ts-gradient-primary)">
                                @(lesson.Subject?.Length > 0 ? lesson.Subject[0].ToString().ToUpperInvariant() : "?")
                            </div>
                            <div class="lesson-info">
                                <strong>@lesson.Title</strong>
                                <span>@lesson.StartTime.ToLocalTime().ToString("ddd dd/MM HH:mm")</span>
                            </div>
                            <span class="lesson-time">@LessonService.ModeToDisplay(lesson.Mode)</span>
                        </li>
                    }
                </ul>
            }
        </div>
    </div>
    <div class="col-lg-5">
        <div class="section-card h-100">
            <div class="section-card-header">
                <h2>@L["StudentDashboard_RecentReports"]</h2>
            </div>
            @if (_reportsLoading)
            {
                <div class="d-flex align-items-center gap-2 p-3">
                    <span class="spinner-border spinner-border-sm text-primary"></span>
                    <span class="text-muted small">Chargement…</span>
                </div>
            }
            else if (_recentReports.Count == 0)
            {
                <p class="text-muted small p-3">Aucun rapport disponible.</p>
            }
            else
            {
                @foreach (var report in _recentReports)
                {
                    <div class="lesson-list-item mb-2">
                        <div class="lesson-avatar">📋</div>
                        <div class="lesson-info">
                            <strong>@(report.TopicsStudied ?? "Séance")</strong>
                            <span>@report.CreatedAt.ToString("dd MMMM yyyy")</span>
                        </div>
                    </div>
                }
            }
        </div>
    </div>
</div>

<div class="row g-3">
    <div class="col-md-4">
        <div class="mini-stat-card">
            <i class="bi bi-journal-text mini-stat-icon mini-stat-icon--warning"></i>
            <div>
                <span class="mini-stat-label">@L["StudentDashboard_PendingHomework"]</span>
                <span class="mini-stat-value">@_pendingHomework</span>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="mini-stat-card">
            <i class="bi bi-folder2-open mini-stat-icon mini-stat-icon--info"></i>
            <div>
                <span class="mini-stat-label">@L["StudentDashboard_Documents"]</span>
                <span class="mini-stat-value">@_documentCount</span>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="mini-stat-card">
            <i class="bi bi-star-fill mini-stat-icon mini-stat-icon--success"></i>
            <div>
                <span class="mini-stat-label">@L["StudentDashboard_LastGrade"]</span>
                <span class="mini-stat-value">@(_lastGrade.HasValue ? $"{_lastGrade:N0}%" : "—")</span>
            </div>
        </div>
    </div>
</div>

@code {
    private string _studentName   = "Élève";
    private bool   _lessonsLoading  = true;
    private bool   _reportsLoading  = true;
    private int    _weekLessons     = 0;
    private int    _pendingHomework = 0;
    private int    _documentCount   = 0;
    private decimal? _lastGrade;
    private List<LessonDto>            _upcomingLessons = [];
    private List<LessonReportApiDto>   _recentReports   = [];

    protected override async Task OnInitializedAsync()
    {
        var t1 = LoadLessonsAsync();
        var t2 = LoadProfileAsync();
        await Task.WhenAll(t1, t2);
    }

    private async Task LoadLessonsAsync()
    {
        try
        {
            var lessons = await LessonSvc.GetLessonsAsync();
            var now     = DateTime.UtcNow;
            _upcomingLessons = lessons
                .Where(l => l.StartTime >= now)
                .OrderBy(l => l.StartTime)
                .Take(5)
                .ToList();

            var weekEnd = now.AddDays(7);
            _weekLessons = lessons.Count(l => l.StartTime >= now && l.StartTime < weekEnd);
        }
        catch { }
        finally { _lessonsLoading = false; }
    }

    private async Task LoadProfileAsync()
    {
        try
        {
            var profile = await Api.GetAsync<StudentProfileDto>("api/students/me");
            if (profile != null)
            {
                _studentName = profile.FirstName ?? "Élève";

                var reports = await Api.GetAsync<List<LessonReportApiDto>>(
                    $"api/lessonreports/student/{profile.Id}") ?? [];
                _recentReports = [.. reports.OrderByDescending(r => r.CreatedAt).Take(3)];
                _reportsLoading = false;

                var homework = await Api.GetAsync<List<HomeworkDto>>(
                    $"api/homework/student/{profile.Id}") ?? [];
                _pendingHomework = homework.Count(h => h.SubmittedAt == null && !h.IsGraded);
                _lastGrade = homework
                    .Where(h => h.Grade.HasValue)
                    .OrderByDescending(h => h.CreatedAt)
                    .Select(h => h.Grade)
                    .FirstOrDefault();

                var docs = await Api.GetAsync<List<DocumentDto>>(
                    $"api/documents?studentId={profile.Id}") ?? [];
                _documentCount = docs.Count;
                return;
            }
        }
        catch { }
        _reportsLoading = false;
    }

    private record LessonReportApiDto(
        Guid Id, Guid TenantId, Guid LessonId, Guid StudentId,
        string? TopicsStudied, string? Participation, string? Strengths,
        string? Weaknesses, string? HomeworkAssigned, string? Observations,
        bool SentToParent, DateTime? SentAt, DateTime CreatedAt, DateTime? UpdatedAt);

    private record HomeworkDto(
        Guid Id, Guid TenantId, Guid StudentId, Guid? LessonId,
        string Title, string? Description, DateTime? DueDate,
        DateTime? SubmittedAt, string? SubmissionNotes, decimal? Grade,
        string? Feedback, bool IsGraded, DateTime CreatedAt, DateTime? UpdatedAt);

    private record DocumentDto(Guid Id, string Name, string? Url, long? Size, DateTime CreatedAt);
    private record StudentProfileDto(Guid Id, string? FirstName, string? LastName);
}
