            if (p is null) return;
            p.IsOnline = true;
            p.HasRemoteVideo = hasVideo;
            if (hasVideo) p.CamOn = true;
            if (hasAudio) p.MicOn = true;
            if (hasAudio) p.IsSpeaking = true;

            if (hasVideo && _watchingBoardShareFrom == connectionId)
            {
                try { await JS.InvokeVoidAsync("classroomRtc.focusBoardShare", connectionId); } catch { }
            }
            else if (hasVideo && _viewMode is "speaker" or "presenter"
                && (_focusedPeer is null || _focusedPeer.ConnectionId == connectionId))
            {
                _focusedPeer = p;
                try { await JS.InvokeVoidAsync("classroomRtc.focusRemote", connectionId); } catch { }
            }
            _needRtcRemount = true;
            StateHasChanged();
            try { await JS.InvokeVoidAsync("classroomRtc.setRemoteMediaVisible", connectionId, p.CamOn && hasVideo); } catch { }
            try { await JS.InvokeVoidAsync("classroomRtc.unlockAudio"); } catch { }
        });

    [JSInvokable]
    public Task OnRtcConnectionState(string connectionId, string state) =>
        InvokeAsync(() =>
        {
            var p = _participants.FirstOrDefault(x => x.ConnectionId == connectionId);
            if (p is null) return Task.CompletedTask;
            if (state == "closed")
            {
                p.HasRemoteVideo = false;
                p.IsOnline = false;
                StateHasChanged();
            }
            else if (state == "failed")
            {
                p.HasRemoteVideo = false;
                StateHasChanged();
            }
            else if (state == "connected")
            {
                p.IsOnline = true;
                StateHasChanged();
            }
            return Task.CompletedTask;
        });

