    private async Task SetBackgroundAsync(string mode, string? preset = null, string? imageUrl = null)
    {
        _showBgMenu = false;
        if (!_mediaReady || !_camOn)
        {
            _mediaError = L["Classroom_BgNeedCamera"].Value;
            return;
        }

        try
        {
            var result = await JS.InvokeAsync<MediaStartResult>(
                "classroomMedia.setBackgroundEffect",
                _localVideo,
                new { mode, preset, imageUrl });

            if (result is null || !result.Ok)
            {
                _mediaError = result?.Error ?? L["Classroom_BgFailed"].Value;
                return;
            }

            _bgMode = mode;
            _bgPreset = mode == "image" ? preset : null;
            _mediaError = null;
        }
        catch (JSException ex)
        {
            _mediaError = ex.Message;
        }
    }

    private async Task OnBackgroundFileAsync(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file is null) return;
        try
        {
            await using var stream = file.OpenReadStream(maxAllowedSize: 4 * 1024 * 1024);
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);
            var b64 = Convert.ToBase64String(ms.ToArray());
            var mime = string.IsNullOrWhiteSpace(file.ContentType) ? "image/jpeg" : file.ContentType;
            await SetBackgroundAsync("image", null, $"data:{mime};base64,{b64}");
            _bgPreset = "custom";
        }
        catch (Exception ex)
        {
            _mediaError = ex.Message;
        }
    }

    private async Task ToggleShare()
    {
        if (_sharing)
        {
            try { await JS.InvokeVoidAsync("classroomMedia.stopScreenShare", _localVideo); }
            catch { }
            _sharing = false;
            return;
        }

        try
        {
            var result = await JS.InvokeAsync<MediaStartResult>("classroomMedia.startScreenShare", _localVideo);
            if (result is null || !result.Ok)
            {
                _mediaError = result?.Error ?? "Partage d'écran impossible.";
                return;
            }
            _sharing = true;
            _mediaError = null;
        }
        catch (JSException ex)
        {
            _mediaError = ex.Message;
        }
    }

