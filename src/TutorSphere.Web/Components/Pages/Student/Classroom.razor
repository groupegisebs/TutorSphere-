        await PresentDocumentOnBoardAsync(
            doc.Id.Value,
            doc.ContentType,
            broadcast: _shareLive && _sharingWhiteboard,
            displayName: doc.Name);
    }

    /// <summary>
    /// Affiche un document comme le tableau en avant (zone principale + panélistes à gauche),
    /// puis le diffuse aux autres participants si demandé.
    /// </summary>
    private async Task PresentDocumentOnBoardAsync(Guid documentId, string? contentType, bool broadcast, string? displayName)
    {
        _wbForeground = true;
        _wbCollapsed = false;
        _boardDocName = displayName
            ?? _documents.FirstOrDefault(d => d.Id == documentId)?.Name
            ?? L["Classroom_SharedDoc"].Value;
        _needRtcRemount = true;
        await InvokeAsync(StateHasChanged);
        await Task.Delay(50);

        try
        {
            await JS.InvokeVoidAsync("whiteboard.init", _canvasRef);
            _wbReady = true;
        }
        catch { /* circuit not ready */ }

        await ApplyDocumentBackgroundLocalAsync(documentId, contentType, broadcast);
        await InvokeAsync(StateHasChanged);
    }

    private async Task ApplyDocumentBackgroundLocalAsync(Guid documentId, string? contentType, bool broadcast)
    {
        var result = await Api.GetBytesWithErrorAsync($"api/students/me/documents/{documentId}/file");
        if (result.Value is null || result.Value.Length == 0)
        {
            // Fallback: tutor-uploaded lesson docs may only be on the tutor API for the teacher;
            // students use the portal route. If that fails, try the shared documents route.
            result = await Api.GetBytesWithErrorAsync($"api/documents/{documentId}/file");
        }

        if (result.Value is null || result.Value.Length == 0)
        {
            _mediaError = result.Error ?? L["Classroom_BgFailed"].Value;
            return;
        }

        var mime = string.IsNullOrWhiteSpace(contentType) ? "image/png" : contentType;
        if (!mime.StartsWith("image/", StringComparison.OrdinalIgnoreCase))
        {
            _mediaError = L["Classroom_AnnotateImagesOnly"].Value;
            return;
        }

        var dataUrl = $"data:{mime};base64,{Convert.ToBase64String(result.Value)}";
        try
        {
            var ok = await JS.InvokeAsync<bool>("whiteboard.setBackground", dataUrl);
            if (!ok)
            {
                await Task.Delay(80);
                try { await JS.InvokeVoidAsync("whiteboard.init", _canvasRef); } catch { }
                ok = await JS.InvokeAsync<bool>("whiteboard.setBackground", dataUrl);
            }
            if (!ok)
            {
                _mediaError = L["Classroom_BgFailed"].Value;
                return;
            }
        }
        catch (JSException ex)
        {
            _mediaError = ex.Message;
            return;
        }

        var local = _documents.FirstOrDefault(d => d.Id == documentId);
        _boardDocName = local?.Name ?? _boardDocName ?? L["Classroom_SharedDoc"].Value;

        if (broadcast && _lessonGuid is Guid lid)
            await ClassroomRt.SetBackgroundAsync(lid, documentId.ToString("D"), mime);
    }

    private void PrevPage() { if (_wbPage > 1)             _wbPage--; }
    private void NextPage() { if (_wbPage < _wbTotalPages) _wbPage++; }
    private void ZoomOut()  { if (_wbZoom > 25)  _wbZoom = Math.Max(25,  _wbZoom - 25); }
    private void ZoomIn()   { if (_wbZoom < 200) _wbZoom = Math.Min(200, _wbZoom + 25); }

    private static string GetSenderColor(string sender) =>
        sender.StartsWith("É", StringComparison.OrdinalIgnoreCase) ? "#7c3aed" : "#5831E0";

    private static string GetSenderInitials(string sender)
    {
        var parts = sender.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length >= 2)
            return $"{char.ToUpperInvariant(parts[0][0])}{char.ToUpperInvariant(parts[^1][0])}";
        return sender.Length > 0 ? sender[..Math.Min(2, sender.Length)].ToUpperInvariant() : "?";
    }

    private List<ParticipantVM> _participants = [];

    private List<ChatMsg> _chatMessages = [];

    private void InitChatMessages()
    {
        _chatMessages = [];
    }

    private List<DocumentVM> _documents = [];

    private static string FormatSize(long bytes) =>
        bytes < 1024 ? $"{bytes} o"
        : bytes < 1024 * 1024 ? $"{bytes / 1024.0:0.#} Ko"
        : $"{bytes / (1024.0 * 1024):0.#} Mo";

    private static string InitialsFrom(string name)
    {
        var parts = name.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length >= 2)
            return $"{char.ToUpperInvariant(parts[0][0])}{char.ToUpperInvariant(parts[^1][0])}";
        return name.Length > 0 ? name[..Math.Min(2, name.Length)].ToUpperInvariant() : "?";
    }

