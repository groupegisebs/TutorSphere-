@page "/student/classroom/{lessonId}"
@layout StudentLayout
@rendermode InteractiveServer
@implements IDisposable
@inject IStringLocalizer<SharedResources> L
@inject NavigationManager Navigation
@inject IJSRuntime JS
@using TutorSphere.Application.DTOs.Lessons
@using TutorSphere.Application.DTOs.Documents
@using TutorSphere.Application.DTOs.Messages
@inject AuthService Auth
@inject ApiClient Api
@inject RealtimeClassroomClient ClassroomRt

<PageTitle>@L["Classroom_Title"] – TutorSphere</PageTitle>

<div class="cr-page @(_wbForeground ? "cr-page--wb-front" : null)">

    <!-- ── Lesson header (light) ── -->
    <div class="cr-lesson-header">
        <div class="cr-lesson-meta">
            <div class="cr-lesson-icon">
                <i class="bi bi-mortarboard-fill"></i>
            </div>
            <div>
                <div class="cr-lesson-title">@_lesson.Title</div>
                <div class="cr-lesson-sub">@_lesson.Subject</div>
            </div>
            <span class="cr-badge-live">
                <i class="bi bi-circle-fill" style="font-size:0.45rem;vertical-align:middle;"></i>
                @L["Classroom_Live"]
            </span>
        </div>
        <div class="cr-lesson-actions">
            <a href="/student/courses" class="cr-school-link">
                @L["Nav_Courses"] <i class="bi bi-box-arrow-up-right" style="font-size:0.75rem;"></i>
            </a>
            <span class="cr-elapsed-badge">
                <i class="bi bi-clock" style="font-size:0.75rem;margin-right:3px;"></i>
                @FormatElapsed(_elapsedSeconds)
            </span>
            <button class="cr-end-btn" @onclick="EndSession">
                <i class="bi bi-box-arrow-left me-1"></i>@L["Classroom_Leave"]
            </button>
        </div>
    </div>

    <!-- ── Video gallery (dark) ── -->
    <div class="cr-video-section">
        <div class="cr-gallery-header">
            <span class="cr-gallery-label">
                <i class="bi bi-camera-video-fill me-1"></i>@L["Classroom_Title"]
            </span>
            <button class="cr-gallery-mode-btn">
                <i class="bi bi-grid me-1"></i>@L["Classroom_Gallery"]
            </button>
        </div>
        <div class="cr-gallery">
            <div class="cr-tile-main">
                <div class="cr-tile-bg cr-tile-bg--student">
                    <video data-rtc-main
                           class="cr-tile-video @(_showRemoteMain ? "" : "is-hidden")"
                           autoplay
                           playsinline></video>
                    <video @ref="_localVideo"
                           class="cr-tile-video @(_showLocalVideo && !_showRemoteMain ? "" : "is-hidden")"
                           autoplay
                           playsinline
                           muted></video>
                    @if (!_showLocalVideo && !_showRemoteMain)
                    {
                        <i class="bi bi-person-fill cr-tile-placeholder-icon"></i>
                    }
                    @if (!string.IsNullOrEmpty(_mediaError) && !_showRemoteMain)
                    {
                        <div class="cr-media-error" role="alert">
                            <i class="bi bi-exclamation-triangle-fill" aria-hidden="true"></i>
                            <span>@_mediaError</span>
                        </div>
                    }
                </div>
                <div class="cr-tile-label">
                    @if (_showRemoteMain && _focusedPeer is not null)
                    {
                        <div class="cr-tile-av" style="background:@_focusedPeer.Color;">@_focusedPeer.Initials</div>
                        <span class="cr-tile-name">@_focusedPeer.Name</span>
                        <span class="cr-tile-media-icons">
                            <i class="bi @(_focusedPeer.MicOn ? "bi-mic-fill" : "bi-mic-mute-fill") @(_focusedPeer.MicOn ? "" : "cr-icon-off")"></i>
                            <i class="bi @(_focusedPeer.CamOn || _focusedPeer.HasRemoteVideo ? "bi-camera-video-fill" : "bi-camera-video-off-fill") @(_focusedPeer.CamOn || _focusedPeer.HasRemoteVideo ? "" : "cr-icon-off")"></i>
                        </span>
                    }
                    else
                    {
                        <div class="cr-tile-av" style="background:#7c3aed;">@SelfInitials</div>
                        <span class="cr-tile-name">@SelfDisplayName</span>
                        <span class="cr-tile-you">Vous</span>
                        <span class="cr-tile-media-icons">
                            <i class="bi @(_micOn ? "bi-mic-fill" : "bi-mic-mute-fill") @(_micOn ? "" : "cr-icon-off")"></i>
                            <i class="bi @(_camOn ? "bi-camera-video-fill" : "bi-camera-video-off-fill") @(_camOn ? "" : "cr-icon-off")"></i>
                        </span>
                    }
                </div>
            </div>
            <div class="cr-tiles-col">
                @foreach (var p in _participants.Where(x => x.Role != "Élève"))
                {
                    <div class="cr-tile-student" @onclick="() => FocusPeer(p)" title="@p.Name">
                        <div class="cr-tile-bg cr-tile-bg--tutor">
                            @if (!string.IsNullOrEmpty(p.ConnectionId))
                            {
                                <video data-rtc-peer="@p.ConnectionId"
                                       class="cr-tile-video @(p.HasRemoteVideo && !_showRemoteMain ? "" : "is-hidden")"
                                       autoplay
                                       playsinline></video>
                            }
                            @if (!p.HasRemoteVideo || _showRemoteMain || string.IsNullOrEmpty(p.ConnectionId))
                            {
                                <i class="bi bi-person-fill" style="font-size:1.5rem;color:rgba(255,255,255,0.2);"></i>
                            }
                            @if (p.IsOnline)
                            {
                                <span class="cr-peer-online" title="@L["Classroom_Online"]"></span>
                            }
                        </div>
                        <div class="cr-tile-label cr-tile-label-sm">
                            <div class="cr-tile-av cr-tile-av-sm" style="background:@p.Color;">@p.Initials</div>
                            <span class="cr-tile-name">@p.Name</span>
                            <span class="cr-tile-media-icons">
                                <i class="bi @(p.MicOn ? "bi-mic-fill" : "bi-mic-mute-fill") @(p.MicOn ? "" : "cr-icon-off")"></i>
                                <i class="bi @(p.CamOn || p.HasRemoteVideo ? "bi-camera-video-fill" : "bi-camera-video-off-fill") @(p.CamOn || p.HasRemoteVideo ? "" : "cr-icon-off")"></i>
                            </span>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- ── Work area: whiteboard (left) + chat panel (right) ── -->
    <div class="cr-work-area">

        <!-- Whiteboard section -->
        <div class="cr-wb-section">
            <!-- Toolbar -->
            <div class="cr-wb-toolbar">
                <div class="cr-wb-tools">
                    <button class="cr-wb-tool @(_wbTool == "select" ? "active" : "")" @onclick='() => SetWbTool("select")' title="@L["Classroom_Select"]">
                        <i class="bi bi-cursor-fill"></i>
                    </button>
                    <button class="cr-wb-tool @(_wbTool == "pen" ? "active" : "")" @onclick='() => SetWbTool("pen")' title="@L["Classroom_Pen"]">
                        <i class="bi bi-pencil-fill"></i>
                    </button>
                    <button class="cr-wb-tool @(_wbTool == "eraser" ? "active" : "")" @onclick='() => SetWbTool("eraser")' title="@L["Classroom_Eraser"]">
                        <i class="bi bi-eraser-fill"></i>
                    </button>
                    <button class="cr-wb-tool @(_wbTool == "rect" ? "active" : "")" @onclick='() => SetWbTool("rect")' title="Rectangle">
                        <i class="bi bi-square"></i>
                    </button>
                    <button class="cr-wb-tool @(_wbTool == "text" ? "active" : "")" @onclick='() => SetWbTool("text")' title="Texte">
                        <i class="bi bi-fonts"></i>
                    </button>
                    <button class="cr-wb-tool @(_wbTool == "line" ? "active" : "")" @onclick='() => SetWbTool("line")' title="Ligne">
                        <i class="bi bi-slash-lg"></i>
                    </button>
                    <button class="cr-wb-tool" title="Image"><i class="bi bi-image"></i></button>
                    <button class="cr-wb-tool" title="Emoji"><i class="bi bi-emoji-smile"></i></button>
                    <button class="cr-wb-tool" title="Plus"><i class="bi bi-three-dots"></i></button>
                </div>
                <div class="cr-wb-sep"></div>
                <div class="cr-wb-colors">
                    @foreach (var clr in _wbColors)
                    {
                        <button class="cr-wb-color @(_wbColor == clr ? "active" : "")"
                                style="background:@clr;"
                                @onclick='() => SetWbColor(clr)'
                                title="@clr"></button>
                    }
                </div>
                <div class="cr-wb-sep"></div>
                <button class="cr-wb-size-btn @(_wbSize == "thin" ? "active" : "")" @onclick='() => SetWbSize("thin")' title="Fin">
                    <span class="cr-size-dot" style="width:3px;height:3px;"></span>
                </button>
                <button class="cr-wb-size-btn @(_wbSize == "medium" ? "active" : "")" @onclick='() => SetWbSize("medium")' title="Moyen">
                    <span class="cr-size-dot" style="width:7px;height:7px;"></span>
                </button>
                <button class="cr-wb-size-btn @(_wbSize == "thick" ? "active" : "")" @onclick='() => SetWbSize("thick")' title="Épais">
                    <span class="cr-size-dot" style="width:12px;height:12px;"></span>
                </button>
                <div class="cr-wb-sep"></div>
                <button class="cr-wb-tool" @onclick="ClearWhiteboard" title="@L["Classroom_ClearAll"]">
                    <i class="bi bi-trash3"></i>
                </button>
            </div>

            <!-- Canvas -->
            <div class="cr-canvas-wrapper">
                @if (!string.IsNullOrEmpty(_boardDocName))
                {
                    <div class="cr-board-doc-badge">
                        <i class="bi bi-image me-1"></i>@_boardDocName
                        <span class="text-muted"> — @L["Classroom_AnnotateHint"]</span>
                    </div>
                }
                <canvas @ref="_canvasRef" class="cr-canvas"></canvas>
            </div>

            <!-- Footer: page nav + zoom -->
            <div class="cr-wb-footer">
                <button class="cr-wb-foot-btn" @onclick="PrevPage" title="Page précédente">
                    <i class="bi bi-chevron-left"></i>
                </button>
                <span class="cr-wb-page-info">@_wbPage / @_wbTotalPages</span>
                <button class="cr-wb-foot-btn" @onclick="NextPage" title="Page suivante">
                    <i class="bi bi-chevron-right"></i>
                </button>
                <div style="flex:1;"></div>
                <button class="cr-wb-foot-btn" @onclick="ZoomOut" title="Zoom arrière">−</button>
                <span class="cr-wb-zoom-label">@_wbZoom%</span>
                <button class="cr-wb-foot-btn" @onclick="ZoomIn" title="Zoom avant">+</button>
                <button class="cr-wb-foot-btn ms-2 @(_wbForeground ? "active" : "")"
                        @onclick="ToggleWhiteboardForeground"
                        title="@L["Classroom_WbForeground"]">
                    <i class="bi @(_wbForeground ? "bi-fullscreen-exit" : "bi-fullscreen")"></i>
                </button>
            </div>
        </div>

        <!-- Right panel: Chat / Participants / Documents -->
        <div class="cr-panel">
            <div class="cr-panel-tabs">
                <button class="cr-panel-tab @(_activeTab == "Chat" ? "active" : "")" @onclick='() => _activeTab = "Chat"'>
                    @L["Classroom_Chat"]
                </button>
                <button class="cr-panel-tab @(_activeTab == "Participants" ? "active" : "")" @onclick='() => _activeTab = "Participants"'>
                    @L["Classroom_Participants"] <span class="cr-tab-count">@_participants.Count</span>
                </button>
                <button class="cr-panel-tab @(_activeTab == "Documents" ? "active" : "")" @onclick='() => _activeTab = "Documents"'>
                    @L["Classroom_Documents"]
                </button>
            </div>

            <div class="cr-panel-body">
                @if (_activeTab == "Chat")
                {
                    <div class="cr-chat-messages" id="cr-chat-scroll">
                        <div class="cr-chat-date-sep">Aujourd'hui</div>
                        @foreach (var msg in _chatMessages)
                        {
                            @if (msg.IsMe)
                            {
                                <div class="cr-msg-row cr-msg-me">
                                    <div class="cr-msg-bubble cr-msg-bubble-me">@msg.Text</div>
                                    <div class="cr-msg-time-me">@msg.Time</div>
                                </div>
                            }
                            else
                            {
                                <div class="cr-msg-row cr-msg-them">
                                    <div class="cr-msg-av-sm" style="background:@GetSenderColor(msg.Sender);">
                                        @GetSenderInitials(msg.Sender)
                                    </div>
                                    <div class="cr-msg-body">
                                        <div class="cr-msg-header">
                                            <span class="cr-msg-sender">@msg.Sender</span>
                                            <span class="cr-msg-time">@msg.Time</span>
                                        </div>
                                        <div class="cr-msg-bubble cr-msg-bubble-them">@msg.Text</div>
                                    </div>
                                </div>
                            }
                        }
                    </div>
                    <div class="cr-chat-input-bar">
                        <button class="cr-chat-icon-btn" title="Emoji">
                            <i class="bi bi-emoji-smile"></i>
                        </button>
                        <input class="cr-chat-input"
                               placeholder="@L["Classroom_TypeMessage"]"
                               @bind="_newMessage"
                               @bind:event="oninput"
                               @onkeydown="OnChatKeyDown" />
                        <button class="cr-chat-icon-btn" title="Pièce jointe">
                            <i class="bi bi-paperclip"></i>
                        </button>
                        <button class="cr-chat-send-btn" @onclick="SendMessage" title="Envoyer">
                            <i class="bi bi-send-fill"></i>
                        </button>
                    </div>
                }
                else if (_activeTab == "Participants")
                {
                    <div class="cr-participants-list">
                        @foreach (var p in _participants)
                        {
                            <div class="cr-participant-row">
                                <div class="cr-p-avatar" style="background:@p.Color;">@p.Initials</div>
                                <div class="cr-p-info">
                                    <div class="cr-p-name">@p.Name</div>
                                    <div class="cr-p-role">@p.Role</div>
                                </div>
                                <div class="cr-p-media">
                                    <span class="@(p.MicOn ? "cr-p-icon-on" : "cr-p-icon-off")">
                                        <i class="bi @(p.MicOn ? "bi-mic-fill" : "bi-mic-mute-fill")"></i>
                                    </span>
                                    <span class="@(p.CamOn ? "cr-p-icon-on" : "cr-p-icon-off")">
                                        <i class="bi @(p.CamOn ? "bi-camera-video-fill" : "bi-camera-video-off-fill")"></i>
                                    </span>
                                </div>
                            </div>
                        }
                    </div>
                }
                else if (_activeTab == "Documents")
                {
                    <div class="cr-docs-list">
                        @if (_documents.Count == 0)
                        {
                            <p class="text-muted small px-2">Aucun document pour cette séance.</p>
                        }
                        @foreach (var doc in _documents)
                        {
                            <div class="cr-doc-row">
                                <i class="bi @(doc.IsImage ? "bi-file-earmark-image" : "bi-file-earmark-text") cr-doc-icon"></i>
                                <div class="cr-doc-meta">
                                    <div class="cr-doc-name">@doc.Name</div>
                                    <div class="cr-doc-size">@doc.Size</div>
                                </div>
                                @if (doc.IsImage && doc.Id.HasValue)
                                {
                                    <button type="button" class="cr-doc-dl-btn" title="@L["Classroom_AnnotateDoc"]"
                                            @onclick="() => OpenDocumentOnBoardAsync(doc)">
                                        <i class="bi bi-pencil-square"></i>
                                    </button>
                                }
                                @if (!string.IsNullOrEmpty(doc.Url))
                                {
                                    <a class="cr-doc-dl-btn" href="@doc.Url" target="_blank" rel="noopener" title="@L["Common_Download"]">
                                        <i class="bi bi-download"></i>
                                    </a>
                                }
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- ── Bottom toolbar (dark) ── -->
    <div class="cr-toolbar">
        <div class="cr-tool-item">
            <button class="cr-tool-btn @(_micOn ? "" : "cr-tool-btn--muted")" @onclick="ToggleMic"
                    title="@L["Classroom_Mic"]">
                <i class="bi @(_micOn ? "bi-mic-fill" : "bi-mic-mute-fill")"></i>
            </button>
            <span class="cr-tool-lbl">@L["Classroom_Mic"]</span>
        </div>
        <div class="cr-tool-item">
            <button class="cr-tool-btn @(_camOn ? "" : "cr-tool-btn--muted")" @onclick="ToggleCam"
                    title="@(_cameraAvailable ? L["Classroom_Camera"].Value : L["Classroom_NoCamera"].Value)">
                <i class="bi @(_camOn ? "bi-camera-video-fill" : "bi-camera-video-off-fill")"></i>
            </button>
            <span class="cr-tool-lbl">@L["Classroom_Camera"]</span>
        </div>
        <div class="cr-tool-item cr-tool-item--menu">
            <button class="cr-tool-btn @(_bgMode != "none" ? "cr-tool-btn--active" : "")"
                    @onclick="() => _showBgMenu = !_showBgMenu"
                    title="@L["Classroom_Background"]">
                <i class="bi bi-person-bounding-box"></i>
            </button>
            <span class="cr-tool-lbl">@L["Classroom_Background"]</span>
            @if (_showBgMenu)
            {
                <div class="cr-bg-menu" @onclick:stopPropagation="true">
                    <div class="cr-bg-menu-title">@L["Classroom_Background"]</div>
                    <button type="button" class="cr-bg-opt @(_bgMode == "none" ? "active" : "")" @onclick='() => SetBackgroundAsync("none")'>
                        <i class="bi bi-slash-circle"></i> @L["Classroom_BgNone"]
                    </button>
                    <button type="button" class="cr-bg-opt @(_bgMode == "blur" ? "active" : "")" @onclick='() => SetBackgroundAsync("blur")'>
                        <i class="bi bi-droplet-half"></i> @L["Classroom_BgBlur"]
                    </button>
                    <button type="button" class="cr-bg-opt @(_bgPreset == "office" ? "active" : "")" @onclick='() => SetBackgroundAsync("image", "office")'>
                        <i class="bi bi-building"></i> @L["Classroom_BgOffice"]
                    </button>
                    <button type="button" class="cr-bg-opt @(_bgPreset == "library" ? "active" : "")" @onclick='() => SetBackgroundAsync("image", "library")'>
                        <i class="bi bi-book"></i> @L["Classroom_BgLibrary"]
                    </button>
                    <button type="button" class="cr-bg-opt @(_bgPreset == "classroom" ? "active" : "")" @onclick='() => SetBackgroundAsync("image", "classroom")'>
                        <i class="bi bi-easel2"></i> @L["Classroom_BgClassroom"]
                    </button>
                    <label class="cr-bg-opt cr-bg-upload">
                        <i class="bi bi-image"></i> @L["Classroom_BgCustom"]
                        <InputFile OnChange="OnBackgroundFileAsync" accept="image/*" />
                    </label>
                </div>
            }
        </div>
        <div class="cr-tool-item">
            <button class="cr-tool-btn @(_sharing ? "cr-tool-btn--active" : "")" @onclick="ToggleShare" title="@L["Classroom_ShareScreen"]">
                <i class="bi bi-display"></i>
            </button>
            <span class="cr-tool-lbl">@L["Classroom_Share"]</span>
        </div>
        <div class="cr-tool-item">
            <button class="cr-tool-btn @(_wbForeground ? "cr-tool-btn--active" : "")"
                    @onclick="ToggleWhiteboardForeground"
                    title="@L["Classroom_WbForeground"]">
                <i class="bi bi-easel"></i>
            </button>
            <span class="cr-tool-lbl">@L["Classroom_WbForegroundShort"]</span>
        </div>
        <div class="cr-tool-item">
            <button class="cr-tool-btn" @onclick='() => _activeTab = "Participants"' title="@L["Classroom_Participants"]">
                <i class="bi bi-people-fill"></i>
            </button>
            <span class="cr-tool-lbl">@L["Classroom_Participants"]</span>
        </div>
        <div class="cr-tool-item">
            <button class="cr-tool-btn" title="@L["Classroom_Poll"]">
                <i class="bi bi-bar-chart-fill"></i>
            </button>
            <span class="cr-tool-lbl">@L["Classroom_Poll"]</span>
        </div>
        <div class="cr-tool-item">
            <button class="cr-tool-btn @(_recording ? "cr-tool-btn--danger" : "")" @onclick="ToggleRecording"
                    title="@L["Classroom_Record"]">
                <i class="bi @(_recording ? "bi-stop-circle-fill" : "bi-record-circle")"></i>
            </button>
            <span class="cr-tool-lbl">@L["Classroom_Record"]</span>
        </div>
        <div class="cr-tool-sep"></div>
        <div class="cr-tool-item">
            <button class="cr-tool-btn cr-tool-btn--quit" @onclick="GoBack" title="@L["Classroom_Leave"]">
                <i class="bi bi-box-arrow-right"></i>
            </button>
            <span class="cr-tool-lbl">@L["Classroom_Leave"]</span>
        </div>
    </div>
</div>

@code {
    [Parameter] public string LessonId { get; set; } = "";

    [SupplyParameterFromQuery] public string? Student   { get; set; }
    [SupplyParameterFromQuery] public string? Initials  { get; set; }
    [SupplyParameterFromQuery] public string? Title     { get; set; }
    [SupplyParameterFromQuery] public string? Subject   { get; set; }

    private int _elapsedSeconds;
    private System.Threading.Timer? _timer;

    private bool _micOn      = true;
    private bool _camOn      = true;
    private bool _cameraAvailable = true;
    private int _cameraCount;
    private bool _sharing    = false;
    private bool _recording  = false;
    private bool _mediaReady = false;
    private bool _mediaStarted;
    private string? _mediaError;
    private DotNetObjectReference<Classroom>? _jsRef;
    private bool _showBgMenu;
    private string _bgMode = "none";
    private string? _bgPreset;
    private bool _wbForeground;

    private ElementReference _localVideo;
    private bool _showLocalVideo => _sharing || (_camOn && _mediaReady);
    private ParticipantVM? _focusedPeer;
    private bool _showRemoteMain =>
        _focusedPeer is { HasRemoteVideo: true, ConnectionId: not null and not "" };

    private async Task FocusPeer(ParticipantVM peer)
    {
        if (_focusedPeer?.ConnectionId == peer.ConnectionId && _showRemoteMain)
        {
            _focusedPeer = null;
            try { await JS.InvokeVoidAsync("classroomRtc.clearMain"); } catch { }
            try { await JS.InvokeVoidAsync("classroomRtc.remountAll"); } catch { }
            return;
        }

        _focusedPeer = peer;
        if (!string.IsNullOrEmpty(peer.ConnectionId) && peer.HasRemoteVideo)
        {
            try { await JS.InvokeVoidAsync("classroomRtc.focusRemote", peer.ConnectionId); } catch { }
        }
    }

    private string _activeTab  = "Chat";
    private string _newMessage = "";

    private ClassroomLesson _lesson = new();

    // Whiteboard state
    private ElementReference _canvasRef;
    private bool   _wbReady = false;
    private string _wbTool  = "pen";
    private string _wbColor = "#000000";
    private string _wbSize  = "medium";
    private int    _wbPage  = 3;
    private int    _wbTotalPages = 12;
    private int    _wbZoom  = 100;

    private readonly string[] _wbColors =
        ["#ef4444", "#b91c1c", "#22c55e", "#3b82f6", "#000000", "#f97316", "#a855f7", "#eab308"];

    private string SelfDisplayName =>
        string.IsNullOrWhiteSpace(Auth.UserName) ? _lesson.StudentName : Auth.UserName!;

    private string SelfInitials
    {
        get
        {
            var parts = SelfDisplayName.Split([' ', '@'], StringSplitOptions.RemoveEmptyEntries);
            if (parts.Length >= 2)
                return $"{char.ToUpperInvariant(parts[0][0])}{char.ToUpperInvariant(parts[1][0])}";
            return SelfDisplayName.Length > 0 ? char.ToUpperInvariant(SelfDisplayName[0]).ToString() : "E";
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await Auth.EnsureSessionRestoredAsync(forceJs: true);
        LessonDto? dto = null;
        try
        {
            if (Guid.TryParse(LessonId, out var id))
            {
                var lessons = await Api.GetAsync<List<LessonDto>>("api/students/me/lessons") ?? [];
                dto = lessons.FirstOrDefault(l => l.Id == id);
            }
        }
        catch { /* keep query defaults */ }

        _lesson = new ClassroomLesson
        {
            Title           = !string.IsNullOrWhiteSpace(Title) ? Title!
                              : dto?.Title ?? "Cours",
            StudentName     = Auth.UserName ?? "Élève",
            StudentInitials = string.IsNullOrWhiteSpace(Initials)
                ? (Auth.UserName is { Length: > 0 } n ? n[..1].ToUpperInvariant() : "EL")
                : Initials!,
            Subject         = !string.IsNullOrWhiteSpace(Subject) ? Subject!
                              : dto?.Subject ?? "",
            AvatarColor     = "#7c3aed",
        };

        _participants =
        [
            new() { Name = "Tuteur", Initials = "TU", Color = "#5831E0", Role = "Tuteur",
                    MicOn = true, CamOn = true },
            new() { Name = SelfDisplayName, Initials = SelfInitials,
                    Color = _lesson.AvatarColor, Role = "Élève", MicOn = _micOn, CamOn = _camOn },
        ];

        try
        {
            var teachers = await Api.GetAsync<List<ConversationDto>>("api/students/me/teachers") ?? [];
            if (teachers.Count > 0)
            {
                var t = teachers[0];
                var name = string.IsNullOrWhiteSpace(t.OtherUserName) ? "Tuteur" : t.OtherUserName.Trim();
                var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
                var initials = parts.Length >= 2
                    ? $"{char.ToUpperInvariant(parts[0][0])}{char.ToUpperInvariant(parts[^1][0])}"
                    : name[..Math.Min(2, name.Length)].ToUpperInvariant();
                _participants[0] = new ParticipantVM
                {
                    Name = name,
                    Initials = initials,
                    Color = "#5831E0",
                    Role = "Tuteur",
                    MicOn = true,
                    CamOn = true
                };
            }
        }
        catch { /* keep default tutor label */ }

        if (Guid.TryParse(LessonId, out var lid))
        {
            try
            {
                var docs = await Api.GetAsync<List<DocumentDto>>("api/students/me/documents") ?? [];
                _documents = docs
                    .Where(d => d.LessonId == lid || d.LessonId is null)
                    .Select(d => new DocumentVM
                    {
                        Id = d.Id,
                        Name = d.FileName,
                        Size = FormatSize(d.FileSize),
                        Url = d.Url,
                        ContentType = d.ContentType
                    })
                    .ToList();
            }
            catch { _documents = []; }
        }

        InitChatMessages();

        _timer = new System.Threading.Timer(_ =>
        {
            _elapsedSeconds++;
            InvokeAsync(StateHasChanged);
        }, null, 1000, 1000);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!_wbReady)
        {
            try
            {
                await JS.InvokeVoidAsync("whiteboard.init", _canvasRef);
                _wbReady = true;
            }
            catch { /* prerender phase — JS not yet available */ }
        }

        if (firstRender && !_mediaStarted)
        {
            _mediaStarted = true;
            _jsRef = DotNetObjectReference.Create(this);
            try { await JS.InvokeVoidAsync("classroomMedia.setEndedCallback", _jsRef); } catch { }
            try { await JS.InvokeVoidAsync("whiteboard.setStrokeDotNetRef", _jsRef); } catch { }
            await ConnectCollaborativeBoardAsync();
            await StartLocalMediaAsync();
        }
    }

    public void Dispose()
    {
        _timer?.Dispose();
        ClassroomRt.StrokeReceived -= OnRemoteStroke;
        ClassroomRt.BoardCleared -= OnRemoteBoardCleared;
        ClassroomRt.BackgroundChanged -= OnRemoteBackground;
        ClassroomRt.PeerListReceived -= OnPeerList;
        ClassroomRt.PeerJoined -= OnPeerJoined;
        ClassroomRt.PeerLeft -= OnPeerLeft;
        ClassroomRt.PeerMediaStateChanged -= OnPeerMediaState;
        ClassroomRt.RtcSignalReceived -= OnRtcSignal;
        _ = ClassroomRt.LeaveAsync();
        try { _ = JS.InvokeVoidAsync("classroomRtc.stop"); } catch { }
        _jsRef?.Dispose();
        _ = StopLocalMediaAsync();
    }

