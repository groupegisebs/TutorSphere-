    private void OnChatHistory(Guid lessonId, IReadOnlyList<ClassroomChatMessageDto> messages) =>
        _ = InvokeAsync(() =>
        {
            if (_lessonGuid != lessonId) return;
            _chatMessages.Clear();
            foreach (var m in messages)
                AppendChatMessage(m);
            StateHasChanged();
        });

    private void AppendChatMessage(ClassroomChatMessageDto msg)
    {
        var selfId = ClassroomRt.ConnectionId ?? "";
        if (!string.IsNullOrEmpty(selfId) && msg.SenderConnectionId == selfId)
        {
            var pending = _chatMessages.LastOrDefault(m =>
                m.IsMe
                && m.Text == msg.Text
                && Math.Abs((m.SentAtUtc - msg.SentAtUtc).TotalSeconds) < 8);
            if (pending is not null)
            {
                pending.ConnectionId = msg.SenderConnectionId;
                pending.SentAtUtc = msg.SentAtUtc;
                pending.Time = msg.SentAtUtc.ToLocalTime().ToString("HH:mm");
                return;
            }
        }

        _chatMessages.Add(new ChatMsg
        {
            Text = msg.Text,
            IsMe = !string.IsNullOrEmpty(selfId) && msg.SenderConnectionId == selfId,
            Sender = msg.SenderDisplayName,
            Time = msg.SentAtUtc.ToLocalTime().ToString("HH:mm"),
            ConnectionId = msg.SenderConnectionId,
            SentAtUtc = msg.SentAtUtc
        });
    }

