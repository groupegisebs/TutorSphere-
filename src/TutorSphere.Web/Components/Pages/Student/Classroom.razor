    private static string GetSenderInitials(string sender)
    {
        var parts = sender.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length >= 2)
            return $"{char.ToUpperInvariant(parts[0][0])}{char.ToUpperInvariant(parts[^1][0])}";
        return sender.Length > 0 ? sender[..Math.Min(2, sender.Length)].ToUpperInvariant() : "?";
    }

