    private string? _boardDocName;

    private async Task ConnectCollaborativeBoardAsync()
    {
        if (!Guid.TryParse(LessonId, out var lid)) return;
        _lessonGuid = lid;
        ClassroomRt.StrokeReceived += OnRemoteStroke;
        ClassroomRt.BoardCleared += OnRemoteBoardCleared;
        ClassroomRt.BackgroundChanged += OnRemoteBackground;
        ClassroomRt.PeerListReceived += OnPeerList;
        ClassroomRt.PeerJoined += OnPeerJoined;
        ClassroomRt.PeerLeft += OnPeerLeft;
        ClassroomRt.PeerMediaStateChanged += OnPeerMediaState;
        ClassroomRt.RtcSignalReceived += OnRtcSignal;

        if (_jsRef is not null)
        {
            try { await JS.InvokeVoidAsync("classroomRtc.init", _jsRef, new { polite = true }); }
            catch { }
        }

        await ClassroomRt.JoinLessonAsync(lid, SelfDisplayName, "Élève");
        await BroadcastOwnMediaStateAsync();
    }

    private void OnPeerList(Guid lessonId, IReadOnlyList<ClassroomPeerDto> peers) =>
        _ = InvokeAsync(async () =>
        {
            if (_lessonGuid != lessonId) return;
            foreach (var peer in peers)
            {
                UpsertLivePeer(peer);
                try { await JS.InvokeVoidAsync("classroomRtc.connect", peer.ConnectionId, true); }
                catch { }
            }
            await Task.Delay(50);
            try { await JS.InvokeVoidAsync("classroomRtc.remountAll"); } catch { }
            StateHasChanged();
        });

    private void OnPeerJoined(Guid lessonId, ClassroomPeerDto peer) =>
        _ = InvokeAsync(async () =>
        {
            if (_lessonGuid != lessonId) return;
            UpsertLivePeer(peer);
            try { await JS.InvokeVoidAsync("classroomRtc.connect", peer.ConnectionId, false); }
            catch { }
            StateHasChanged();
            await Task.Delay(80);
            try { await JS.InvokeVoidAsync("classroomRtc.remountAll"); } catch { }
        });

    private void OnPeerLeft(Guid lessonId, string connectionId) =>
        _ = InvokeAsync(async () =>
        {
            if (_lessonGuid != lessonId) return;
            try { await JS.InvokeVoidAsync("classroomRtc.closePeer", connectionId); } catch { }
            var p = _participants.FirstOrDefault(x => x.ConnectionId == connectionId);
            if (p is not null)
            {
                p.ConnectionId = null;
                p.IsOnline = false;
                p.HasRemoteVideo = false;
            }
            if (_focusedPeer?.ConnectionId == connectionId)
            {
                _focusedPeer = null;
                try { await JS.InvokeVoidAsync("classroomRtc.clearMain"); } catch { }
            }
            StateHasChanged();
        });

    private void OnPeerMediaState(Guid lessonId, string connectionId, bool micOn, bool camOn) =>
        _ = InvokeAsync(() =>
        {
            if (_lessonGuid != lessonId) return Task.CompletedTask;
            var p = _participants.FirstOrDefault(x => x.ConnectionId == connectionId);
            if (p is not null)
            {
                p.MicOn = micOn;
                p.CamOn = camOn;
                StateHasChanged();
            }
            return Task.CompletedTask;
        });

    private void OnRtcSignal(Guid lessonId, string fromConnectionId, string type, string payload) =>
        _ = InvokeAsync(async () =>
