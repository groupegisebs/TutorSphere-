    private async Task SendMessageAsync()
    {
        var text = _newMessage.Trim();
        if (string.IsNullOrEmpty(text) || _lessonGuid is null) return;
        _newMessage = "";

        var sentAt = DateTime.UtcNow;
        var selfId = ClassroomRt.ConnectionId ?? "";
        _chatMessages.Add(new ChatMsg
        {
            Text = text,
            IsMe = true,
            Sender = SelfDisplayName,
            Time = sentAt.ToLocalTime().ToString("HH:mm"),
            ConnectionId = selfId,
            SentAtUtc = sentAt
        });

        await ClassroomRt.SendChatMessageAsync(_lessonGuid.Value, text);
    }

    private void OnChatMessage(ClassroomChatMessageDto msg) =>
        _ = InvokeAsync(() =>
        {
            if (_lessonGuid is null || msg.LessonId != _lessonGuid.Value) return;
            AppendChatMessage(msg);
