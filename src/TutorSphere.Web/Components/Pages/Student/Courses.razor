@page "/student/courses"
@layout StudentLayout
@rendermode InteractiveServer
@using TutorSphere.Application.DTOs.Lessons
@inject IStringLocalizer<SharedResources> L
@inject ApiClient Api
@inject AuthService Auth

<PageTitle>@L["Nav_Courses"] – TutorSphere</PageTitle>

<div class="ts-page-header">
    <div>
        <h1><i class="bi bi-book me-2"></i>@L["Nav_Courses"]</h1>
        <p class="ts-page-subtitle">@L["StudentCourses_Subtitle"]</p>
    </div>
</div>

<div class="ts-toolbar">
    <div class="ts-search-box">
        <i class="bi bi-search ts-search-icon"></i>
        <input class="form-control" placeholder="@L["Common_Search"]" @bind="_search" @bind:event="oninput" />
    </div>
    <select class="form-select w-auto" @bind="_filter">
        <option value="">@L["Common_All"]</option>
        <option value="upcoming">@L["StudentCourses_Upcoming"]</option>
        <option value="done">@L["StudentCourses_Done"]</option>
    </select>
</div>

@if (_loading)
{
    <div class="d-flex align-items-center justify-content-center py-5">
        <span class="spinner-border text-primary me-3" role="status"></span>
        <span class="text-muted">@L["Common_Loading"]</span>
    </div>
}
else
{
    <div class="ts-table-card">
        <table class="table ts-table">
            <thead>
                <tr>
                    <th>@L["Common_Date"]</th>
                    <th>@L["Common_Title"]</th>
                    <th>@L["Common_Subject"]</th>
                    <th>@L["Common_Duration"]</th>
                    <th>@L["Common_Mode"]</th>
                    <th>@L["Common_Status"]</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var c in FilteredCourses)
                {
                    var status = DeriveStatus(c.StartTime, c.EndTime);
                    var badge = status switch { "done" => "ts-badge-success", "upcoming" => "ts-badge-primary", _ => "ts-badge-warning" };
                    <tr>
                        <td>
                            <strong>@ToLocal(c.StartTime).ToString("dd/MM/yyyy")</strong><br />
                            <small class="text-muted">@ToLocal(c.StartTime).ToString("HH:mm")</small>
                        </td>
                        <td>@c.Title</td>
                        <td>@(c.Subject ?? "—")</td>
                        <td>@((c.EndTime - c.StartTime).TotalHours.ToString("N1")) h</td>
                        <td><span class="ts-badge ts-badge-neutral">@ModeLabel(c.Mode)</span></td>
                        <td><span class="ts-badge @badge">@StatusLabel(status)</span></td>
                        <td>
                            @if (c.SettlementStatus is not "CancelledFree")
                            {
                                @if (!string.IsNullOrWhiteSpace(c.MeetingUrl))
                                {
                                    <a class="btn btn-sm btn-primary" href="@c.MeetingUrl" target="_blank" rel="noopener">@L["StudentCourses_Join"]</a>
                                }
                                else
                                {
                                    <a class="btn btn-sm btn-primary" href="@ClassroomHref(c)">@L["StudentCourses_Join"]</a>
                                }
                            }
                        </td>
                    </tr>
                }
                @if (!FilteredCourses.Any())
                {
                    <tr><td colspan="7" class="text-center text-muted py-4">@L["StudentCourses_Empty"]</td></tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    private string _search = "", _filter = "";
    private bool _loading = true;
    private bool _loaded;
    private List<LessonDto> _courses = [];

    private IEnumerable<LessonDto> FilteredCourses => _courses
        .Where(c => string.IsNullOrEmpty(_search) ||
            c.Title.Contains(_search, StringComparison.OrdinalIgnoreCase) ||
            (c.Subject ?? "").Contains(_search, StringComparison.OrdinalIgnoreCase))
        .Where(c =>
        {
            if (string.IsNullOrEmpty(_filter)) return true;
            return DeriveStatus(c.StartTime, c.EndTime) == _filter;
        })
        .OrderByDescending(c => c.StartTime);

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _loaded) return;
        _loaded = true;
        await Auth.EnsureSessionRestoredAsync(forceJs: true);
        try
        {
            _courses = await Api.GetAsync<List<LessonDto>>("api/students/me/lessons") ?? [];
        }
        catch { _courses = []; }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private static DateTime ToLocal(DateTime dt) =>
        dt.Kind == DateTimeKind.Utc ? dt.ToLocalTime() : DateTime.SpecifyKind(dt, DateTimeKind.Local);

    private static string DeriveStatus(DateTime start, DateTime end)
    {
        var now = DateTime.UtcNow;
        var s = start.Kind == DateTimeKind.Utc ? start : start.ToUniversalTime();
        var e = end.Kind == DateTimeKind.Utc ? end : end.ToUniversalTime();
        if (e < now) return "done";
        if (s > now) return "upcoming";
        return "live";
    }

    private string StatusLabel(string s) => s switch
    {
        "done" => L["StudentCourses_Done"],
        "upcoming" => L["StudentCourses_Upcoming"],
        _ => L["StudentCourses_InProgress"]
    };

    private string ModeLabel(string mode) => mode switch
    {
        "Online" => L["Common_Online"],
        "InPerson" => L["Common_InPerson"],
        _ => mode
    };

    private static string ClassroomHref(LessonDto c) =>
        $"/student/classroom/{c.Id}?title={Uri.EscapeDataString(c.Title)}&subject={Uri.EscapeDataString(c.Subject ?? "")}";
}
