@page "/student/courses"
@layout StudentLayout
@rendermode InteractiveServer
@using TutorSphere.Application.DTOs.Lessons
@inject IStringLocalizer<SharedResources> L
@inject LessonService LessonSvc

<PageTitle>Mes Cours – TutorSphere</PageTitle>

<div class="ts-page-header">
    <div>
        <h1><i class="bi bi-book me-2"></i>Mes Cours</h1>
        <p class="ts-page-subtitle">Vos séances passées et à venir</p>
    </div>
</div>

<div class="ts-toolbar">
    <div class="ts-search-box">
        <i class="bi bi-search ts-search-icon"></i>
        <input class="form-control" placeholder="Chercher…" @bind="_search" @bind:event="oninput" />
    </div>
    <select class="form-select w-auto" @bind="_filter">
        <option value="">Tous</option>
        <option>À venir</option>
        <option>Terminé</option>
    </select>
</div>

@if (_loading)
{
    <div class="d-flex align-items-center justify-content-center py-5">
        <span class="spinner-border text-primary me-3" role="status"></span>
        <span class="text-muted">Chargement des cours…</span>
    </div>
}
else
{
    <div class="ts-table-card">
        <table class="table ts-table">
            <thead><tr><th>Date</th><th>Titre</th><th>Matière</th><th>Durée</th><th>Mode</th><th>Statut</th><th></th></tr></thead>
            <tbody>
                @foreach (var c in FilteredCourses)
                {
                    var status = LessonService.DeriveStatus(c.StartTime, c.EndTime);
                    var badge  = status switch { "Terminé" => "ts-badge-success", "Planifié" => "ts-badge-primary", _ => "ts-badge-warning" };
                    <tr>
                        <td>
                            <strong>@c.StartTime.ToLocalTime().ToString("dd/MM/yyyy")</strong><br />
                            <small class="text-muted">@c.StartTime.ToLocalTime().ToString("HH:mm")</small>
                        </td>
                        <td>@c.Title</td>
                        <td>@(c.Subject ?? "—")</td>
                        <td>@((c.EndTime - c.StartTime).TotalHours.ToString("N1")) h</td>
                        <td><span class="ts-badge ts-badge-neutral">@LessonService.ModeToDisplay(c.Mode)</span></td>
                        <td><span class="ts-badge @badge">@status</span></td>
                        <td>
                            @if (status == "Planifié" && c.Mode == "Online" && !string.IsNullOrEmpty(c.MeetingUrl))
                            {
                                <a class="btn btn-sm btn-primary" href="@c.MeetingUrl" target="_blank">Rejoindre</a>
                            }
                        </td>
                    </tr>
                }
                @if (!FilteredCourses.Any())
                {
                    <tr><td colspan="7" class="text-center text-muted py-4">Aucun cours trouvé.</td></tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    private string _search = "", _filter = "";
    private bool _loading = true;
    private List<TutorSphere.Application.DTOs.Lessons.LessonDto> _courses = [];

    private IEnumerable<TutorSphere.Application.DTOs.Lessons.LessonDto> FilteredCourses => _courses
        .Where(c => string.IsNullOrEmpty(_search) ||
            c.Title.Contains(_search, StringComparison.OrdinalIgnoreCase) ||
            (c.Subject ?? "").Contains(_search, StringComparison.OrdinalIgnoreCase))
        .Where(c =>
        {
            if (string.IsNullOrEmpty(_filter)) return true;
            var status = LessonService.DeriveStatus(c.StartTime, c.EndTime);
            return _filter == "À venir" ? status == "Planifié" : status == "Terminé";
        })
        .OrderByDescending(c => c.StartTime);

    protected override async Task OnInitializedAsync()
    {
        try { _courses = await LessonSvc.GetLessonsAsync(); }
        catch { }
        finally { _loading = false; }
    }

}
