@page "/student/settings"
@layout StudentLayout
@rendermode InteractiveServer
@inject IStringLocalizer<SharedResources> L
@inject AuthService Auth
@inject ApiClient Api

<PageTitle>@L["Nav_Settings"] – TutorSphere</PageTitle>

<div class="ts-page-header">
    <div>
        <h1><i class="bi bi-sliders me-2"></i>@L["Nav_Settings"]</h1>
        <p class="ts-page-subtitle">Profil et préférences de votre compte</p>
    </div>
    <button class="btn btn-primary" @onclick="SaveAsync" disabled="@_saving">
        @if (_saving) { <span class="spinner-border spinner-border-sm me-1"></span> }
        Enregistrer
    </button>
</div>

@if (!string.IsNullOrEmpty(_error))
{
    <div class="alert alert-danger">@_error</div>
}
@if (_saved)
{
    <div class="alert alert-success">Profil et préférences enregistrés.</div>
}

<div class="card ts-card mb-4">
    <div class="card-body">
        <h2 class="h5 mb-3">Profil</h2>
        <div class="row g-3">
            <div class="col-md-6">
                <label class="form-label">Prénom *</label>
                <input class="form-control" @bind="_firstName" />
            </div>
            <div class="col-md-6">
                <label class="form-label">Nom *</label>
                <input class="form-control" @bind="_lastName" />
            </div>
            <div class="col-md-6">
                <label class="form-label">Courriel</label>
                <input class="form-control" value="@(_email)" disabled />
            </div>
            <div class="col-md-6">
                <label class="form-label">Téléphone</label>
                <input class="form-control" @bind="_phone" />
            </div>
            <div class="col-md-6">
                <label class="form-label">Date de naissance *</label>
                <input type="date" class="form-control" @bind="_dob" />
                <div class="form-text">Obligatoire pour rechercher et s’abonner seul (14 ans et plus).</div>
            </div>
        </div>
    </div>
</div>

<div class="card ts-card">
    <div class="card-body">
        <h2 class="h5 mb-3">Notifications</h2>
        <p class="text-muted small">Rappels de cours envoyés par e-mail environ 24&nbsp;h avant la séance.</p>
        <div class="form-check form-switch">
            <input class="form-check-input" type="checkbox" id="student-reminders" @bind="_emailLessonReminders" />
            <label class="form-check-label" for="student-reminders">Recevoir les rappels de cours par e-mail</label>
        </div>
    </div>
</div>

@code {
    private bool _emailLessonReminders = true;
    private bool _saving, _saved;
    private string? _error;
    private string _firstName = "";
    private string _lastName = "";
    private string _email = "";
    private string _phone = "";
    private DateTime? _dob;

    private record NotificationPreferencesDto(bool EmailLessonReminders);
    private record UserProfileDto(
        string Email, string FirstName, string LastName, string FullName,
        string? Phone, string? Bio, string PreferredLanguage, string TimeZone, string Role);

    protected override async Task OnInitializedAsync()
    {
        await Auth.EnsureSessionRestoredAsync();
        var prefs = await Api.GetAsync<NotificationPreferencesDto>("api/me/notification-preferences");
        if (prefs is not null)
            _emailLessonReminders = prefs.EmailLessonReminders;

        var me = await Api.GetAsync<UserProfileDto>("api/me/profile");
        if (me is not null)
        {
            _firstName = me.FirstName;
            _lastName = me.LastName;
            _email = me.Email;
            _phone = me.Phone ?? "";
        }
        else
        {
            _email = Auth.UserEmail ?? "";
            var parts = (Auth.UserName ?? "").Split(' ', 2, StringSplitOptions.RemoveEmptyEntries);
            _firstName = parts.Length > 0 ? parts[0] : "";
            _lastName = parts.Length > 1 ? parts[1] : "";
        }

        try
        {
            var student = await Api.GetAsync<StudentDto>("api/students/me");
            if (student is not null)
            {
                _firstName = student.FirstName;
                _lastName = student.LastName;
                _phone = student.Phone ?? _phone;
                _dob = student.DateOfBirth?.Date;
                if (!string.IsNullOrWhiteSpace(student.Email))
                    _email = student.Email;
            }
        }
        catch { /* profil élève absents — compte Identity seul */ }
    }

    private async Task SaveAsync()
    {
        if (string.IsNullOrWhiteSpace(_firstName) || string.IsNullOrWhiteSpace(_lastName))
        {
            _error = "Prénom et nom sont obligatoires.";
            _saved = false;
            return;
        }

        _saving = true;
        _saved = false;
        _error = null;
        try
        {
            var studentResult = await Api.PutWithErrorAsync<StudentDto>("api/students/me", new
            {
                firstName = _firstName.Trim(),
                lastName = _lastName.Trim(),
                phone = string.IsNullOrWhiteSpace(_phone) ? null : _phone.Trim(),
                dateOfBirth = _dob
            });
            if (studentResult.Error is not null)
            {
                _error = studentResult.Error;
                return;
            }

            var profileResult = await Api.PutWithErrorAsync<UserProfileDto>("api/me/profile", new
            {
                firstName = _firstName.Trim(),
                lastName = _lastName.Trim(),
                phone = string.IsNullOrWhiteSpace(_phone) ? null : _phone.Trim()
            });
            if (profileResult.Error is not null)
            {
                _error = profileResult.Error;
                return;
            }

            var prefsResult = await Api.PutWithErrorAsync<NotificationPreferencesDto>(
                "api/me/notification-preferences",
                new { emailLessonReminders = _emailLessonReminders });
            if (prefsResult.Error is not null)
            {
                _error = prefsResult.Error;
                return;
            }

            var fullName = profileResult.Value?.FullName ?? $"{_firstName} {_lastName}".Trim();
            await Auth.UpdateLocalDisplayNameAsync(fullName);
            _saved = true;
        }
        finally
        {
            _saving = false;
        }
    }
}
