@page "/student/settings"
@layout StudentLayout
@rendermode InteractiveServer
@inject IStringLocalizer<SharedResources> L
@inject AuthService Auth

<PageTitle>@L["Nav_Settings"] – TutorSphere</PageTitle>

<div class="ts-page-header">
    <div>
        <h1><i class="bi bi-sliders me-2"></i>@L["Nav_Settings"]</h1>
        <p class="ts-page-subtitle">Préférences de votre compte</p>
    </div>
</div>

<div class="card ts-card">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">Courriel</dt>
            <dd class="col-sm-9">@(Auth.UserEmail ?? "—")</dd>
            <dt class="col-sm-3">Nom</dt>
            <dd class="col-sm-9">@(Auth.UserName ?? "—")</dd>
        </dl>
    </div>
</div>
