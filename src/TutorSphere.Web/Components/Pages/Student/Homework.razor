@page "/student/homework"
@layout StudentLayout
@rendermode InteractiveServer
@inject IStringLocalizer<SharedResources> L
@inject ApiClient Api

<PageTitle>Mes Devoirs – TutorSphere</PageTitle>

<div class="ts-page-header">
    <div>
        <h1><i class="bi bi-journal-text me-2"></i>Mes Devoirs</h1>
        <p class="ts-page-subtitle">Devoirs à rendre et corrections</p>
    </div>
</div>

@if (_loading)
{
    <div class="d-flex align-items-center justify-content-center py-5">
        <span class="spinner-border text-primary me-3" role="status"></span>
        <span class="text-muted">Chargement des devoirs…</span>
    </div>
}
else
{
    <div class="homework-grid">
        @foreach (var hw in _homeworks)
        {
            var statusLabel = hw.IsGraded ? "Corrigé" : hw.SubmittedAt.HasValue ? "Rendu" :
                (hw.DueDate.HasValue && hw.DueDate.Value < DateTime.Today) ? "En retard" : "À rendre";
            var isOverdue   = !hw.IsGraded && !hw.SubmittedAt.HasValue && hw.DueDate.HasValue && hw.DueDate.Value < DateTime.Today;

            <div class="hw-card">
                <div class="hw-card-head">
                    <span class="ts-badge @HwBadge(statusLabel)">@statusLabel</span>
                    @if (hw.DueDate.HasValue)
                    {
                        <span class="hw-due @(isOverdue ? "text-danger" : "text-muted")">
                            <i class="bi bi-calendar3 me-1"></i>@hw.DueDate.Value.ToString("dd/MM")
                        </span>
                    }
                </div>
                <h3 class="hw-title">@hw.Title</h3>
                @if (!string.IsNullOrEmpty(hw.Description))
                {
                    <p class="hw-desc">@hw.Description</p>
                }
                @if (hw.Grade.HasValue)
                {
                    <div class="hw-grade-chip">Note : <strong>@hw.Grade.Value/20</strong></div>
                }
                @if (!string.IsNullOrEmpty(hw.Feedback))
                {
                    <p class="hw-desc text-muted small"><i class="bi bi-chat-square-text me-1"></i>@hw.Feedback</p>
                }
                <div class="hw-card-footer">
                    @if (statusLabel == "À rendre" && !_submitting.Contains(hw.Id))
                    {
                        <button class="btn btn-sm btn-primary" @onclick="async () => await SubmitAsync(hw.Id)">
                            <i class="bi bi-check-lg me-1"></i>Marquer rendu
                        </button>
                    }
                    else if (_submitting.Contains(hw.Id))
                    {
                        <span class="spinner-border spinner-border-sm text-primary me-2"></span>
                    }
                </div>
            </div>
        }
        @if (_homeworks.Count == 0)
        {
            <div class="text-center py-5 text-muted" style="grid-column:1/-1">
                <i class="bi bi-journal-text fs-1 d-block mb-3 opacity-50"></i>
                <p>Aucun devoir trouvé.</p>
            </div>
        }
    </div>
}

@code {
    private bool _loading = true;
    private List<HomeworkDto> _homeworks = [];
    private HashSet<Guid> _submitting = [];

    private static string HwBadge(string s) => s switch
    {
        "Corrigé"  => "ts-badge-success",
        "Rendu"    => "ts-badge-primary",
        "En retard"=> "ts-badge-danger",
        _          => "ts-badge-muted"
    };

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var profile = await Api.GetAsync<StudentProfileDto>("api/students/me");
            if (profile != null)
            {
                var result = await Api.GetAsync<List<HomeworkDto>>(
                    $"api/homework/student/{profile.Id}") ?? [];
                _homeworks = [.. result.OrderBy(h => h.DueDate ?? DateTime.MaxValue)];
            }
        }
        catch { }
        finally { _loading = false; }
    }

    private async Task SubmitAsync(Guid id)
    {
        _submitting.Add(id);
        try
        {
            var result = await Api.PostAsync<HomeworkDto>(
                $"api/homework/{id}/submit", new { SubmissionNotes = "" });
            if (result != null)
            {
                var idx = _homeworks.FindIndex(h => h.Id == id);
                if (idx >= 0) _homeworks[idx] = result;
            }
        }
        finally { _submitting.Remove(id); }
    }

    private record HomeworkDto(
        Guid Id, Guid TenantId, Guid StudentId, Guid? LessonId,
        string Title, string? Description, DateTime? DueDate,
        DateTime? SubmittedAt, string? SubmissionNotes, decimal? Grade,
        string? Feedback, bool IsGraded, DateTime CreatedAt, DateTime? UpdatedAt);

    private record StudentProfileDto(Guid Id, string? FirstName, string? LastName);
}
