@page "/student/homework"
@layout StudentLayout
@rendermode InteractiveServer
@inject ApiClient Api
@inject NavigationManager Nav
@using TutorSphere.Application.DTOs.Homework
@using TutorSphere.Domain.Enums

<PageTitle>Mes Devoirs – TutorSphere</PageTitle>

<div class="ts-page-header">
    <div>
        <h1><i class="bi bi-journal-text me-2"></i>Mes Devoirs</h1>
        <p class="ts-page-subtitle">Devoirs à rendre et corrections</p>
    </div>
</div>

@if (_loading)
{
    <div class="d-flex align-items-center justify-content-center py-5">
        <span class="spinner-border text-primary me-3" role="status"></span>
        <span class="text-muted">Chargement des devoirs…</span>
    </div>
}
else
{
    <div class="homework-grid">
        @foreach (var hw in _homeworks)
        {
            var statusLabel = hw.IsGraded ? "Corrigé" : hw.SubmittedAt.HasValue ? "Rendu" :
                (hw.DueDate.HasValue && hw.DueDate.Value.Date < DateTime.Today) ? "En retard" : "À rendre";
            var isOverdue = statusLabel == "En retard";
            var payload = HomeworkJson.TryParseSubmission(hw.SubmissionNotes);
            var points = hw.Criteria.Sum(c => c.Points);

            <div class="hw-card">
                <div class="hw-card-head">
                    <span class="ts-badge @HwBadge(statusLabel)">@statusLabel</span>
                    @if (hw.DueDate.HasValue)
                    {
                        <span class="hw-due @(isOverdue ? "text-danger" : "text-muted")">
                            <i class="bi bi-calendar3 me-1"></i>@hw.DueDate.Value.ToLocalTime().ToString("dd/MM")
                        </span>
                    }
                </div>
                <h3 class="hw-title">@hw.Title</h3>
                @if (!string.IsNullOrEmpty(hw.Subject))
                {
                    <p class="hw-subject"><i class="bi bi-book me-1 text-muted"></i>@hw.Subject</p>
                }
                @if (!string.IsNullOrEmpty(hw.Description))
                {
                    <p class="hw-desc">@(hw.Description.Length > 120 ? hw.Description[..120] + "…" : hw.Description)</p>
                }
                @if (points > 0)
                {
                    <p class="hw-desc small text-muted mb-0"><i class="bi bi-trophy me-1"></i>@points points</p>
                }
                @if (hw.Grade.HasValue)
                {
                    <div class="hw-grade-chip">Note : <strong>@hw.Grade.Value/100</strong></div>
                }
                @if (!string.IsNullOrEmpty(hw.Feedback))
                {
                    <p class="hw-desc text-muted small"><i class="bi bi-chat-square-text me-1"></i>@hw.Feedback</p>
                }
                @if (payload?.Attachments is { Count: > 0 })
                {
                    <p class="hw-desc small"><i class="bi bi-paperclip me-1"></i>@payload.Attachments.Count fichier(s) remis</p>
                }
                <div class="hw-card-footer">
                    @if (statusLabel is "À rendre" or "En retard")
                    {
                        <button class="btn btn-sm btn-primary" @onclick="() => OpenSubmit(hw.Id)">
                            <i class="bi bi-pencil-square me-1"></i>Répondre
                        </button>
                    }
                    else if (statusLabel == "Rendu")
                    {
                        <span class="small text-muted"><i class="bi bi-check2-circle me-1"></i>En attente de correction</span>
                    }
                </div>
            </div>
        }
        @if (_homeworks.Count == 0)
        {
            <div class="text-center py-5 text-muted" style="grid-column:1/-1">
                <i class="bi bi-journal-text fs-1 d-block mb-3 opacity-50"></i>
                <p>Aucun devoir trouvé.</p>
            </div>
        }
    </div>
}

@code {
    private bool _loading = true;
    private List<HomeworkDto> _homeworks = [];

    private static string HwBadge(string s) => s switch
    {
        "Corrigé" => "ts-badge-success",
        "Rendu" => "ts-badge-primary",
        "En retard" => "ts-badge-danger",
        _ => "ts-badge-muted"
    };

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var result = await Api.GetAsync<List<HomeworkDto>>("api/students/me/homework") ?? [];
            _homeworks = [.. result.OrderBy(h => h.DueDate ?? DateTime.MaxValue)];
        }
        catch { }
        finally { _loading = false; }
    }

    private void OpenSubmit(Guid id) => Nav.NavigateTo($"/student/homework/{id}/submit");
}
