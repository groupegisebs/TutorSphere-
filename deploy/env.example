# Copy to DEPLOY_PATH/env on the server (chmod 640).
# GitHub Actions writes this file automatically on each deploy from repository secrets.
# Convention ASP.NET Core: Section__Key

ASPNETCORE_ENVIRONMENT=Production

# PostgreSQL (Npgsql)
CONNECTIONSTRINGS__DEFAULTCONNECTION=Host=localhost;Port=5432;Database=TutorSphere;Username=tutorsphere;Password=CHANGE_ME

# JWT
JWT__KEY=CHANGE_ME_MIN_32_CHARACTERS_LONG_SECRET_KEY
JWT__ISSUER=TutorSphere
JWT__AUDIENCE=TutorSphere

# Stripe
STRIPE__SECRETKEY=sk_live_...
STRIPE__PUBLISHABLEKEY=pk_live_...
STRIPE__WEBHOOKSECRET=whsec_...

# Blazor Web — public API URL (must match nginx API hostname)
APIBASEURL=https://api.tutorsphere.example.com
