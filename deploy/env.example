# Copiez vers APP_ROOT/app/.env sur le serveur (chmod 600).
# GitHub Actions génère ce fichier automatiquement via deploy/build-app-env.sh.
# Convention ASP.NET Core : Section__Key

ASPNETCORE_ENVIRONMENT=Production

# Ports locaux (docker-compose.prod.yml, réseau host)
API_PORT=55099
WEB_PORT=55010

# PostgreSQL externe (serveur partagé)
CONNECTIONSTRINGS__DEFAULTCONNECTION=Host=localhost;Port=5432;Database=TutorSphere;Username=tutorsphere;Password=CHANGE_ME

# JWT
JWT__KEY=CHANGE_ME_MIN_32_CHARACTERS_LONG_SECRET_KEY
JWT__ISSUER=TutorSphere
JWT__AUDIENCE=TutorSphere

# GiseBs Pay Gateway
PAYGATEWAY__BASEURL=https://gisebsapipaygateway.gisebs.com
PAYGATEWAY__APPCODE=TUTORSPHERE
PAYGATEWAY__APIKEY=gbsk_...

# Blazor Web — URL publique de l'API (Nginx Proxy Manager HTTPS)
APIBASEURL=https://api.tutorsphere.gisebs.com
