# Example nginx reverse proxy for TutorSphere (Docker Compose, host network).
# Containers listen on 0.0.0.0:55099 (API) and 0.0.0.0:55010 (Web) — reachable via 127.0.0.1 or 172.17.0.1 (NPM).
# Production GISEBS domains — adjust if your DNS differs.
#
# Prefer Nginx Proxy Manager on shared GISEBS servers — see deploy/nginx/NPM.md
#
# Install (native nginx on host):
#   sudo cp deploy/nginx/tutorsphere.conf.example /etc/nginx/sites-available/tutorsphere
#   sudo ln -s /etc/nginx/sites-available/tutorsphere /etc/nginx/sites-enabled/
#   sudo nginx -t && sudo systemctl reload nginx
#
# TLS: use certbot (Let's Encrypt) after DNS points to this server.

upstream tutorsphere_api {
    server 127.0.0.1:55099;
    keepalive 32;
}

upstream tutorsphere_web {
    server 127.0.0.1:55010;
    keepalive 32;
}

# API — https://api.tutorsphere.gisebs.com
server {
    listen 80;
    server_name api.tutorsphere.gisebs.com;

    location / {
        proxy_pass         http://tutorsphere_api;
        proxy_http_version 1.1;
        proxy_set_header   Host $host;
        proxy_set_header   X-Real-IP $remote_addr;
        proxy_set_header   X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
    }

    # SignalR / WebSocket (messages hub)
    location /hubs/ {
        proxy_pass         http://tutorsphere_api;
        proxy_http_version 1.1;
        proxy_set_header   Upgrade $http_upgrade;
        proxy_set_header   Connection "upgrade";
        proxy_set_header   Host $host;
        proxy_set_header   X-Real-IP $remote_addr;
        proxy_set_header   X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_read_timeout 86400;
    }
}

# Blazor Web — https://tutorsphere.gisebs.com
server {
    listen 80;
    server_name tutorsphere.gisebs.com;

    location / {
        proxy_pass         http://tutorsphere_web;
        proxy_http_version 1.1;
        proxy_set_header   Host $host;
        proxy_set_header   X-Real-IP $remote_addr;
        proxy_set_header   X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
    }

    # Blazor Server interactive circuits (WebSockets)
    location /_blazor {
        proxy_pass         http://tutorsphere_web;
        proxy_http_version 1.1;
        proxy_set_header   Upgrade $http_upgrade;
        proxy_set_header   Connection "upgrade";
        proxy_set_header   Host $host;
        proxy_set_header   X-Real-IP $remote_addr;
        proxy_set_header   X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_read_timeout 86400;
    }
}
