# Example nginx reverse proxy for TutorSphere on a shared Linux server.
# Replace example.com with your domains and adjust ports if needed.
#
# Install:
#   sudo cp deploy/nginx/tutorsphere.conf.example /etc/nginx/sites-available/tutorsphere
#   sudo ln -s /etc/nginx/sites-available/tutorsphere /etc/nginx/sites-enabled/
#   sudo nginx -t && sudo systemctl reload nginx
#
# TLS: use certbot (Let's Encrypt) after DNS points to this server.

upstream tutorsphere_api {
    server 127.0.0.1:55099;
    keepalive 32;
}

upstream tutorsphere_web {
    server 127.0.0.1:55010;
    keepalive 32;
}

# API — e.g. https://api.tutorsphere.example.com
server {
    listen 80;
    server_name api.tutorsphere.example.com;

    location / {
        proxy_pass         http://tutorsphere_api;
        proxy_http_version 1.1;
        proxy_set_header   Host $host;
        proxy_set_header   X-Real-IP $remote_addr;
        proxy_set_header   X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
    }

    # SignalR / WebSocket (messages hub)
    location /hubs/ {
        proxy_pass         http://tutorsphere_api;
        proxy_http_version 1.1;
        proxy_set_header   Upgrade $http_upgrade;
        proxy_set_header   Connection "upgrade";
        proxy_set_header   Host $host;
        proxy_set_header   X-Real-IP $remote_addr;
        proxy_set_header   X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_read_timeout 86400;
    }
}

# Blazor Web — e.g. https://app.tutorsphere.example.com
server {
    listen 80;
    server_name app.tutorsphere.example.com tutorsphere.example.com;

    location / {
        proxy_pass         http://tutorsphere_web;
        proxy_http_version 1.1;
        proxy_set_header   Host $host;
        proxy_set_header   X-Real-IP $remote_addr;
        proxy_set_header   X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
    }

    # Blazor Server interactive circuits (WebSockets)
    location /_blazor {
        proxy_pass         http://tutorsphere_web;
        proxy_http_version 1.1;
        proxy_set_header   Upgrade $http_upgrade;
        proxy_set_header   Connection "upgrade";
        proxy_set_header   Host $host;
        proxy_set_header   X-Real-IP $remote_addr;
        proxy_set_header   X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_read_timeout 86400;
    }
}
